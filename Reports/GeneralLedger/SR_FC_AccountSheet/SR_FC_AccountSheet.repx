                    </Item2>
                    <Item3 Ref="317" ControlType="XRTableCell" Name="thOpenDebit_GPT" Multiline="true" TextAlignment="MiddleRight">
                      <Summary Ref="318" Running="Group" />
                      <ExpressionBindings>
                        <Item1 Ref="319" EventName="BeforePrint" PropertyName="Text" Expression="Iif([OpenBalance] &gt; 0, [OpenBalance], null)" />
                        <Item2 Ref="320" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                      </ExpressionBindings>
                      <StylePriority Ref="321" UseFont="false" UseTextAlignment="false" />
                    </Item3>
                    <Item4 Ref="322" ControlType="XRTableCell" Name="thOpenCredit_GPT" Multiline="true" TextAlignment="MiddleRight">
                      <Summary Ref="323" Running="Group" />
                      <ExpressionBindings>
                        <Item1 Ref="324" EventName="BeforePrint" PropertyName="Text" Expression="Iif([OpenBalance] &lt; 0, Abs([OpenBalance]), null)" />
                        <Item2 Ref="325" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                      </ExpressionBindings>
                      <StylePriority Ref="326" UseFont="false" UseTextAlignment="false" />
                    </Item4>
                  </Cells>
                </Item1>
              </Rows>
              <StylePriority Ref="327" UseBackColor="false" UseBorders="false" />
            </Item1>
          </Controls>
        </Item2>
      </SubBands>
      <GroupFields>
        <Item1 Ref="328" FieldName="AccountName" />
      </GroupFields>
    </Item7>
    <Item8 Ref="329" ControlType="GroupFooterBand" Name="GroupFooter1">
      <Scripts Ref="330" OnBeforePrint="GroupFooter1_BeforePrint" />
      <Controls>
        <Item1 Ref="331" ControlType="XRTable" Name="tFooter" AnchorHorizontal="Both" Borders="All">
          <Rows>
            <Item1 Ref="332" ControlType="XRTableRow" Name="trFooter">
              <Cells>
                <Item1 Ref="333" ControlType="XRTableCell" Name="tfTotal" Multiline="true" />
                <Item2 Ref="334" ControlType="XRTableCell" Name="tfDebit_GPT" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="335" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="336" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Debit])&#xA;" />
                    <Item2 Ref="337" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xD;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="338" UseTextAlignment="false" />
                </Item2>
                <Item3 Ref="339" ControlType="XRTableCell" Name="tfCredit_GPT" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="340" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="341" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="342" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Credit])" />
                  </ExpressionBindings>
                  <StylePriority Ref="343" UseTextAlignment="false" />
                </Item3>
                <Item4 Ref="344" ControlType="XRTableCell" Name="tfDebitBal_GPT" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="345" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="346" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="347" EventName="BeforePrint" PropertyName="Text" Expression="iif&#xA;(&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]) &gt; 0,&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]),&#xA;&#x9;null&#xA;)" />
                  </ExpressionBindings>
                  <StylePriority Ref="348" UseTextAlignment="false" />
                </Item4>
                <Item5 Ref="349" ControlType="XRTableCell" Name="tfCreditBal_GPT" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="350" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="351" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xD;&#xA;" />
                    <Item2 Ref="352" EventName="BeforePrint" PropertyName="Text" Expression="iif&#xA;(&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]) &lt; 0,&#xA;&#x9;Abs(IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit])),&#xA;&#x9;null&#xA;)" />
                  </ExpressionBindings>
                  <StylePriority Ref="353" UseTextAlignment="false" />
                </Item5>
              </Cells>
            </Item1>
          </Rows>
          <StylePriority Ref="354" UseBorders="false" />
        </Item1>
      </Controls>
    </Item8>
