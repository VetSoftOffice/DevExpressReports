            <Item1 Ref="305" ControlType="XRTable" Name="tHeader" AnchorHorizontal="Both" BackColor="255,235,235,235" Borders="All">
              <Rows>
                <Item1 Ref="306" ControlType="XRTableRow" Name="trHeader1">
                  <Cells>
                    <Item1 Ref="307" ControlType="XRTableCell" Name="thDate1" RowSpan="2" Multiline="true" TextAlignment="MiddleCenter" BorderWidth="1.4">
                      <StylePriority Ref="308" UseBorderWidth="false" />
                    </Item1>
                    <Item2 Ref="309" ControlType="XRTableCell" Name="thMovement" Multiline="true" TextAlignment="MiddleCenter" BorderWidth="1.4">
                      <StylePriority Ref="310" UseBorderWidth="false" />
                    </Item2>
                    <Item3 Ref="311" ControlType="XRTableCell" Name="thBalance" Multiline="true" TextAlignment="MiddleCenter" BorderWidth="1.4">
                      <StylePriority Ref="312" UseBorderWidth="false" />
                    </Item3>
                  </Cells>
                </Item1>
                <Item2 Ref="313" ControlType="XRTableRow" Name="trHeader2">
                  <Cells>
                    <Item1 Ref="314" ControlType="XRTableCell" Name="thDate2" Multiline="true" TextAlignment="MiddleCenter" />
                    <Item2 Ref="315" ControlType="XRTableCell" Name="thDebit" Multiline="true" TextAlignment="MiddleCenter" BorderWidth="1.4">
                      <StylePriority Ref="316" UseBorderWidth="false" />
                    </Item2>
                    <Item3 Ref="317" ControlType="XRTableCell" Name="thCredit" Multiline="true" TextAlignment="MiddleCenter" BorderWidth="1.4">
                      <StylePriority Ref="318" UseBorderWidth="false" />
                    </Item3>
                    <Item4 Ref="319" ControlType="XRTableCell" Name="thDebitBal" Multiline="true" TextAlignment="MiddleCenter" BorderWidth="1.4">
                      <StylePriority Ref="320" UseBorderWidth="false" />
                    </Item4>
                    <Item5 Ref="321" ControlType="XRTableCell" Name="thCreditBal" Multiline="true" TextAlignment="MiddleCenter" BorderWidth="1.4">
                      <StylePriority Ref="322" UseBorderWidth="false" />
                    </Item5>
                  </Cells>
                </Item2>
              </Rows>
              <StylePriority Ref="323" UseBackColor="false" UseBorders="false" />
            </Item1>
          </Controls>
        </Item1>
        <Item2 Ref="324" ControlType="SubBand" Name="GroupHeaderSub2">
          <Controls>
            <Item1 Ref="325" ControlType="XRTable" Name="xrTable1" AnchorHorizontal="Both" BackColor="Transparent" Borders="All">
              <Rows>
                <Item1 Ref="326" ControlType="XRTableRow" Name="xrTableRow1">
                  <Cells>
                    <Item1 Ref="327" ControlType="XRTableCell" Name="thAccountName" Multiline="true" TextAlignment="MiddleLeft" BorderWidth="1.4">
                      <ExpressionBindings>
                        <Item1 Ref="328" EventName="BeforePrint" PropertyName="Text" Expression="[AccountName]" />
                      </ExpressionBindings>
                      <StylePriority Ref="329" UseFont="false" UseBorderWidth="false" UseTextAlignment="false" />
                    </Item1>
                    <Item2 Ref="330" ControlType="XRTableCell" Name="thOpenBalance" Multiline="true" TextAlignment="MiddleCenter" BorderWidth="1.4">
                      <StylePriority Ref="331" UseFont="false" UseBorderWidth="false" UseTextAlignment="false" />
                    </Item2>
                    <Item3 Ref="332" ControlType="XRTableCell" Name="thOpenDebit_GPT" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                      <Summary Ref="333" Running="Group" />
                      <ExpressionBindings>
                        <Item1 Ref="334" EventName="BeforePrint" PropertyName="Text" Expression="Iif([OpenBalance] &gt; 0, [OpenBalance], null)" />
                        <Item2 Ref="335" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                      </ExpressionBindings>
                      <StylePriority Ref="336" UseFont="false" UseBorderWidth="false" UseTextAlignment="false" />
                    </Item3>
                    <Item4 Ref="337" ControlType="XRTableCell" Name="thOpenCredit_GPT" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                      <Summary Ref="338" Running="Group" />
                      <ExpressionBindings>
                        <Item1 Ref="339" EventName="BeforePrint" PropertyName="Text" Expression="Iif([OpenBalance] &lt; 0, Abs([OpenBalance]), null)" />
                        <Item2 Ref="340" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                      </ExpressionBindings>
                      <StylePriority Ref="341" UseFont="false" UseBorderWidth="false" UseTextAlignment="false" />
                    </Item4>
                  </Cells>
                </Item1>
              </Rows>
              <StylePriority Ref="342" UseBackColor="false" UseBorders="false" />
            </Item1>
          </Controls>
        </Item2>
      </SubBands>
      <GroupFields>
        <Item1 Ref="343" FieldName="AccountName" />
      </GroupFields>
    </Item7>
    <Item8 Ref="344" ControlType="GroupFooterBand" Name="GroupFooter1">
      <Scripts Ref="345" OnBeforePrint="GroupFooter1_BeforePrint" />
      <Controls>
        <Item1 Ref="346" ControlType="XRTable" Name="tFooter" AnchorHorizontal="Both" Borders="All">
          <Rows>
            <Item1 Ref="347" ControlType="XRTableRow" Name="trFooter">
              <Cells>
                <Item1 Ref="348" ControlType="XRTableCell" Name="tfTotal" Multiline="true" BorderWidth="1.4">
                  <StylePriority Ref="349" UseBorderWidth="false" />
                </Item1>
                <Item2 Ref="350" ControlType="XRTableCell" Name="tfDebit_GPT" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="351" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="352" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Debit])&#xA;" />
                    <Item2 Ref="353" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xD;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="354" UseBorderWidth="false" UseTextAlignment="false" />
                </Item2>
                <Item3 Ref="355" ControlType="XRTableCell" Name="tfCredit_GPT" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="356" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="357" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="358" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Credit])" />
                  </ExpressionBindings>
                  <StylePriority Ref="359" UseBorderWidth="false" UseTextAlignment="false" />
                </Item3>
                <Item4 Ref="360" ControlType="XRTableCell" Name="tfDebitBal_GPT" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="361" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="362" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="363" EventName="BeforePrint" PropertyName="Text" Expression="iif&#xA;(&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]) &gt; 0,&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]),&#xA;&#x9;null&#xA;)" />
                  </ExpressionBindings>
                  <StylePriority Ref="364" UseBorderWidth="false" UseTextAlignment="false" />
                </Item4>
                <Item5 Ref="365" ControlType="XRTableCell" Name="tfCreditBal_GPT" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="366" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="367" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xD;&#xA;" />
                    <Item2 Ref="368" EventName="BeforePrint" PropertyName="Text" Expression="iif&#xA;(&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]) &lt; 0,&#xA;&#x9;Abs(IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit])),&#xA;&#x9;null&#xA;)" />
                  </ExpressionBindings>
                  <StylePriority Ref="369" UseBorderWidth="false" UseTextAlignment="false" />
                </Item5>
              </Cells>
            </Item1>
          </Rows>
          <StylePriority Ref="370" UseBorders="false" />
        </Item1>
      </Controls>
    </Item8>
  </Bands>
