<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_FC_AccountSheetDet" ScriptsSource="using System.Collections.Generic;&#xD;&#xA;using System.Text.RegularExpressions;&#xD;&#xA;&#xD;&#xA;Dictionary&lt;string, decimal&gt; debitRunningTotals = new Dictionary&lt;string, decimal&gt;();&#xD;&#xA;Dictionary&lt;string, decimal&gt; creditRunningTotals = new Dictionary&lt;string, decimal&gt;();&#xD;&#xA;Dictionary&lt;string, int&gt; lastProcessedYear = new Dictionary&lt;string, int&gt;();&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell10_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal openBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenBalance&quot;) ?? 0);&#xD;&#xA;    decimal debitMinusCredit = Convert.ToDecimal(GetCurrentColumnValue(&quot;DebitMinusCredit&quot;) ?? 0);&#xD;&#xA;    string accountName = Convert.ToString(GetCurrentColumnValue(&quot;AccountName&quot;) ?? &quot;&quot;);&#xD;&#xA;    int currentYear = Convert.ToInt32(GetCurrentColumnValue(&quot;ResetField&quot;) ?? 0);&#xD;&#xA;    bool isContinuous = Convert.ToBoolean(GetCurrentColumnValue(&quot;IsContinuous&quot;) ?? false);&#xD;&#xA;&#xD;&#xA;    string key = $&quot;{accountName}_DEBIT&quot;;&#xD;&#xA;    string yearKey = $&quot;{accountName}_YEAR_DEBIT&quot;;&#xD;&#xA;&#xD;&#xA;    decimal runningTotal = 0m;&#xD;&#xA;&#xD;&#xA;    if (!debitRunningTotals.ContainsKey(key) || !lastProcessedYear.ContainsKey(yearKey)) {&#xD;&#xA;        // First record for this account&#xD;&#xA;        runningTotal = openBalance + debitMinusCredit;&#xD;&#xA;    }&#xD;&#xA;    else if (lastProcessedYear[yearKey] != currentYear &amp;&amp; !isContinuous) {&#xD;&#xA;        // New year and not continuous — reset&#xD;&#xA;        runningTotal = debitMinusCredit;&#xD;&#xA;    }&#xD;&#xA;    else {&#xD;&#xA;        // Continue summing total in same year or new year if isContinuos true&#xD;&#xA;        runningTotal = debitRunningTotals[key] + debitMinusCredit;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    // Update state&#xD;&#xA;    debitRunningTotals[key] = runningTotal;&#xD;&#xA;    lastProcessedYear[yearKey] = currentYear;&#xD;&#xA;&#xD;&#xA;    ((XRTableCell)sender).Text = runningTotal &gt; 0 ? runningTotal.ToString(&quot;N2&quot;) : &quot;&quot;;&#xD;&#xA;                &#xD;&#xA;                      }&#xD;&#xA; &#xD;&#xA;&#xD;&#xA;private void xrTableCell11_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;     decimal openBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenBalance&quot;) ?? 0);&#xD;&#xA;    decimal debitMinusCredit = Convert.ToDecimal(GetCurrentColumnValue(&quot;DebitMinusCredit&quot;) ?? 0);&#xD;&#xA;    string accountName = Convert.ToString(GetCurrentColumnValue(&quot;AccountName&quot;) ?? &quot;&quot;);&#xD;&#xA;    int currentYear = Convert.ToInt32(GetCurrentColumnValue(&quot;ResetField&quot;) ?? 0);&#xD;&#xA;    bool isContinuous = Convert.ToBoolean(GetCurrentColumnValue(&quot;IsContinuous&quot;) ?? false);&#xD;&#xA;&#xD;&#xA;    string key = $&quot;{accountName}_CREDIT&quot;;&#xD;&#xA;    string yearKey = $&quot;{accountName}_YEAR_CREDIT&quot;;&#xD;&#xA;&#xD;&#xA;    decimal runningTotal = 0m;&#xD;&#xA;&#xD;&#xA;    if (!creditRunningTotals.ContainsKey(key) || !lastProcessedYear.ContainsKey(yearKey)) {&#xD;&#xA;        // First record for this account&#xD;&#xA;        runningTotal = openBalance + debitMinusCredit;&#xD;&#xA;    }&#xD;&#xA;    else if (lastProcessedYear[yearKey] != currentYear &amp;&amp; !isContinuous) {&#xD;&#xA;        // New year and not continuous — reset&#xD;&#xA;        runningTotal = debitMinusCredit;&#xD;&#xA;    }&#xD;&#xA;    else {&#xD;&#xA;        // Continue from previous total&#xD;&#xA;        runningTotal = creditRunningTotals[key] + debitMinusCredit;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    // Update state&#xD;&#xA;    creditRunningTotals[key] = runningTotal;&#xD;&#xA;    lastProcessedYear[yearKey] = currentYear;&#xD;&#xA;&#xD;&#xA;    ((XRTableCell)sender).Text = runningTotal &lt; 0 ? Math.Abs(runningTotal).ToString(&quot;N2&quot;) : &quot;&quot;;    }&#xD;&#xA;&#xD;&#xA;private void xrLabel4_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     string rawValue = Parameters[&quot;AccountDim&quot;].Value as string;&#xD;&#xA;&#xD;&#xA;    if (!string.IsNullOrWhiteSpace(rawValue))&#xD;&#xA;    {&#xD;&#xA;        rawValue = rawValue.Trim();&#xD;&#xA;&#xD;&#xA;        // Remove single quotes only if they're wrapping the value&#xD;&#xA;        if (rawValue.StartsWith(&quot;'&quot;) &amp;&amp; rawValue.EndsWith(&quot;'&quot;))&#xD;&#xA;        {&#xD;&#xA;            rawValue = rawValue.Substring(1, rawValue.Length - 2);&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;        // Optional: remove other special characters&#xD;&#xA;        rawValue = Regex.Replace(rawValue, @&quot;[^\w\s\-]&quot;, &quot;&quot;); // keeps letters, digits, space, dash&#xD;&#xA;&#xD;&#xA;        xrLabel4.Text = rawValue;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        xrLabel4.Text = string.Empty;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidth="1169" PageHeight="827" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="24.2" DataMember="SR_FC_AccountSheet" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
