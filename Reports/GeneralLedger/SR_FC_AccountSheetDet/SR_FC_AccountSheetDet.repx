    <Item8 Ref="346" ControlType="GroupFooterBand" Name="GroupFooter1">
      <Scripts Ref="347" OnBeforePrint="GroupFooter1_BeforePrint" />
      <Controls>
        <Item1 Ref="348" ControlType="XRTable" Name="tFooter" AnchorHorizontal="Both" Borders="All">
          <Rows>
            <Item1 Ref="349" ControlType="XRTableRow" Name="trFooter">
              <Cells>
                <Item1 Ref="350" ControlType="XRTableCell" Name="tfTotal" CanGrow="false" Multiline="true" />
                <Item2 Ref="351" ControlType="XRTableCell" Name="tfDebit_GPT" CanGrow="false" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="352" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="353" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Debit])" />
                    <Item2 Ref="354" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="355" UseTextAlignment="false" />
                </Item2>
                <Item3 Ref="356" ControlType="XRTableCell" Name="tfCredit_GPT" CanGrow="false" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="357" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="358" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Credit])" />
                    <Item2 Ref="359" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')" />
                  </ExpressionBindings>
                  <StylePriority Ref="360" UseTextAlignment="false" />
                </Item3>
                <Item4 Ref="361" ControlType="XRTableCell" Name="xrTableCell8" CanGrow="false" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="362" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="363" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')" />
                    <Item2 Ref="364" EventName="BeforePrint" PropertyName="Text" Expression="iif&#xA;(&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]) &gt; 0,&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]),&#xA;&#x9;null&#xA;)" />
                  </ExpressionBindings>
                  <StylePriority Ref="365" UseTextAlignment="false" />
                </Item4>
                <Item5 Ref="366" ControlType="XRTableCell" Name="xrTableCell18" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="367" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="368" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')" />
                    <Item2 Ref="369" EventName="BeforePrint" PropertyName="Text" Expression="iif&#xA;(&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]) &lt; 0,&#xA;&#x9;Abs(IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit])),&#xA;&#x9;null&#xA;)" />
                  </ExpressionBindings>
                  <StylePriority Ref="370" UseTextAlignment="false" />
                </Item5>
                <Item6 Ref="371" ControlType="XRTableCell" Name="xrTableCell20" Multiline="true" />
              </Cells>
            </Item1>
          </Rows>
        </Item1>
      </Controls>
    </Item8>
