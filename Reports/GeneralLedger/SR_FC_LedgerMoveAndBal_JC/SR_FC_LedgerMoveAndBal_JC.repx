                    <Item1 Ref="500" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="501" EventName="BeforePrint" PropertyName="Text" Expression="    IIF(&#xA;        ?WhichReport In (7, 9),&#xA;        IIF(&#xA;            (SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))) &gt; 0, &#xA;            Abs(SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))), &#xA;            0&#xA;        ),&#xA;        0 &#xA;    )" />
                  </ExpressionBindings>
                  <StylePriority Ref="502" UseFont="false" />
                </Item4>
                <Item5 Ref="503" ControlType="XRTableCell" Name="xrTableCell12" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="504" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="505" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="506" EventName="BeforePrint" PropertyName="Text" Expression="    IIF(&#xA;        ?WhichReport In (7, 9),&#xA;        IIF(&#xA;            (SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))) &lt; 0, &#xA;            Abs(SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))), &#xA;            0&#xA;        ),&#xA;        0 &#xA;    )&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="507" UseFont="false" UseTextAlignment="false" />
                </Item5>
              </Cells>
            </Item1>
          </Rows>
          <StylePriority Ref="508" UseBorders="false" />
        </Item1>
      </Controls>
    </Item10>
