                    <Item2 Ref="485" EventName="BeforePrint" PropertyName="Text" Expression="    IIF(&#xD;&#xA;        ?WhichReport In (7, 9),&#xD;&#xA;        IIF(&#xD;&#xA;            (SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))) &gt; 0, &#xD;&#xA;            Abs(SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))), &#xD;&#xA;            0&#xD;&#xA;        ),&#xD;&#xA;        0 &#xD;&#xA;    )" />
