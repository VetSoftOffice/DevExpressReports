      <Controls>
        <Item1 Ref="451" ControlType="XRTable" Name="xrTable3" ProcessHiddenCellMode="ResizeCellsProportionally" AnchorHorizontal="Both" Borders="All">
          <Rows>
            <Item1 Ref="452" ControlType="XRTableRow" Name="xrTableRow3">
              <Cells>
                <Item1 Ref="453" ControlType="XRTableCell" Name="xrTableCell3" Multiline="true">
                  <ExpressionBindings>
                    <Item1 Ref="454" EventName="BeforePrint" PropertyName="Text" Expression="Iif(?IsRTL == True, &#xA;    Iif(IsNullOrEmpty([AccountName_From]), 'الإجمالي', ' إجمالي'+[AccountName_From]), &#xA;    Iif(IsNullOrEmpty([AccountName_From]), 'Total', 'Total of '+[AccountName_From])&#xA;)" />
                  </ExpressionBindings>
                </Item1>
                <Item2 Ref="455" ControlType="XRTableCell" Name="xrTableCell30" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="456" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="457" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="458" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Debit])" />
                  </ExpressionBindings>
                  <StylePriority Ref="459" UseFont="false" />
                </Item2>
                <Item3 Ref="460" ControlType="XRTableCell" Name="xrTableCell31" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="461" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="462" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="463" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Credit])" />
                  </ExpressionBindings>
                  <StylePriority Ref="464" UseFont="false" />
                </Item3>
                <Item4 Ref="465" ControlType="XRTableCell" Name="xrTableCell53" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="466" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="467" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="468" EventName="BeforePrint" PropertyName="Text" Expression="    IIF(&#xA;        ?WhichReport In (3, 5),&#xA;        IIF(&#xA;            (SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))) &gt; 0, &#xA;            Abs(SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))), &#xA;            0&#xA;        ),&#xA;        0 &#xA;    )&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="469" UseFont="false" />
                </Item4>
                <Item5 Ref="470" ControlType="XRTableCell" Name="xrTableCell54" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="471" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="472" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="473" EventName="BeforePrint" PropertyName="Text" Expression="    IIF(&#xA;        ?WhichReport In (3, 5),&#xA;        IIF(&#xA;            (SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))) &lt; 0, &#xA;            Abs(SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))), &#xA;            0&#xA;        ),&#xA;        0 &#xA;    )&#xA;" />
                  </ExpressionBindings>
