                    <Item1 Ref="486" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="487" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Credit])" />
                  </ExpressionBindings>
                  <StylePriority Ref="488" UseFont="false" UseBorderWidth="false" />
                </Item3>
                <Item4 Ref="489" ControlType="XRTableCell" Name="xrTableCell53" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="490" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="491" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="492" EventName="BeforePrint" PropertyName="Text" Expression="    IIF(&#xD;&#xA;        ?WhichReport In (3, 5),&#xD;&#xA;        IIF(&#xD;&#xA;            (SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))) &gt; 0, &#xD;&#xA;            Abs(SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))), &#xD;&#xA;            0&#xD;&#xA;        ),&#xD;&#xA;        0 &#xD;&#xA;    )&#xD;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="493" UseFont="false" UseBorderWidth="false" />
                </Item4>
                <Item5 Ref="494" ControlType="XRTableCell" Name="xrTableCell54" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="495" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="496" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="497" EventName="BeforePrint" PropertyName="Text" Expression="    IIF(&#xD;&#xA;        ?WhichReport In (3, 5),&#xD;&#xA;        IIF(&#xD;&#xA;            (SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))) &lt; 0, &#xD;&#xA;            Abs(SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))), &#xD;&#xA;            0&#xD;&#xA;        ),&#xD;&#xA;        0 &#xD;&#xA;    )&#xD;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="498" UseFont="false" UseBorderWidth="false" UseTextAlignment="false" />
                </Item5>
              </Cells>
            </Item1>
          </Rows>
          <StylePriority Ref="499" UseBorders="false" />
        </Item1>
      </Controls>
      <ExpressionBindings>
        <Item1 Ref="500" EventName="BeforePrint" PropertyName="Visible" Expression="?UniqueAccountFromCount &gt; 1" />
      </ExpressionBindings>
    </Item8>
