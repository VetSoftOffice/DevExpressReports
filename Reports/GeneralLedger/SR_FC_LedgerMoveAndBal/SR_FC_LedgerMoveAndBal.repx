                <Item1 Ref="459" ControlType="XRTableCell" Name="xrTableCell3" Multiline="true">
                  <ExpressionBindings>
                    <Item1 Ref="460" EventName="BeforePrint" PropertyName="Text" Expression="Iif(?IsRTL == True, &#xA;    Iif(IsNullOrEmpty([AccountName_From]), 'الإجمالي', ' إجمالي'+[AccountName_From]), &#xA;    Iif(IsNullOrEmpty([AccountName_From]), 'Total', 'Total of '+[AccountName_From])&#xA;)" />
