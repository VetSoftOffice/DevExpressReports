                <Item4 Ref="490" ControlType="XRTableCell" Name="xrTableCell53" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="491" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="492" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="493" EventName="BeforePrint" PropertyName="Text" Expression="    IIF(&#xD;&#xA;        ?WhichReport In (3, 5),&#xD;&#xA;        IIF(&#xD;&#xA;            (SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))) &gt; 0, &#xD;&#xA;            Abs(SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))), &#xD;&#xA;            0&#xD;&#xA;        ),&#xD;&#xA;        0 &#xD;&#xA;    )&#xD;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="494" UseFont="false" UseBorderWidth="false" />
                </Item4>
                <Item5 Ref="495" ControlType="XRTableCell" Name="xrTableCell54" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="496" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="497" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="498" EventName="BeforePrint" PropertyName="Text" Expression="    IIF(&#xD;&#xA;        ?WhichReport In (3, 5),&#xD;&#xA;        IIF(&#xD;&#xA;            (SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))) &lt; 0, &#xD;&#xA;            Abs(SumRunningSum(ISNULL([Debit], 0) - ISNULL([Credit], 0)) + SumDSum(ISNULL([OpenBalanceDebit], 0) - ISNULL([OpenBalanceCredit], 0))), &#xD;&#xA;            0&#xD;&#xA;        ),&#xD;&#xA;        0 &#xD;&#xA;    )&#xD;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="499" UseFont="false" UseBorderWidth="false" UseTextAlignment="false" />
                </Item5>
              </Cells>
            </Item1>
          </Rows>
