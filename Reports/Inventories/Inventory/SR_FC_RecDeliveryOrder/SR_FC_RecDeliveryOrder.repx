        <Item3 Ref="338" ControlType="XRLabel" Name="CustSuppNameLabel">
          <ExpressionBindings>
            <Item1 Ref="339" EventName="BeforePrint" PropertyName="Visible" Expression=" Not IsNullOrEmpty(?ActionType)" />
            <Item2 Ref="340" EventName="BeforePrint" PropertyName="Text" Expression="Iif(?ActionType == 6, ?Customer, ?Supplier) + ':  ' + [To]" />
          </ExpressionBindings>
          <StylePriority Ref="341" UseFont="false" />
        </Item3>
        <Item4 Ref="342" ControlType="XRLabel" Name="CustSuppCodeLabel">
          <ExpressionBindings>
            <Item1 Ref="343" EventName="BeforePrint" PropertyName="Visible" Expression=" Not IsNullOrEmpty(?ActionType)" />
            <Item2 Ref="344" EventName="BeforePrint" PropertyName="Text" Expression="Iif(?ActionType == 6, ?CustomerCode, ?SupplierCode) + ':  ' + [CodeTo]&#xA;" />
          </ExpressionBindings>
          <StylePriority Ref="345" UseFont="false" />
        </Item4>
        <Item5 Ref="346" ControlType="XRLabel" Name="DocumentNoLabel">
          <StylePriority Ref="347" UseFont="false" />
        </Item5>
      </Controls>
