            <Item2 Ref="537" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
          </ExpressionBindings>
          <StylePriority Ref="538" UseFont="false" UseBorders="false" UseTextAlignment="false" />
