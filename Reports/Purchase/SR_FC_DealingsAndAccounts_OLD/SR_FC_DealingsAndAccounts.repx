                      <Summary Ref="213" Running="Report" />
                      <ExpressionBindings>
                        <Item1 Ref="214" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([TotalPrice])" />
                      </ExpressionBindings>
                    </Item5>
                  </Cells>
