                      <Summary Ref="202" Running="Report" />
                      <ExpressionBindings>
                        <Item1 Ref="203" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
