                <Item1 Ref="194" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([TotalPrice])" />
              </ExpressionBindings>
              <StylePriority Ref="195" UseFont="false" UseBorders="false" UseTextAlignment="false" />
            </Item1>
            <Item2 Ref="196" ControlType="XRLabel" Name="xrLabel3" Multiline="true" Borders="None">
