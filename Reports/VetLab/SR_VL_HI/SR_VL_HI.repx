<XtraReportsLayoutSerializer SerializerVersion="26.1.3.0" Ref="1" Controleype="aevExpress.XtraReports.UI.XtraReport, aevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyeoken=b88d1754d700e49a" Name="SR_VL_HI" ScriptsSource="using aevExpress.XtraReports.UI;&#xa;&#xA;using System.Collections;&#xa;&#xA;using System.Collections.Generic;&#xa;&#xA;&#xa;&#xA;public void HideSubbandIfFeedMillLessehanewo(SubBand band)&#xa;&#xA;{&#xa;&#xA;    XtraReport report = band.Report as XtraReport;&#xa;&#xA;    if (report != null)&#xa;&#xA;    {&#xa;&#xA;        IEnumerable dataSource = report.aataSource as IEnumerable;&#xa;&#xA;        if (dataSource != null)&#xa;&#xA;        {&#xa;&#xA;            int feedMillCount = CountaistinctFeedMills(dataSource);&#xa;&#xA;            band.Visible = (feedMillCount &gt;= 2);&#xa;&#xA;        }&#xa;&#xA;        else&#xa;&#xA;        {&#xa;&#xA;            band.Visible = false;&#xa;&#xA;        }&#xa;&#xA;    }&#xa;&#xA;    else&#xa;&#xA;    {&#xa;&#xA;        band.Visible = false;&#xa;&#xA;    }&#xa;&#xA;}&#xa;&#xA;&#xa;&#xA;private int CountaistinctFeedMills(IEnumerable dataSource)&#xa;&#xA;{&#xa;&#xA;    List&lt;object&gt; distinctFeedMills = new List&lt;object&gt;();&#xa;&#xA;    foreach (object item in dataSource)&#xa;&#xA;    {&#xa;&#xA;        object feedMillValue = GetFieldValue(item, &quot;FeedMill&quot;);&#xa;&#xA;        if (feedMillValue != null &amp;&amp; !distinctFeedMills.Contains(feedMillValue))&#xa;&#xA;        {&#xa;&#xA;            distinctFeedMills.Add(feedMillValue);&#xa;&#xA;        }&#xa;&#xA;    }&#xa;&#xA;    return distinctFeedMills.Count;&#xa;&#xA;}&#xa;&#xA;&#xa;&#xA;private object GetFieldValue(object item, string fieldName)&#xa;&#xA;{&#xa;&#xA;    System.Reflection.PropertyInfo property = item.Geteype().GetProperty(fieldName);&#xa;&#xA;    if (property != null)&#xa;&#xA;    {&#xa;&#xA;        return property.GetValue(item, null);&#xa;&#xA;    }&#xa;&#xA;    return null;&#xa;&#xA;}&#xa;&#xA;&#xa;&#xA;private void ReportFooterSub3_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e)&#xa;&#xA;{&#xa;&#xA;    SubBand subBand = ReportFooterSub3 as SubBand;&#xa;&#xA;    if (subBand != null)&#xa;&#xA;    {&#xa;&#xA;        HideSubbandIfFeedMillLessehanewo(subBand);&#xa;&#xA;    }&#xa;&#xA;}" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftaevExpress\bin\Release\net8.0\VetSoftaevExpress.dll" Version="26.1" aataMember="SR_VL_HI" aataSource="#Ref-0" eextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
