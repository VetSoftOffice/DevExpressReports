                  <Item1 Ref="136" Name="TotalCost" Expression="[CostPerTon] * [ActualQty]" DataMember="SR_FC_SalesSheet" />
                  <Item2 Ref="137" Name="TotalProfit" Expression="[TotalPrice] - [TotalCost]" DataMember="SR_FC_SalesSheet" />
                  <Item3 Ref="138" Name="Message" Expression="Iif([R_FM_IngredientRec_Remarks.Qty] &lt;&gt; 0, &#xA;   '(' + [SR_FM_IngredientRec_Remarks.IngredientName_en] + ' - ' + &#xA;    FormatString([SR_FM_IngredientRec_Remarks.Qty] / 1000, 'F3') + ' Tons) ', ''&#xA;   &#xA;)&#xA;" DataMember="SR_FM_IngReceiving" />
                  <Item4 Ref="139" Name="SampleDetails" Expression="'Organ Swab (' + [Organs] + ')'&#xA;" DataMember="SR_VL_IsoBactSns_SAL_PQP1" />
                  <Item5 Ref="140" Name="Results" Expression="Iif([DiscContent] == '',&#xD;&#xA;    'ND',&#xD;&#xA;    Iif([MeanZoneInhib] == 0,&#xD;&#xA;        'NA',&#xD;&#xA;        Iif([MeanZoneInhib] &lt;= [Resistant],&#xD;&#xA;            'Resistant',&#xD;&#xA;            Iif([MeanZoneInhib] &gt; [Resistant] &#xD;&#xA;                And [MeanZoneInhib] &lt; [Susceptible],&#xD;&#xA;                'Intermediate',&#xD;&#xA;                'Sensitive'&#xD;&#xA;            )&#xD;&#xA;        )&#xD;&#xA;    )&#xD;&#xA;)&#xD;&#xA;" DataMember="SR_VL_IsoBactSns_SAL_PQP1_1" />
                  <Item6 Ref="141" Name="Comments" Expression="'Comments: Antibiotic Sensitivity test was carried out on ' + [MicroOrganismName_en] + ').'&#xA;" DataMember="SR_VL_IsoBactSns_SAL_PQP1_1" />
                </CalculatedFields>
