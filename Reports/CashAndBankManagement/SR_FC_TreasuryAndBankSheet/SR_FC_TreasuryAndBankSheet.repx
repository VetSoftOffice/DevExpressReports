    <Item8 Ref="253" ControlType="GroupFooterBand" Name="GroupFooter1">
      <Scripts Ref="254" OnBeforePrint="GroupFooter1_BeforePrint" />
      <Controls>
        <Item1 Ref="255" ControlType="XRTable" Name="tFooter" AnchorHorizontal="Both" Borders="All">
          <Rows>
            <Item1 Ref="256" ControlType="XRTableRow" Name="trFooter">
