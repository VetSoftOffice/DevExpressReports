                <Item2 Ref="298" ControlType="XRTableCell" Name="tfDebit_GPT" CanGrow="false" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="299" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="300" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Debit])" />
                    <Item2 Ref="301" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="302" UseFont="false" UseBorderWidth="false" UseTextAlignment="false" />
                </Item2>
                <Item3 Ref="303" ControlType="XRTableCell" Name="tfCredit_GPT" CanGrow="false" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="304" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="305" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Credit])" />
                    <Item2 Ref="306" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')" />
                  </ExpressionBindings>
                  <StylePriority Ref="307" UseFont="false" UseBorderWidth="false" UseTextAlignment="false" />
                </Item3>
                <Item4 Ref="308" ControlType="XRTableCell" Name="xrTableCell8" CanGrow="false" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="309" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="310" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')" />
                    <Item2 Ref="311" EventName="BeforePrint" PropertyName="Text" Expression="iif&#xA;(&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]) &gt; 0,&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]),&#xA;&#x9;null&#xA;)" />
                  </ExpressionBindings>
                  <StylePriority Ref="312" UseFont="false" UseBorderWidth="false" UseTextAlignment="false" />
                </Item4>
                <Item5 Ref="313" ControlType="XRTableCell" Name="xrTableCell18" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="314" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="315" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')" />
                    <Item2 Ref="316" EventName="BeforePrint" PropertyName="Text" Expression="iif&#xA;(&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]) &lt; 0,&#xA;&#x9;Abs(IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit])),&#xA;&#x9;null&#xA;)" />
                  </ExpressionBindings>
                  <StylePriority Ref="317" UseFont="false" UseBorderWidth="false" UseTextAlignment="false" />
