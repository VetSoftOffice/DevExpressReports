    <Item8 Ref="250" ControlType="GroupFooterBand" Name="GroupFooter1">
      <Scripts Ref="251" OnBeforePrint="GroupFooter1_BeforePrint" />
      <Controls>
        <Item1 Ref="252" ControlType="XRTable" Name="tFooter" AnchorHorizontal="Both" Borders="All">
          <Rows>
            <Item1 Ref="253" ControlType="XRTableRow" Name="trFooter">
              <Cells>
                <Item1 Ref="254" ControlType="XRTableCell" Name="tfTotal" CanGrow="false" Multiline="true">
                  <StylePriority Ref="255" UseFont="false" />
                </Item1>
                <Item2 Ref="256" ControlType="XRTableCell" Name="tfDebit_GPT" CanGrow="false" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="257" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="258" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Debit])" />
                    <Item2 Ref="259" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="260" UseFont="false" UseTextAlignment="false" />
                </Item2>
                <Item3 Ref="261" ControlType="XRTableCell" Name="tfCredit_GPT" CanGrow="false" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="262" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="263" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Credit])" />
                    <Item2 Ref="264" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')" />
                  </ExpressionBindings>
                  <StylePriority Ref="265" UseFont="false" UseTextAlignment="false" />
                </Item3>
                <Item4 Ref="266" ControlType="XRTableCell" Name="xrTableCell8" CanGrow="false" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="267" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="268" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')" />
                    <Item2 Ref="269" EventName="BeforePrint" PropertyName="Text" Expression="iif&#xA;(&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]) &gt; 0,&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]),&#xA;&#x9;null&#xA;)" />
                  </ExpressionBindings>
                  <StylePriority Ref="270" UseFont="false" UseTextAlignment="false" />
                </Item4>
                <Item5 Ref="271" ControlType="XRTableCell" Name="xrTableCell18" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="272" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="273" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')" />
                    <Item2 Ref="274" EventName="BeforePrint" PropertyName="Text" Expression="iif&#xA;(&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]) &lt; 0,&#xA;&#x9;Abs(IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit])),&#xA;&#x9;null&#xA;)" />
                  </ExpressionBindings>
                  <StylePriority Ref="275" UseFont="false" UseTextAlignment="false" />
                </Item5>
                <Item6 Ref="276" ControlType="XRTableCell" Name="xrTableCell20" Multiline="true" />
              </Cells>
            </Item1>
          </Rows>
        </Item1>
      </Controls>
