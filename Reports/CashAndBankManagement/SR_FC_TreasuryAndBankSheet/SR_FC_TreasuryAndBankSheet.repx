                  <StylePriority Ref="258" UseFont="false" />
                </Item1>
                <Item2 Ref="259" ControlType="XRTableCell" Name="tfDebit_GPT" CanGrow="false" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="260" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="261" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Debit])" />
                    <Item2 Ref="262" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="263" UseFont="false" UseTextAlignment="false" />
                </Item2>
                <Item3 Ref="264" ControlType="XRTableCell" Name="tfCredit_GPT" CanGrow="false" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="265" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="266" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Credit])" />
                    <Item2 Ref="267" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')" />
                  </ExpressionBindings>
                  <StylePriority Ref="268" UseFont="false" UseTextAlignment="false" />
                </Item3>
                <Item4 Ref="269" ControlType="XRTableCell" Name="xrTableCell8" CanGrow="false" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="270" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="271" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')" />
                    <Item2 Ref="272" EventName="BeforePrint" PropertyName="Text" Expression="iif&#xA;(&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]) &gt; 0,&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]),&#xA;&#x9;null&#xA;)" />
                  </ExpressionBindings>
                  <StylePriority Ref="273" UseFont="false" UseTextAlignment="false" />
                </Item4>
                <Item5 Ref="274" ControlType="XRTableCell" Name="xrTableCell18" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="275" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="276" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')" />
                    <Item2 Ref="277" EventName="BeforePrint" PropertyName="Text" Expression="iif&#xA;(&#xA;&#x9;IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit]) &lt; 0,&#xA;&#x9;Abs(IsNull([OpenBalance], 0) + sumSum([DebitMinusCredit])),&#xA;&#x9;null&#xA;)" />
                  </ExpressionBindings>
                  <StylePriority Ref="278" UseFont="false" UseTextAlignment="false" />
                </Item5>
                <Item6 Ref="279" ControlType="XRTableCell" Name="xrTableCell20" Multiline="true" />
              </Cells>
            </Item1>
