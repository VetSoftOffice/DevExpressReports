      <Scripts Ref="293" OnBeforePrint="GroupFooter1_BeforePrint" />
      <Controls>
        <Item1 Ref="294" ControlType="XRTable" Name="tFooter" AnchorHorizontal="Both" Borders="All">
          <Rows>
            <Item1 Ref="295" ControlType="XRTableRow" Name="trFooter">
