      <Scripts Ref="292" OnBeforePrint="GroupFooter1_BeforePrint" />
      <Controls>
        <Item1 Ref="293" ControlType="XRTable" Name="tFooter" AnchorHorizontal="Both" Borders="All">
          <Rows>
            <Item1 Ref="294" ControlType="XRTableRow" Name="trFooter">
