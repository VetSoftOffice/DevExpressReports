    <Item10 Ref="41" Name="Inputs_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([InputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
    <Item11 Ref="42" Name="Consumed_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([Consumed])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
    <Item12 Ref="43" Name="Outputs_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([SoldTransferOut])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
    <Item13 Ref="44" Name="Other_Output_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([OtherOutputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
    <Item14 Ref="45" Name="Close_Balance_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([CloseBalance])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
    <Item15 Ref="46" Name="Test" DataMember="SR_FC_FM_StockMovement" />
    <Item16 Ref="47" Name="Avg_Wt_PP" Expression="Iif([Birds_PT] &gt; 0, &#xA;    [TotalWt_PT] / [Birds_PT], &#xA;    Null)&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
    <Item17 Ref="48" Name="Avg_Wt_SL" Expression="Iif([Birds_SL] &gt; 0, &#xA;    [TotalWt_SL] / [Birds_SL], &#xA;    Null)&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
    <Item18 Ref="49" Name="G_Birds" Expression="[Birds_PT] + [Birds_SL]&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
    <Item19 Ref="50" Name="G_Wt" Expression="[TotalWt_PT] + IsNull([TotalWt_SL],0)&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
    <Item20 Ref="51" Name="G_Avg_Wt" Expression="Iif([G_Birds] &gt; 0, [G_Wt] / [G_Birds], 0)&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
    <Item21 Ref="52" Name="SmallEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.SmallEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item22 Ref="53" Name="OverWeightEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.OverWeightEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item23 Ref="54" Name="DirtyEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.DirtyEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item24 Ref="55" Name="DeformityEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.DeformityEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item25 Ref="56" Name="BrokenEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.BrokenEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item26 Ref="57" Name="DestroyedEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.DestroyedEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item27 Ref="58" Name="CrackedEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.CrackedEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item28 Ref="59" Name="DYE" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.DoubleYolkEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item29 Ref="60" Name="OtherEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.OtherEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item30 Ref="61" Name="TotalUnHatch" Expression="[SR_HT_RecHall.SoftShellEggs] + [SR_HT_RecHall.MinorCrackedEggs] + [SR_HT_RecHall.MajorCrackedEggs] + [SR_HT_RecHall.ThinShellEggs] + [SR_HT_RecHall.OtherEggs] + [SR_HT_RecHall.WholeEggs] + &#xD;&#xA;[SR_HT_RecHall.BrokenEggs] + [SR_HT_RecHall.SmallEggs] + [SR_HT_RecHall.OverWeightEggs] + [SR_HT_RecHall.DirtyEggs] + [SR_HT_RecHall.DeformityEggs] + [SR_HT_RecHall.CrackedEggs] + &#xD;&#xA;[SR_HT_RecHall.DoubleYolkEggs] + [SR_HT_RecHall.DestroyedEggs]&#xD;&#xA;" DataMember="SR_HT_RecHall" />
    <Item31 Ref="62" Name="TotalPerc" Expression="IIf([SR_HT_RecHall.RecEggs] &lt;&gt; 0, [TotalUnHatch] * 100.0 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item32 Ref="63" Name="HatchingEggsPerc" Expression="IIf([SR_HT_RecHall.RecEggs] &lt;&gt; 0, [SR_HT_RecHall.HatchingEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item33 Ref="64" Name="TotalBalance" Expression="[HatchingEggs] + [OpenStock]" DataMember="SR_HT_RecHall" />
    <Item34 Ref="65" Name="DailyBalance" Expression="[SR_HT_RecHall.HatchingEggs] + [SR_HT_RecHall.OpenStock] - [SR_HT_RecHall.SoldEggs] - [SR_HT_RecHall.SettedEggs]&#xA;" DataMember="SR_HT_RecHall" />
    <Item35 Ref="66" Name="OpenMachineEggs" Expression="[OpenSetterEggs] + [OpenHatcherEggs]" DataMember="SR_HT_RecAndSettedEggs" />
    <Item36 Ref="67" Name="Total" Expression="[OpenEggStoreEggs] + [RecEggs]" DataMember="SR_HT_RecAndSettedEggs" />
    <Item37 Ref="68" Name="TotalExitHatchers" Expression="[Deads] + [Culls] + [DestroyedEggs] + [UnHatEggs] + [Chicks]" DataMember="SR_HT_RecAndSettedEggs" />
    <Item38 Ref="69" Name="CloseMachineEggs" Expression="[CloseSetterEggs] + [CloseHatcherEggs]" DataMember="SR_HT_RecAndSettedEggs" />
    <Item39 Ref="70" Name="TotalFem" Expression="IIF(IsNullOrEmpty([FemaleMort]), 0, [FemaleMort]) + &#xA;IIF(IsNullOrEmpty([FemalCulls]), 0, [FemalCulls])&#xA;" DataMember="SR_BRD_DailySiteWise" />
    <Item40 Ref="71" Name="TotalMale" Expression="IIF(IsNullOrEmpty([MaleMort]), 0, [MaleMort]) + &#xA;IIF(IsNullOrEmpty([MaleCulls]), 0, [MaleCulls])&#xA;" DataMember="SR_BRD_DailySiteWise" />
    <Item41 Ref="72" Name="FlockAge" Expression="30" DataMember="SR_BRD_DailyProduction" />
    <Item42 Ref="73" Name="GroupByWeek" Expression="IIF(&#xA;    IsNull([AgeWeek]) OR ?FlockAge Is Null, &#xA;    ?FlockAge, &#xA;    IIF([AgeWeek] &lt;= ?FlockAge, ?FlockAge, ?FlockAge + 1)&#xA;)" DataMember="SR_BRD_DailyProduction" />
    <Item43 Ref="74" Name="Group1" Expression="IIF(&#xA;    IsNullOrEmpty([GroupByWeek]) OR IsNullOrEmpty([FlockAge]),&#xA;    ' ',&#xA;    IIF([GroupByWeek] = [FlockAge], &#xA;        ToStr([FlockAge]) + ' ' + IIF(IsNullOrEmpty(?WeeksOfAgeAndBelow), ' ', ?WeeksOfAgeAndBelow), &#xA;        ToStr([FlockAge]) + ' ' + IIF(IsNullOrEmpty(?AgeWeeks), '', ?AgeWeeks) + ' ' + IIF(IsNullOrEmpty(?TotalAbove), ' ', ?TotalAbove)&#xA;    )&#xA;)" DataMember="SR_BRD_DailyProduction" />
