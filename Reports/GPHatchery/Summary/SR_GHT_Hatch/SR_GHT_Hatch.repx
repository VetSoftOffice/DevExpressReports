<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_GHT_Hatch" ScriptsSource="decimal DeadsReport  = 0;&#xD;&#xA;decimal CullsReport  = 0;&#xD;&#xA;decimal SettedEggsGradeOutReport  = 0;&#xD;&#xA;decimal GradeOutReport = 0;&#xD;&#xA;decimal DeadsGroup = 0;&#xD;&#xA;decimal CullsGroup = 0;&#xD;&#xA;decimal SettedEggsGradeOutGroup = 0;&#xD;&#xA;decimal GradeOutGroup = 0;&#xD;&#xA;decimal FChicksReport  = 0;&#xD;&#xA;decimal MChicksReport = 0;&#xD;&#xA;decimal BreederTotal = 0;&#xD;&#xA;decimal SettedEggsBreederReport = 0;&#xD;&#xA;decimal FChicksGroup = 0;&#xD;&#xA;decimal MChicksGroup = 0;&#xD;&#xA;decimal SettedEggsBreederGroup = 0;&#xD;&#xA;decimal BreederGroup = 0;&#xD;&#xA;decimal ChicksGroup = 0;&#xD;&#xA;decimal SettedEggsChicksGroup = 0;&#xD;&#xA;decimal ChicksReport  = 0;&#xD;&#xA;decimal SettedEggsChicksReport  = 0;&#xD;&#xA;decimal TotalChicksReport  = 0;&#xD;&#xA;decimal SettedEggsTotalChicksReport  = 0;&#xD;&#xA;decimal TotalChicksGroup = 0;&#xD;&#xA;decimal SettedEggstotalChicksGroup = 0;&#xD;&#xA;decimal NonHatchedReport  = 0;&#xD;&#xA;private void xrTableCell6_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal Deads = 0;&#xD;&#xA;    decimal Culls= 0;&#xD;&#xA;    decimal SettedEggsGradeOut = 0;&#xD;&#xA;    decimal result = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Deads&quot;) != null )&#xD;&#xA;        Deads = Convert.ToDecimal(GetCurrentColumnValue(&quot;Deads&quot;));&#xD;&#xA;        &#xD;&#xA;    if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;        Culls= Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;        &#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        SettedEggsGradeOut = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    &#xD;&#xA;    if (SettedEggsGradeOut != 0)&#xD;&#xA;    result = ((Deads  + Culls) *100)/ SettedEggsGradeOut ;&#xD;&#xA;&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); &#xD;&#xA;    DeadsReport += Deads ;&#xD;&#xA;    CullsReport += Culls;&#xD;&#xA;    SettedEggsGradeOutReport += SettedEggsGradeOut ;&#xD;&#xA;    GradeOutReport = DeadsReport  + CullsReport ;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      decimal Deads = 0;&#xD;&#xA;    decimal Culls= 0;&#xD;&#xA;    decimal SettedEggsGradeOut = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Deads&quot;) != null )&#xD;&#xA;        Deads = Convert.ToDecimal(GetCurrentColumnValue(&quot;Deads&quot;));&#xD;&#xA;        &#xD;&#xA;    if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;        Culls= Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;        &#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        SettedEggsGradeOut = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;        &#xD;&#xA;    DeadsGroup += Deads ;&#xD;&#xA;    CullsGroup += Culls;&#xD;&#xA;    SettedEggsGradeOutGroup += SettedEggsGradeOut ;&#xD;&#xA;    GradeOutGroup = DeadsGroup + CullsGroup ;&#xD;&#xA;    &#xD;&#xA;    //new lgoc for breeder&#xD;&#xA;    decimal FChicks = 0;&#xD;&#xA;    decimal MChicks = 0;&#xD;&#xA;    decimal SettedEggs_Breeder = 0;&#xD;&#xA;    &#xD;&#xA;    // --- FChicks ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FChicks&quot;) != null)&#xD;&#xA;        FChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;FChicks&quot;));&#xD;&#xA;    &#xD;&#xA;    // --- MChicks ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;MChicks&quot;) != null)&#xD;&#xA;        MChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;MChicks&quot;));&#xD;&#xA;    &#xD;&#xA;    // --- SettedEggs ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        SettedEggs_Breeder = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;        &#xD;&#xA;    FChicksGroup += FChicks ;&#xD;&#xA;    MChicksGroup += MChicks ;&#xD;&#xA;    SettedEggsBreederGroup += SettedEggs_Breeder ;&#xD;&#xA;    BreederGroup = FChicksGroup + MChicksGroup ;&#xD;&#xA;    &#xD;&#xA;    //new logic for broiler&#xD;&#xA;    decimal Chicks = 0;&#xD;&#xA;    decimal SettedEggsChicks = 0;&#xD;&#xA;    &#xD;&#xA;    // --- Chicks ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Chicks&quot;) != null)&#xD;&#xA;        Chicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;Chicks&quot;));&#xD;&#xA;    &#xD;&#xA;    // --- SettedEggs ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        SettedEggsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    ChicksGroup += Chicks ;&#xD;&#xA;    SettedEggsChicksGroup += SettedEggsChicks  ;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;    //new logic for Total Chicks&#xD;&#xA;    decimal SettedEggsTotalChicks = 0;&#xD;&#xA;    decimal UnHatEggs = 0;&#xD;&#xA;    decimal DestroyEggs = 0;&#xD;&#xA;    decimal NonHatched = 0;&#xD;&#xA;    decimal TotalChicks = 0;&#xD;&#xA;    &#xD;&#xA;    // --- SettedEggs ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;       SettedEggsTotalChicks  = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;    &#xD;&#xA;    // --- UnHatEggs ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;UnHatEggs&quot;) != null)&#xD;&#xA;        UnHatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;UnHatEggs&quot;));&#xD;&#xA;    &#xD;&#xA;    // --- DestroyEggs ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;DestroyEggs&quot;) != null)&#xD;&#xA;        DestroyEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DestroyEggs&quot;));&#xD;&#xA;    &#xD;&#xA;    // --- @NonHatched = UnHatEggs + DestroyEggs ---&#xD;&#xA;    NonHatched = UnHatEggs + DestroyEggs;&#xD;&#xA;    &#xD;&#xA;    // --- @TotalChicks = SettedEggs - NonHatched ---&#xD;&#xA;    TotalChicks = SettedEggsTotalChicks  - NonHatched;&#xD;&#xA;    TotalChicksGroup += TotalChicks;&#xD;&#xA;    SettedEggstotalChicksGroup += SettedEggsTotalChicks  ;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell43_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal GradeGradeOutTotalGroup  = 0;&#xD;&#xA;    if(SettedEggsGradeOutGroup  != 0){&#xD;&#xA;        &#xD;&#xA;            GradeGradeOutTotalGroup = ((DeadsGroup + CullsGroup) * 100) / SettedEggsGradeOutGroup;         }&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;     cell.Text = GradeGradeOutTotalGroup.ToString(&quot;0.00&quot;);&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;private void xrTableCell25_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal GradeGradeOutTotalReport  = 0;&#xD;&#xA;     if(SettedEggsGradeOutReport  != 0){&#xD;&#xA;        &#xD;&#xA;            GradeGradeOutTotalReport = (GradeOutReport * 100m) / SettedEggsGradeOutReport ;&#xD;&#xA;        }&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;     cell.Text = GradeGradeOutTotalReport.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void tdCredit_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;decimal FChicks = 0;&#xD;&#xA;decimal MChicks = 0;&#xD;&#xA;decimal SettedEggs = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;// --- FChicks ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;FChicks&quot;) != null)&#xD;&#xA;    FChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;FChicks&quot;));&#xD;&#xA;&#xD;&#xA;// --- MChicks ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;MChicks&quot;) != null)&#xD;&#xA;    MChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;MChicks&quot;));&#xD;&#xA;&#xD;&#xA;// --- SettedEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    SettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Breeders = FChicks + MChicks ---&#xD;&#xA;decimal Breeders = FChicks + MChicks;&#xD;&#xA;&#xD;&#xA;// --- Calculate result ---&#xD;&#xA;if (SettedEggs != 0)&#xD;&#xA;    result = (Breeders * 100) / SettedEggs;&#xD;&#xA;&#xD;&#xA;// --- Write result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;// If you need accumulators (same style as your previous code)&#xD;&#xA;FChicksReport += FChicks ;&#xD;&#xA;MChicksReport += MChicks ;&#xD;&#xA;BreederTotal = FChicksReport  + MChicksReport ;&#xD;&#xA;SettedEggsBreederReport += SettedEggs;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell45_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       decimal BreederTotalGroup  = 0;&#xD;&#xA;    if(SettedEggsBreederGroup != 0){&#xD;&#xA;        &#xD;&#xA;            BreederTotalGroup  = (BreederGroup * 100m) / SettedEggsBreederGroup ;&#xD;&#xA;        }&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;     cell.Text = BreederTotalGroup.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell51_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        decimal BreederTotalReport  = 0;&#xD;&#xA;     if(SettedEggsBreederReport != 0){&#xD;&#xA;        &#xD;&#xA;            BreederTotalReport  = (BreederTotal * 100m) / SettedEggsBreederReport ;&#xD;&#xA;        }&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;     cell.Text = BreederTotalReport.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell15_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;decimal Chicks = 0;&#xD;&#xA;decimal SettedEggs = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;// --- Chicks ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Chicks&quot;) != null)&#xD;&#xA;    Chicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;Chicks&quot;));&#xD;&#xA;&#xD;&#xA;// --- SettedEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    SettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Calculate Percentage ---&#xD;&#xA;if (SettedEggs != 0)&#xD;&#xA;    result = (Chicks * 100m) / SettedEggs;&#xD;&#xA;&#xD;&#xA;// --- Write to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;// --- Accumulators (Group or Report totals) ---&#xD;&#xA;ChicksReport += Chicks;&#xD;&#xA;SettedEggsChicksReport += SettedEggs;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell47_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal ChicksTotalGroup  = 0;&#xD;&#xA;    if(SettedEggsChicksGroup != 0){&#xD;&#xA;        &#xD;&#xA;            ChicksTotalGroup  = (ChicksGroup  * 100m) / SettedEggsChicksGroup ;&#xD;&#xA;        }&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;     cell.Text = ChicksTotalGroup.ToString(&quot;0.00&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell53_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal ChicksTotalReport = 0;&#xD;&#xA;    if(SettedEggsChicksReport != 0){&#xD;&#xA;        &#xD;&#xA;                   ChicksTotalReport = (ChicksReport * 100m) / SettedEggsChicksReport ;&#xD;&#xA;       }&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;     cell.Text = ChicksTotalReport.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell17_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;decimal SettedEggsTotalChicks = 0;&#xD;&#xA;decimal UnHatEggs = 0;&#xD;&#xA;decimal DestroyEggs = 0;&#xD;&#xA;decimal NonHatched = 0;&#xD;&#xA;decimal TotalChicks = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;// --- SettedEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;   SettedEggsTotalChicks  = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- UnHatEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;UnHatEggs&quot;) != null)&#xD;&#xA;    UnHatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;UnHatEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- DestroyEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;DestroyEggs&quot;) != null)&#xD;&#xA;    DestroyEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DestroyEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- @NonHatched = UnHatEggs + DestroyEggs ---&#xD;&#xA;NonHatched = UnHatEggs + DestroyEggs;&#xD;&#xA;&#xD;&#xA;// --- @TotalChicks = SettedEggs - NonHatched ---&#xD;&#xA;TotalChicks = SettedEggsTotalChicks  - NonHatched;&#xD;&#xA;&#xD;&#xA;// --- Calculate result ---&#xD;&#xA;if (SettedEggsTotalChicks  != 0)&#xD;&#xA;    result = (TotalChicks * 100) / SettedEggsTotalChicks  ;&#xD;&#xA;&#xD;&#xA;// --- Write result ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;// --- Accumulators if needed ---&#xD;&#xA;NonHatchedReport +=  NonHatched ;&#xD;&#xA;TotalChicksReport += TotalChicks;&#xD;&#xA;SettedEggsTotalChicksReport += SettedEggsTotalChicks ;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell49_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        decimal TotalChicksGroupPer  = 0;&#xD;&#xA;    if(SettedEggstotalChicksGroup != 0){&#xD;&#xA;        &#xD;&#xA;            TotalChicksGroupPer  = (TotalChicksGroup * 100m) / SettedEggstotalChicksGroup ;&#xD;&#xA;        }&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;     cell.Text = TotalChicksGroupPer.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell55_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal TotalChicksReportPer  = 0;&#xD;&#xA;    if(SettedEggsTotalChicksReport != 0){&#xD;&#xA;        &#xD;&#xA;            TotalChicksReportPer   = (TotalChicksReport * 100m) / SettedEggsTotalChicksReport ;&#xD;&#xA;        }&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;     cell.Text = TotalChicksReportPer.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void GroupHeader3_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // RESET group variables for next group&#xD;&#xA;    DeadsGroup = 0;&#xD;&#xA;    CullsGroup = 0;&#xD;&#xA;    SettedEggsGradeOutGroup = 0;&#xD;&#xA;    &#xD;&#xA;    //for breeders&#xD;&#xA;    FChicksGroup = 0;&#xD;&#xA;    MChicksGroup = 0;&#xD;&#xA;    SettedEggsBreederGroup = 0 ;&#xD;&#xA;    BreederGroup = 0;&#xD;&#xA;    //for broilers&#xD;&#xA;    ChicksGroup = 0;&#xD;&#xA;    SettedEggsChicksGroup = 0;&#xD;&#xA;    // for total chicks&#xD;&#xA;    TotalChicksGroup = 0;&#xD;&#xA;    SettedEggstotalChicksGroup = 0;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void GroupHeader1_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    DeadsReport = 0;&#xD;&#xA;    CullsReport = 0;&#xD;&#xA;    SettedEggsGradeOutReport = 0;&#xD;&#xA;    &#xD;&#xA;    //for breeders&#xD;&#xA;    FChicksReport = 0;&#xD;&#xA;    MChicksReport = 0;&#xD;&#xA;    SettedEggsBreederReport = 0;&#xD;&#xA;    BreederTotal = 0;&#xD;&#xA;    //for broilers&#xD;&#xA;    ChicksReport = 0;&#xD;&#xA;    SettedEggsChicksReport = 0;&#xD;&#xA;    &#xD;&#xA;    // for total chicks&#xD;&#xA;    TotalChicksReport = 0;&#xD;&#xA;    SettedEggsTotalChicksReport = 0;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;" PageWidth="1169" PageHeight="1654" Version="24.2" DataMember="SR_GHT_Hatch" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
