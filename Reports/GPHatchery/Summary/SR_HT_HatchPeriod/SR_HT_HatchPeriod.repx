<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="26.1.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_HatchPeriod" ScriptsSource="decimal TotalPercentageSellableChicks  =0;&#xD;&#xA;decimal TotalPercentageHatchPer = 0;&#xD;&#xA;decimal totalReportSellableChicks = 0;&#xD;&#xA;decimal totalReportSettedEggs = 0;&#xD;&#xA;decimal totalFertileEggs = 0;&#xD;&#xA;decimal totalSettedEggs = 0;&#xD;&#xA;decimal totalFertPerc  = 0;&#xD;&#xA;decimal totalHatchPerc  = 0;&#xD;&#xA;decimal totalHOFFertPer  = 0;&#xD;&#xA;decimal totalsellableChicks  = 0;&#xD;&#xA;decimal groupSettedEggs = 0;&#xD;&#xA;decimal groupSellableChicks = 0;&#xD;&#xA;decimal GroupFertPer = 0;&#xD;&#xA;decimal GroupFertileEggs = 0;&#xD;&#xA;decimal GroupfertilityPercentage = 0;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal fertPer = 0;&#xD;&#xA;    decimal settedEggs = 0;&#xD;&#xA;    decimal sellableChicks  = 0;&#xD;&#xA;    // Read fields safely&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FertPer&quot;) != null)&#xD;&#xA;        fertPer = Convert.ToDecimal(GetCurrentColumnValue(&quot;FertPer&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null)&#xD;&#xA;        sellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;        &#xD;&#xA;&#xD;&#xA;    // Calculate FertileEggs = FertPer * SettedEggs / 100&#xD;&#xA;    decimal fertileEggs = (fertPer * settedEggs) / 100;&#xD;&#xA;&#xD;&#xA; &#xD;&#xA;    // Sum Running totals&#xD;&#xA;    totalFertPerc += fertPer ;&#xD;&#xA;    totalFertileEggs += fertileEggs;&#xD;&#xA;    totalSettedEggs += settedEggs;&#xD;&#xA;    totalsellableChicks += sellableChicks ;&#xD;&#xA;    // Get the sum values from the current group&#xD;&#xA;     groupSettedEggs += settedEggs ;&#xD;&#xA;    &#xD;&#xA;     groupSellableChicks += sellableChicks ;&#xD;&#xA;     GroupFertPer += fertPer  ; &#xD;&#xA;     &#xD;&#xA;   }&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal sellableChicks = 0;&#xD;&#xA;    decimal settedEggs = 0;&#xD;&#xA;    decimal fertPer = 0;&#xD;&#xA;&#xD;&#xA;    // Read fields safely&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null)&#xD;&#xA;        sellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FertPer&quot;) != null)&#xD;&#xA;        fertPer = Convert.ToDecimal(GetCurrentColumnValue(&quot;FertPer&quot;));&#xD;&#xA;&#xD;&#xA;    // @HatchPer = SellableChicks * 100 / SettedEggs  (null-safe)&#xD;&#xA;    decimal hatchPer = 0;&#xD;&#xA;    if (settedEggs != 0)&#xD;&#xA;        hatchPer = (sellableChicks * 100) / settedEggs;&#xD;&#xA;&#xD;&#xA;    // Final = @HatchPer * 100 / FertPer&#xD;&#xA;    if (fertPer != 0){&#xD;&#xA;                TotalPercentageHatchPer = (hatchPer * 100) / fertPer;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign row % to the cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = TotalPercentageHatchPer.ToString(&quot;0.00&quot;);  // Row level %&#xD;&#xA;   // accumulate total&#xD;&#xA; totalHatchPerc += hatchPer ;&#xD;&#xA; totalHOFFertPer += fertPer ;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell30_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       // --- Declare values ---&#xD;&#xA;decimal sellableChicks = 0;&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;&#xD;&#xA;// --- SellableChicks ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null)&#xD;&#xA;    sellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;&#xD;&#xA;// --- SettedEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation (row level %) ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (settedEggs != 0)&#xD;&#xA;    percentage = (sellableChicks * 100m) / settedEggs;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign row % to the cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.00&quot;);  // Row level %&#xD;&#xA;totalReportSellableChicks += sellableChicks;&#xD;&#xA;totalReportSettedEggs += settedEggs;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;private void xrTableCell47_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    if (totalReportSettedEggs != 0)&#xD;&#xA;    TotalPercentageSellableChicks = (totalReportSellableChicks * 100m) / totalReportSettedEggs;&#xD;&#xA;    ((XRTableCell)sender).Text = TotalPercentageSellableChicks.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void tdCredit_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    object handledEggsValue = GetCurrentColumnValue(&quot;HandledEggs&quot;);&#xD;&#xA;    &#xD;&#xA;    if (handledEggsValue == null || handledEggsValue == DBNull.Value || string.IsNullOrEmpty(handledEggsValue.ToString()))&#xD;&#xA;    {&#xD;&#xA;        // Set to 0 if null, DBNull, or empty&#xD;&#xA;        tdCredit.Text = &quot;0&quot;;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        // Use the actual value&#xD;&#xA;        tdCredit.Text = handledEggsValue.ToString();&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell51_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal fertPerc = 0;&#xD;&#xA;    decimal totalHatchPerc = 0;&#xD;&#xA;    decimal finalResult = 0;&#xD;&#xA;    // @FertPerc&#xD;&#xA;    if (totalSettedEggs != 0)&#xD;&#xA;        fertPerc = (totalFertileEggs * 100) / totalSettedEggs ;&#xD;&#xA;&#xD;&#xA;    // @TotalHatchPerc&#xD;&#xA;    if (totalSettedEggs != 0)&#xD;&#xA;        totalHatchPerc = (totalsellableChicks * 100) / totalSettedEggs ;&#xD;&#xA;&#xD;&#xA;    // FinalResult = TotalHatchPerc * 100 / FertPerc&#xD;&#xA;    if (fertPerc != 0)&#xD;&#xA;        finalResult = (totalHatchPerc * 100) / fertPerc;&#xD;&#xA;&#xD;&#xA;    XRTableCell cell = (XRTableCell)sender;&#xD;&#xA;    cell.Text = finalResult.ToString(&quot;N2&quot;) ;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell49_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Final Result&#xD;&#xA;    decimal finalResult = 0;&#xD;&#xA;    &#xD;&#xA;    if (totalSettedEggs != 0){&#xD;&#xA;                finalResult =  (totalFertileEggs * 100m) / totalSettedEggs  ; &#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;    // Display formatted value (2 decimals + % sign)&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = finalResult.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell64_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     decimal percentage = 0;&#xD;&#xA;&#xD;&#xA;     // Calculate percentage&#xD;&#xA;    if (groupSettedEggs != 0)&#xD;&#xA;        percentage = groupSellableChicks * 100 / groupSettedEggs;&#xD;&#xA;        // Display formatted value (2 decimals + % sign)&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = percentage.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell66_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     if (groupSettedEggs != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate total fertile eggs&#xD;&#xA;        GroupFertileEggs += GroupFertPer * groupSettedEggs / 100;&#xD;&#xA;        &#xD;&#xA;        // Calculate final percentage&#xD;&#xA;        GroupfertilityPercentage = GroupFertileEggs * 100 / groupSettedEggs ;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = GroupfertilityPercentage.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell68_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal GroupfertPerc  = 0;&#xD;&#xA;    decimal GroupHatchPerc= 0 ;&#xD;&#xA;    decimal finalResult  = 0;&#xD;&#xA;     // @FertPerc&#xD;&#xA;    if (groupSettedEggs != 0)&#xD;&#xA;        GroupfertPerc = (GroupFertileEggs * 100) / groupSettedEggs ;&#xD;&#xA;&#xD;&#xA;    // @TotalHatchPerc&#xD;&#xA;    if (groupSettedEggs != 0)&#xD;&#xA;        GroupHatchPerc = (groupSellableChicks * 100) / groupSettedEggs ;&#xD;&#xA;&#xD;&#xA;    // FinalResult = TotalHatchPerc * 100 / FertPerc&#xD;&#xA;    if (GroupfertPerc != 0)&#xD;&#xA;        finalResult = (GroupHatchPerc * 100) / GroupfertPerc ;    &#xD;&#xA;        &#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = finalResult.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" Version="26.1" DataMember="SR_HT_Hatch" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
