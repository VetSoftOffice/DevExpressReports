xt group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell51_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       // --- Declare values ---  &#xD;&#xA;decimal otherEggs = 0;&#xD;&#xA;decimal recEggs = 0;&#xD;&#xA;decimal totalPerc = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;OtherEggs&quot;) != null)&#xD;&#xA;    otherEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;OtherEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecEggs&quot;) != null)&#xD;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- IIf logic: OtherEggs % of RecEggs ---&#xD;&#xA;if (recEggs != 0)&#xD;&#xA;    totalPerc = (otherEggs * 100.0m / recEggs);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = string.Format(&quot;{0:N0}\n{1:N2}&quot;, otherEggs , totalPerc);&#xD;&#xA;// --- Add to group totals ---&#xD;&#xA;TotalRecEggs += recEggs ;&#xD;&#xA;TotalOtherEggs += otherEggs ;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell63_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    if(TotalRecEggs  != 0){&#xD;&#xA;        TotalOtherEggsReport = (TotalOtherEggs  * 100m) / TotalRecEggs ;&#xD;&#xA;        &#xD;&#xA;        }&#xD;&#xA;    xrTableCell63.Text = TotalOtherEggsReport.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell73_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;          // --- Declare values ---&#xD;&#xA;decimal deformityEggs = 0;&#xD;&#xA;decimal recEggs = 0;&#xD;&#xA;decimal total = 0;&#xD;&#xA;decimal totalPerc = 0;&#xD;&#xA;decimal totalDeformityEggs = 0;&#xD;&#xA;decimal TotalReport  = 0;&#xD;&#xA;decimal TotalPercReport  = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;DeformityEggs&quot;) != null)&#xD;&#xA;    deformityEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeformityEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecEggs&quot;) != null)&#xD;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Base total (DeformityEggs) ---&#xD;&#xA;total = deformityEggs;&#xD;&#xA;&#xD;&#xA;// --- IIf logic: DeformityEggs % of RecEggs ---&#xD;&#xA;if (recEggs != 0)&#xD;&#xA;    totalPerc = (deformityEggs * 100.0m / recEggs);&#xD;&#xA;&#xD;&#xA;// --- Final sum ---&#xD;&#xA;totalDeformityEggs = total + totalPerc;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = totalPerc.ToString(&quot;N2&quot;); // no decimals&#xD;&#xA;&#xD;&#xA;// --- Add to group totals ---&#xD;&#xA;TotalReport += total;&#xD;&#xA;TotalPercReport += totalPerc;&#xD;&#xA;TotalDeformityEggsReport = TotalReport + TotalPercReport;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell40_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        decimal brokenEggs = 0;&#xD;&#xA;decimal recEggs = 0;&#xD;&#xA;decimal total = 0;&#xD;&#xA;decimal totalPerc = 0;&#xD;&#xA;decimal totalBrokenEggs = 0;&#xD;&#xA;decimal TotalReport  = 0;&#xD;&#xA;decimal TotalPercReport  = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;BrokenEggs&quot;) != null)&#xD;&#xA;    brokenEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;BrokenEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecEggs&quot;) != null)&#xD;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Base total (BrokenEggs) ---&#xD;&#xA;total = brokenEggs;&#xD;&#xA;&#xD;&#xA;// --- IIf logic: BrokenEggs % of RecEggs ---&#xD;&#xA;if (recEggs != 0)&#xD;&#xA;    totalPerc = (brokenEggs * 100.0m / recEggs);&#xD;&#xA;&#xD;&#xA;// --- Final sum ---&#xD;&#xA;totalBrokenEggs = total + totalPerc;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = string.Format(&quot;{0:N0}\n{1:N2}&quot;, brokenEggs, totalPerc);&#xD;&#xA;// --- Add to group totals ---&#xD;&#xA;TotalReport += total;&#xD;&#xA;TotalPercReport += totalPerc;&#xD;&#xA;TotalBrokenEggsReport = TotalReport + TotalPercReport;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    totalRecEggsGroup += Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;) ?? 0);&#xD;&#xA;    totalHatchingEggsGroup += Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchingEggs&quot;) ?? 0);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell88_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;if (totalRecEggsGroup != 0)&#xD;&#xA;        cell.Text =&#xD;&#xA;            ((totalHatchingEggsGroup * 100) / totalRecEggsGroup).ToString(&quot;N2&quot;);&#xD;&#xA;    else&#xD;&#xA;        cell.Text = &quot;0&quot;;&#xD;&#xA;}&#xD;&#xA;" PageWidthF="1169.29138" PageHeightF="1653.54333" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="26.1" DataMember="SR_HT_RecHall" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
