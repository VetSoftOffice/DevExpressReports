                    <Item1 Ref="476" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="477" UseFont="false" UsePadding="false" UseBorders="false" UseTextAlignment="false" />
                </Item3>
                <Item4 Ref="478" ControlType="XRTableCell" Name="xrTableCell20" Multiline="true" TextAlignment="MiddleCenter" Padding="2,2,0,0,100" Borders="All">
                  <Summary Ref="479" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="480" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([ChicksPlaced])" />
                    <Item2 Ref="481" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="482" UseFont="false" UsePadding="false" UseBorders="false" UseTextAlignment="false" />
                </Item4>
                <Item5 Ref="483" ControlType="XRTableCell" Name="xrTableCell21" Multiline="true" TextAlignment="MiddleCenter" Padding="2,2,0,0,100" Borders="All">
                  <Summary Ref="484" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="485" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([TotalReceived])" />
                    <Item2 Ref="486" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="487" UseFont="false" UsePadding="false" UseBorders="false" UseTextAlignment="false" />
                </Item5>
