<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="ChicksReceiving" ScriptsSource="decimal TotaltotalReceived   = 0;&#xD;&#xA;decimal TotalarrivalMortality  = 0;&#xD;&#xA;decimal TotaltotalReceivedReport  = 0;&#xD;&#xA;decimal TotalarrivalMortalityReport  = 0;&#xD;&#xA;decimal sumArrivalMortalityPercent = 0;&#xD;&#xA;int validRowCount = 0;&#xD;&#xA;    &#xD;&#xA;private void xrTableCell7_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get TotalReceived&#xD;&#xA;    decimal totalReceived = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalReceived&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Get rs_Female_ArrivalMortality&#xD;&#xA;    decimal arrivalMortality = Convert.ToDecimal(GetCurrentColumnValue(&quot;rs_Female_ArrivalMortality&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (totalReceived != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate arrival mortality percentage&#xD;&#xA;        decimal result = (arrivalMortality / totalReceived) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;    TotaltotalReceivedReport += totalReceived ;&#xD;&#xA;    TotalarrivalMortalityReport += TotalarrivalMortality  ;&#xD;&#xA;    &#xD;&#xA;     if (totalReceived != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal percent = (arrivalMortality / totalReceived) * 100;&#xD;&#xA;            sumArrivalMortalityPercent += percent;&#xD;&#xA;            validRowCount++;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     // Get TotalReceived&#xD;&#xA;    decimal totalReceived = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalReceived&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Get rs_Female_ArrivalMortality&#xD;&#xA;    decimal arrivalMortality = Convert.ToDecimal(GetCurrentColumnValue(&quot;rs_Female_ArrivalMortality&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;    TotaltotalReceived  += totalReceived ;&#xD;&#xA;    TotalarrivalMortality  += arrivalMortality ;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell19_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;       if (TotaltotalReceived  != 0)&#xD;&#xA;        {&#xD;&#xA;            // Calculate arrival mortality percentage&#xD;&#xA;            decimal result = (TotalarrivalMortality  / TotaltotalReceived  ) * 100;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell14_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;       if (TotaltotalReceived  != 0)&#xD;&#xA;        {&#xD;&#xA;            // Calculate arrival mortality percentage&#xD;&#xA;            decimal result = (TotalarrivalMortality  / TotaltotalReceived  ) * 100;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrLabel10_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRLabel label = sender as XRLabel;&#xD;&#xA;        &#xD;&#xA;        if (validRowCount &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal avg = sumArrivalMortalityPercent / validRowCount;&#xD;&#xA;            label.Text = avg.ToString(&qu