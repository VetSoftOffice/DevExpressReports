                  <Summary Ref="489" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="490" EventName="BeforePrint" PropertyName="Text" Expression="sumAvg([FBW])" />
                    <Item2 Ref="491" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                  </ExpressionBindings>
