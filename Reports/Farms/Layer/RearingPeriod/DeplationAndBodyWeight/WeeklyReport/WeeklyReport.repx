umnValue(&quot;TotalMort&quot;));&#xD;&#xA;&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (femaleStarted != 0)&#xD;&#xA;{&#xD;&#xA;    percentage = (totalMort / femaleStarted) * 100;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;totalPercentageSum += percentage;&#xD;&#xA;totalRowsCount++;&#xD;&#xA;&#xD;&#xA;decimal totalCulls = GetCurrentColumnValue(&quot;TotalCulls&quot;) == null&#xD;&#xA;    ? 0&#xD;&#xA;    : Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalCulls&quot;));&#xD;&#xA;&#xD;&#xA;decimal percentageCulls = 0;&#xD;&#xA;if (femaleStarted != 0)&#xD;&#xA;{&#xD;&#xA;    percentageCulls = (totalCulls / femaleStarted) * 100;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;totalCullPercentageSum += percentageCulls ;&#xD;&#xA;totalRowsCountCulls++;&#xD;&#xA;&#xD;&#xA;decimal totalDep = GetCurrentColumnValue(&quot;TotalDep&quot;) == null&#xD;&#xA;    ? 0&#xD;&#xA;    : Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalDep&quot;));&#xD;&#xA;&#xD;&#xA;decimal percentageDep = 0;&#xD;&#xA;if (femaleStarted != 0)&#xD;&#xA;{&#xD;&#xA;    percentageDep = (totalDep / femaleStarted) * 100;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;totalDepPercentageSum += percentageDep ;&#xD;&#xA;totalRowsCountDep++;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;decimal totalCumDep = GetCurrentColumnValue(&quot;TotalCummDep&quot;) == null&#xD;&#xA;    ? 0&#xD;&#xA;    : Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalCummDep&quot;));&#xD;&#xA;&#xD;&#xA;decimal percentageCumDep = 0;&#xD;&#xA;if (femaleStarted != 0)&#xD;&#xA;{&#xD;&#xA;    percentageCumDep = (totalCumDep / femaleStarted) * 100;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;totalCumDepPercentageSum += percentageDep ;&#xD;&#xA;totalRowsCountCumDep++;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell33_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;  if (totalRowsCount &gt; 0)&#xD;&#xA;{&#xD;&#xA;    cell.Text = (totalPercentageSum / totalRowsCount).ToString(&quot;0.##&quot;) + &quot;%&quot;;&#xD;&#