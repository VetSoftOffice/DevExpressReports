= 0;&#xD;&#xA;    sumUniformity   = 0;&#xD;&#xA;    validRowUniformityCount  = 0;&#xD;&#xA;    sumFemaleCV = 0;&#xD;&#xA;    validRowFemaleCVCount  = 0;&#xD;&#xA;    sumfabw   = 0;&#xD;&#xA;    validRowCount = 0;&#xD;&#xA;    sumStdVSact = 0;&#xD;&#xA;    sumNonZeroBWvsStd  = 0;&#xD;&#xA;    sumPercentageDiff = 0;&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell31_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        decimal stanBodyWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;StanBodyWeight&quot;) ?? 0);&#xD;&#xA;        if (stanBodyWeight != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = stanBodyWeight ;&#xD;&#xA;            cell.Text =  result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;        if (stanBodyWeight != 0)&#xD;&#xA;         {&#xD;&#xA;             reportSumstanBodyWeight  += stanBodyWeight ;&#xD;&#xA;            reportValidRowstanBodyWeightCount++;&#xD;&#xA;         }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell37_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (reportValidRowstanBodyWeightCount &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = reportSumstanBodyWeight  / reportValidRowstanBodyWeightCount;&#xD;&#xA;            cell.Text =  result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell36_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        decimal fabw = Convert.ToDecimal(GetCurrentColumnValue(&quot;FABW&quot;) ?? 0);&#xD;&#xA;        if (fabw  != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = fabw ;&#xD;&#xA;            cell.Text =  result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;        if (fabw  != 0)&#xD;&#xA;         {&#xD;&#xA;             reportSumFABW += fabw ;&#xD;&#xA;             reportValidRowFABWCount ++;&#xD;&#xA;         }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell38_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (reportValidRowFABWCount &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = reportSumFABW / reportValidRowFABWCount ;&#xD;&#xA;            cell.Text =  result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell16_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        decimal Uniformity = Convert.ToDecimal(GetCurrentColumnValue(&quot;Uniformity&quot;) ?? 0);&#xD;&#xA;        if (Uniformity != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = Uniformity ;&#xD;&#xA;            cell.Text =  result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;        if (Uniformity != 0)&#xD;&#xA;         {&#xD;&#xA;             reportSumUniformity  += Uniformity ;&#xD;&#xA;             reportValidRowUniformityCount++;&#xD;&#xA;         }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell41_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (reportValidRowUniformityCount  &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = reportSumUniformity  / reportValidRowUniformityCount ;&#xD;&#xA;            cell.Text =  result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell18_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        decimal FemaleCV = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleCV&quot;) ?? 0);&#xD;&#xA;        if (FemaleCV != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = FemaleCV ;&#xD;&#xA;            cell.Text =  result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;         if (FemaleCV != 0)&#xD;&#xA;        {&#xD;&#xA;             reportSumFemaleCV += FemaleCV ;&#xD;&#xA;             reportValidRowFemaleCVCount++;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;          &#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell42_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (reportValidRowFemaleCVCount &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = reportSumFemaleCV / reportValidRowFemaleCVCount;&#xD;&#xA;            cell.Text =  result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell44_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;