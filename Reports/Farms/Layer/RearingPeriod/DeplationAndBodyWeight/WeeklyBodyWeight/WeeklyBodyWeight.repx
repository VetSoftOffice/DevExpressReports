<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="WeeklyBodyWeight" ScriptsSource="decimal sumPercentageDiff = 0;&#xD;&#xA;int validRowCount = 0;&#xD;&#xA;decimal sumFirstWeekMort = 0;&#xD;&#xA;decimal sumTotalCulls = 0;&#xD;&#xA;decimal sumCocks = 0;&#xD;&#xA;decimal sumTotalMort = 0;&#xD;&#xA;decimal sumTotalDepl = 0;&#xD;&#xA;decimal sumBodyWeight  = 0;&#xD;&#xA;decimal sumfabw    = 0;&#xD;&#xA;decimal validRowBodyWeightCount = 0;&#xD;&#xA;decimal sumUniformity   = 0;&#xD;&#xA;decimal validRowUniformityCount = 0 ;&#xD;&#xA;decimal sumFemaleCV = 0;&#xD;&#xA;decimal validRowFemaleCVCount = 0;&#xD;&#xA;decimal reportSumstanBodyWeight  = 0;&#xD;&#xA;int reportValidRowstanBodyWeightCount = 0;&#xD;&#xA;decimal reportSumUniformity = 0;&#xD;&#xA;int reportValidRowUniformityCount = 0;&#xD;&#xA;decimal reportSumFABW = 0;&#xD;&#xA;int reportValidRowFABWCount = 0;&#xD;&#xA;decimal reportSumFemaleCV = 0;&#xD;&#xA;int reportValidRowFemaleCVCount = 0;&#xD;&#xA;decimal sumStdVSactReport  = 0;&#xD;&#xA;int sumNonZeroBWvsStdReport = 0;&#xD;&#xA;decimal sumPercentReport = 0;&#xD;&#xA;int countPercentReport = 0;&#xD;&#xA;private void xrTableCell15_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;            XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        // Get FABW and StanBodyWeight values&#xD;&#xA;        decimal fabw = Convert.ToDecimal(GetCurrentColumnValue(&quot;FABW&quot;) ?? 0);&#xD;&#xA;        decimal stanBodyWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;StanBodyWeight&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        // Calculate {@stdVSact} - difference between actual and standard&#xD;&#xA;        decimal stdVSact = 0;&#xD;&#xA;        decimal difference = fabw - stanBodyWeight;&#xD;&#xA;        &#xD;&#xA;        if (difference != 0)&#xD;&#xA;        {&#xD;&#xA;            stdVSact = difference;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // Calculate percentage if FABW is not zero&#xD;&#xA;        if (fabw != 0)&#xD;&#xA;        {&#xD;&#xA;             decimal result = 0;&#xD;&#xA;            result = (stdVSact / fabw) * 100;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        decimal percent = 0;&#xD;&#xA;        if (fabw != 0)&#xD;&#xA;        {&#xD;&#xA;               percent = (stdVSact / fabw) * 100;&#xD;&#xA;               sumPercentReport += percent ;&#xD;&#xA;               countPercentReport++;       &#xD;&#xA;    &#xD;&#xA;      }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell25_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;           XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        // Get rf_Female_Started value&#xD;&#xA;        decimal rfFemaleStarted = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_Female_Started&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        // Calculate {@TotalDepl} (TotalMort + TotalCulls + Cocks)&#xD;&#xA;        decimal totalMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalMort&quot;) ?? 0);&#xD;&#xA;        decimal totalCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalCulls&quot;) ?? 0);&#xD;&#xA;        decimal cocks = Convert.ToDecimal(GetCurrentColumnValue(&quot;Cocks&quot;) ?? 0);&#xD;&#xA;        decimal totalDepl = totalMort + totalCulls + cocks;&#xD;&#xA;        &#xD;&#xA;        if (rfFemaleStarted != 0)&#xD;&#xA;        {&#xD;&#xA;            // Calculate total depletion percentage&#xD;&#xA;            decimal result = (totalDepl / rfFemaleStarted) * 100;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;// Method to calculate {@stdVSact} for a row&#xD;&#xA;    private decimal CalculateStdVSact(decimal fabw, decimal stanBodyWeight)&#xD;&#xA;    {&#xD;&#xA;        decimal difference = fabw - stanBodyWeight;&#xD;&#xA;        return (difference != 0) ? difference : 0;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Method to calculate {@NonZeroBWvsStd} for a row&#xD;&#xA;    private int CalculateNonZeroBWvsStd(decimal stdVSact)&#xD;&#xA;    {&#xD;&#xA;        return (stdVSact != 0) ? 1 : 0;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Variables to store sums&#xD;&#xA;    private decimal sumStdVSact = 0;&#xD;&#xA;    private decimal sumNonZeroBWvsStd = 0;&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        decimal fabw = Convert.ToDecimal(GetCurrentColumnValue(&quot;FABW&quot;) ?? 0);&#xD;&#xA;        decimal stanBodyWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;StanBodyWeight&quot;) ?? 0);&#xD;&#xA;        decimal Uniformity = Convert.ToDecimal(GetCurrentColumnValue(&quot;Uniformity&quot;) ?? 0);&#xD;&#xA;        decimal FemaleCV = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleCV&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;        // Calculate {@stdVSact} for this row&#xD;&#xA;        decimal stdVSact = CalculateStdVSact(fabw, stanBodyWeight);&#xD;&#xA;        &#xD;&#xA;        // Calculate {@NonZeroBWvsStd} for this row&#xD;&#xA;        int nonZeroBWvsStd = CalculateNonZeroBWvsStd(stdVSact);&#xD;&#xA;        &#xD;&#xA;        // Accumulate sums&#xD;&#xA;        sumStdVSact += stdVSact;&#xD;&#xA;        sumNonZeroBWvsStd += nonZeroBWvsStd;&#xD;&#xA;        &#xD;&#xA;        // Calculate percentage if FABW is not zero&#xD;&#xA;        if (fabw != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal percentageDiff = (stdVSact / fabw) * 100;&#xD;&#xA;            sumfabw  += fabw ;&#xD;&#xA;            sumPercentageDiff += percentageDiff;&#xD;&#xA;            validRowCount++;&#xD;&#xA;        }&#xD;&#xA;        if (stanBodyWeight != 0)&#xD;&#xA;        {&#xD;&#xA;            sumBodyWeight += stanBodyWeight ;&#xD;&#xA;            validRowBodyWeightCount++;&#xD;&#xA;        }&#xD;&#xA;        if (Uniformity != 0)&#xD;&#xA;         {&#xD;&#xA;             sumUniformity  += Uniformity ;&#xD;&#xA;             validRowUniformityCount++;&#xD;&#xA;         }&#xD;&#xA;         if (FemaleCV != 0)&#xD;&#xA;        {&#xD;&#xA;            sumFemaleCV += FemaleCV ;&#xD;&#xA;            validRowFemaleCVCount++;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;        // Calculate FirstWeekMort for this row (TotalMort + TotalCulls + Cocks)&#xD;&#xA;        decimal totalMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalMort&quot;) ?? 0);&#xD;&#xA;        decimal totalCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalCulls&quot;) ?? 0);&#xD;&#xA;        decimal cocks = Convert.ToDecimal(GetCurrentColumnValue(&quot;Cocks&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        decimal firstWeekMort = totalMort + totalCulls + cocks;&#xD;&#xA;        &#xD;&#xA;        // Add to the running total&#xD;&#xA;        sumFirstWeekMort += firstWeekMort;&#xD;&#xA;        &#xD;&#xA;                // Add current row's TotalCulls to the running total&#xD;&#xA;        sumTotalCulls += Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalCulls&quot;) ?? 0);&#xD;&#xA;        sumCocks += Convert.ToDecimal(GetCurrentColumnValue(&quot;Cocks&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;         sumTotalMort += Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalMort&quot;) ?? 0);&#xD;&#xA;         &#xD;&#xA;        decimal totalDepl = totalMort + totalCulls + cocks;&#xD;&#xA;        &#xD;&#xA;        // Add to running totals&#xD;&#xA;        sumTotalDepl += totalDepl;&#xD;&#xA;         &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell79_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (sumNonZeroBWvsStd != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = sumStdVSact / sumNonZeroBWvsStd;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell80_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (validRowCount &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal avg = sumPercentageDiff / validRowCount;&#xD;&#xA;            cell.Text = avg.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell27_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get rf_Female_Started and DOA values&#xD;&#xA;    decimal rfFemaleStarted = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_Female_Started&quot;) ?? 0);&#xD;&#xA;    decimal doa = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (rfFemaleStarted != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate DOA percentage&#xD;&#xA;        decimal result = (doa / rfFemaleStarted) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell33_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        // Get rf_Female_Started (you might need to decide which row's value to use)&#xD;&#xA;        // Option A: Use the current row's value&#xD;&#xA;        decimal rfFemaleStarted = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_Female_Started&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        // Option B: Use the sum of rf_Female_Started across all rows&#xD;&#xA;        // decimal rfFemaleStarted = sumRFemaleStarted; // You'd need to accumulate this too&#xD;&#xA;        &#xD;&#xA;        if (rfFemaleStarted != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = (sumFirstWeekMort / rfFemaleStarted) * 100;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell48_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        // Get {@ChicksPlaced} (rf_Female_Started) - using current row's value&#xD;&#xA;        // You need to decide which row's value to use for the denominator&#xD;&#xA;        decimal chicksPlaced = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_Female_Started&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        if (chicksPlaced != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = (sumTotalCulls / chicksPlaced) * 100;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell51_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;             decimal chicksPlaced = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_Female_Started&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;        &#xD;&#xA;        if (chicksPlaced != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = (sumCocks / chicksPlaced ) * 100;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell54_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        decimal chicksPlaced = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_Female_Started&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;        if (chicksPlaced != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = (sumTotalMort / chicksPlaced ) * 100;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell57_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        decimal chicksPlaced = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_Female_Started&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;        if (chicksPlaced != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = (sumTotalDepl / chicksPlaced ) * 100;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell77_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;        if (validRowBodyWeightCount != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = (sumBodyWeight / validRowBodyWeightCount) ;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell78_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;            XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;        if (validRowCount != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = (sumfabw   / validRowCount) ;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell81_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;        if (validRowUniformityCount != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = (sumUniformity  / validRowUniformityCount) ;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell82_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;        if (validRowFemaleCVCount != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = (sumFemaleCV / validRowFemaleCVCount ) ;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void GroupHeader1_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    validRowBodyWeightCount  = 0;&#xD;&#xA;    sumBodyWeight  = 0;&#xD;&#xA;    sumUniformity   = 0;&#xD;&#xA;    validRowUniformityCount  = 0;&#xD;&#xA;    sumFemaleCV = 0;&#xD;&#xA;    validRowFemaleCVCount  = 0;&#xD;&#xA;    sumfabw   = 0;&#xD;&#xA;    validRowCount = 0;&#xD;&#xA;    sumStdVSact = 0;&#xD;&#xA;    sumNonZeroBWvsStd  = 0;&#xD;&#xA;    sumPercentageDiff = 0;&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell31_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        decimal stanBodyWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;StanBodyWeight&quot;) ?? 0);&#xD;&#xA;        if (stanBodyWeight != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = stanBodyWeight ;&#xD;&#xA;            cell.Text =  result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;        if (stanBodyWeight != 0)&#xD;&#xA;         {&#xD;&#xA;             reportSumstanBodyWeight  += stanBodyWeight ;&#xD;&#xA;            reportValidRowstanBodyWeightCount++;&#xD;&#xA;         }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell37_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (reportValidRowstanBodyWeightCount &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = reportSumstanBodyWeight  / reportValidRowstanBodyWeightCount;&#xD;&#xA;            cell.Text =  result.ToString(&quot;N0&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell36_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        decimal fabw = Convert.ToDecimal(GetCurrentColumnValue(&quot;FABW&quot;) ?? 0);&#xD;&#xA;        if (fabw  != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = fabw ;&#xD;&#xA;            cell.Text =  result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;        if (fabw  != 0)&#xD;&#xA;         {&#xD;&#xA;             reportSumFABW += fabw ;&#xD;&#xA;             reportValidRowFABWCount ++;&#xD;&#xA;         }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell38_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (reportValidRowFABWCount &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = reportSumFABW / reportValidRowFABWCount ;&#xD;&#xA;            cell.Text =  result.ToString(&quot;N1&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.0&quot;;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell16_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        decimal Uniformity = Convert.ToDecimal(GetCurrentColumnValue(&quot;Uniformity&quot;) ?? 0);&#xD;&#xA;        if (Uniformity != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = Uniformity ;&#xD;&#xA;            cell.Text =  result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;        if (Uniformity != 0)&#xD;&#xA;         {&#xD;&#xA;             reportSumUniformity  += Uniformity ;&#xD;&#xA;             reportValidRowUniformityCount++;&#xD;&#xA;         }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell41_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (reportValidRowUniformityCount  &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = reportSumUniformity  / reportValidRowUniformityCount ;&#xD;&#xA;            cell.Text =  result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell18_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        decimal FemaleCV = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleCV&quot;) ?? 0);&#xD;&#xA;        if (FemaleCV != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = FemaleCV ;&#xD;&#xA;            cell.Text =  result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;         if (FemaleCV != 0)&#xD;&#xA;        {&#xD;&#xA;             reportSumFemaleCV += FemaleCV ;&#xD;&#xA;             reportValidRowFemaleCVCount++;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;          &#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell42_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (reportValidRowFemaleCVCount &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = reportSumFemaleCV / reportValidRowFemaleCVCount;&#xD;&#xA;            cell.Text =  result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell44_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    if (cell == null)&#xD;&#xA;        return;&#xD;&#xA;&#xD;&#xA;    decimal fabw = Convert.ToDecimal(GetCurrentColumnValue(&quot;FABW&quot;) ?? 0);&#xD;&#xA;    decimal stanBodyWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;StanBodyWeight&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;    decimal diff = fabw - stanBodyWeight;&#xD;&#xA;    if (diff != 0){&#xD;&#xA;        decimal result = diff ;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;    }&#xD;&#xA;    else{&#xD;&#xA;        &#xD;&#xA;        cell.Text = &quot;0.00&quot;;  &#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    if(diff != 0){&#xD;&#xA;        sumStdVSactReport  += diff ;&#xD;&#xA;        sumNonZeroBWvsStdReport++ ;&#xD;&#xA;        &#xD;&#xA;      }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell39_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    if (cell == null)&#xD;&#xA;        return;&#xD;&#xA;    &#xD;&#xA;    if (sumNonZeroBWvsStdReport &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal avg = sumStdVSactReport / sumNonZeroBWvsStdReport;&#xD;&#xA;        cell.Text = avg.ToString(&quot;N0&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0&quot;;&#xD;&#xA;    }&#xD;&#xA; }&#xD;&#xA;&#xD;&#xA;private void xrTableCell40_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;if (cell == null)&#xD;&#xA;    return;&#xD;&#xA;&#xD;&#xA;if (countPercentReport &gt; 0)&#xD;&#xA;{&#xD;&#xA;    decimal avg = sumPercentReport / countPercentReport;&#xD;&#xA;    cell.Text = avg.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1169.29138" PageHeightF="826.771667" Version="25.2" DataMember="SR_LAY_WeeklyBodyWeight" DataSource="#Ref-0" TextAlignment=