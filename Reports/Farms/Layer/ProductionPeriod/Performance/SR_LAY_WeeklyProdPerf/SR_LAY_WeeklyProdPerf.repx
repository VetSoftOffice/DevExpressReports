    <Item3 Ref="23" Name="MortPerc" Expression="IIF(ISNULL([NoBirds],0) &gt; 0, (ToFloat(ISNULL([TotalDepl],0)) / [NoBirds]) * 100.00, 0)" DataMember="SR_LAY_WeeklyProdPerf" />
