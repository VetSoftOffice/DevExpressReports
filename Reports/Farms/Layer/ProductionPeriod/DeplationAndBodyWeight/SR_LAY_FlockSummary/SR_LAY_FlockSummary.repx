    <Item5 Ref="21" Name="LayingLossPerc" Expression="Iif(IsNull([BirdsTransferToLay], 0) &gt; 0, IsNull([LayLoss],0) * 100.00 / [BirdsTransferToLay], 0)" DataMember="SR_LAY_FlockSummary" />
    <Item6 Ref="22" Name="TotalWholeEggs" Expression="IsNull([TotalEggs], 0) - IsNull([CondemnEggs], 0)" DataMember="SR_LAY_FlockSummary" />
    <Item7 Ref="23" Name="GoodEggsPerBird" Expression="Iif(IsNull([LayBirdsPlaced], 0) &gt; 0, ToDecimal(IsNull([TotalWholeEggs], 0)) / [LayBirdsPlaced] , 0)" DataMember="SR_LAY_FlockSummary" />
    <Item8 Ref="24" Name="TotalEggsPerBird" Expression="Iif(IsNull([LayBirdsPlaced], 0) &gt; 0, ToDecimal(IsNull([TotalEggs], 0)) / [LayBirdsPlaced], 0)" DataMember="SR_LAY_FlockSummary" />
    <Item9 Ref="25" Name="TotalEggsPerBird_Ach" Expression="Iif(IsNull([EggsPerBird100PerStd], 0) &gt; 0, (ToDecimal(IsNull([TotalEggsPerBird], 0)) / [EggsPerBird100PerStd]) * 100.00, 0)" DataMember="SR_LAY_FlockSummary" />
    <Item10 Ref="26" Name="TotalTableEggs_Ach" Expression="Iif(IsNull([EggsPerBird55WeekStd], 0) &gt; 0, (ToDecimal(IsNull([GoodEggsPerBird], 0)) / [EggsPerBird55WeekStd]) * 100.00, 0)" DataMember="SR_LAY_FlockSummary" />
