oftDevExpress.dll" Version="25.2" DataMember="SR_LAY_DailyDepl" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
