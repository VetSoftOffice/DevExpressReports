        <Item2 Ref="431" ControlType="SubBand" Name="SubBand7">
          <Controls>
            <Item1 Ref="432" ControlType="XRSubreport" Name="DailyMort_RT6_Ext1">
              <ReportSource Ref="434" ControlType="DevExpressReports.Reports.Farms.Broiler.DeplationAndBodyWeight.DailyMort_RT6_Ext1.DailyMort_RT6_Ext1, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="decimal totalFeedQtn = 0;      // {#FeedCumm} - sum of FeedQtn&#xD;&#xA;decimal totalDepletion = 0;    // {#Cumm} - sum of Depletion&#xD;&#xA;decimal totalTrialFeedQtn = 0;      // {#TrialFeedCumm} - sum of TrialFeedQtn&#xD;&#xA;decimal totalTrialDepletion = 0;    // {#TrialCumm} - sum of TrialDepilation&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     // Helper function to safely convert values&#xD;&#xA;    decimal SafeConvert(object value)&#xD;&#xA;    {&#xD;&#xA;        if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;            return 0;&#xD;&#xA;        return Convert.ToDecimal(value);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Accumulate FeedQtn for {#FeedCumm}&#xD;&#xA;    totalFeedQtn += SafeConvert(GetCurrentColumnValue(&quot;FeedQtn&quot;));&#xD;&#xA;    &#xD;&#xA;    // Accumulate Depletion for {#Cumm}&#xD;&#xA;    totalDepletion += SafeConvert(GetCurrentColumnValue(&quot;Depilation&quot;));&#xD;&#xA;      // Accumulate TrialFeedQtn for {#TrialFeedCumm}&#xD;&#xA;    totalTrialFeedQtn += SafeConvert(GetCurrentColumnValue(&quot;TrialFeedQtn&quot;));&#xD;&#xA;    &#xD;&#xA;    // Accumulate TrialDepilation for {#TrialCumm}&#xD;&#xA;    totalTrialDepletion += SafeConvert(GetCurrentColumnValue(&quot;TrialDepilation&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell15_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get current row values&#xD;&#xA;    decimal chicksPlaced = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChicksPlaced&quot;) ?? 0);&#xD;&#xA;    decimal avgBodyWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;AvgBodyWeight&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate (ChicksPlaced - {#Cumm})&#xD;&#xA;    decimal adjustedBirds = chicksPlaced - totalDepletion;&#xD;&#xA;    &#xD;&#xA;    // Check if conditions are met&#xD;&#xA;    if (adjustedBirds &gt; 0 &amp;&amp; avgBodyWeight &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate: ({#FeedCumm} * 1000.0 / (ChicksPlaced - {#Cumm})) / AvgBodyWeight&#xD;&#xA;        decimal result = (totalFeedQtn * 1000.0m / adjustedBirds) / avgBodyWeight;&#xD;&#xA;        &#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;        &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell23_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get current row values for trial group&#xD;&#xA;    decimal chicksPlacedTrial = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChicksPlacedTrial&quot;) ?? 0);&#xD;&#xA;    decimal trialAvgBodyWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;TrialAvgBodyWeight&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate (ChicksPlacedTrial - {#TrialCumm})&#xD;&#xA;    decimal adjustedTrialBirds = chicksPlacedTrial - totalTrialDepletion;&#xD;&#xA;    &#xD;&#xA;    // Check if conditions are met&#xD;&#xA;    if (chicksPlacedTrial &gt; 0 &amp;&amp; trialAvgBodyWeight &gt; 0 &amp;&amp; adjustedTrialBirds &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate: (1000 * ({#TrialFeedCumm} / (ChicksPlacedTrial - {#TrialCumm}))) / TrialAvgBodyWeight&#xD;&#xA;        // Step by step for clarity:&#xD;&#xA;        decimal feedPerBird = totalTrialFeedQtn / adjustedTrialBirds;           // Feed per bird&#xD;&#xA;        decimal feedGrams = 1000.0m * feedPerBird;                               // Convert to grams&#xD;&#xA;        decimal result = feedGrams / trialAvgBodyWeight;                         // Divide by body weight&#xD;&#xA;        &#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;        &#xD;&#xA;            }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell24_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get current row value for trial group chicks placed&#xD;&#xA;    decimal chicksPlacedTrial = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChicksPlacedTrial&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Check if chicks placed is greater than 0&#xD;&#xA;    if (chicksPlacedTrial &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate: ({#TrialCumm} / ChicksPlacedTrial) * 100&#xD;&#xA;        decimal result = (totalTrialDepletion / chicksPlacedTrial) * 100.0m;&#xD;&#xA;        string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;        cell.Text = formattedResult ;&#xD;&#xA;        &#xD;&#xA;        // Optional tooltip with details&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell44_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get current row values for control group&#xD;&#xA;    decimal chicksPlacedControl = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChicksPlacedControl&quot;) ?? 0);&#xD;&#xA;    decimal controlAvgBodyWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;ControlAvgBodyWeight&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate (ChicksPlacedControl - {#ControlCumm})&#xD;&#xA;    decimal adjustedControlBirds = chicksPlacedControl - totalControlDepletion;&#xD;&#xA;    &#xD;&#xA;    // Check if all conditions are met&#xD;&#xA;    if (chicksPlacedControl &gt; 0 &amp;&amp; controlAvgBodyWeight &gt; 0 &amp;&amp; adjustedControlBirds &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate: (1000 * ({#ControlFeedCumm} / (ChicksPlacedControl - {#ControlCumm}))) / ControlAvgBodyWeight&#xD;&#xA;        // Step by step for clarity:&#xD;&#xA;        decimal feedPerBird = totalControlFeedQtn / adjustedControlBirds;           // Feed per bird in kg&#xD;&#xA;        decimal feedGrams = 1000.0m * feedPerBird;                                   // Convert to grams&#xD;&#xA;        decimal result = feedGrams / controlAvgBodyWeight;                           // Divide by body weight in grams&#xD;&#xA;        &#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Using 4 decimals for precision&#xD;&#xA;        &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell52_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get current row value for control group chicks placed&#xD;&#xA;    decimal chicksPlacedControl = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChicksPlacedControl&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Check if chicks placed is greater than 0&#xD;&#xA;    if (chicksPlacedControl &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate: ({#ControlCumm} / ChicksPlacedControl) * 100&#xD;&#xA;        decimal result = (totalControlDepletion / chicksPlacedControl) * 100.0m;&#xD;&#xA;        string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;        cell.Text = formattedResult ;&#xD;&#xA;        &#xD;&#xA;           }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1169.29138" PageHeightF="826.771667" Version="25.2" DataMember="SR_BRO_DailyMort_P3" DataSource="#Ref-433" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
