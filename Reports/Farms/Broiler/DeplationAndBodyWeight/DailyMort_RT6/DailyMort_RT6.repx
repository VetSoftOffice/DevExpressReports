                  <Item13 Ref="479" Name="TotalHE" Expression="Iif(IsNullOrEmpty([CloseFHTEggsC]), 0, [CloseFHTEggsC]) +&#xD;&#xA;Iif(IsNullOrEmpty([CloseFHTEggsF]), 0, [CloseFHTEggsF]) +&#xD;&#xA;Iif(IsNullOrEmpty([CloseHTEggsC]), 0, [CloseHTEggsC]) +&#xD;&#xA;Iif(IsNullOrEmpty([CloseHTEggsF]), 0, [CloseHTEggsF])&#xD;&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item14 Ref="480" Name="WeekMortTotal" Expression="IIF(IsNullOrEmpty([Sat]), 0, [Sat]) + &#xD;&#xA;IIF(IsNullOrEmpty([Sun]), 0, [Sun]) + &#xD;&#xA;IIF(IsNullOrEmpty([Mon]), 0, [Mon]) + &#xD;&#xA;IIF(IsNullOrEmpty([Tue]), 0, [Tue]) + &#xD;&#xA;IIF(IsNullOrEmpty([Wed]), 0, [Wed]) + &#xD;&#xA;IIF(IsNullOrEmpty([Thru]), 0, [Thru]) + &#xD;&#xA;IIF(IsNullOrEmpty([Fri]), 0, [Fri])&#xD;&#xA;" DataMember="SR_BRO_DailyMort" />
