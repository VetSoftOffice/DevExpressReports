<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="DailyMort_RT6" ScriptsSource="decimal totalChicksPlaced = 0;&#xD;&#xA;decimal totalCobbField = 0;&#xD;&#xA;decimal totalRossField = 0;&#xD;&#xA;decimal totalOtherField = 0;&#xD;&#xA;decimal totalWeekMort = 0;&#xD;&#xA;decimal totalCumDep = 0;&#xD;&#xA;decimal totalSat = 0;&#xD;&#xA;decimal totalSun = 0;&#xD;&#xA;decimal totalMon = 0;&#xD;&#xA;decimal totalTue = 0;&#xD;&#xA;decimal totalWed = 0;&#xD;&#xA;decimal totalThru = 0;&#xD;&#xA;decimal totalFri = 0;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // Get ChickPlaced value&#xD;&#xA;    object chicksObj = GetCurrentColumnValue(&quot;ChickPlaced&quot;);&#xD;&#xA;    decimal chickPlaced = 0;&#xD;&#xA;    &#xD;&#xA;    if (chicksObj != null &amp;&amp; chicksObj != DBNull.Value)&#xD;&#xA;    {&#xD;&#xA;        chickPlaced = Convert.ToDecimal(chicksObj);&#xD;&#xA;        totalChicksPlaced += chickPlaced;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Calculate @CobbField: if tFrGroupBreedID = 2 then ChickPlaced else 0&#xD;&#xA;    object breedIdObj = GetCurrentColumnValue(&quot;tFrGroupBreedID&quot;);&#xD;&#xA;    decimal cobbFieldValue = 0;&#xD;&#xA;    &#xD;&#xA;    if (breedIdObj != null &amp;&amp; breedIdObj != DBNull.Value)&#xD;&#xA;    {&#xD;&#xA;        int breedId = Convert.ToInt32(breedIdObj);&#xD;&#xA;        &#xD;&#xA;        // @CobbField logic: if tFrGroupBreedID = 2 then ChickPlaced else 0&#xD;&#xA;        if (breedId == 2)&#xD;&#xA;        {&#xD;&#xA;            cobbFieldValue = chickPlaced;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    totalCobbField += cobbFieldValue;&#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;     // Helper function to get int values&#xD;&#xA;    int GetInt(string fieldName)&#xD;&#xA;    {&#xD;&#xA;        object value = GetCurrentColumnValue(fieldName);&#xD;&#xA;        if (value == null || value == DBNull.Value)&#xD;&#xA;            return 0;&#xD;&#xA;        return Convert.ToInt32(value);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;    // Calculate @RossField based on tFrGroupBreedID = 1&#xD;&#xA;    int breedId = GetInt(&quot;tFrGroupBreedID&quot;);&#xD;&#xA;    decimal rossFieldValue = (breedId == 1) ? chickPlaced : 0;&#xD;&#xA;    totalRossField += rossFieldValue;&#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;    // Calculate @OtherField: if tFrGroupBreedID is NOT 1 AND NOT 2 then ChickPlaced else 0&#xD;&#xA;    int breedId = GetInt(&quot;tFrGroupBreedID&quot;);&#xD;&#xA;    &#xD;&#xA;    // Check if breedId is neither 1 nor 2&#xD;&#xA;    if (breedId != 1 &amp;&amp; breedId != 2)&#xD;&#xA;    {&#xD;&#xA;        totalOtherField += chickPlaced;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;        // Helper function to safely convert values&#xD;&#xA;    decimal SafeConvert(object value)&#xD;&#xA;    {&#xD;&#xA;        if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;            return 0;&#xD;&#xA;        return Convert.ToDecimal(value);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;        &#xD;&#xA;    // Calculate @WeekMortTotal for this row: Sat + Sun + Mon + Tue + Wed + Thru + Fri&#xD;&#xA;    decimal weekMortTotal = &#xD;&#xA;        SafeConvert(GetCurrentColumnValue(&quot;Sat&quot;)) +&#xD;&#xA;        SafeConvert(GetCurrentColumnValue(&quot;Sun&quot;)) +&#xD;&#xA;        SafeConvert(GetCurrentColumnValue(&quot;Mon&quot;)) +&#xD;&#xA;        SafeConvert(GetCurrentColumnValue(&quot;Tue&quot;)) +&#xD;&#xA;        SafeConvert(GetCurrentColumnValue(&quot;Wed&quot;)) +&#xD;&#xA;        SafeConvert(GetCurrentColumnValue(&quot;Thru&quot;)) +&#xD;&#xA;        SafeConvert(GetCurrentColumnValue(&quot;Fri&quot;));&#xD;&#xA;    &#xD;&#xA;    // Accumulate weekly mortality&#xD;&#xA;    totalWeekMort += weekMortTotal;&#xD;&#xA;    &#xD;&#xA;        // Accumulate CumTotalDep&#xD;&#xA;    totalCumDep += SafeConvert(GetCurrentColumnValue(&quot;CumTotalDep&quot;));&#xD;&#xA;    // Accumulate Saturday mortality&#xD;&#xA;    totalSat += SafeConvert(GetCurrentColumnValue(&quot;Sat&quot;));&#xD;&#xA;    // Accumulate Sunday mortality&#xD;&#xA;    totalSun += SafeConvert(GetCurrentColumnValue(&quot;Sun&quot;));&#xD;&#xA;    // Accumulate Monday mortality&#xD;&#xA;    totalMon += SafeConvert(GetCurrentColumnValue(&quot;Mon&quot;));&#xD;&#xA;    // Accumulate Tuesday mortality&#xD;&#xA;    totalTue += SafeConvert(GetCurrentColumnValue(&quot;Tue&quot;));&#xD;&#xA;        // Accumulate Wednesday mortality&#xD;&#xA;    totalWed += SafeConvert(GetCurrentColumnValue(&quot;Wed&quot;));&#xD;&#xA;     // Accumulate Thursday (Thru) mortality&#xD;&#xA;    totalThru += SafeConvert(GetCurrentColumnValue(&quot;Thru&quot;));&#xD;&#xA;        // Accumulate Friday mortality&#xD;&#xA;    totalFri += SafeConvert(GetCurrentColumnValue(&quot;Fri&quot;));&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;private void xrLabel7_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get RTL parameter&#xD;&#xA;    bool isRTL = false;&#xD;&#xA;    if (Report.Parameters[&quot;IsRTL&quot;] != null)&#xD;&#xA;    {&#xD;&#xA;        isRTL = Convert.ToBoolean(Report.Parameters[&quot;IsRTL&quot;].Value);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Calculate and display&#xD;&#xA;    if (totalChicksPlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (totalCobbField / totalChicksPlaced) * 100.0m;&#xD;&#xA;        string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;        if (isRTL)&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;كوب%: &quot; + formattedResult;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;COBB%: &quot; + formattedResult;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        if (isRTL)&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;كوب%: 0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;COBB%: 0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrLabel8_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get RTL parameter&#xD;&#xA;    bool isRTL = false;&#xD;&#xA;    if (Report.Parameters[&quot;IsRTL&quot;] != null)&#xD;&#xA;    {&#xD;&#xA;        isRTL = Convert.ToBoolean(Report.Parameters[&quot;IsRTL&quot;].Value);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Calculate and display&#xD;&#xA;    if (totalChicksPlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (totalRossField / totalChicksPlaced) * 100.0m;&#xD;&#xA;        string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;        if (isRTL)&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;روس%: &quot; + formattedResult;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;ROSS%: &quot; + formattedResult;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        if (isRTL)&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;روس%: 0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;ROSS%: 0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrLabel9_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get RTL parameter&#xD;&#xA;    bool isRTL = false;&#xD;&#xA;    if (Report.Parameters[&quot;IsRTL&quot;] != null)&#xD;&#xA;    {&#xD;&#xA;        isRTL = Convert.ToBoolean(Report.Parameters[&quot;IsRTL&quot;].Value);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Calculate and display&#xD;&#xA;    if (totalChicksPlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (totalOtherField / totalChicksPlaced) * 100.0m;&#xD;&#xA;        string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;        if (isRTL)&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;أخرى%: &quot; + formattedResult;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;OTHERS%: &quot; + formattedResult;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        if (isRTL)&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;أخرى%: 0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;OTHERS%: 0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;private void xrTableCell44_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal chickPlaced = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlaced&quot;) ?? 0);&#xD;&#xA;decimal sat = Convert.ToDecimal(GetCurrentColumnValue(&quot;Sat&quot;) ?? 0);&#xD;&#xA;decimal sun = Convert.ToDecimal(GetCurrentColumnValue(&quot;Sun&quot;) ?? 0);&#xD;&#xA;decimal mon = Convert.ToDecimal(GetCurrentColumnValue(&quot;Mon&quot;) ?? 0);&#xD;&#xA;decimal tue = Convert.ToDecimal(GetCurrentColumnValue(&quot;Tue&quot;) ?? 0);&#xD;&#xA;decimal wed = Convert.ToDecimal(GetCurrentColumnValue(&quot;Wed&quot;) ?? 0);&#xD;&#xA;decimal thru = Convert.ToDecimal(GetCurrentColumnValue(&quot;Thru&quot;) ?? 0);&#xD;&#xA;decimal fri = Convert.ToDecimal(GetCurrentColumnValue(&quot;Fri&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Calculate @WeekMortTotal = Sat + Sun + Mon + Tue + Wed + Thru + Fri&#xD;&#xA;decimal weekMortTotal = sat + sun + mon + tue + wed + thru + fri;&#xD;&#xA;&#xD;&#xA;if (chickPlaced &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (@WeekMortTotal / ChickPlaced) * 100&#xD;&#xA;    // This gives weekly mortality percentage&#xD;&#xA;    decimal result = (weekMortTotal / chickPlaced) * 100.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell53_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal chickPlaced = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlaced&quot;) ?? 0);&#xD;&#xA;decimal cumTotalDep = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumTotalDep&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (chickPlaced &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (CumTotalDep / ChickPlaced) * 100&#xD;&#xA;    // This gives cumulative total depletion percentage&#xD;&#xA;    decimal result = (cumTotalDep / chickPlaced) * 100.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell58_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (totalChicksPlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal totalWeekMort = totalSat + totalSun + totalMon + totalTue + totalWed + totalThu + totalFri;&#xD;&#xA;        decimal result = (totalWeekMort / totalChicksPlaced) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell60_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Check if total chicks placed is greater than 0 (@TotalChicksPlacedParam &gt; 0)&#xD;&#xA;    if (totalChicksPlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate: (totalCumDep / totalChicksPlaced) * 100&#xD;&#xA;        decimal result = (totalCumDep / totalChicksPlaced) * 100.0m;&#xD;&#xA;        string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;        cell.Text = formattedResult;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell37_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Check if total chicks placed is greater than 0&#xD;&#xA;    if (totalChicksPlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate: (totalSat / totalChicksPlaced) * 100&#xD;&#xA;        decimal result = (totalSat / totalChicksPlaced) * 100.0m;&#xD;&#xA;        string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;        cell.Text = formattedResult ;&#xD;&#xA;  }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell38_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Check if total chicks placed is greater than 0&#xD;&#xA;    if (totalChicksPlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate: (totalSun / totalChicksPlaced) * 100&#xD;&#xA;        decimal result = (totalSun / totalChicksPlaced) * 100.0m;&#xD;&#xA;        string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;        cell.Text = formattedResult ;&#xD;&#xA;        &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell39_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Check if total chicks placed is greater than 0&#xD;&#xA;    if (totalChicksPlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate: (totalMon / totalChicksPlaced) * 100&#xD;&#xA;        decimal result = (totalMon / totalChicksPlaced) * 100.0m;&#xD;&#xA;        string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;        cell.Text = formattedResult ;&#xD;&#xA;        &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell40_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Check if total chicks placed is greater than 0&#xD;&#xA;    if (totalChicksPlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate: (totalTue / totalChicksPlaced) * 100&#xD;&#xA;        decimal result = (totalTue / totalChicksPlaced) * 100.0m;&#xD;&#xA;        string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;        cell.Text = formattedResult ;&#xD;&#xA;        &#xD;&#xA;       &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell61_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Check if total chicks placed is greater than 0&#xD;&#xA;    if (totalChicksPlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate: (totalWed / totalChicksPlaced) * 100&#xD;&#xA;        decimal result = (totalWed / totalChicksPlaced) * 100.0m;&#xD;&#xA;        string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;        cell.Text = formattedResult ;&#xD;&#xA;        &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell62_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Check if total chicks placed is greater than 0&#xD;&#xA;    if (totalChicksPlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate: (totalThru / totalChicksPlaced) * 100&#xD;&#xA;        decimal result = (totalThru / totalChicksPlaced) * 100.0m;&#xD;&#xA;        string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;        cell.Text = formattedResult + &quot;%&quot;;&#xD;&#xA;        &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00%&quot;;&#xD;&#xA;    }&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;private void xrTableCell63_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Check if total chicks placed is greater than 0&#xD;&#xA;    if (totalChicksPlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate: (totalFri / totalChicksPlaced) * 100&#xD;&#xA;        decimal result = (totalFri / totalChicksPlaced) * 100.0m;&#xD;&#xA;        string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;        cell.Text = formattedResult + &quot;%&quot;;&#xD;&#xA;        &#xD;&#xA;            }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00%&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1169.29138" PageHeightF="826.771667" Version="25.2" DataMember="SR_BRO_DailyMort" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
