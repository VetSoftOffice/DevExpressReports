bject sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    groupSumCumHsCulls += Convert.ToDecimal(GetCurrentColumnValue(&quot;CumHsCulls&quot;) ?? 0);&#xD;&#xA;    groupSumCumHsMort += Convert.ToDecimal(GetCurrentColumnValue(&quot;CumHsMort&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Assuming StartBirds is the same for all rows in the group, capture it once&#xD;&#xA;    if (groupStartBirds == 0)&#xD;&#xA;    {&#xD;&#xA;        groupStartBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartBirds&quot;) ?? 0);&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell35_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal startBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartBirds&quot;) ?? 0);&#xD;&#xA;decimal cumMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumMort&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (startBirds != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: CumMort * 100 / StartBirds&#xD;&#xA;    // This gives cumulative mortality percentage&#xD;&#xA;    decimal result = (cumMort * 100.0m) / startBirds;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell50_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (groupStartBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        decimal totalRemovals = groupSumCumHsCulls + groupSumCumHsMort;&#xD;&#xA;        decimal result = (totalRemovals * 100.0m) / groupStartBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;