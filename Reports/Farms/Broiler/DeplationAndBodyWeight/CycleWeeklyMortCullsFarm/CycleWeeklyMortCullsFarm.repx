) * 100.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell74_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlace&quot;) ?? 0);&#xD;&#xA;decimal totalCullsMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalCullsMort&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (chickPlace != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (TotalCullsMort / ChickPlace) * 100&#xD;&#xA;    // This gives total removals (mortality + culls) percentage for the entire cycle&#xD;&#xA;    decimal result = (totalCullsMort / chickPlace) * 100.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlace&quot;) ?? 0);&#xD;&#xA;    decimal m1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;M1&quot;) ?? 0);&#xD;&#xA;    decimal c1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;C1&quot;) ?? 0);&#xD;&#xA;    decimal m2 = Convert.ToDecimal(GetCurrentColumnValue(&quot;M2&quot;) ?? 0);&#xD;&#xA;    decimal c2 = Convert.ToDecimal(GetCurrentColumnValue(&quot;C2&quot;) ?? 0);&#xD;&#xA;    decimal m3 = Convert.ToDecimal(GetCurrentColumnValue(&quot;M3&quot;) ?? 0);&#xD;&#xA;    decimal c3 = Convert.ToDecimal(GetCurrentColumnValue(&quot;C3&quot;) ?? 0);&#xD;&#xA;    decimal m4 = Convert.ToDecimal(GetCurrentColumnValue(&quot;M4&quot;) ?? 0);&#xD;&#xA;    decimal c4 = Convert.ToDecimal(GetCurrentColu