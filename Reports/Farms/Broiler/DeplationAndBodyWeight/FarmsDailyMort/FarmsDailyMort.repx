<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="FarmsDailyMort" ScriptsSource="decimal sumCobbPercentage = 0;&#xD;&#xA;int validRowCount = 0;&#xD;&#xA;decimal sumRossPercentage = 0;&#xD;&#xA;int validRowCountRoss = 0;&#xD;&#xA;decimal sumOtherPercentage = 0;&#xD;&#xA;int validRowCountOther = 0&#xD;&#xA;decimal totalMort = 0;&#xD;&#xA;decimal totalChickPlace = 0;&#xD;&#xA;decimal totalCulls = 0;&#xD;&#xA;decimal sumCumDepPercentage = 0;&#xD;&#xA;int validRowCumDepCount = 0;&#xD;&#xA;private void xrTableCell16_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get Cobb and ChickPlace values&#xD;&#xA;    decimal cobb = Convert.ToDecimal(GetCurrentColumnValue(&quot;Cobb&quot;) ?? 0);&#xD;&#xA;    decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlace&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (chickPlace != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate Cobb percentage&#xD;&#xA;        decimal result = (cobb / chickPlace) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal cobb = Convert.ToDecimal(GetCurrentColumnValue(&quot;Cobb&quot;) ?? 0);&#xD;&#xA;        decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlace&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        if (chickPlace != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal percentage = (cobb / chickPlace) * 100;&#xD;&#xA;            sumCobbPercentage += percentage;&#xD;&#xA;            validRowCount++;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        decimal ross = Convert.ToDecimal(GetCurrentColumnValue(&quot;Ross&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        if (chickPlace != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal percentage = (ross / chickPlace) * 100;&#xD;&#xA;            sumRossPercentage += percentage;&#xD;&#xA;            validRowCountRoss++;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;         decimal other = Convert.ToDecimal(GetCurrentColumnValue(&quot;Other&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        if (chickPlace != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal percentage = (other / chickPlace) * 100;&#xD;&#xA;            sumOtherPercentage += percentage;&#xD;&#xA;            validRowCountOther++;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // Sum each field separately&#xD;&#xA;        totalMort += Convert.ToDecimal(GetCurrentColumnValue(&quot;Mort&quot;) ?? 0);&#xD;&#xA;        totalChickPlace += Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlace&quot;) ?? 0);&#xD;&#xA;         totalCulls += Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;) ?? 0);&#xD;&#xA;         &#xD;&#xA;        decimal cumTotalDep = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumTotalDep&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        if (chickPlace &gt; 0 &amp;&amp; cumTotalDep &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal percentage = (cumTotalDep / chickPlace) * 100;&#xD;&#xA;            sumCumDepPercentage += percentage;&#xD;&#xA;            validRowCumDepCount++;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell45_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (validRowCount &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal avg = sumCobbPercentage / validRowCount;&#xD;&#xA;            cell.Text = avg.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell19_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get Ross and ChickPlace values&#xD;&#xA;    decimal ross = Convert.ToDecimal(GetCurrentColumnValue(&quot;Ross&quot;) ?? 0);&#xD;&#xA;    decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlace&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (chickPlace != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate Ross percentage&#xD;&#xA;        decimal result = (ross / chickPlace) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell46_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (validRowCount &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal avg = sumRossPercentage / validRowCount;&#xD;&#xA;            cell.Text = avg.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell20_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get Other and ChickPlace values&#xD;&#xA;    decimal other = Convert.ToDecimal(GetCurrentColumnValue(&quot;Other&quot;) ?? 0);&#xD;&#xA;    decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlace&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (chickPlace != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate Other breed percentage&#xD;&#xA;        decimal result = (other / chickPlace) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell52_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (validRowCount &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal avg = sumOtherPercentage / validRowCount;&#xD;&#xA;            cell.Text = avg.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get Mort and ChickPlace values&#xD;&#xA;    decimal mort = Convert.ToDecimal(GetCurrentColumnValue(&quot;Mort&quot;) ?? 0);&#xD;&#xA;    decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlace&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (chickPlace != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate mortality percentage&#xD;&#xA;        decimal result = (mort / chickPlace) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell54_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (totalChickPlace &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal overallPercent = (totalMort / totalChickPlace) * 100;&#xD;&#xA;            cell.Text = overallPercent.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell24_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get Culls and ChickPlace values&#xD;&#xA;    decimal culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;) ?? 0);&#xD;&#xA;    decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlace&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (chickPlace != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate culls percentage&#xD;&#xA;        decimal result = (culls / chickPlace) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell75_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (totalChickPlace &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal overallPercent = (totalCulls / totalChickPlace) * 100;&#xD;&#xA;            cell.Text = overallPercent.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell64_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get ChickPlace and CumTotalDep values&#xD;&#xA;    decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlace&quot;) ?? 0);&#xD;&#xA;    decimal cumTotalDep = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumTotalDep&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (chickPlace &gt; 0 &amp;&amp; cumTotalDep &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate cumulative depletion percentage&#xD;&#xA;        decimal result = (cumTotalDep / chickPlace) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell77_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (validRowCount &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal avg = sumCumDepPercentage / validRowCount;&#xD;&#xA;            cell.Text = avg.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell96_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Calculate total depletion (Mort + Culls)&#xD;&#xA;    decimal totalDepletion = totalMort + totalCulls ;&#xD;&#xA;    &#xD;&#xA;    if (totalChickPlace &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate total depletion percentage&#xD;&#xA;        decimal result = (totalDepletion / totalChickPlace ) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" Version="25.2" DataMember="SR_BRO_FarmsDailyMort" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
