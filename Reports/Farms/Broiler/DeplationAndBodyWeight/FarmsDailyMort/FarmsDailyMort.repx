A;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell24_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get Culls and ChickPlace values&#xD;&#xA;    decimal culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;) ?? 0);&#xD;&#xA;    decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlace&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (chickPlace != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate culls percentage&#xD;&#xA;        decimal result = (culls / chickPlace) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell75_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (totalChickPlace &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal overallPercent = (totalCulls / totalChickPlace) * 100;&#xD;&#xA;            cell.Text = overallPercent.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell64_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get ChickPlace and CumTotalDep values&#xD;&#xA;    decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlace&quot;) ?? 0);&#xD;&#xA;    decimal cumTotalDep = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumTotalDep&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (chickPlace &gt; 0 &amp;&amp; cumTotalDep &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate cumulative depletion percentage&#xD;&#xA;        decimal result = (cumTotalDep / chickPlace) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell77_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (validRowCount &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal avg = sumCumDepPercentage / validRowCount;&#xD;&#xA;            cell.Text = avg.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell96_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Calculate total depletion (Mort + Culls)&#xD;&#xA;    decimal totalDepletion = totalMort + totalCulls ;&#xD;&#xA;    &#xD;&#xA;    if (totalChickPlace &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate total depletion percentage&#xD;&#xA;        decimal result = (totalDepletion / totalChickPlace ) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" Version="26.1" DataMember="SR_BRO_FarmsDailyMort" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
