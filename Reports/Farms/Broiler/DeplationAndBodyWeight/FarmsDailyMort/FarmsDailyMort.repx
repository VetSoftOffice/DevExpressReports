;        }&#xD;&#xA;        &#xD;&#xA;        decimal ross = Convert.ToDecimal(GetCurrentColumnValue(&quot;Ross&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        if (chickPlace != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal percentage = (ross / chickPlace) * 100;&#xD;&#xA;            sumRossPercentage += percentage;&#xD;&#xA;            validRowCountRoss++;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;         decimal other = Convert.ToDecimal(GetCurrentColumnValue(&quot;Other&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        if (chickPlace != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal percentage = (other / chickPlace) * 100;&#xD;&#xA;            sumOtherPercentage += percentage;&#xD;&#xA;            validRowCountOther++;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // Sum each field separately&#xD;&#xA;        totalMort += Convert.ToDecimal(GetCurrentColumnValue(&quot;Mort&quot;) ?? 0);&#xD;&#xA;        totalChickPlace += Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlace&quot;) ?? 0);&#xD;&#xA;         totalCulls += Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;) ?? 0);&#xD;&#xA;         &#xD;&#xA;        decimal cumTotalDep = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumTotalDep&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        if (chickPlace &gt; 0 &amp;&amp; cumTotalDep &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal percentage = (cumTotalDep / chickPlace) * 100;&#xD;&#xA;            sumCumDepPercentage += percentage;&#xD;&#xA;            validRowCumDepCount++;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell45_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (validRowCount &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal avg = sumCobbPercentage / validRowCount;&#xD;&#xA;            cell.Text = avg.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&