<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_BRO_WeeklyDeplAllFarmWise" ScriptsSource="private decimal runningSum = 0;&#xD;&#xA;&#xD;&#xA;private void xrTableCell30_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Add the current record value to the running sum&#xD;&#xA;    runningSum += Convert.ToDecimal(GetCurrentColumnValue(&quot;CumMort&quot;));&#xD;&#xA;&#xD;&#xA;    // Get the value of StartBirds&#xD;&#xA;    decimal startBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartBirds&quot;));&#xD;&#xA;&#xD;&#xA;    // Avoid division by zero&#xD;&#xA;    if (startBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        xrTableCell30.Text = ((runningSum * 100) / startBirds).ToString(&quot;N2&quot;); // Format to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        xrTableCell30.Text = &quot;0.00&quot;; // Handle case where StartBirds is 0&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private decimal runningSumCulls = 0;&#xD;&#xA;private void xrTableCell31_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // Add the current record value of CumCulls to the running sum&#xD;&#xA;    runningSumCulls += Convert.ToDecimal(GetCurrentColumnValue(&quot;CumCulls&quot;));&#xD;&#xA;&#xD;&#xA;    // Get the value of StartBirds&#xD;&#xA;    decimal startBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartBirds&quot;));&#xD;&#xA;&#xD;&#xA;    // Avoid division by zero&#xD;&#xA;    if (startBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        xrTableCell31.Text = ((runningSumCulls * 100) / startBirds).ToString(&quot;N2&quot;); // Format to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        xrTableCell31.Text = &quot;0&quot;; // Handle case where StartBirds is 0&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;public decimal RoundCustom(decimal value)&#xD;&#xA;{&#xD;&#xA;    decimal shiftedValue = value * 100;&#xD;&#xA;    int intValue = (int)shiftedValue; // Convert to integer&#xD;&#xA;&#xD;&#xA;    int firstDecimal = (intValue / 10) % 10; // Extract first decimal digit&#xD;&#xA;    int secondDecimal = intValue % 10;       // Extract second decimal digit&#xD;&#xA;&#xD;&#xA;    if (secondDecimal &gt;= 5)&#xD;&#xA;    {&#xD;&#xA;        firstDecimal += 1; // Round up first decimal if second decimal is &gt;= 5&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    decimal roundedValue = (intValue / 100) + (firstDecimal / 10.0m);&#xD;&#xA;&#xD;&#xA;    // **Second rounding step**&#xD;&#xA;    int firstPrecision = (int)(roundedValue * 10) % 10; // First decimal after rounding&#xD;&#xA;    int secondPrecision = (int)(roundedValue * 100) % 10; // Second decimal&#xD;&#xA;&#xD;&#xA;    if (secondPrecision &gt;= 5)&#xD;&#xA;    {&#xD;&#xA;        roundedValue = Math.Ceiling(roundedValue * 10) / 10; // Round up if second precision &gt;= 5&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    return roundedValue;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell55_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal avgWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;AvgWt&quot;));&#xD;&#xA;    decimal liveChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveChicks&quot;));&#xD;&#xA;&#xD;&#xA;    decimal roundedAvgWt = RoundCustom(avgWt); // Apply rounding function&#xD;&#xA;    decimal finalValue = (roundedAvgWt * liveChicks) / 1000; // Multiply by LiveChicks and divide by 1000&#xD;&#xA;&#xD;&#xA;    xrTableCell55.Text = finalValue.ToString(&quot;N1&quot;); // Format as needed&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private decimal runningSumTotalFeed = 0;&#xD;&#xA;&#xD;&#xA;private void xrTableCell56_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // Add the current value of TotalFeed to the running sum&#xD;&#xA;    runningSumTotalFeed += Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalFeed&quot;));&#xD;&#xA;&#xD;&#xA;    // Format the output to always have two decimal places&#xD;&#xA;    xrTableCell56.Text = runningSumTotalFeed.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private decimal cumulativeFeed = 0;&#xD;&#xA;&#xD;&#xA;private void xrTableCell18_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Add the current value of TotalFeed to the cumulative sum&#xD;&#xA;    cumulativeFeed += Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalFeed&quot;));&#xD;&#xA;&#xD;&#xA;    // Retrieve the LiveChicks field value&#xD;&#xA;    decimal liveChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveChicks&quot;));&#xD;&#xA;&#xD;&#xA;    // Ensure division by zero does not occur&#xD;&#xA;    decimal result = liveChicks != 0 ? (cumulativeFeed * 1000) / liveChicks : 0;&#xD;&#xA;&#xD;&#xA;    // Format the output to always have two decimal places&#xD;&#xA;    xrTableCell18.Text = result.ToString(&quot;0.00&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private decimal runningSumTotalFeed1 = 0;&#xD;&#xA;private decimal result = 0;&#xD;&#xA;private void xrTableCell19_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Retrieve field values again since xrTableCell55 is not directly accessible&#xD;&#xA;    decimal avgWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;AvgWt&quot;));&#xD;&#xA;    decimal liveChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveChicks&quot;));&#xD;&#xA;    decimal totalFeed = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalFeed&quot;));&#xD;&#xA;&#xD;&#xA;    // Apply rounding function to AvgWt&#xD;&#xA;    decimal roundedAvgWt = RoundCustom(avgWt);&#xD;&#xA;&#xD;&#xA;    // Compute the same value as in xrTableCell55&#xD;&#xA;    decimal calculatedValue55 = (roundedAvgWt * liveChicks) / 1000;&#xD;&#xA;     // Update the running sum of TotalFeed&#xD;&#xA;    runningSumTotalFeed1 += totalFeed;&#xD;&#xA;    &#xD;&#xA;    // Compute the running sum from TotalFeed (like in xrTableCell56)&#xD;&#xA;     if (calculatedValue55 &gt;= 0)&#xD;&#xA;    {&#xD;&#xA;             result = runningSumTotalFeed1  / calculatedValue55 ;&#xD;&#xA;    }&#xD;&#xA;        &#xD;&#xA;    // Format output to one decimal place&#xD;&#xA;    xrTableCell19.Text = result.ToString(&quot;N4&quot;);&#xD;&#xA;}" Landscape="true" PageWidthF="1606" PageHeightF="827" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="25.2" DataMember="SR_BRO_WeeklyDeplAllFarmWise" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
