private decimal cumulativeFeed = 0;

private void xrTableCell18_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    // Add the current value of TotalFeed to the cumulative sum
    cumulativeFeed += Convert.ToDecimal(GetCurrentColumnValue("TotalFeed"));

    // Retrieve the LiveChicks field value
    decimal liveChicks = Convert.ToDecimal(GetCurrentColumnValue("LiveChicks"));

    // Ensure division by zero does not occur
    decimal result = liveChicks != 0 ? (cumulativeFeed * 1000) / liveChicks : 0;

    // Format the output to always have two decimal places
    xrTableCell18.Text = result.ToString("0.00");
}



