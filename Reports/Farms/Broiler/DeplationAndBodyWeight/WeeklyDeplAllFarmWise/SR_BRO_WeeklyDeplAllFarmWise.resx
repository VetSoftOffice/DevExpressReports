    decimal avgWt = Convert.ToDecimal(GetCurrentColumnValue("AvgWt"));
    decimal liveChicks = Convert.ToDecimal(GetCurrentColumnValue("LiveChicks"));
    decimal totalFeed = Convert.ToDecimal(GetCurrentColumnValue("TotalFeed"));

    // Apply rounding function to AvgWt
    decimal roundedAvgWt = RoundCustom(avgWt);

    // Compute the same value as in xrTableCell55
    decimal calculatedValue55 = (roundedAvgWt * liveChicks) / 1000;
     // Update the running sum of TotalFeed
    runningSumTotalFeed1 += totalFeed;
    
    // Compute the running sum from TotalFeed (like in xrTableCell56)
     if (calculatedValue55 &gt; 0)
    {
             result = runningSumTotalFeed1  / calculatedValue55 ;
    }
        
    // Format output to one decimal place
    xrTableCell19.Text = result.ToString("N4");
