private void xrTableCell30_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    // Add the current record value to the running sum
    runningSum += Convert.ToDecimal(GetCurrentColumnValue("CumMort"));

    // Get the value of StartBirds
    decimal startBirds = Convert.ToDecimal(GetCurrentColumnValue("StartBirds"));

    // Avoid division by zero
    if (startBirds != 0)
    {
        xrTableCell30.Text = ((runningSum * 100) / startBirds).ToString("N2"); // Format to 2 decimal places
    }
    else
    {
        xrTableCell30.Text = "0.00"; // Handle case where StartBirds is 0
    }
}

