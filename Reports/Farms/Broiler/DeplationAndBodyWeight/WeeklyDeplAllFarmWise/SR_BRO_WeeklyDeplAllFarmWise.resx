public decimal RoundCustom(decimal value)
{
    decimal shiftedValue = value * 100;
    int intValue = (int)shiftedValue; // Convert to integer

    int firstDecimal = (intValue / 10) % 10; // Extract first decimal digit
    int secondDecimal = intValue % 10;       // Extract second decimal digit

    if (secondDecimal &gt;= 5)
    {
        firstDecimal += 1; // Round up first decimal if second decimal is &gt;= 5
    }

    decimal roundedValue = (intValue / 100) + (firstDecimal / 10.0m);

    // **Second rounding step**
    int firstPrecision = (int)(roundedValue * 10) % 10; // First decimal after rounding
    int secondPrecision = (int)(roundedValue * 100) % 10; // Second decimal

    if (secondPrecision &gt;= 5)
    {
        roundedValue = Math.Ceiling(roundedValue * 10) / 10; // Round up if second precision &gt;= 5
    }

    return roundedValue;
    }



private void xrTableCell55_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    decimal avgWt = Convert.ToDecimal(GetCurrentColumnValue("AvgWt"));
    decimal liveChicks = Convert.ToDecimal(GetCurrentColumnValue("LiveChicks"));

    decimal roundedAvgWt = RoundCustom(avgWt); // Apply rounding function
    decimal finalValue = (roundedAvgWt * liveChicks) / 1000; // Multiply by LiveChicks and divide by 1000

    xrTableCell55.Text = finalValue.ToString("N1"); // Format as needed
}

