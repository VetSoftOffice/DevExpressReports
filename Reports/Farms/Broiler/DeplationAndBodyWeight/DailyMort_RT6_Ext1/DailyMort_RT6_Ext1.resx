private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
     // Helper function to safely convert values
    decimal SafeConvert(object value)
    {
        if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))
            return 0;
        return Convert.ToDecimal(value);
    }
    
    // Accumulate FeedQtn for {#FeedCumm}
    totalFeedQtn += SafeConvert(GetCurrentColumnValue("FeedQtn"));
    
    // Accumulate Depletion for {#Cumm}
    totalDepletion += SafeConvert(GetCurrentColumnValue("Depilation"));
      // Accumulate TrialFeedQtn for {#TrialFeedCumm}
    totalTrialFeedQtn += SafeConvert(GetCurrentColumnValue("TrialFeedQtn"));
    
    // Accumulate TrialDepilation for {#TrialCumm}
    totalTrialDepletion += SafeConvert(GetCurrentColumnValue("TrialDepilation"));
}

private void xrTableCell15_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
        XRTableCell cell = sender as XRTableCell;
    
    // Get current row values
    decimal chicksPlaced = Convert.ToDecimal(GetCurrentColumnValue("ChicksPlaced") ?? 0);
    decimal avgBodyWeight = Convert.ToDecimal(GetCurrentColumnValue("AvgBodyWeight") ?? 0);
    
    // Calculate (ChicksPlaced - {#Cumm})
    decimal adjustedBirds = chicksPlaced - totalDepletion;
    
    // Check if conditions are met
    if (adjustedBirds &gt; 0 &amp;&amp; avgBodyWeight &gt; 0)
    {
        // Calculate: ({#FeedCumm} * 1000.0 / (ChicksPlaced - {#Cumm})) / AvgBodyWeight
        decimal result = (totalFeedQtn * 1000.0m / adjustedBirds) / avgBodyWeight;
        
        cell.Text = result.ToString("N2"); // Formats to 2 decimal places
        
    }
    else
    {
        cell.Text = "0.00";
    }
}

private void xrTableCell23_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
        XRTableCell cell = sender as XRTableCell;
    
    // Get current row values for trial group
    decimal chicksPlacedTrial = Convert.ToDecimal(GetCurrentColumnValue("ChicksPlacedTrial") ?? 0);
    decimal trialAvgBodyWeight = Convert.ToDecimal(GetCurrentColumnValue("TrialAvgBodyWeight") ?? 0);
    
    // Calculate (ChicksPlacedTrial - {#TrialCumm})
    decimal adjustedTrialBirds = chicksPlacedTrial - totalTrialDepletion;
    
    // Check if conditions are met
    if (chicksPlacedTrial &gt; 0 &amp;&amp; trialAvgBodyWeight &gt; 0 &amp;&amp; adjustedTrialBirds &gt; 0)
    {
        // Calculate: (1000 * ({#TrialFeedCumm} / (ChicksPlacedTrial - {#TrialCumm}))) / TrialAvgBodyWeight
        // Step by step for clarity:
        decimal feedPerBird = totalTrialFeedQtn / adjustedTrialBirds;           // Feed per bird
        decimal feedGrams = 1000.0m * feedPerBird;                               // Convert to grams
        decimal result = feedGrams / trialAvgBodyWeight;                         // Divide by body weight
        
        cell.Text = result.ToString("N2"); // Formats to 2 decimal places
        
            }
    else
    {
        cell.Text = "0.00";
    }
}

private void xrTableCell24_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
        XRTableCell cell = sender as XRTableCell;
    
    // Get current row value for trial group chicks placed
    decimal chicksPlacedTrial = Convert.ToDecimal(GetCurrentColumnValue("ChicksPlacedTrial") ?? 0);
    
