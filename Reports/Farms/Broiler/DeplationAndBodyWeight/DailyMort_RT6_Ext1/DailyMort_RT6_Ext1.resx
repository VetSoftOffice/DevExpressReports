    decimal chicksPlacedControl = Convert.ToDecimal(GetCurrentColumnValue("ChicksPlacedControl") ?? 0);
    decimal controlAvgBodyWeight = Convert.ToDecimal(GetCurrentColumnValue("ControlAvgBodyWeight") ?? 0);
    
    // Calculate (ChicksPlacedControl - {#ControlCumm})
    decimal adjustedControlBirds = chicksPlacedControl - totalControlDepletion;
    
    // Check if all conditions are met
    if (chicksPlacedControl &gt; 0 &amp;&amp; controlAvgBodyWeight &gt; 0 &amp;&amp; adjustedControlBirds &gt; 0)
    {
        // Calculate: (1000 * ({#ControlFeedCumm} / (ChicksPlacedControl - {#ControlCumm}))) / ControlAvgBodyWeight
        // Step by step for clarity:
        decimal feedPerBird = totalControlFeedQtn / adjustedControlBirds;           // Feed per bird in kg
        decimal feedGrams = 1000.0m * feedPerBird;                                   // Convert to grams
        decimal result = feedGrams / controlAvgBodyWeight;                           // Divide by body weight in grams
        
        cell.Text = result.ToString("N2"); // Using 4 decimals for precision
        
