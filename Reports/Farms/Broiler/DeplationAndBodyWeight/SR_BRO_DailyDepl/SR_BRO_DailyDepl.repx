            <Item1 Ref="118" ControlType="XRSubreport" Name="SR_BRO_DailyDepl_Sub1">
              <ReportSource Ref="120" ControlType="DevExpressReports.Reports.Farms.Broiler.DeplationAndBodyWeight.SR_BRO_DailyDepl_Sub1, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="decimal totalCumMort = 0; &#xD;&#xA;decimal totalCumCulls = 0;&#xD;&#xA;decimal totalFeed = 0;&#xD;&#xA;decimal maxBW = 0;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     // Helper function to safely convert values&#xD;&#xA;    decimal SafeConvert(object value)&#xD;&#xA;    {&#xD;&#xA;        if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;            return 0;&#xD;&#xA;        return Convert.ToDecimal(value);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Accumulate Mort for {#RT_CumMort}&#xD;&#xA;    totalCumMort += SafeConvert(GetCurrentColumnValue(&quot;Mort&quot;));&#xD;&#xA;    // Accumulate Culls for {#RT_CumCulls}&#xD;&#xA;    totalCumCulls += SafeConvert(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;    &#xD;&#xA;    // Get TotalFeed&#xD;&#xA;    object feedObj = GetCurrentColumnValue(&quot;TotalFeed&quot;);&#xD;&#xA;    if (feedObj != null &amp;&amp; feedObj != DBNull.Value)&#xD;&#xA;    {&#xD;&#xA;        totalFeed += Convert.ToDecimal(feedObj);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Track max BW&#xD;&#xA;    object bwObj = GetCurrentColumnValue(&quot;BW&quot;);&#xD;&#xA;    if (bwObj != null &amp;&amp; bwObj != DBNull.Value)&#xD;&#xA;    {&#xD;&#xA;        decimal bw = Convert.ToDecimal(bwObj);&#xD;&#xA;        if (bw &gt; maxBW)&#xD;&#xA;        {&#xD;&#xA;            maxBW = bw;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell23_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartBirds parameter value&#xD;&#xA;    decimal startBirds = 0;&#xD;&#xA;    if (Report.Parameters[&quot;StartBirds&quot;] != null)&#xD;&#xA;    {&#xD;&#xA;        startBirds = Convert.ToDecimal(Report.Parameters[&quot;StartBirds&quot;].Value);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Check if StartBirds is not zero&#xD;&#xA;    if (startBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate: ({#RT_CumMort} * 100) / {@StartBirds}&#xD;&#xA;        decimal result = (totalCumMort * 100.0m) / startBirds;&#xD;&#xA;        string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;        cell.Text = formattedResult ;&#xD;&#xA;        &#xD;&#xA;       &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell24_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartBirds parameter value&#xD;&#xA;    decimal startBirds = 0;&#xD;&#xA;    if (Report.Parameters[&quot;StartBirds&quot;] != null)&#xD;&#xA;    {&#xD;&#xA;        startBirds = Convert.ToDecimal(Report.Parameters[&quot;StartBirds&quot;].Value);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Check if StartBirds is not zero&#xD;&#xA;    if (startBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate: ({#RT_CumCulls} * 100) / {@StartBirds}&#xD;&#xA;        decimal result = (totalCumCulls * 100.0m) / startBirds;&#xD;&#xA;        string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;        cell.Text = formattedResult + &quot;%&quot;;&#xD;&#xA;   }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00%&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell25_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartBirds parameter&#xD;&#xA;    decimal startBirds = 0;&#xD;&#xA;    if (Report.Parameters[&quot;StartBirds&quot;] != null)&#xD;&#xA;    {&#xD;&#xA;        startBirds = Convert.ToDecimal(Report.Parameters[&quot;StartBirds&quot;].Value);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    if (startBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        decimal totalCumLose = totalCumMort + totalCumCulls;&#xD;&#xA;        decimal lossPct = (totalCumLose * 100.0m) / startBirds;&#xD;&#xA;        decimal mortPct = (totalCumMort * 100.0m) / startBirds;&#xD;&#xA;        decimal cullsPct = (totalCumCulls * 100.0m) / startBirds;&#xD;&#xA;        &#xD;&#xA;        cell.Text = lossPct.ToString(&quot;N2&quot;) + &quot;%&quot;;&#xD;&#xA;        &#xD;&#xA;            }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00%&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell30_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    decimal liveChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveChicks&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (maxBW != 0 &amp;&amp; liveChicks != 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (totalFeed * 1000.0m / maxBW) / liveChicks;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" PageWidthF="1169.29138" PageHeightF="1653.54333" Version="25.2" DataMember="SR_BRO_DailyDepl_Sub1" DataSource="#Ref-119" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
