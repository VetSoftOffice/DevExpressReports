        <Item2 Ref="354" ControlType="SubBand" Name="SubBand9">
          <Controls>
            <Item1 Ref="355" ControlType="XRSubreport" Name="SR_BRO_DailyDepl_Sub2">
              <ReportSource Ref="357" ControlType="DevExpressReports.Reports.Farms.Broiler.DeplationAndBodyWeight.SR_BRO_DailyDepl_Sub2.SR_BRO_DailyDepl_Sub2, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="decimal totalMort = 0;    // {@TotalMort} - sum of Mort1-Mort5&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     // Helper function to safely convert values&#xD;&#xA;    decimal SafeConvert(object value)&#xD;&#xA;    {&#xD;&#xA;        if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;            return 0;&#xD;&#xA;        return Convert.ToDecimal(value);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Accumulate all mortality fields for {@TotalMort}&#xD;&#xA;    totalMort += SafeConvert(GetCurrentColumnValue(&quot;Mort1&quot;));&#xD;&#xA;    totalMort += SafeConvert(GetCurrentColumnValue(&quot;Mort2&quot;));&#xD;&#xA;    totalMort += SafeConvert(GetCurrentColumnValue(&quot;Mort3&quot;));&#xD;&#xA;    totalMort += SafeConvert(GetCurrentColumnValue(&quot;Mort4&quot;));&#xD;&#xA;    totalMort += SafeConvert(GetCurrentColumnValue(&quot;Mort5&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell16_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartBirds parameter value&#xD;&#xA;    decimal startBirds = 0;&#xD;&#xA;    if (Report.Parameters[&quot;StartBirds&quot;] != null)&#xD;&#xA;    {&#xD;&#xA;        startBirds = Convert.ToDecimal(Report.Parameters[&quot;StartBirds&quot;].Value);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Check if StartBirds is not zero&#xD;&#xA;    if (startBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate: ({@TotalMort} * 100) / {@StartBirds}&#xD;&#xA;        decimal result = (totalMort * 100.0m) / startBirds;&#xD;&#xA;        string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;        cell.Text = formattedResult + &quot;%&quot;;&#xD;&#xA;        &#xD;&#xA;        // Optional tooltip with details&#xD;&#xA;        cell.ToolTip = string.Format(&#xD;&#xA;            &quot;TOTAL MORTALITY (Periods 1-5)\n\n&quot; +&#xD;&#xA;            &quot;Total Mortality ({@TotalMort}): {0} birds\n&quot; +&#xD;&#xA;            &quot;  Mort1: {1}\n&quot; +&#xD;&#xA;            &quot;  Mort2: {2}\n&quot; +&#xD;&#xA;            &quot;  Mort3: {3}\n&quot; +&#xD;&#xA;            &quot;  Mort4: {4}\n&quot; +&#xD;&#xA;            &quot;  Mort5: {5}\n\n&quot; +&#xD;&#xA;            &quot;Start Birds Parameter ({@StartBirds}): {6}\n&quot; +&#xD;&#xA;            &quot;Mortality Percentage: {7}%&quot;,&#xD;&#xA;            totalMort.ToString(&quot;N0&quot;),&#xD;&#xA;            SafeConvert(GetCurrentColumnValue(&quot;Mort1&quot;)).ToString(&quot;N0&quot;),&#xD;&#xA;            SafeConvert(GetCurrentColumnValue(&quot;Mort2&quot;)).ToString(&quot;N0&quot;),&#xD;&#xA;            SafeConvert(GetCurrentColumnValue(&quot;Mort3&quot;)).ToString(&quot;N0&quot;),&#xD;&#xA;            SafeConvert(GetCurrentColumnValue(&quot;Mort4&quot;)).ToString(&quot;N0&quot;),&#xD;&#xA;            SafeConvert(GetCurrentColumnValue(&quot;Mort5&quot;)).ToString(&quot;N0&quot;),&#xD;&#xA;            startBirds.ToString(&quot;N0&quot;),&#xD;&#xA;            formattedResult);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00%&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" PageWidthF="1169.29138" PageHeightF="1653.54333" Version="25.2" DataMember="SR_BRO_DailyDepl_Sub2" DataSource="#Ref-356" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
                <Parameters>
