    <Item16 Ref="35" Name="TotalDelayedTime" Expression="Iif(DateDiffMinute([SR_BRO_FeedCatching.LineUpTime], [SR_BRO_FeedCatching.CatchingFinishTime]) &gt;= 0, &#xD;&#xA;    DateDiffMinute([SR_BRO_FeedCatching.LineUpTime], [SR_BRO_FeedCatching.CatchingFinishTime]) / 60.0, &#xD;&#xA;    0)&#xD;&#xA;" DataMember="SR_BRO_FeedCatching" />
