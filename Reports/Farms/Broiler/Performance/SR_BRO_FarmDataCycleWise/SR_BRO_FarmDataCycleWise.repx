<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_BRO_FarmDataCycleWise" ScriptsSource="decimal totalChickPlace = 0;&#xD;&#xA;decimal totalBlowStan = 0;&#xD;&#xA;int recordCount = 0;&#xD;&#xA;decimal sumOfPercentages = 0;&#xD;&#xA;decimal totalChicksPlaced = 0;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// Helper function for safe conversion&#xD;&#xA;private decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value?.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;private void xrTableCell21_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlace&quot;) ?? 0);&#xD;&#xA;decimal blowStan = Convert.ToDecimal(GetCurrentColumnValue(&quot;BlowStan&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (chickPlace != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (BlowStan / ChickPlace) * 100&#xD;&#xA;    decimal result = (blowStan / chickPlace) * 100.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places (e.g., 2.50)&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell56_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlace&quot;) ?? 0);&#xD;&#xA;decimal totalMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalMort&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (chickPlace != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (TotalMort / ChickPlace) * 100&#xD;&#xA;    // This gives total mortality percentage&#xD;&#xA;    decimal result = (totalMort / chickPlace) * 100.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickPlace&quot;) ?? 0);&#xD;&#xA;    decimal blowStan = Convert.ToDecimal(GetCurrentColumnValue(&quot;BlowStan&quot;) ?? 0);&#xD;&#xA;     decimal totalMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalMort&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;    totalChickPlace += chickPlace;&#xD;&#xA;    totalBlowStan += blowStan;&#xD;&#xA;    totalChicksPlaced += SafeConvert(GetCurrentColumnValue(&quot;ChickPlace&quot;));&#xD;&#xA;    &#xD;&#xA;    if (chickPlace != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate percentage for this record&#xD;&#xA;        decimal percentage = (totalMort / chickPlace) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumOfPercentages += percentage;&#xD;&#xA;        recordCount++;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell112_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (totalChickPlace != 0)&#xD;&#xA;    {&#xD;&#xA;        // @BeloStandTotal = sum of BlowStan&#xD;&#xA;        decimal beloStandTotal = totalBlowStan;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (@BeloStandTotal / totalChickPlace) * 100&#xD;&#xA;        decimal result = (beloStandTotal / totalChickPlace) * 100.0m;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell139_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (totalChickPlace != 0)&#xD;&#xA;    {&#xD;&#xA;        // @BeloStandTotal = sum of BlowStan&#xD;&#xA;        decimal beloStandTotal = totalBlowStan;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (@BeloStandTotal / totalChickPlace) * 100&#xD;&#xA;        decimal result = (beloStandTotal / totalChickPlace) * 100.0m;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell121_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (recordCount &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate average&#xD;&#xA;        decimal average = sumOfPercentages / recordCount;&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell148_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (recordCount &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate average&#xD;&#xA;        decimal average = sumOfPercentages / recordCount;&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrLabel9_