    <value>decimal totalChickPlace = 0;
decimal totalBlowStan = 0;
int recordCount = 0;
decimal sumOfPercentages = 0;
decimal totalChicksPlaced = 0;



// Helper function for safe conversion
private decimal SafeConvert(object value)
{
    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value?.ToString()))
        return 0;
    return Convert.ToDecimal(value);
}
private void xrTableCell21_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    XRTableCell cell = sender as XRTableCell;

// Get values from the data source
decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue("ChickPlace") ?? 0);
decimal blowStan = Convert.ToDecimal(GetCurrentColumnValue("BlowStan") ?? 0);

if (chickPlace != 0)
{
    // Calculate: (BlowStan / ChickPlace) * 100
    decimal result = (blowStan / chickPlace) * 100.0m;
    cell.Text = result.ToString("N2"); // Formats to 2 decimal places (e.g., 2.50)
}
else
{
    cell.Text = "0.00";
}
}

private void xrTableCell56_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    XRTableCell cell = sender as XRTableCell;

// Get values from the data source
decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue("ChickPlace") ?? 0);
decimal totalMort = Convert.ToDecimal(GetCurrentColumnValue("TotalMort") ?? 0);

if (chickPlace != 0)
{
