}
else
{
    cell.Text = "0.00";
}
}

private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    decimal chickPlace = Convert.ToDecimal(GetCurrentColumnValue("ChickPlace") ?? 0);
    decimal blowStan = Convert.ToDecimal(GetCurrentColumnValue("BlowStan") ?? 0);
     decimal totalMort = Convert.ToDecimal(GetCurrentColumnValue("TotalMort") ?? 0);

    totalChickPlace += chickPlace;
    totalBlowStan += blowStan;
    totalChicksPlaced += SafeConvert(GetCurrentColumnValue("ChickPlace"));
    
    if (chickPlace != 0)
    {
        // Calculate percentage for this record
        decimal percentage = (totalMort / chickPlace) * 100.0m;
        
        // Add to sum and increment counter
        sumOfPercentages += percentage;
        recordCount++;
    }
}

