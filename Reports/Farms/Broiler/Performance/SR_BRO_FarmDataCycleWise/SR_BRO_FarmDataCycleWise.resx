private void xrLabel9_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    XRLabel label = sender as XRLabel;
    
    // Check if IsRTL parameter exists and is true
    bool isRTL = false;
    if (this.Parameters["IsRTL"] != null)
    {
        bool.TryParse(this.Parameters["IsRTL"].Value?.ToString(), out isRTL);
    }
    
    if (isRTL)
    {
        // Display Arabic text with RTL formatting
        label.Text = string.Format("رصيد بداية الانتاج: {0:N0}", totalChicksPlaced);
    }
    else
    {
        // Display English text with LTR formatting
        label.Text = string.Format("Chicks Placed: {0:N0}", totalChicksPlaced);
    }
}
