<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="26.1.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_BRO_LiveAndSlaughter" ScriptsSource="&#xD;&#xA;private void xrTableCell30_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get ChicksPlaced and TotalLose&#xD;&#xA;    decimal chicksPlaced = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChicksPlaced&quot;) ?? 0);&#xD;&#xA;    decimal totalLose = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalLose&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (chicksPlaced != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate loss percentage&#xD;&#xA;        decimal result = (totalLose / chicksPlaced) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell32_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get ChicksPlaced and Dev&#xD;&#xA;    decimal chicksPlaced = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChicksPlaced&quot;) ?? 0);&#xD;&#xA;    decimal dev = Convert.ToDecimal(GetCurrentColumnValue(&quot;Dev&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (chicksPlaced != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate absolute deviation percentage&#xD;&#xA;        decimal result = Math.Abs(dev) * 100 / chicksPlaced;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell44_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get ChicksPlaced and TotalDevLose&#xD;&#xA;    decimal chicksPlaced = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChicksPlaced&quot;) ?? 0);&#xD;&#xA;    decimal totalDevLose = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalDevLose&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (chicksPlaced != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate total deviation loss percentage&#xD;&#xA;        decimal result = totalDevLose * 100 / chicksPlaced;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell25_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get FemaleNo_Catch (TotalChicks)&#xD;&#xA;    decimal totalChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleNo_Catch&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Get TotalWeightFR&#xD;&#xA;    decimal totalWeightFR = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalWeightFR&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (totalChicks != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate average weight per chick&#xD;&#xA;        decimal result = totalWeightFR / totalChicks;&#xD;&#xA;        cell.Text = result.ToString(&quot;N3&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.000&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell39_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get components for TotalSellPluck (PluckedQty + TotalSellNo)&#xD;&#xA;    decimal pluckedQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;PluckedQty&quot;) ?? 0);&#xD;&#xA;    decimal totalSellNo = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalSellNo&quot;) ?? 0);&#xD;&#xA;    decimal totalSellPluck = pluckedQty + totalSellNo;&#xD;&#xA;    &#xD;&#xA;    // Get components for TotalWetSellPluck (TotalSellWeight + ChicksProcessingWeight)&#xD;&#xA;    decimal totalSellWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalSellWeight&quot;) ?? 0);&#xD;&#xA;    decimal chicksProcessingWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChicksProcessingWeight&quot;) ?? 0);&#xD;&#xA;    decimal totalWetSellPluck = totalSellWeight + chicksProcessingWeight;&#xD;&#xA;    &#xD;&#xA;    if (totalSellPluck != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate average weight per item&#xD;&#xA;        decimal result = totalWetSellPluck / totalSellPluck;&#xD;&#xA;        cell.Text = result.ToString(&quot;N3&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.000&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" PageWidthF="1169.29138" PageHeightF="1653.54333" Version="26.1" DataMember="SR_BRO_LiveAndSlaughter" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
