private void xrTableCell30_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    XRTableCell cell = sender as XRTableCell;
    
    // Get ChicksPlaced and TotalLose
    decimal chicksPlaced = Convert.ToDecimal(GetCurrentColumnValue("ChicksPlaced") ?? 0);
    decimal totalLose = Convert.ToDecimal(GetCurrentColumnValue("TotalLose") ?? 0);
    
    if (chicksPlaced != 0)
    {
        // Calculate loss percentage
        decimal result = (totalLose / chicksPlaced) * 100;
        cell.Text = result.ToString("N2");
    }
    else
    {
        cell.Text = "0.00";
    }
}

private void xrTableCell32_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
     XRTableCell cell = sender as XRTableCell;
    
    // Get ChicksPlaced and Dev
    decimal chicksPlaced = Convert.ToDecimal(GetCurrentColumnValue("ChicksPlaced") ?? 0);
    decimal dev = Convert.ToDecimal(GetCurrentColumnValue("Dev") ?? 0);
    
    if (chicksPlaced != 0)
    {
        // Calculate absolute deviation percentage
        decimal result = Math.Abs(dev) * 100 / chicksPlaced;
        cell.Text = result.ToString("N2");
    }
    else
    {
        cell.Text = "0.00";
    }
}

private void xrTableCell44_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    XRTableCell cell = sender as XRTableCell;
    
    // Get ChicksPlaced and TotalDevLose
    decimal chicksPlaced = Convert.ToDecimal(GetCurrentColumnValue("ChicksPlaced") ?? 0);
    decimal totalDevLose = Convert.ToDecimal(GetCurrentColumnValue("TotalDevLose") ?? 0);
    
    if (chicksPlaced != 0)
    {
        // Calculate total deviation loss percentage
        decimal result = totalDevLose * 100 / chicksPlaced;
        cell.Text = result.ToString("N2") ;
    }
    else
    {
        cell.Text = "0.00";
    }
}

private void xrTableCell25_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
     XRTableCell cell = sender as XRTableCell;
    
    // Get FemaleNo_Catch (TotalChicks)
    decimal totalChicks = Convert.ToDecimal(GetCurrentColumnValue("FemaleNo_Catch") ?? 0);
    
    // Get TotalWeightFR
    decimal totalWeightFR = Convert.ToDecimal(GetCurrentColumnValue("TotalWeightFR") ?? 0);
    
    if (totalChicks != 0)
    {
        // Calculate average weight per chick
        decimal result = totalWeightFR / totalChicks;
        cell.Text = result.ToString("N3");
    }
    else
    {
        cell.Text = "0.000";
    }
}

private void xrTableCell39_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    XRTableCell cell = sender as XRTableCell;
    
    // Get components for TotalSellPluck (PluckedQty + TotalSellNo)
    decimal pluckedQty = Convert.ToDecimal(GetCurrentColumnValue("PluckedQty") ?? 0);
    decimal totalSellNo = Convert.ToDecimal(GetCurrentColumnValue("TotalSellNo") ?? 0);
    decimal totalSellPluck = pluckedQty + totalSellNo;
    
    // Get components for TotalWetSellPluck (TotalSellWeight + ChicksProcessingWeight)
    decimal totalSellWeight = Convert.ToDecimal(GetCurrentColumnValue("TotalSellWeight") ?? 0);
    decimal chicksProcessingWeight = Convert.ToDecimal(GetCurrentColumnValue("ChicksProcessingWeight") ?? 0);
    decimal totalWetSellPluck = totalSellWeight + chicksProcessingWeight;
    
    if (totalSellPluck != 0)
    {
        // Calculate average weight per item
        decimal result = totalWetSellPluck / totalSellPluck;
        cell.Text = result.ToString("N3");
    }
    else
    {
        cell.Text = "0.000";
    }
}
