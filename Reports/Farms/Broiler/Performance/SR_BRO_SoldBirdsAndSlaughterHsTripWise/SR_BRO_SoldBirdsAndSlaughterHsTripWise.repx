<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_BRO_SoldBirdsAndSlaughterHsTripWise" ScriptsSource="decimal sumBirds_PT = 0;&#xD;&#xA;decimal sumTotalWt_PT = 0;&#xD;&#xA;decimal sumBirds_SL = 0;&#xD;&#xA;decimal sumTotalWt_SL = 0;&#xD;&#xA;private void xrTableCell18_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get Birds_PT (number of birds)&#xD;&#xA;    decimal birds_PT = Convert.ToDecimal(GetCurrentColumnValue(&quot;Birds_PT&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Get TotalWt_PT (total weight)&#xD;&#xA;    decimal totalWt_PT = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalWt_PT&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (birds_PT &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate average weight per bird&#xD;&#xA;        decimal result = totalWt_PT / birds_PT;&#xD;&#xA;        cell.Text = result.ToString(&quot;N3&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.000&quot;;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     sumBirds_PT += Convert.ToDecimal(GetCurrentColumnValue(&quot;Birds_PT&quot;) ?? 0);&#xD;&#xA;        sumTotalWt_PT += Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalWt_PT&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        // Sum each field separately for slaughter birds&#xD;&#xA;        sumBirds_SL += Convert.ToDecimal(GetCurrentColumnValue(&quot;Birds_SL&quot;) ?? 0);&#xD;&#xA;        sumTotalWt_SL += Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalWt_SL&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell40_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (sumBirds_PT &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal overallAvg = sumTotalWt_PT / sumBirds_PT;&#xD;&#xA;            cell.Text = overallAvg.ToString(&quot;N3&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.000&quot;;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell23_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get Birds_SL (number of slaughter birds)&#xD;&#xA;    decimal birds_SL = Convert.ToDecimal(GetCurrentColumnValue(&quot;Birds_SL&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Get TotalWt_SL (total weight of slaughter birds)&#xD;&#xA;    decimal totalWt_SL = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalWt_SL&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (birds_SL &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate average weight per slaughter bird&#xD;&#xA;        decimal result = totalWt_SL / birds_SL;&#xD;&#xA;        cell.Text = result.ToString(&quot;N3&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.000&quot;;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell49_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (sumBirds_SL &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal overallAvg = sumTotalWt_SL / sumBirds_SL;&#xD;&#xA;            cell.Text = overallAvg.ToString(&quot;N3&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.000&quot;;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell43_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        decimal totalGBirds = sumBirds_PT + sumBirds_SL;&#xD;&#xA;        decimal totalGWt = sumTotalWt_PT + sumTotalWt_SL;&#xD;&#xA;        &#xD;&#xA;        if (totalGBirds &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal overallAvg = totalGWt / totalGBirds;&#xD;&#xA;            cell.Text = overallAvg.ToString(&quot;N3&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.000&quot;;&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1169.29138" PageHeightF="826.771667" Version="25.2" DataMember="SR_BRO_SoldBirdsAndSlaughterHs" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
