              <ReportSource Ref="417" ControlType="DevExpressReports.Reports.Farms.Broiler.Performance.SR_BRO_FarmsEvalOrderByRegions.SR_BRO_FarmsEvalOrderByRegions, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource=" decimal sumLiveWeightPerBird = 0;&#xD;&#xA; int validRowCount = 0;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal liveNo = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveNo&quot;) ?? 0);&#xD;&#xA;        decimal totalLiveWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalLiveWt&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        if (liveNo != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal liveWeightPerBird = (totalLiveWt * 1000.0m) / liveNo;&#xD;&#xA;            sumLiveWeightPerBird += liveWeightPerBird;&#xD;&#xA;            validRowCount++;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell14_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (validRowCount &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal avg = sumLiveWeightPerBird / validRowCount;&#xD;&#xA;            cell.Text = avg.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" Version="25.2" DataMember="SR_BRO_FarmsEvalOrderByRegions" DataSource="#Ref-416" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
