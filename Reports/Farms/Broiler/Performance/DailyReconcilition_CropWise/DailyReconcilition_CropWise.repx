<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="DailyReconcilition_CropWise" ScriptsSource="decimal sumRFemaleStarted = 0;&#xD;&#xA;decimal sumCounterTotal = 0;&#xD;&#xA;decimal sumDOA = 0;&#xD;&#xA;decimal sumRFemaleCatchLoss = 0;&#xD;&#xA;decimal sumScaleWeight = 0;&#xD;&#xA;decimal sumRFemaleStarted = 0;&#xD;&#xA;decimal sumDeplation = 0;&#xD;&#xA;decimal sumTotalWeightWithLoss = 0;&#xD;&#xA;decimal sumBroScaleWeight = 0;&#xD;&#xA;decimal sumDeviation = 0;&#xD;&#xA;decimal sumCounterTotal = 0;&#xD;&#xA;decimal sumCulls = 0;&#xD;&#xA;decimal sumDOA = 0;&#xD;&#xA;private void xrTableCell20_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get the required field values&#xD;&#xA;    decimal rfFemaleStarted = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_Female_Started&quot;) ?? 0);&#xD;&#xA;    decimal counterTotal = Convert.ToDecimal(GetCurrentColumnValue(&quot;CounterTotal&quot;) ?? 0);&#xD;&#xA;    decimal doa = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA&quot;) ?? 0);&#xD;&#xA;    decimal rfFemaleCatchLoss = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_FemaleCatchLoss&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (rfFemaleStarted != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate total depletion (CounterTotal + DOA + rf_FemaleCatchLoss)&#xD;&#xA;        decimal totalDepletion = counterTotal + doa + rfFemaleCatchLoss;&#xD;&#xA;        &#xD;&#xA;        // Calculate percentage&#xD;&#xA;        decimal result = (totalDepletion / rfFemaleStarted) * 100.0m;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell12_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get the required field values&#xD;&#xA;    decimal counterTotal = Convert.ToDecimal(GetCurrentColumnValue(&quot;CounterTotal&quot;) ?? 0);&#xD;&#xA;    decimal doa = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA&quot;) ?? 0);&#xD;&#xA;    decimal scaleWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;ScaleWeight&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate total birds (CounterTotal + DOA)&#xD;&#xA;    decimal totalBirds = counterTotal + doa;&#xD;&#xA;    &#xD;&#xA;    if (totalBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate average weight per bird&#xD;&#xA;        decimal result = scaleWeight / totalBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell50_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get the required field values&#xD;&#xA;    decimal rfFemaleStarted = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_Female_Started&quot;) ?? 0);&#xD;&#xA;    decimal deplation = Convert.ToDecimal(GetCurrentColumnValue(&quot;DEPLATION&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (rfFemaleStarted != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate survival percentage&#xD;&#xA;        decimal result = ((rfFemaleStarted - deplation) / rfFemaleStarted) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell36_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;            XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        // Get required field values&#xD;&#xA;        decimal rfFemaleCatchLoss = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_FemaleCatchLoss&quot;) ?? 0);&#xD;&#xA;        decimal counterTotal = Convert.ToDecimal(GetCurrentColumnValue(&quot;CounterTotal&quot;) ?? 0);&#xD;&#xA;        decimal doa = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA&quot;) ?? 0);&#xD;&#xA;        decimal scaleWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;ScaleWeight&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        // Calculate {@Pt_AvgLive} - average live weight&#xD;&#xA;        decimal ptAvgLive = 0;&#xD;&#xA;        decimal totalBirds = counterTotal + doa;&#xD;&#xA;        &#xD;&#xA;        if (totalBirds != 0)&#xD;&#xA;        {&#xD;&#xA;            ptAvgLive = scaleWeight / totalBirds;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // Calculate total weight with catch loss&#xD;&#xA;        decimal result = (rfFemaleCatchLoss * ptAvgLive) + scaleWeight;&#xD;&#xA;        &#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell55_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;            XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        // Get all required field values&#xD;&#xA;        decimal rfFemaleStarted = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_Female_Started&quot;) ?? 0);&#xD;&#xA;        decimal deplation = Convert.ToDecimal(GetCurrentColumnValue(&quot;DEPLATION&quot;) ?? 0);&#xD;&#xA;        decimal rfFemaleCatchLoss = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_FemaleCatchLoss&quot;) ?? 0);&#xD;&#xA;        decimal counterTotal = Convert.ToDecimal(GetCurrentColumnValue(&quot;CounterTotal&quot;) ?? 0);&#xD;&#xA;        decimal doa = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA&quot;) ?? 0);&#xD;&#xA;        decimal scaleWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;ScaleWeight&quot;) ?? 0);&#xD;&#xA;        // Calculate {@Pt_AvgLive} - average live weight&#xD;&#xA;        decimal ptAvgLive = 0;&#xD;&#xA;        decimal totalBirds = counterTotal + doa;&#xD;&#xA;        if (totalBirds != 0)&#xD;&#xA;        {&#xD;&#xA;            ptAvgLive = scaleWeight / totalBirds;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // Calculate {@Bro_ScaleWeight} - total weight including catch loss&#xD;&#xA;        decimal broScaleWeight = (rfFemaleCatchLoss * ptAvgLive) + scaleWeight;&#xD;&#xA;        &#xD;&#xA;        // Calculate denominator (rf_Female_Started - DEPLATION)&#xD;&#xA;        decimal denominator = rfFemaleStarted - deplation;&#xD;&#xA;        &#xD;&#xA;        if (denominator != 0)&#xD;&#xA;        {&#xD;&#xA;            // Calculate final average weight&#xD;&#xA;            decimal result = broScaleWeight / denominator;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;            sumRFemaleStarted += Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_Female_Started&quot;) ?? 0);&#xD;&#xA;        sumCounterTotal += Convert.ToDecimal(GetCurrentColumnValue(&quot;CounterTotal&quot;) ?? 0);&#xD;&#xA;        sumDOA += Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA&quot;) ?? 0);&#xD;&#xA;        sumRFemaleCatchLoss += Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_FemaleCatchLoss&quot;) ?? 0);&#xD;&#xA;        sumScaleWeight += Convert.ToDecimal(GetCurrentColumnValue(&quot;ScaleWeight&quot;) ?? 0);&#xD;&#xA;        sumDeplation += Convert.ToDecimal(GetCurrentColumnValue(&quot;DEPLATION&quot;) ?? 0);&#xD;&#xA;        sumDeviation += Convert.ToDecimal(GetCurrentColumnValue(&quot;Dev&quot;) ?? 0); // {@Deviation} is the Dev field&#xD;&#xA;        sumCulls += Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;) ?? 0);&#xD;&#xA;        sumDOA += Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA&quot;) ?? 0);&#xD;&#xA;        // Calculate {@Pt_AvgLive} for this row&#xD;&#xA;        decimal ptAvgLive = 0;&#xD;&#xA;        decimal totalBirds = counterTotal + doa;&#xD;&#xA;        if (totalBirds != 0)&#xD;&#xA;        {&#xD;&#xA;            ptAvgLive = scaleWeight / totalBirds;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // Calculate total weight with loss for this row&#xD;&#xA;        decimal rowTotalWeightWithLoss = (rfFemaleCatchLoss * ptAvgLive) + scaleWeight;&#xD;&#xA;        &#xD;&#xA;        // Add to running total&#xD;&#xA;        sumTotalWeightWithLoss += rowTotalWeightWithLoss;&#xD;&#xA;        &#xD;&#xA;        decimal broScaleWeight = rowTotalWeightWithLoss ;&#xD;&#xA;        sumBroScaleWeight += broScaleWeight;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell42_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (sumRFemaleStarted != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal totalDepletion = sumCounterTotal + sumDOA + sumRFemaleCatchLoss;&#xD;&#xA;            decimal result = (totalDepletion / sumRFemaleStarted) * 100.0m;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell62_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;            XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        decimal totalBirds = sumCounterTotal + sumDOA;&#xD;&#xA;        &#xD;&#xA;        if (totalBirds != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = sumScaleWeight / totalBirds;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell63_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (sumRFemaleStarted != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal survival = sumRFemaleStarted - sumDeplation;&#xD;&#xA;            decimal result = (survival / sumRFemaleStarted) * 100.0m;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell75_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        cell.Text = sumTotalWeightWithLoss.ToString(&quot;N2&quot;) ;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell76_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        decimal remainingBirds = sumRFemaleStarted - sumDeplation;&#xD;&#xA;        &#xD;&#xA;        if (remainingBirds != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = sumBroScaleWeight / remainingBirds;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell81_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (sumRFemaleStarted != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = (sumDeplation / sumRFemaleStarted) * 100.0m;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell82_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (sumRFemaleStarted != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = (sumDeviation / sumRFemaleStarted) * 100.0m;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell84_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;          XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (sumRFemaleStarted != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = (sumCounterTotal / sumRFemaleStarted) * 100.0m;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell85_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (sumRFemaleStarted != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = (sumCulls / sumRFemaleStarted) * 100.0m;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell86_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (sumRFemaleStarted != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = (sumDOA / sumRFemaleStarted) * 100.0m;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell87_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (sumRFemaleStarted != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = (sumRFemaleCatchLoss / sumRFemaleStarted) * 100.0m;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell34_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (sumRFemaleStarted != 0)&#xD;&#xA;        {&#xD;&#xA;            // Calculate {@LiveNo} - sum of all depletion components&#xD;&#xA;            decimal liveNo = sumCounterTotal + sumDOA + sumRFemaleCatchLoss;&#xD;&#xA;            &#xD;&#xA;            decimal result = (liveNo / sumRFemaleStarted) * 100.0m;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell32_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (sumRFemaleStarted != 0)&#xD;&#xA;        {&#xD;&#xA;            // Calculate {@LiveNo} - sum of all depletion components&#xD;&#xA;            decimal liveNo = sumCounterTotal + sumDOA + sumRFemaleCatchLoss;&#xD;&#xA;            &#xD;&#xA;            decimal result = liveNo ;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" Version="25.2" DataMember="SR_BRO_DailyReconilition" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
