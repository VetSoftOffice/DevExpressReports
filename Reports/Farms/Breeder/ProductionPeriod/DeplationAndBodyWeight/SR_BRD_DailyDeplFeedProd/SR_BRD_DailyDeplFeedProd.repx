<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_BRD_DailyDeplFeedProd" ScriptsSource="decimal sumWeightedProdValues = 0;  // Σ(TotalProd × FemaleBalance)&#xD;&#xA;decimal sumWeights = 0;            // Σ(FemaleBalance)&#xD;&#xA;decimal sumWeightedHatEggValues = 0;  // Σ(TotalHatEgg × TotalProd)&#xD;&#xA;decimal sumWeightedHatEggValuesReport = 0;  // Σ(TotalHatEgg × TotalProd)&#xD;&#xA;decimal sumWeightsHatEggReport = 0;              // Σ(TotalProd)&#xD;&#xA;decimal TotalFemaleBalanceGroup  = 0;&#xD;&#xA;decimal TotalMaleBalanceGroup = 0;&#xD;&#xA;decimal sumFeedPer1000 = 0;&#xD;&#xA;int countFeedPer1000 = 0;&#xD;&#xA;decimal sumMaleFeedPer1000 = 0;&#xD;&#xA;decimal countMaleFeedPer1000 = 0;&#xD;&#xA;decimal sumStockToHatEggRatio = 0;&#xD;&#xA;int countStockToHatEggRatio = 0;&#xD;&#xA;decimal sumFemaleDeplPercent = 0;&#xD;&#xA;int countFemaleDeplPercent = 0;&#xD;&#xA;decimal sumMaleDeplPercent = 0;&#xD;&#xA;int countMaleDeplPercent = 0;&#xD;&#xA;private void xrTableCell101_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get values from fields&#xD;&#xA;    decimal femaleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleBalance&quot;) ?? 0);&#xD;&#xA;    decimal totalProd = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalProd&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate: (TotalProd / FemaleBalance) * 100&#xD;&#xA;    if (femaleBalance &gt; 0 &amp;&amp; totalProd &gt; 0) {&#xD;&#xA;        decimal result = (totalProd / femaleBalance) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N0&quot;); // 1 decimal place with %&#xD;&#xA;        // Or: result.ToString(&quot;F1&quot;) without %&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0&quot;; // or &quot;0&quot;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     // Get values from fields&#xD;&#xA;    decimal femaleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleBalance&quot;) ?? 0);&#xD;&#xA;    decimal totalProd = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalProd&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Only accumulate if both values are positive&#xD;&#xA;    if (femaleBalance &gt; 0 &amp;&amp; totalProd &gt; 0) {&#xD;&#xA;        // For weighted average: (TotalProd × FemaleBalance)&#xD;&#xA;        // This gives more weight to rows with more birds&#xD;&#xA;        sumWeightedProdValues += (totalProd * femaleBalance);&#xD;&#xA;        sumWeights += femaleBalance;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;        // Get values from fields&#xD;&#xA;    decimal totalHatEgg = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalHatEgg&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Only accumulate if both values are positive&#xD;&#xA;    if (totalProd &gt; 0 &amp;&amp; totalHatEgg &gt; 0) {&#xD;&#xA;        // Weighted value: TotalHatEgg × TotalProd&#xD;&#xA;        sumWeightedHatEggValues += (totalHatEgg * totalProd);&#xD;&#xA;        sumWeights += totalProd;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;     &#xD;&#xA;    // Get values from fields&#xD;&#xA;    decimal maleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleBalance&quot;) ?? 0);&#xD;&#xA;    TotalFemaleBalanceGroup += femaleBalance ;&#xD;&#xA;    TotalMaleBalanceGroup += maleBalance ;&#xD;&#xA;&#xD;&#xA;    decimal femaleFeedCons = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleFeedCons&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (femaleBalance &gt; 0) {&#xD;&#xA;        decimal feedPer1000 = (femaleFeedCons * 1000) / femaleBalance;&#xD;&#xA;        sumFeedPer1000 += feedPer1000;&#xD;&#xA;        countFeedPer1000++;&#xD;&#xA;    }&#xD;&#xA;    decimal maleFeedCons = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleFeedCons&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (maleBalance &gt; 0) {&#xD;&#xA;        decimal feedPer1000 = (maleFeedCons * 1000) / maleBalance;&#xD;&#xA;        sumMaleFeedPer1000 += feedPer1000;&#xD;&#xA;        countMaleFeedPer1000++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal eggStock = Convert.ToDecimal(GetCurrentColumnValue(&quot;EggStock&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (totalHatEgg &gt; 0) {&#xD;&#xA;        decimal ratio = eggStock / totalHatEgg;&#xD;&#xA;        sumStockToHatEggRatio += ratio;&#xD;&#xA;        countStockToHatEggRatio++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;     decimal femaleDepl = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleDepl&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (femaleBalance &gt; 0) {&#xD;&#xA;        decimal percent = (femaleDepl * 100) / femaleBalance;&#xD;&#xA;        sumFemaleDeplPercent += percent;&#xD;&#xA;        countFemaleDeplPercent++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal maleDepl = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleDepl&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (maleBalance &gt; 0) {&#xD;&#xA;        decimal percent = (maleDepl * 100) / maleBalance;&#xD;&#xA;        sumMaleDeplPercent += percent;&#xD;&#xA;        countMaleDeplPercent++;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell15_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Calculate weighted average: Σ(TotalProd×FemaleBalance) / Σ(FemaleBalance) × 100&#xD;&#xA;    if (sumWeights &gt; 0) {&#xD;&#xA;        decimal weightedAvg = (sumWeightedProdValues / sumWeights) * 100;&#xD;&#xA;        cell.Text = weightedAvg.ToString(&quot;N2&quot;) ; // 1 decimal place&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell104_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get values from fields&#xD;&#xA;    decimal totalProd = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalProd&quot;) ?? 0);&#xD;&#xA;    decimal totalHatEgg = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalHatEgg&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate: (TotalHatEgg × 100) / TotalProd&#xD;&#xA;    if (totalProd &gt; 0 &amp;&amp; totalHatEgg &gt; 0) {&#xD;&#xA;        decimal result = (totalHatEgg * 100) / totalProd;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ; // 1 decimal place with %&#xD;&#xA;        // Or without %: result.ToString(&quot;F1&quot;)&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or &quot;0&quot;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell19_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Calculate weighted average: Σ(TotalHatEgg×TotalProd) / Σ(TotalProd) × 100&#xD;&#xA;    if (sumWeights &gt; 0) {&#xD;&#xA;        decimal weightedAvg = (sumWeightedHatEggValues / sumWeights) * 100;&#xD;&#xA;        cell.Text = weightedAvg.ToString(&quot;N2&quot;) ; // 1 decimal place&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell43_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {  &#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;     decimal totalProd = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalProd&quot;) ?? 0);&#xD;&#xA;    decimal totalHatEgg = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalHatEgg&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Only accumulate if both values are positive&#xD;&#xA;    if (totalProd &gt; 0 &amp;&amp; totalHatEgg &gt; 0) {&#xD;&#xA;        // Weighted value: TotalHatEgg × TotalProd&#xD;&#xA;        sumWeightedHatEggValuesReport += (totalHatEgg * totalProd);&#xD;&#xA;        sumWeightsHatEggReport += totalProd;&#xD;&#xA;    }&#xD;&#xA;     // Calculate weighted average: Σ(TotalHatEgg×TotalProd) / Σ(TotalProd) × 100&#xD;&#xA;    if (sumWeightsHatEggReport &gt; 0) {&#xD;&#xA;        decimal weightedAvg = (sumWeightedHatEggValuesReport / sumWeightsHatEggReport ) * 100;&#xD;&#xA;        cell.Text = weightedAvg.ToString(&quot;N2&quot;); // 1 decimal place&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell114_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get values from fields&#xD;&#xA;    decimal femaleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleBalance&quot;) ?? 0);&#xD;&#xA;    decimal maleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleBalance&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate: (MaleBalance × 100) / FemaleBalance&#xD;&#xA;    if (femaleBalance &gt; 0) {&#xD;&#xA;        decimal result = (maleBalance * 100) / femaleBalance;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ; // 1 decimal place with %&#xD;&#xA;        // Or without %: result.ToString(&quot;F1&quot;)&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or &quot;0&quot;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell61_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;          XRTableCell cell = sender as XRTableCell;&#xD;&#xA; // Calculate: (MaleBalance × 100) / FemaleBalance&#xD;&#xA;    if (TotalFemaleBalanceGroup &gt; 0) {&#xD;&#xA;        decimal result = (TotalMaleBalanceGroup* 100) / TotalFemaleBalanceGroup ;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ; // 1 decimal place with %&#xD;&#xA;        // Or without %: result.ToString(&quot;F1&quot;)&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or &quot;0&quot;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell118_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;decimal femaleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleBalance&quot;) ?? 0);&#xD;&#xA;decimal femaleFeedCons = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleFeedCons&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;if (femaleBalance &gt; 0) {&#xD;&#xA;    decimal feedPer1000 = (femaleFeedCons * 1000) / femaleBalance;&#xD;&#xA;    cell.Text = feedPer1000.ToString(&quot;N2&quot;);&#xD;&#xA;} else {&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell65_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (countFeedPer1000 &gt; 0) {&#xD;&#xA;        decimal avgFeedPer1000 = sumFeedPer1000 / countFeedPer1000;&#xD;&#xA;        cell.Text = avgFeedPer1000.ToString(&quot;N2&quot;);&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell119_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;decimal maleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleBalance&quot;) ?? 0);&#xD;&#xA;decimal maleFeedCons = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleFeedCons&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;if (maleBalance &gt; 0) {&#xD;&#xA;    decimal feedPer1000 = (maleFeedCons * 1000) / maleBalance;&#xD;&#xA;    cell.Text = feedPer1000.ToString(&quot;N2&quot;);&#xD;&#xA;} else {&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell66_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (countMaleFeedPer1000 &gt; 0) {&#xD;&#xA;        decimal avgFeedPer1000 = sumMaleFeedPer1000 / countMaleFeedPer1000;&#xD;&#xA;        cell.Text = avgFeedPer1000.ToString(&quot;N2&quot;);&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell120_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;decimal totalHatEgg = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalHatEgg&quot;) ?? 0);&#xD;&#xA;decimal eggStock = Convert.ToDecimal(GetCurrentColumnValue(&quot;EggStock&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;if (totalHatEgg &gt; 0) {&#xD;&#xA;    decimal result = eggStock / totalHatEgg;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;} else {&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell67_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (countStockToHatEggRatio &gt; 0) {&#xD;&#xA;        decimal avgRatio = sumStockToHatEggRatio / countStockToHatEggRatio;&#xD;&#xA;        cell.Text = avgRatio.ToString(&quot;N2&quot;);&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;private void xrTableCell121_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    decimal femaleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleBalance&quot;) ?? 0);&#xD;&#xA;    decimal femaleDepl = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleDepl&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (femaleBalance &gt; 0) {&#xD;&#xA;        decimal percent = (femaleDepl * 100) / femaleBalance;&#xD;&#xA;        cell.Text = percent.ToString(&quot;N2&quot;) ;&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell68_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (countFemaleDeplPercent &gt; 0) {&#xD;&#xA;        decimal avgPercent = sumFemaleDeplPercent / countFemaleDeplPercent;&#xD;&#xA;        cell.Text = avgPercent.ToString(&quot;N2&quot;) ;&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell122_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    decimal maleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleBalance&quot;) ?? 0);&#xD;&#xA;    decimal maleDepl = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleDepl&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (maleBalance &gt; 0) {&#xD;&#xA;        decimal percent = (maleDepl * 100) / maleBalance;&#xD;&#xA;        cell.Text = percent.ToString(&quot;N2&quot;);&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell69_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (countMaleDeplPercent &gt; 0) {&#xD;&#xA;        decimal avgPercent = sumMaleDeplPercent / countMaleDeplPercent;&#xD;&#xA;        cell.Text = avgPercent.ToString(&quot;N2&quot;);&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" Version="25.2" Dat