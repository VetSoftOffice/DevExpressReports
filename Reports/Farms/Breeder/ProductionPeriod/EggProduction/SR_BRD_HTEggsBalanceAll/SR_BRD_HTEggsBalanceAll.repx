<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_BRD_HTEggsBalanceAll" ScriptsSource="using System;&#xD;&#xA;using System.Collections;&#xD;&#xA;using System.Collections.Generic;&#xD;&#xA;using System.Drawing;&#xD;&#xA;using System.ComponentModel;&#xD;&#xA;using DevExpress.XtraReports.UI;&#xD;&#xA;&#xD;&#xA;private Dictionary&lt;string, DateTime&gt; flockFirstDate = new Dictionary&lt;string, DateTime&gt;();&#xD;&#xA;private Dictionary&lt;string, decimal&gt; flockFirstBalance = new Dictionary&lt;string, decimal&gt;();&#xD;&#xA;// Dictionary to store the last date and close balance for each flock&#xD;&#xA;private Dictionary&lt;string, DateTime&gt; flockLastDateClose = new Dictionary&lt;string, DateTime&gt;();&#xD;&#xA;private Dictionary&lt;string, decimal&gt; flockLastCloseBalance = new Dictionary&lt;string, decimal&gt;();&#xD;&#xA;// Dictionary to store the first date and open balance for category C for each flock&#xD;&#xA;private Dictionary&lt;string, DateTime&gt; flockFirstDateOpenC = new Dictionary&lt;string, DateTime&gt;();&#xD;&#xA;private Dictionary&lt;string, decimal&gt; flockFirstOpenBalanceC = new Dictionary&lt;string, decimal&gt;();&#xD;&#xA;private Dictionary&lt;string, DateTime&gt; flockLastDateCloseC = new Dictionary&lt;string, DateTime&gt;();&#xD;&#xA;private Dictionary&lt;string, decimal&gt; flockLastCloseBalanceC = new Dictionary&lt;string, decimal&gt;();&#xD;&#xA;&#xD;&#xA;// Dictionary to store the first date and total close balance for each flock&#xD;&#xA;private Dictionary&lt;string, DateTime&gt; flockLastDateTotalClose = new Dictionary&lt;string, DateTime&gt;();&#xD;&#xA;private Dictionary&lt;string, decimal&gt; flockLastTotalCloseBalance = new Dictionary&lt;string, decimal&gt;();&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        string flockCode = Convert.ToString(GetCurrentColumnValue(&quot;FlockCode&quot;) ?? &quot;&quot;);&#xD;&#xA;    DateTime regDate = Convert.ToDateTime(GetCurrentColumnValue(&quot;RegDate&quot;) ?? DateTime.MinValue);&#xD;&#xA;    decimal openBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenFHTEggsF&quot;) ?? 0) + &#xD;&#xA;                          Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenHTEggsF&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;    decimal closeBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;CloseFHTEggsF&quot;) ?? 0) + &#xD;&#xA;                           Convert.ToDecimal(GetCurrentColumnValue(&quot;CloseHTEggsF&quot;) ?? 0);&#xD;&#xA;                           &#xD;&#xA;     decimal openBalanceC = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenFHTEggsC&quot;) ?? 0) + &#xD;&#xA;                           Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenHTEggsC&quot;) ?? 0);&#xD;&#xA;           &#xD;&#xA;     decimal closeBalanceC = Convert.ToDecimal(GetCurrentColumnValue(&quot;CloseFHTEggsC&quot;) ?? 0) + &#xD;&#xA;                            Convert.ToDecimal(GetCurrentColumnValue(&quot;CloseHTEggsC&quot;) ?? 0);&#xD;&#xA;           &#xD;&#xA;                &#xD;&#xA;      // Calculate total close balance (all categories)&#xD;&#xA;    decimal totalCloseBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;CloseFHTEggsC&quot;) ?? 0) + &#xD;&#xA;                                Convert.ToDecimal(GetCurrentColumnValue(&quot;CloseFHTEggsF&quot;) ?? 0) +&#xD;&#xA;                                Convert.ToDecimal(GetCurrentColumnValue(&quot;CloseHTEggsC&quot;) ?? 0) + &#xD;&#xA;                                Convert.ToDecimal(GetCurrentColumnValue(&quot;CloseHTEggsF&quot;) ?? 0);&#xD;&#xA;                                     &#xD;&#xA;    if (string.IsNullOrEmpty(flockCode) || regDate == DateTime.MinValue)&#xD;&#xA;        return;&#xD;&#xA;&#xD;&#xA;    // If this flock is not yet recorded, add it with current date and balance&#xD;&#xA;    if (!flockFirstDate.ContainsKey(flockCode))&#xD;&#xA;    {&#xD;&#xA;        flockFirstDate[flockCode] = regDate;&#xD;&#xA;        flockFirstBalance[flockCode] = openBalance;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        // If this date is earlier than the stored date, update the balance&#xD;&#xA;        if (regDate &lt; flockFirstDate[flockCode])&#xD;&#xA;        {&#xD;&#xA;            flockFirstDate[flockCode] = regDate;&#xD;&#xA;            flockFirstBalance[flockCode] = openBalance;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // If this flock is not yet recorded, add it with current date and balance&#xD;&#xA;    if (!flockLastDateClose.ContainsKey(flockCode))&#xD;&#xA;    {&#xD;&#xA;        flockLastDateClose[flockCode] = regDate;&#xD;&#xA;        flockLastCloseBalance[flockCode] = closeBalance;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        // If this date is LATER than the stored date, update the balance (for Close balance)&#xD;&#xA;        if (regDate &gt; flockLastDateClose[flockCode])&#xD;&#xA;        {&#xD;&#xA;            flockLastDateClose[flockCode] = regDate;&#xD;&#xA;            flockLastCloseBalance[flockCode] = closeBalance;&#xD;&#xA;        }&#xD;&#xA;    }    &#xD;&#xA;    &#xD;&#xA;     // If this flock is not yet recorded, add it with current date and balance&#xD;&#xA;    if (!flockFirstDateOpenC.ContainsKey(flockCode))&#xD;&#xA;    {&#xD;&#xA;        flockFirstDateOpenC[flockCode] = regDate;&#xD;&#xA;        flockFirstOpenBalanceC[flockCode] = openBalanceC;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        // If this date is earlier than the stored date, update the balance&#xD;&#xA;        if (regDate &lt; flockFirstDateOpenC[flockCode])&#xD;&#xA;        {&#xD;&#xA;            flockFirstDateOpenC[flockCode] = regDate;&#xD;&#xA;            flockFirstOpenBalanceC[flockCode] = openBalanceC;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;     if (!flockLastDateCloseC.ContainsKey(flockCode))&#xD;&#xA;    {&#xD;&#xA;        flockLastDateCloseC[flockCode] = regDate;&#xD;&#xA;        flockLastCloseBalanceC[flockCode] = closeBalanceC;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        // Keep the LATEST date&#xD;&#xA;        if (regDate &gt; flockLastDateCloseC[flockCode])&#xD;&#xA;        {&#xD;&#xA;            flockLastDateCloseC[flockCode] = regDate;&#xD;&#xA;            flockLastCloseBalanceC[flockCode] = closeBalanceC;&#xD;&#xA;        }&#xD;&#xA;    }  &#xD;&#xA;      &#xD;&#xA;    &#xD;&#xA;    if (!flockLastDateTotalClose.ContainsKey(flockCode))&#xD;&#xA;    {&#xD;&#xA;        flockLastDateTotalClose[flockCode] = regDate;&#xD;&#xA;        flockLastTotalCloseBalance[flockCode] = totalCloseBalance;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        // Keep the LATEST date for close balance&#xD;&#xA;        if (regDate &gt; flockLastDateTotalClose[flockCode])&#xD;&#xA;        {&#xD;&#xA;            flockLastDateTotalClose[flockCode] = regDate;&#xD;&#xA;            flockLastTotalCloseBalance[flockCode] = totalCloseBalance;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;private void xrTableCell35_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    decimal total = 0;&#xD;&#xA;    foreach (var balance in flockFirstBalance.Values)&#xD;&#xA;    {&#xD;&#xA;        total += balance;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    cell.Text = total.ToString(&quot;N0&quot;); // or &quot;N2&quot; if you need decimals&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell40_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;   XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    decimal total = 0;&#xD;&#xA;    foreach (var balance in flockLastCloseBalance.Values)&#xD;&#xA;    {&#xD;&#xA;        total += balance;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    cell.Text = total.ToString(&quot;N0&quot;);&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell41_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    decimal total = 0;&#xD;&#xA;    foreach (var balance in flockFirstOpenBalanceC.Values)&#xD;&#xA;    {&#xD;&#xA;        total += balance;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    cell.Text = total.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell45_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    decimal total = 0;&#xD;&#xA;    foreach (var balance in flockLastCloseBalanceC.Values)&#xD;&#xA;        total += balance;&#xD;&#xA;    cell.Text = total.ToString(&quot;N0&quot;);&#xD;&#xA;    &#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;private void xrTableCell46_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;   XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    decimal total = 0;&#xD;&#xA;    foreach (var balance in flockLastTotalCloseBalance.Values)&#xD;&#xA;        total += balance;&#xD;&#xA;    cell.Text = total.ToString(&quot;N0&quot;);&#xD;&#xA;    &#xD;&#xA;    }&#xD;&#xA;" PageWidthF="1169.29138" PageHeightF="1653.54333" Version="25.2" DataMember="SR_BRD_HTEggsBalance" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
