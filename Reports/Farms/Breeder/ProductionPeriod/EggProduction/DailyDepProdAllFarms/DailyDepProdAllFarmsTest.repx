                  <Item13 Ref="294" Name="Other_Output_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([OtherOutputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item14 Ref="295" Name="Close_Balance_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([CloseBalance])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item15 Ref="296" Name="Test" DataMember="SR_FC_FM_StockMovement" />
                  <Item16 Ref="297" Name="Avg_Wt_PP" Expression="Iif([Birds_PT] &gt; 0, &#xA;    [TotalWt_PT] / [Birds_PT], &#xA;    Null)&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
                  <Item17 Ref="298" Name="Avg_Wt_SL" Expression="Iif([Birds_SL] &gt; 0, &#xA;    [TotalWt_SL] / [Birds_SL], &#xA;    Null)&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
                  <Item18 Ref="299" Name="G_Birds" Expression="[Birds_PT] + [Birds_SL]&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
                  <Item19 Ref="300" Name="G_Wt" Expression="[TotalWt_PT] + IsNull([TotalWt_SL],0)&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
