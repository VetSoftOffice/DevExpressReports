A;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell93_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cumFemaleDeplRecordCount &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumOfCumFemaleDeplPercentages / cumFemaleDeplRecordCount;&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell58_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal femalePlaced = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemalePlaced&quot;) ?? 0);&#xD;&#xA;decimal cummFemaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummFemaleMort&quot;) ?? 0);&#xD;&#xA;decimal cummFemalCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummFemalCulls&quot;) ?? 0);&#xD;&#xA;decimal cumFemaleCond = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumFemaleCond&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Calculate total cumulative female depletion&#xD;&#xA;decimal totalCumFemaleDepl = cummFemaleMort + cummFemalCulls + cumFemaleCond;&#xD;&#xA;&#xD;&#xA;if (femalePlaced &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (Total Cumulative Depletion / FemalePlaced) * 100&#xD;&#xA;    decimal result = (totalCumFemaleDepl / femalePlaced) * 100.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;    &#xD;&#xA;    if (femalePlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate cumulative depletion percentage for this record&#xD;&#xA;        decimal cumFemaleDeplPercentage = (totalCumFemaleDepl / femalePlaced) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumOfCumFemaleDeplPercentagesReport += cumFemaleDeplPercentage;&#xD;&#xA;        cumFemaleDeplRecordCountReport++;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell70_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cumFemaleDeplRecordCountReport &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumOfCumFemaleDeplPercentagesReport / cumFemaleDeplRecordCountReport;&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell96_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cumMaleDeplRecordCount &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumOfCumMaleDeplPercentages / cumMaleDeplRecordCount;&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell75_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cumMaleDeplRecordCount &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumOfCumMaleDeplPercentages / cumMaleDeplRecordCount;&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevE