;        cullRecordCount++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal malePlaced = Convert.ToDecimal(GetCurrentColumnValue(&quot;MalePlaced&quot;) ?? 0);&#xD;&#xA;    decimal maleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleMort&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (malePlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate mortality percentage for this record&#xD;&#xA;        decimal maleMortPercentage = (maleMort / malePlaced) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumOfMaleMortPercentages += maleMortPercentage;&#xD;&#xA;        maleMortRecordCount++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;     decimal maleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleCulls&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (malePlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate cull percentage for this record&#xD;&#xA;        decimal maleCullPercentage = (maleCulls / malePlaced) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumOfMaleCullPercentages += maleCullPercentage;&#xD;&#xA;        maleCullRecordCount++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;      &#xD;&#xA;    if (femalePlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate {@FemaleDepl} = FemaleMort + FemaleCulls&#xD;&#xA;        decimal femaleDepl = femaleMort + femaleCulls;&#xD;&#xA;        &#xD;&#xA;        // Calculate depletion percentage for this record&#xD;&#xA;        decimal femaleDeplPercentage = (femaleDepl / femalePlaced) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumOfFemaleDeplPercentages += femaleDeplPercentage;&#xD;&#xA;        femaleDeplRecordCount++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;    decimal cummFemaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummFemaleMort&quot;) ?? 0);&#xD;&#xA;    decimal cummFemalCulls = Convert.To