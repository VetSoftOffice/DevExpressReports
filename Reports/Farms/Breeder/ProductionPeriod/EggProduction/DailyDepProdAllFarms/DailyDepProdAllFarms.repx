    <Item21 Ref="52" Name="SmallEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.SmallEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item22 Ref="53" Name="OverWeightEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.OverWeightEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item23 Ref="54" Name="DirtyEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.DirtyEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item24 Ref="55" Name="DeformityEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.DeformityEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item25 Ref="56" Name="BrokenEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.BrokenEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item26 Ref="57" Name="DestroyedEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.DestroyedEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item27 Ref="58" Name="CrackedEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.CrackedEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item28 Ref="59" Name="DYE" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.DoubleYolkEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item29 Ref="60" Name="OtherEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.OtherEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item30 Ref="61" Name="TotalUnHatch" Expression="[SR_HT_RecHall.SoftShellEggs] + [SR_HT_RecHall.MinorCrackedEggs] + [SR_HT_RecHall.MajorCrackedEggs] + [SR_HT_RecHall.ThinShellEggs] + [SR_HT_RecHall.OtherEggs] + [SR_HT_RecHall.WholeEggs] + &#xD;&#xA;[SR_HT_RecHall.BrokenEggs] + [SR_HT_RecHall.SmallEggs] + [SR_HT_RecHall.OverWeightEggs] + [SR_HT_RecHall.DirtyEggs] + [SR_HT_RecHall.DeformityEggs] + [SR_HT_RecHall.CrackedEggs] + &#xD;&#xA;[SR_HT_RecHall.DoubleYolkEggs] + [SR_HT_RecHall.DestroyedEggs]&#xD;&#xA;" DataMember="SR_HT_RecHall" />
    <Item31 Ref="62" Name="TotalPerc" Expression="IIf([SR_HT_RecHall.RecEggs] &lt;&gt; 0, [TotalUnHatch] * 100.0 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item32 Ref="63" Name="HatchingEggsPerc" Expression="IIf([SR_HT_RecHall.RecEggs] &lt;&gt; 0, [SR_HT_RecHall.HatchingEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
