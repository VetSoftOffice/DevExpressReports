    <Item39 Ref="69" Name="TotalFem" Expression="IIF(IsNullOrEmpty([FemaleMort]), 0, [FemaleMort]) + &#xA;IIF(IsNullOrEmpty([FemalCulls]), 0, [FemalCulls])&#xA;" DataMember="SR_BRD_DailySiteWise" />
    <Item40 Ref="70" Name="TotalMale" Expression="IIF(IsNullOrEmpty([MaleMort]), 0, [MaleMort]) + &#xA;IIF(IsNullOrEmpty([MaleCulls]), 0, [MaleCulls])&#xA;" DataMember="SR_BRD_DailySiteWise" />
    <Item41 Ref="71" Name="FlockAge" Expression="30" DataMember="SR_BRD_DailyProduction" />
