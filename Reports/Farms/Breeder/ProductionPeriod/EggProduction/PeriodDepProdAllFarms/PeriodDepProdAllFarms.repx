                  <Item10 Ref="301" Name="Inputs_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([InputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item11 Ref="302" Name="Consumed_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([Consumed])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item12 Ref="303" Name="Outputs_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([SoldTransferOut])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item13 Ref="304" Name="Other_Output_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([OtherOutputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item14 Ref="305" Name="Close_Balance_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([CloseBalance])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item15 Ref="306" Name="Test" DataMember="SR_FC_FM_StockMovement" />
                  <Item16 Ref="307" Name="Avg_Wt_PP" Expression="Iif([Birds_PT] &gt; 0, &#xA;    [TotalWt_PT] / [Birds_PT], &#xA;    Null)&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
                  <Item17 Ref="308" Name="Avg_Wt_SL" Expression="Iif([Birds_SL] &gt; 0, &#xA;    [TotalWt_SL] / [Birds_SL], &#xA;    Null)&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
                  <Item18 Ref="309" Name="G_Birds" Expression="[Birds_PT] + [Birds_SL]&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
                  <Item19 Ref="310" Name="G_Wt" Expression="[TotalWt_PT] + IsNull([TotalWt_SL],0)&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
                  <Item20 Ref="311" Name="G_Avg_Wt" Expression="Iif([G_Birds] &gt; 0, [G_Wt] / [G_Birds], 0)&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
                  <Item21 Ref="312" Name="SmallEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.SmallEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
                  <Item22 Ref="313" Name="OverWeightEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.OverWeightEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
                  <Item23 Ref="314" Name="DirtyEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.DirtyEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
                  <Item24 Ref="315" Name="DeformityEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.DeformityEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
                  <Item25 Ref="316" Name="BrokenEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.BrokenEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
                  <Item26 Ref="317" Name="DestroyedEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.DestroyedEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
                  <Item27 Ref="318" Name="CrackedEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.CrackedEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
                  <Item28 Ref="319" Name="DYE" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.DoubleYolkEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
                  <Item29 Ref="320" Name="OtherEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.OtherEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
                  <Item30 Ref="321" Name="TotalUnHatch" Expression="[SR_HT_RecHall.SoftShellEggs] + [SR_HT_RecHall.MinorCrackedEggs] + [SR_HT_RecHall.MajorCrackedEggs] + [SR_HT_RecHall.ThinShellEggs] + [SR_HT_RecHall.OtherEggs] + [SR_HT_RecHall.WholeEggs] + &#xD;&#xA;[SR_HT_RecHall.BrokenEggs] + [SR_HT_RecHall.SmallEggs] + [SR_HT_RecHall.OverWeightEggs] + [SR_HT_RecHall.DirtyEggs] + [SR_HT_RecHall.DeformityEggs] + [SR_HT_RecHall.CrackedEggs] + &#xD;&#xA;[SR_HT_RecHall.DoubleYolkEggs] + [SR_HT_RecHall.DestroyedEggs]&#xD;&#xA;" DataMember="SR_HT_RecHall" />
                  <Item31 Ref="322" Name="TotalPerc" Expression="IIf([SR_HT_RecHall.RecEggs] &lt;&gt; 0, [TotalUnHatch] * 100.0 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
                  <Item32 Ref="323" Name="HatchingEggsPerc" Expression="IIf([SR_HT_RecHall.RecEggs] &lt;&gt; 0, [SR_HT_RecHall.HatchingEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
                  <Item33 Ref="324" Name="TotalBalance" Expression="[HatchingEggs] + [OpenStock]" DataMember="SR_HT_RecHall" />
