    <Item43 Ref="73" Name="Group1" Expression="IIF(&#xA;    IsNullOrEmpty([GroupByWeek]) OR IsNullOrEmpty([FlockAge]),&#xA;    ' ',&#xA;    IIF([GroupByWeek] = [FlockAge], &#xA;        ToStr([FlockAge]) + ' ' + IIF(IsNullOrEmpty(?WeeksOfAgeAndBelow), ' ', ?WeeksOfAgeAndBelow), &#xA;        ToStr([FlockAge]) + ' ' + IIF(IsNullOrEmpty(?AgeWeeks), '', ?AgeWeeks) + ' ' + IIF(IsNullOrEmpty(?TotalAbove), ' ', ?TotalAbove)&#xA;    )&#xA;)" DataMember="SR_BRD_DailyProduction" />
    <Item44 Ref="74" Name="FDepl" Expression="IIF(IsNullOrEmpty([FemaleMort]), 0, [FemaleMort]) + &#xA;IIF(IsNullOrEmpty([FemalCulls]), 0, [FemalCulls])&#xA;" DataMember="SR_BRD_DailyProduction" />
    <Item45 Ref="75" Name="EggsProd" Expression="IIF(IsNullOrEmpty([NestedEggs]), 0, [NestedEggs]) + &#xA;IIF(IsNullOrEmpty([FloorEggs]), 0, [FloorEggs])" DataMember="SR_BRD_DailyProduction" />
    <Item46 Ref="76" Name="HatchingFloorEggs" Expression="IIF(IsNullOrEmpty([HatchingFloorG_B]), 0, [HatchingFloorG_B]) + &#xA;IIF(IsNullOrEmpty([HatchingFloorG_A]), 0, [HatchingFloorG_A])" DataMember="SR_BRD_DailyProduction" />
