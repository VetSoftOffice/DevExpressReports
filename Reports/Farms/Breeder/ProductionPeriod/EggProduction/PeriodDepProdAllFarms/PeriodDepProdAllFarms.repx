                  <Item36 Ref="327" Name="Total" Expression="[OpenEggStoreEggs] + [RecEggs]" DataMember="SR_HT_RecAndSettedEggs" />
                  <Item37 Ref="328" Name="TotalExitHatchers" Expression="[Deads] + [Culls] + [DestroyedEggs] + [UnHatEggs] + [Chicks]" DataMember="SR_HT_RecAndSettedEggs" />
