                  <Item36 Ref="286" Name="Total" Expression="[OpenEggStoreEggs] + [RecEggs]" DataMember="SR_HT_RecAndSettedEggs" />
                  <Item37 Ref="287" Name="TotalExitHatchers" Expression="[Deads] + [Culls] + [DestroyedEggs] + [UnHatEggs] + [Chicks]" DataMember="SR_HT_RecAndSettedEggs" />
