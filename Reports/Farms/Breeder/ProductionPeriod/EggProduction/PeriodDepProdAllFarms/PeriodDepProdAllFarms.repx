                  <Item17 Ref="267" Name="Avg_Wt_SL" Expression="Iif([Birds_SL] &gt; 0, &#xA;    [TotalWt_SL] / [Birds_SL], &#xA;    Null)&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
                  <Item18 Ref="268" Name="G_Birds" Expression="[Birds_PT] + [Birds_SL]&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
