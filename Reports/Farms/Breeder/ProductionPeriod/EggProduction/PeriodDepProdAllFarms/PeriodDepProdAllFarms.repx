    <Item40 Ref="70" Name="TotalMale" Expression="IIF(IsNullOrEmpty([MaleMort]), 0, [MaleMort]) + &#xA;IIF(IsNullOrEmpty([MaleCulls]), 0, [MaleCulls])&#xA;" DataMember="SR_BRD_DailySiteWise" />
