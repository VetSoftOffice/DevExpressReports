quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;   // Calculate percentage for this record if conditions are met&#xD;&#xA;    if (weekStartFemales &gt; 0 &amp;&amp; days &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percentage = ((eggsProd / days) / weekStartFemales) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumHenDayPercent += percentage;&#xD;&#xA;        henDayRecordCount++;&#xD;&#xA;    }&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;private void xrTableCell70_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cumFemaleDeplRecordCountReport &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumOfCumFemaleDeplPercentagesReport / cumFemaleDeplRecordCountReport;&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell96_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;           XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (henDayRecordCount &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumHenDayPercent / henDayRecordCount;&#xD;&#xA;        average = Math.Round(average, 2);&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell75_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (totalEggsProdReport &gt; 0 &amp;&amp; totalFloorEggsReport &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (totalFloorEggsReport / totalEggsProdReport ) * 100.0m;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell54_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal femalePlaced = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemalePlaced&quot;) ?? 0);&#xD;&#xA;decimal femaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleMort&quot;) ?? 0);&#xD;&#xA;decimal femaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemalCulls&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Calculate {@FemaleDepl} = FemaleMort + FemaleCulls&#xD;&#xA;decimal femaleDepl = femaleMort + femaleCulls;&#xD;&#xA;&#xD;&#xA;if (femalePlaced &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: ({@FemaleDepl} / FemalePlaced) * 100&#xD;&#xA;    decimal result = (femaleDepl / femalePlaced) * 100.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA; if (femalePlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        &#xD;&#xA;        // Calculate depletion percentage for this record&#xD;&#xA;        decimal femaleDeplPercentage = (femaleDepl / femalePlaced) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumOfFemaleDeplPercentagesReport += femaleDeplPercentage;&#xD;&#xA;        femaleDeplRecordCountReport++;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell92_BeforePrint_1(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (femaleDeplRecordCount &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumOfFemaleDeplPercentages / femaleDeplRecordCount;&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell65_BeforePrint_1(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (femaleDeplRecordCountReport &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumOfFemaleDeplPercentagesReport / femaleDeplRecordCountReport ;&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell55_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal malePlaced = Convert.ToDecimal(GetCurrentColumnValue(&quot;MalePlaced&quot;) ?? 0);&#xD;&#xA;decimal cummMaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummMaleMort&quot;) ?? 0);&#xD;&#xA;decimal cummMaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummMaleCulls&quot;) ?? 0);&#xD;&#xA;decimal cumMaleCond = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumMaleCond&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Calculate total cumulative male depletion&#xD;&#xA;decimal totalCumMaleDepl = cummMaleMort + cummMaleCulls + cumMaleCond;&#xD;&#xA;&#xD;&#xA;if (malePlaced &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (Total Cumulative Depletion / MalePlaced) * 100&#xD;&#xA;    decimal result = (totalCumMaleDepl / malePlaced) * 100.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (malePlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        &#xD;&#xA;        // Calculate cumulative depletion percentage for this record&#xD;&#xA;        decimal cumMaleDeplPercentage = (totalCumMaleDepl / malePlaced) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumOfCumMaleDeplPercentagesReport += cumMaleDeplPercentage;&#xD;&#xA;        cumMaleDeplRecordCountReport++;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell72_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;) ?? 0);&#xD;&#xA;decimal nestedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;NestedEggs&quot;) ?? 0);&#xD;&#xA;decimal floorEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;FloorEggs&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Get Days parameter&#xD;&#xA;decimal days = 0;&#xD;&#xA;if (Parameters[&quot;Days&quot;] != null)&#xD;&#xA;{&#xD;&#xA;    days = Convert.ToDecimal(Parameters[&quot;Days&quot;].Value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Calculate {@EggsProd}&#xD;&#xA;decimal eggsProd = nestedEggs + floorEggs;&#xD;&#xA;&#xD;&#xA;// Calculate the value (EggsProd / Days / POL)&#xD;&#xA;decimal value = 0;&#xD;&#xA;if (days &gt; 0 &amp;&amp; pol &gt; 0)&#xD;&#xA;{&#xD;&#xA;    value = (eggsProd / days) / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Apply the condition&#xD;&#xA;if (pol &gt; 0 &amp;&amp; days &gt; 0 &amp;&amp; value &lt;= 100.0m)&#xD;&#xA;{&#xD;&#xA;    decimal result = value * 100.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA; // Apply conditions: POL &gt; 0, Days &gt; 0&#xD;&#xA;    if (pol &gt; 0 &amp;&amp; days &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal dailyEggsPerHen = (eggsProd / days) / pol;&#xD;&#xA;        &#xD;&#xA;        // Only include if dailyEggsPerHen &lt;= 100&#xD;&#xA;        if (dailyEggsPerHen &lt;= 100.0m)&#xD;&#xA;        {&#xD;&#xA;            decimal henDayPercent = dailyEggsPerHen * 100.0m;&#xD;&#xA;            &#xD;&#xA;            // Add to sum and increment counter&#xD;&#xA;            sumHenDayProdReport += henDayPercent;&#xD;&#xA;            henDayCountReport++;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell111_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (henDayCount &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumHenDayProd / henDayCount;&#xD;&#xA;        average = Math.Round(average, 2);&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell71_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (henDayCountReport &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumHenDayProdReport / henDayCountReport ;&#xD;&#xA;        average = Math.Round(average, 2);&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell103_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal nestedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;NestedEggs&quot;) ?? 0);&#xD;&#xA;decimal floorEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;FloorEggs&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Calculate {@EggsProd}&#xD;&#xA;decimal eggsProd = nestedEggs + floorEggs;&#xD;&#xA;&#xD;&#xA;if (eggsProd &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (FloorEggs / EggsProd) * 100&#xD;&#xA;    decimal result = (floorEggs / eggsProd) * 100.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA; totalEggsProdReport += eggsProd;&#xD;&#xA; totalFloorEggsReport += floorEggs;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell113_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (totalEggsProd &gt; 0 &amp;&amp; totalFloorEggs &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (totalFloorEggs / totalEggsProd) * 100.0m;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell106_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal nestedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;NestedEggs&quot;) ?? 0);&#xD;&#xA;decimal floorEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;FloorEggs&quot;) ?? 0);&#xD;&#xA;decimal hatchingEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchingEggs&quot;) ?? 0);&#xD;&#xA;decimal hatchingFloorG_B = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchingFloorG_B&quot;) ?? 0);&#xD;&#xA;decimal hatchingFloorG_A = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchingFloorG_A&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Calculate {@EggsProd}&#xD;&#xA;decimal eggsProd = nestedEggs + floorEggs;&#xD;&#xA;&#xD;&#xA;// Calculate {@HatchingFloorEggs}&#xD;&#xA;decimal hatchingFloorEggs = hatchingFloorG_B + hatchingFloorG_A;&#xD;&#xA;&#xD;&#xA;// Calculate {@HatchsEggs}&#xD;&#xA;decimal hatchsEggs = hatchingEggs + hatchingFloorEggs;&#xD;&#xA;&#xD;&#xA;if (eggsProd &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (HatchsEggs / EggsProd) * 100&#xD;&#xA;    decimal result = (hatchsEggs / eggsProd) * 100.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA; // Add to cumulative totals (report-level)&#xD;&#xA;    totalEggsProdReport += eggsProd;&#xD;&#xA;    totalHatchingEggsReport += hatchingEggs;&#xD;&#xA;    totalHatchingFloorG_BReport += hatchingFloorG_B;&#xD;&#xA;    totalHatchingFloorG_AReport += hatchingFloorG_A;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell116_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Calculate total hatching floor eggs&#xD;&#xA;    decimal totalHatchingFloorEggs = totalHatchingFloorG_B + totalHatchingFloorG_A;&#xD;&#xA;    &#xD;&#xA;    // Calculate total hatchs eggs&#xD;&#xA;    decimal totalHatchsEggs = totalHatchingEggs + totalHatchingFloorEggs;&#xD;&#xA;    &#xD;&#xA;    if (totalEggsProd &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (totalHatchsEggs / totalEggsProd) * 100.0m;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell79_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    decimal totalHatchingFloorEggs = totalHatchingFloorG_BReport + totalHatchingFloorG_AReport;&#xD;&#xA;    decimal totalHatchsEggs = totalHatchingEggsReport + totalHatchingFloorEggs;&#xD;&#xA;&#xD;&#xA;    if (totalEggsProdReport &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (totalHatchsEggs / totalEggsProdReport) * 100.0m;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell107_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal femaleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleBalance&quot;) ?? 0);&#xD;&#xA;decimal pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;) ?? 0);&#xD;&#xA;decimal total = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummChicks1&quot;) ?? 0) + &#xD;&#xA;                    Convert.ToDecimal(GetCurrentColumnValue(&quot;CummCulls1&quot;) ?? 0) + &#xD;&#xA;                    Convert.ToDecimal(GetCurrentColumnValue(&quot;CummDeads1&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (femaleBalance == 0)&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;else if (pol &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (CummChicks1 + CummCulls1 + CummDeads1) / POL&#xD;&#xA;    decimal result = (total ) / pol;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;    // Add to cumulative totals for weighted average&#xD;&#xA;    if (femaleBalance != 0 &amp;&amp; pol &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        totalChicksSumReport += total;&#xD;&#xA;        totalPolSumReport += pol;&#xD;&#xA;        weightedCountReport++;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell117_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (chicksPerPolCount &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumOfChicksPerPol / chicksPerPolCount;&#xD;&#xA;        average = Math.Round(average, 2);&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell80_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    if (totalPolSumReport &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal weightedAverage = totalChicksSumReport / totalPolSumReport;&#xD;&#xA;        weightedAverage = Math.Round(weightedAverage, 2);&#xD;&#xA;        cell.Text = weightedAverage.ToString(&quot;N2&quot;);&#xD;&#xA;        &#xD;&#xA;     }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell108_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal femaleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleBalance&quot;) ?? 0);&#xD;&#xA;decimal pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;) ?? 0);&#xD;&#xA;decimal estHatchEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;EstHatchEggs&quot;) ?? 0);&#xD;&#xA;decimal cummSettedEggs1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummSettedEggs1&quot;) ?? 0);&#xD;&#xA;decimal cummChicks1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummChicks1&quot;) ?? 0);&#xD;&#xA;decimal cummCulls1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummCulls1&quot;) ?? 0);&#xD;&#xA;decimal cummDeads1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummDeads1&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Calculate {@ActCumHatchFarmWise}&#xD;&#xA;decimal actCumHatchFarmWise = 0;&#xD;&#xA;if (cummSettedEggs1 != 0)&#xD;&#xA;{&#xD;&#xA;    actCumHatchFarmWise = ((cummChicks1 + cummCulls1 + cummDeads1) / cummSettedEggs1) * 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;decimal currentValue = 0;&#xD;&#xA;if (femaleBalance == 0)&#xD;&#xA;{&#xD;&#xA;    currentValue = 0;&#xD;&#xA;&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;else if (pol &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (EstHatchEggs * ActCumHatchFarmWise / 100) / POL&#xD;&#xA;     currentValue = ((estHatchEggs * actCumHatchFarmWise) / 100.0m) / pol;&#xD;&#xA;    cell.Text = currentValue.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    currentValue = 0;&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;    sumEstHatchPerPolReport += currentValue;&#xD;&#xA;    countEstHatchPerPolReport++;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell121_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    if (countEstHatchPerPolReport &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumEstHatchPerPolReport / countEstHatchPerPolReport;&#xD;&#xA;        average = Math.Round(average, 2);&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell118_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    if (countEstHatchPerPolGroup &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumEstHatchPerPolGroup / countEstHatchPerPolGroup;&#xD;&#xA;        average = Math.Round(average, 2);&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell109_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal femaleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleBalance&quot;) ?? 0);&#xD;&#xA;decimal cumChicksHenHoused = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumChicksHenHoused&quot;) ?? 0);&#xD;&#xA;decimal currentValue = 0;&#xD;&#xA;&#xD;&#xA;if (femaleBalance == 0)&#xD;&#xA;{&#xD;&#xA;    currentValue = 0;&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    currentValue = cumChicksHenHoused;&#xD;&#xA;    cell.Text = currentValue.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA; // Add to report totals&#xD;&#xA;    sumCumChicksHenHousedReport += currentValue;&#xD;&#xA;    countCumChicksHenHousedReport++;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell119_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    if (countCumChicksHenHoused &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumCumChicksHenHoused / countCumChicksHenHoused;&#xD;&#xA;        average = Math.Round(average, 2);&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell122_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    if (countCumChicksHenHousedReport &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumCumChicksHenHousedReport / countCumChicksHenHousedReport;&#xD;&#xA;        average = Math.Round(average, 2);&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrLabel11_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;  XRLabel label = sender as XRLabel;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal weeklySettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;WeeklySettedEggs&quot;) ?? 0);&#xD;&#xA;decimal weeklyChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;WeeklyChicks&quot;) ?? 0);&#xD;&#xA;decimal weeklyCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;WeeklyCulls&quot;) ?? 0);&#xD;&#xA;decimal weeklyDeads = Convert.ToDecimal(GetCurrentColumnValue(&quot;WeeklyDeads&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (weeklySettedEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (WeeklyChicks + WeeklyCulls + WeeklyDeads) / WeeklySettedEggs * 100&#xD;&#xA;    decimal totalOutput = weeklyChicks + weeklyCulls + weeklyDeads;&#xD;&#xA;    decimal result = (totalOutput / weeklySettedEggs) * 100.0m;&#xD;&#xA;    label.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    label.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrLabel13_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRLabel label = sender as XRLabel;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal cummSettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummSettedEggs&quot;) ?? 0);&#xD;&#xA;decimal cummChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummChicks&quot;) ?? 0);&#xD;&#xA;decimal cummCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummCulls&quot;) ?? 0);&#xD;&#xA;decimal cummDeads = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummDeads&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (cummSettedEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (CummChicks + CummCulls + CummDeads) / CummSettedEggs * 100&#xD;&#xA;    decimal totalOutput = cummChicks + cummCulls + cummDeads;&#xD;&#xA;    decimal result = (totalOutput / cummSettedEggs) * 100.0m;&#xD;&#xA;    label.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    label.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="25.2" DataMember="SR_BRD_DailyProduction" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
