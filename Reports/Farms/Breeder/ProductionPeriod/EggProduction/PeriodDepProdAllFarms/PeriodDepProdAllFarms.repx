  decimal femaleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleBalance&quot;) ?? 0);&#xD;&#xA;    decimal maleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleBalance&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    sumOfFemales += femaleBalance;&#xD;&#xA;    sumOfMales += maleBalance;&#xD;&#xA;    &#xD;&#xA;    decimal femalePlaced = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemalePlaced&quot;) ?? 0);&#xD;&#xA;    decimal femaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleMort&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (femalePlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate percentage for this record&#xD;&#xA;        decimal percentage = (femaleMort / femalePlaced) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumOfPercentages += percentage;&#xD;&#xA;        recordCount++;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    decimal femaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemalCulls&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (femalePlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate cull percentage for this record&#xD;&#xA;        decimal cullPercentage = (femaleCulls / femalePlaced) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumOfCullPercentages += cullPercentage;&#xD;&#xA;        cullRecordCount++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal malePlaced = Convert.ToDecimal(GetCurrentColumnValue(&quot;MalePlaced&quot;) ?? 0);&#xD;&#xA;    decimal maleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleMort&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (malePlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate mortality percentage for this record&#xD;&#xA;        decimal maleMortPercentage = (maleMort / malePlaced) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumOfMaleMortPercentages += maleMortPercentage;&#xD;&#xA;        maleMortRecordCount++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;     decimal maleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleCulls&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (malePlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate cull percentage for this record&#xD;&#xA;        decimal maleCullPercentage = (maleCulls / malePlaced) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumOfMaleCullPercentages += maleCullPercentage;&#xD;&#xA;        maleCullRecordCount++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;      &#xD;&#xA;    if (femalePlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate {@FemaleDepl} = FemaleMort + FemaleCulls&#xD;&#xA;        decimal femaleDepl = femaleMort + femaleCulls;&#xD;&#xA;        &#xD;&#xA;        // Calculate depletion percentage for this record&#xD;&#xA;        decimal femaleDeplPercentage = (femaleDepl / femalePlaced) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumOfFemaleDeplPercentages += femaleDeplPercentage;&#xD;&#xA;        femaleDeplRecordCount++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;    decimal cummFemaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummFemaleMort&quot;) ?? 0);&#xD;&#xA;    decimal cummFemalCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummFemalCulls&quot;) ?? 0);&#xD;&#xA;    decimal cumFemaleCond = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumFemaleCond&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (femalePlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate total cumulative female depletion&#xD;&#xA;        decimal totalCumFemaleDepl = cummFemaleMort + cummFemalCulls + cumFemaleCond;&#xD;&#xA;        &#xD;&#xA;        // Calculate cumulative depletion percentage for this record&#xD;&#xA;        decimal cumFemaleDeplPercentage = (totalCumFemaleDepl / femalePlaced) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumOfCumFemaleDeplPercentages += cumFemaleDeplPercentage;&#xD;&#xA;        cumFemaleDeplRecordCount++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal cummMaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummMaleMort&quot;) ?? 0);&#xD;&#xA;    decimal cummMaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummMaleCulls&quot;) ?? 0);&#xD;&#xA;    decimal cumMaleCond = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumMaleCond&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (malePlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate total cumulative male depletion&#xD;&#xA;        decimal totalCumMaleDepl = cummMaleMort + cummMaleCulls + cumMaleCond;&#xD;&#xA;        &#xD;&#xA;        // Calculate cumulative depletion percentage for this record&#xD;&#xA;        decimal cumMaleDeplPercentage = (totalCumMaleDepl / malePlaced) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumOfCumMaleDeplPercentages += cumMaleDeplPercentage;&#xD;&#xA;        cumMaleDeplRecordCount++;&#xD;&#xA;    }&#xD;&#xA;        // Get values from the data source&#xD;&#xA;    decimal weekStartFemales = Convert.ToDecimal(GetCurrentColumnValue(&quot;WeekStartFemales&quot;) ?? 0);&#xD;&#xA;    decimal nestedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;NestedEggs&quot;) ?? 0);&#xD;&#xA;    decimal floorEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;FloorEggs&quot;) ?? 0);&#xD;&#xA;    decimal pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;) ?? 0);&#xD;&#xA;    // Get Days parameter&#xD;&#xA;    decimal days = 0;&#xD;&#xA;    if (Parameters[&quot;Days&quot;] != null)&#xD;&#xA;    {&#xD;&#xA;        days = Convert.ToDecimal(Parameters[&quot;Days&quot;].Value);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Calculate total eggs produced&#xD;&#xA;    decimal eggsProd = nestedEggs + floorEggs;&#xD;&#xA;    &#xD;&#xA;    // Calculate percentage for this record if conditions are met&#xD;&#xA;    if (weekStartFemales &gt; 0 &amp;&amp; days &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percentage = ((eggsProd / days) / weekStartFemales) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumHenDayPercent += percentage;&#xD;&#xA;        henDayRecordCount++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;     // Apply conditions: POL &gt; 0, Days &gt; 0&#xD;&#xA;    if (pol &gt; 0 &amp;&amp; days &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal dailyEggsPerHen = (eggsProd / days) / pol;&#xD;&#xA;        &#xD;&#xA;        // Only include if dailyEggsPerHen &lt;= 100&#xD;&#xA;        if (dailyEggsPerHen &lt;= 100.0m)&#xD;&#xA;        {&#xD;&#xA;            decimal henDayPercent = dailyEggsPerHen * 100.0m;&#xD;&#xA;            &#xD;&#xA;            // Add to sum and increment counter&#xD;&#xA;            sumHenDayProd += henDayPercent;&#xD;&#xA;            henDayCount++;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;     // Accumulate totals&#xD;&#xA;    totalEggsProd += eggsProd;&#xD;&#xA;    totalFloorEggs += floorEggs;&#xD;&#xA;    &#xD;&#xA;    decimal hatchingEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchingEggs&quot;) ?? 0);&#xD;&#xA;    decimal hatchingFloorG_B = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchingFloorG_B&quot;) ?? 0);&#xD;&#xA;    decimal hatchingFloorG_A = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchingFloorG_A&quot;) ?? 0);&#xD;&#xA;    totalEggsProd += nestedEggs + floorEggs;&#xD;&#xA;&#xD;&#xA;    &#xD;&#xA;    // Accumulate {@HatchingFloorEggs} components&#xD;&#xA;    totalHatchingFloorG_B += hatchingFloorG_B;&#xD;&#xA;    totalHatchingFloorG_A += hatchingFloorG_A;&#xD;&#xA;    &#xD;&#xA;    // Accumulate {@HatchsEggs}&#xD;&#xA;    totalHatchingEggs += hatchingEggs;&#xD;&#xA;    &#xD;&#xA;    decimal cummChicks1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummChicks1&quot;) ?? 0);&#xD;&#xA;    decimal cummCulls1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummCulls1&quot;) ?? 0);&#xD;&#xA;    decimal cummDeads1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummDeads1&quot;) ?? 0);&#xD;&#xA;    decimal estHatchEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;EstHatchEggs&quot;) ?? 0);&#xD;&#xA;    decimal cummSettedEggs1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;CummSettedEggs1&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate value for this record&#xD;&#xA;    if (femaleBalance != 0 &amp;&amp; pol &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal value = (cummChicks1 + cummCulls1 + cummDeads1) / pol;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumOfChicksPerPol += value;&#xD;&#xA;        chicksPerPolCount++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;     // Calculate {@ActCumHatchFarmWise}&#xD;&#xA;    decimal actCumHatchFarmWise = 0;&#xD;&#xA;    decimal totalChicks  = 0;&#xD;&#xA;    totalChicks   = (cummChicks1 + cummCulls1 + cummDeads1);&#xD;&#xA;    if (cummSettedEggs1 != 0)&#xD;&#xA;    {&#xD;&#xA;        actCumHatchFarmWise = (totalChicks / cummSettedEggs1) * 100.0m;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    // Calculate value for this record&#xD;&#xA;    if (femaleBalance != 0 &amp;&amp; pol &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal currentValue = ((estHatchEggs * actCumHatchFarmWise) / 100.0m) / pol;&#xD;&#xA;        &#xD;&#xA;        // Add to group totals&#xD;&#xA;        sumEstHatchPerPolGroup += currentValue;&#xD;&#xA;        countEstHatchPerPolGroup++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;     decimal cumChicksHenHoused = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumChicksHenHoused&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;    // Accumulate only when FemaleBalance is not zero&#xD;&#xA;    if (femaleBalance != 0)&#xD;&#xA;    {&#xD;&#xA;        sumCumChicksHenHoused += cumChicksHenHoused;&#xD;&#xA;        countCumChicksHenHoused++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;   }&#xD;&#xA;&#xD;&#xA;private void