  cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;    &#xD;&#xA;    if (femalePlaced &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate total cumulative female depletion&#xD;&#xA;        decimal totalCumFemaleDepl = cummFemaleMort + cummFemalCulls + cumFemaleCond;&#xD;&#xA;        &#xD;&#xA;        // Calculate cumulative depletion percentage for this record&#xD;&#xA;        decimal cumFemaleDeplPercentage = (totalCumFemaleDepl / femalePlaced) * 100.0m;&#xD;&#xA;        &#xD;&#xA;        // Add to sum and increment counter&#xD;&#xA;        sumOfCumFemaleDeplPercentagesReport += cumFemaleDeplPercentage;&#xD;&#xA;        cumFemaleDeplRecordCountReport++;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell70_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cumFemaleDeplRecordCountReport &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumOfCumFemaleDeplPercentagesReport / cumFemaleDeplRecordCountReport;&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell96_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cumMaleDeplRecordCount &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumOfCumMaleDeplPercentages / cumMaleDeplRecordCount;&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell75_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cumMaleDeplRecordCount &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal average = sumOfCumMaleDeplPercentages / cumMaleDeplRecordCount;&#xD;&#xA;        cell.Text = average.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="25.2" DataMember="SR_BRD_DailySiteWise" DataSource="#Ref-224" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
