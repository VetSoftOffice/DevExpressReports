private void xrTableCell17_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
        XRTableCell cell = sender as XRTableCell;
    
    if (cell != null)
    {
        // Get WC_LiveFemale value
        double wcLiveFemale = Convert.ToDouble(GetCurrentColumnValue("WC_LiveFemale"));
        
        if (wcLiveFemale &gt; 0)
        {
            // Get Female Feed
            double femaleFeed = Convert.ToDouble(GetCurrentColumnValue("FemaleFeed"));
            
            // Calculate: (FemaleFeed / 7) / WC_LiveFemale * 1000
            double feedPerDay = femaleFeed / 7;
            double feedPer1000 = feedPerDay / wcLiveFemale * 1000;
            
            // Format and display
            cell.Text = feedPer1000.ToString("N2");
        }
        else
        {
            cell.Text = "0.00";
        }
    }
}

