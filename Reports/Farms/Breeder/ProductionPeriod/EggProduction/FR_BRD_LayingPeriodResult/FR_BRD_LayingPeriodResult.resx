private void xrTableCell1_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
        XRTableCell cell = sender as XRTableCell;
    
    if (cell != null)
    {
        // Get values from data source
        double rf_POL = Convert.ToDouble(GetCurrentColumnValue("rf_POL"));
        
        if (rf_POL &gt; 0)
        {
            double nestedEggs = Convert.ToDouble(GetCurrentColumnValue("NestedEggs"));
            double floorEggs = Convert.ToDouble(GetCurrentColumnValue("FloorEggs"));
            double totalEggs = nestedEggs + floorEggs;
            
            // Calculate: TotalEggs / 7 / rf_POL * 100
            double weeklyEggPercent = totalEggs / 7 / rf_POL * 100;
            
            // Format and display
            cell.Text = weeklyEggPercent.ToString("N2") ;
        }
        else
        {
            cell.Text = "0.00";
        }
    }
}

