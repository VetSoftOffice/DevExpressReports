private void xrTableCell19_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
     XRTableCell cell = sender as XRTableCell;
    
    if (cell != null)
    {
        double wcLiveFemale = Convert.ToDouble(GetCurrentColumnValue("WC_LiveFemale"));
        
        if (wcLiveFemale &gt; 0)
        {
            double femaleMort = Convert.ToDouble(GetCurrentColumnValue("FemaleMort"));
            double femaleCulls = Convert.ToDouble(GetCurrentColumnValue("FemalCulls"));
            double fDepTotal = femaleMort + femaleCulls;
            double result = fDepTotal / wcLiveFemale * 100;
            
            cell.Text = result.ToString("N2") ;
        }
        else
        {
            cell.Text = "0.00";
        }
    }
}

