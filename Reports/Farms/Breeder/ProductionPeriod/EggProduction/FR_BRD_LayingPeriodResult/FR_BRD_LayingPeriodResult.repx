    <Item15 Ref="44" Name="TotalHatchingEggs" Expression="Iif(IsNullOrEmpty([HatchingEggs]),0 , [HatchingEggs]) + Iif(IsNullOrEmpty([HatchingFloorG_A]),0 , [HatchingFloorG_A]) + Iif(IsNullOrEmpty([HatchingFloorG_B]),0 , [HatchingFloorG_B])&#xA;" DataMember="SR_BRD_DailyDeplProd" />
    <Item16 Ref="45" Name="FemaleCullsAndSexError" Expression="Iif(IsNullOrEmpty([CullsFemale]), 0,[CullsFemale] ) + Iif(IsNullOrEmpty([FemaleSexError]), 0,[FemaleSexError] )&#xA;" DataMember="SR_BRD_DailyDeplProd" />
    <Item17 Ref="46" Name="MaleCullsAndSexError" Expression="Iif(IsNullOrEmpty([CullsMort]),0 , [CullsMort])+ Iif(IsNullOrEmpty([MaleSexError]),0 , [MaleSexError])&#xA;" DataMember="SR_BRD_DailyDeplProd" />
    <Item18 Ref="47" Name="AgePerWeeks" Expression="Iif(&#xD;&#xA;    Max([rf_Day]) % 7 = 0,&#xD;&#xA;&#xD;&#xA;    FormatString('{0}', [rf_WeeKNo]),&#xD;&#xA;&#xD;&#xA;    FormatString('{0}', [rf_WeeKNo])&#xD;&#xA;    + ' , '&#xD;&#xA;    + FormatString('{0}', Floor(Max([rf_Day]) / 7))&#xD;&#xA;    + '+'&#xD;&#xA;    + FormatString('{0}', Max([rf_Day]) % 7)&#xD;&#xA;    + ' Day'&#xD;&#xA;)&#xD;&#xA;" DataMember="SR_BRD_DailyDeplProd" />
