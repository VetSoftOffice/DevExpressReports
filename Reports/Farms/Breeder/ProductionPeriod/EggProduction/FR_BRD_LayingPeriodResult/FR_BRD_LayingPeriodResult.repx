    <Item20 Ref="49" Name="FDeplTotal" Expression="Iif(IsNullOrEmpty([FemaleMort]),0 , [FemaleMort]) + Iif(IsNullOrEmpty([FemalCulls]),0 , [FemalCulls])&#xA;" DataMember="SR_BRD_LayPeriodResult" />
    <Item21 Ref="50" Name="MDeplTotal" Expression="Iif(IsNullOrEmpty([MaleMort]),0 , [MaleMort]) + Iif(IsNullOrEmpty([MaleCulls]),0 , [MaleCulls])&#xA;" DataMember="SR_BRD_LayPeriodResult" />
