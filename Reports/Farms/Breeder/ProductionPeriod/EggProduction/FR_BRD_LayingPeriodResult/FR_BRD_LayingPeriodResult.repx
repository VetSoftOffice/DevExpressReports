<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="FR_BRD_LayingPeriodResult" ScriptsSource="&#xD;&#xA;private void xrTableCell19_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cell != null)&#xD;&#xA;    {&#xD;&#xA;        double wcLiveFemale = Convert.ToDouble(GetCurrentColumnValue(&quot;WC_LiveFemale&quot;));&#xD;&#xA;        &#xD;&#xA;        if (wcLiveFemale &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            double femaleMort = Convert.ToDouble(GetCurrentColumnValue(&quot;FemaleMort&quot;));&#xD;&#xA;            double femaleCulls = Convert.ToDouble(GetCurrentColumnValue(&quot;FemalCulls&quot;));&#xD;&#xA;            double fDepTotal = femaleMort + femaleCulls;&#xD;&#xA;            double result = fDepTotal / wcLiveFemale * 100;&#xD;&#xA;            &#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell26_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cell != null)&#xD;&#xA;    {&#xD;&#xA;        double wcLiveMale = Convert.ToDouble(GetCurrentColumnValue(&quot;WC_LiveMale&quot;));&#xD;&#xA;        &#xD;&#xA;        if (wcLiveMale &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            double maleMort = Convert.ToDouble(GetCurrentColumnValue(&quot;MaleMort&quot;));&#xD;&#xA;            double maleCulls = Convert.ToDouble(GetCurrentColumnValue(&quot;MaleCulls&quot;));&#xD;&#xA;            double mDepTotal = maleMort + maleCulls;&#xD;&#xA;            double result = mDepTotal / wcLiveMale * 100;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell76_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cell != null)&#xD;&#xA;    {&#xD;&#xA;        double wcLiveFemale = Convert.ToDouble(GetCurrentColumnValue(&quot;WC_LiveFemale&quot;));&#xD;&#xA;        &#xD;&#xA;        if (wcLiveFemale &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            double nestedEggs = Convert.ToDouble(GetCurrentColumnValue(&quot;NestedEggs&quot;));&#xD;&#xA;            double floorEggs = Convert.ToDouble(GetCurrentColumnValue(&quot;FloorEggs&quot;));&#xD;&#xA;            double totalEggs = nestedEggs + floorEggs;&#xD;&#xA;            double eggsPerFemale = totalEggs / wcLiveFemale;&#xD;&#xA;            cell.Text = eggsPerFemale.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell77_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cell != null)&#xD;&#xA;    {&#xD;&#xA;        double rf_POL = Convert.ToDouble(GetCurrentColumnValue(&quot;rf_POL&quot;));&#xD;&#xA;        &#xD;&#xA;        if (rf_POL &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            double cumEggs = Convert.ToDouble(GetCurrentColumnValue(&quot;CumEggs&quot;));&#xD;&#xA;            double cumEggsPerPOL = cumEggs / rf_POL;&#xD;&#xA;            cell.Text = cumEggsPerPOL.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell79_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cell != null)&#xD;&#xA;    {&#xD;&#xA;        double wcLiveFemale = Convert.ToDouble(GetCurrentColumnValue(&quot;WC_LiveFemale&quot;));&#xD;&#xA;        &#xD;&#xA;        if (wcLiveFemale &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            double hatchingEggs = Convert.ToDouble(GetCurrentColumnValue(&quot;HatchingEggs&quot;));&#xD;&#xA;            double hatchingEggsPerFemale = hatchingEggs / wcLiveFemale;&#xD;&#xA;            cell.Text = hatchingEggsPerFemale.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell80_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cell != null)&#xD;&#xA;    {&#xD;&#xA;        double rf_POL = Convert.ToDouble(GetCurrentColumnValue(&quot;rf_POL&quot;));&#xD;&#xA;        &#xD;&#xA;        if (rf_POL &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            double cumHatEggs = Convert.ToDouble(GetCurrentColumnValue(&quot;CumHatEggs&quot;));&#xD;&#xA;            double cumHatEggsPerPOL = cumHatEggs / rf_POL;&#xD;&#xA;            cell.Text = cumHatEggsPerPOL.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell82_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cell != null)&#xD;&#xA;    {&#xD;&#xA;        double nestedEggs = Convert.ToDouble(GetCurrentColumnValue(&quot;NestedEggs&quot;));&#xD;&#xA;        double floorEggs = Convert.ToDouble(GetCurrentColumnValue(&quot;FloorEggs&quot;));&#xD;&#xA;        double totalEggs = nestedEggs + floorEggs;&#xD;&#xA;        &#xD;&#xA;        if (totalEggs &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            double hatchingEggs = Convert.ToDouble(GetCurrentColumnValue(&quot;HatchingEggs&quot;));&#xD;&#xA;            double hatchingEggsPercent = hatchingEggs * 100 / totalEggs;&#xD;&#xA;            cell.Text = hatchingEggsPercent.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell1_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cell != null)&#xD;&#xA;    {&#xD;&#xA;        // Get values from data source&#xD;&#xA;        double rf_POL = Convert.ToDouble(GetCurrentColumnValue(&quot;rf_POL&quot;));&#xD;&#xA;        &#xD;&#xA;        if (rf_POL &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            double nestedEggs = Convert.ToDouble(GetCurrentColumnValue(&quot;NestedEggs&quot;));&#xD;&#xA;            double floorEggs = Convert.ToDouble(GetCurrentColumnValue(&quot;FloorEggs&quot;));&#xD;&#xA;            double totalEggs = nestedEggs + floorEggs;&#xD;&#xA;            &#xD;&#xA;            // Calculate: TotalEggs / 7 / rf_POL * 100&#xD;&#xA;            double weeklyEggPercent = totalEggs / 7 / rf_POL * 100;&#xD;&#xA;            &#xD;&#xA;            // Format and display&#xD;&#xA;            cell.Text = weeklyEggPercent.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell3_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cell != null)&#xD;&#xA;    {&#xD;&#xA;        // Get WC_LiveFemale value&#xD;&#xA;        double wcLiveFemale = Convert.ToDouble(GetCurrentColumnValue(&quot;WC_LiveFemale&quot;));&#xD;&#xA;        &#xD;&#xA;        if (wcLiveFemale &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            // Get Total Eggs (NestedEggs + FloorEggs)&#xD;&#xA;            double nestedEggs = Convert.ToDouble(GetCurrentColumnValue(&quot;NestedEggs&quot;));&#xD;&#xA;            double floorEggs = Convert.ToDouble(GetCurrentColumnValue(&quot;FloorEggs&quot;));&#xD;&#xA;            double totalEggs = nestedEggs + floorEggs;&#xD;&#xA;            &#xD;&#xA;            // Calculate: TotalEggs / 7 / WC_LiveFemale * 100&#xD;&#xA;            double weeklyEggPercent = totalEggs / 7 / wcLiveFemale * 100;&#xD;&#xA;            &#xD;&#xA;            // Format and display&#xD;&#xA;            cell.Text = weeklyEggPercent.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell17_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cell != null)&#xD;&#xA;    {&#xD;&#xA;        // Get WC_LiveFemale value&#xD;&#xA;        double wcLiveFemale = Convert.ToDouble(GetCurrentColumnValue(&quot;WC_LiveFemale&quot;));&#xD;&#xA;        &#xD;&#xA;        if (wcLiveFemale &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            // Get Female Feed&#xD;&#xA;            double femaleFeed = Convert.ToDouble(GetCurrentColumnValue(&quot;FemaleFeed&quot;));&#xD;&#xA;            &#xD;&#xA;            // Calculate: (FemaleFeed / 7) / WC_LiveFemale * 1000&#xD;&#xA;            double feedPerDay = femaleFeed / 7;&#xD;&#xA;            double feedPer1000 = feedPerDay / wcLiveFemale * 1000;&#xD;&#xA;            &#xD;&#xA;            // Format and display&#xD;&#xA;            cell.Text = feedPer1000.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell28_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (cell != null)&#xD;&#xA;    {&#xD;&#xA;        // Get WC_LiveMale value&#xD;&#xA;        double wcLiveMale = Convert.ToDouble(GetCurrentColumnValue(&quot;WC_LiveMale&quot;));&#xD;&#xA;        &#xD;&#xA;        if (wcLiveMale &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            // Get Male Feed&#xD;&#xA;            double maleFeed = Convert.ToDouble(GetCurrentColumnValue(&quot;MaleFeed&quot;));&#xD;&#xA;            &#xD;&#xA;            // Calculate: (MaleFeed / 7) / WC_LiveMale * 1000&#xD;&#xA;            double feedPerDay = maleFeed / 7;&#xD;&#xA;            double feedPer1000 = feedPerDay / wcLiveMale * 1000;&#xD;&#xA;            &#xD;&#xA;            // Format and display&#xD;&#xA;            cell.Text = feedPer1000.ToString(&quot;N2&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1788" PageHeightF="1169.291" Version="25.2" DataMember="SR_BRD_LayPeriodResult" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
