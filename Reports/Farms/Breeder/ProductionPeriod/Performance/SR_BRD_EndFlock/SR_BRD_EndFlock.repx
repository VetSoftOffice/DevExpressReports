_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal rearingMaleOpen = Convert.ToDecimal(GetCurrentColumnValue(&quot;RearingMaleOpen&quot;) ?? 0);&#xD;&#xA;decimal rearingMaleClose = Convert.ToDecimal(GetCurrentColumnValue(&quot;RearingMaleClose&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (rearingMaleOpen &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (RearingMaleClose * 100) / RearingMaleOpen&#xD;&#xA;    decimal result = (rearingMaleClose * 100.0m) / rearingMaleOpen;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell146_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function to safely convert values&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal rearingFemaleOpen = SafeConvert(GetCurrentColumnValue(&quot;RearingFemaleOpen&quot;));&#xD;&#xA;decimal fdoa = SafeConvert(GetCurrentColumnValue(&quot;FDOA&quot;));&#xD;&#xA;decimal fSampleToVet = SafeConvert(GetCurrentColumnValue(&quot;FSampleToVet&quot;));&#xD;&#xA;decimal rearingFemaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;RearingFemaleConsFeed&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingPlacedFemales} = RearingFemaleOpen - FDOA - FSampleToVet&#xD;&#xA;decimal rearingPlacedFemales = rearingFemaleOpen - fdoa - fSampleToVet;&#xD;&#xA;&#xD;&#xA;if (rearingPlacedFemales &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: RearingFemaleConsFeed / RearingPlacedFemales&#xD;&#xA;    decimal result = rearingFemaleConsFeed / rearingPlacedFemales;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell156_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function to safely convert values&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal rearingMaleOpen = SafeConvert(GetCurrentColumnValue(&quot;RearingMaleOpen&quot;));&#xD;&#xA;decimal mdoa = SafeConvert(GetCurrentColumnValue(&quot;MDOA&quot;));&#xD;&#xA;decimal mSampleToVet = SafeConvert(GetCurrentColumnValue(&quot;MSampleToVet&quot;));&#xD;&#xA;decimal rearingMaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;RearingMaleConsFeed&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingPlacedMales} = RearingMaleOpen - MDOA - MSampleToVet&#xD;&#xA;decimal rearingPlacedMales = rearingMaleOpen - mdoa - mSampleToVet;&#xD;&#xA;&#xD;&#xA;if (rearingPlacedMales &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: RearingMaleConsFeed / RearingPlacedMales&#xD;&#xA;    decimal result = rearingMaleConsFeed / rearingPlacedMales;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell151_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function to safely convert values&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Get raw values from data source&#xD;&#xA;decimal rearingFemaleOpen = SafeConvert(GetCurrentColumnValue(&quot;RearingFemaleOpen&quot;));&#xD;&#xA;decimal fdoa = SafeConvert(GetCurrentColumnValue(&quot;FDOA&quot;));&#xD;&#xA;decimal fSampleToVet = SafeConvert(GetCurrentColumnValue(&quot;FSampleToVet&quot;));&#xD;&#xA;decimal rearingMaleOpen = SafeConvert(GetCurrentColumnValue(&quot;RearingMaleOpen&quot;));&#xD;&#xA;decimal mdoa = SafeConvert(GetCurrentColumnValue(&quot;MDOA&quot;));&#xD;&#xA;decimal mSampleToVet = SafeConvert(GetCurrentColumnValue(&quot;MSampleToVet&quot;));&#xD;&#xA;decimal rearingFemaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;RearingFemaleConsFeed&quot;));&#xD;&#xA;decimal rearingMaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;RearingMaleConsFeed&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingPlacedFemales}&#xD;&#xA;decimal rearingPlacedFemales = rearingFemaleOpen - fdoa - fSampleToVet;&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingPlacedMales}&#xD;&#xA;decimal rearingPlacedMales = rearingMaleOpen - mdoa - mSampleToVet;&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingFemaleConsFeedTon} (convert kg to tons)&#xD;&#xA;decimal rearingFemaleConsFeedTon = rearingFemaleConsFeed / 1000.0m;&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingMaleConsFeedTon} (convert kg to tons)&#xD;&#xA;decimal rearingMaleConsFeedTon = rearingMaleConsFeed / 1000.0m;&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingTotalConsFeed} (total tons)&#xD;&#xA;decimal rearingTotalConsFeed = rearingFemaleConsFeedTon + rearingMaleConsFeedTon;&#xD;&#xA;&#xD;&#xA;// Calculate total placed birds&#xD;&#xA;decimal totalPlacedBirds = rearingPlacedFemales + rearingPlacedMales;&#xD;&#xA;&#xD;&#xA;// Check if total placed birds is greater than 0&#xD;&#xA;if (totalPlacedBirds &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: ({@RearingTotalConsFeed} * 1000) / totalPlacedBirds&#xD;&#xA;    // This gives kg per bird (since totalConsFeed is in tons, *1000 converts to kg)&#xD;&#xA;    decimal result = (rearingTotalConsFeed * 1000.0m) / totalPlacedBirds;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell162_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;// Note: There's a typo in your field name &quot;LayingFeamleOpen&quot; (should be LayingFemaleOpen)&#xD;&#xA;// Using the exact field name from your formula&#xD;&#xA;decimal layingFemaleOpen = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingFeamleOpen&quot;) ?? 0);&#xD;&#xA;decimal layingFemaleDepl = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingFemaleDepl&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (layingFemaleOpen &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (LayingFemaleDepl * 100) / LayingFeamleOpen&#xD;&#xA;    decimal result = (layingFemaleDepl * 100.0m) / layingFemaleOpen;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell164_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal layingMaleOpen = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingMaleOpen&quot;) ?? 0);&#xD;&#xA;decimal layingMaleDepl = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingMaleDepl&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (layingMaleOpen &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (LayingMaleDepl * 100) / LayingMaleOpen&#xD;&#xA;    decimal result = (layingMaleDepl * 100.0m) / layingMaleOpen;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell167_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;// Note: Using the exact field name with typo as in your formula&#xD;&#xA;decimal layingFemaleOpen = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingFeamleOpen&quot;) ?? 0);&#xD;&#xA;decimal layingFemaleCK = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingFemaleCK&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (layingFemaleOpen &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (LayingFemaleCK * 100) / LayingFeamleOpen&#xD;&#xA;    decimal result = (layingFemaleCK * 100.0m) / layingFemaleOpen;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell169_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal layingMaleOpen = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingMaleOpen&quot;) ?? 0);&#xD;&#xA;decimal layingMaleCK = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingMaleCK&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (layingMaleOpen &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (LayingMaleCK * 100) / LayingMaleOpen&#xD;&#xA;    decimal result = (layingMaleCK * 100.0m) / layingMaleOpen;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell182_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function to safely convert values&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Get values from the current row&#xD;&#xA;decimal layingFemaleOpen = SafeConvert(GetCurrentColumnValue(&quot;LayingFeamleOpen&quot;));&#xD;&#xA;decimal layingFemaleDepl = SafeConvert(GetCurrentColumnValue(&quot;LayingFemaleDepl&quot;));&#xD;&#xA;decimal layingFemaleCK = SafeConvert(GetCurrentColumnValue(&quot;LayingFemaleCK&quot;));&#xD;&#xA;decimal layingFemaleCS = SafeConvert(GetCurrentColumnValue(&quot;LayingFemaleCS&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate {@ProductionTotalDepl} for this row&#xD;&#xA;decimal productionTotalDepl = layingFemaleDepl + layingFemaleCK + layingFemaleCS;&#xD;&#xA;&#xD;&#xA;if (layingFemaleOpen &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: ({@ProductionTotalDepl} * 100) / LayingFeamleOpen&#xD;&#xA;    decimal result = (productionTotalDepl * 100.0m) / layingFemaleOpen;&#xD;&#xA;    string formattedResult = result.ToString(&quot;N2&quot;);&#xD;&#xA;    &#xD;&#xA;    cell.Text = formattedResult ;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell184_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function to safely convert values&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull