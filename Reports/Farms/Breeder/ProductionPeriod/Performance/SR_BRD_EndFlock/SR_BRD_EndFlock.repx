al(GetCurrentColumnValue(&quot;LayingMaleFlockCond&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (layingMaleOpen &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (LayingMaleFlockCond * 100) / LayingMaleOpen&#xD;&#xA;    decimal result = (layingMaleFlockCond * 100.0m) / layingMaleOpen;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell44_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;// Note: Using the exact field name with typo as in your formula&#xD;&#xA;decimal layingFemaleOpen = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingFeamleOpen&quot;) ?? 0);&#xD;&#xA;decimal layingFemaleConsFeed = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingFemaleConsFeed&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (layingFemaleOpen &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: LayingFemaleConsFeed / LayingFeamleOpen&#xD;&#xA;    decimal result = layingFemaleConsFeed / layingFemaleOpen;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell37_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal layingMaleOpen = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingMaleOpen&quot;) ?? 0);&#xD;&#xA;decimal layingMaleConsFeed = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingMaleConsFeed&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (layingMaleOpen &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: LayingMaleConsFeed / LayingMaleOpen&#xD;&#xA;    decimal result = layingMaleConsFeed / layingMaleOpen;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell67_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal layingFemaleOpen = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingFeamleOpen&quot;) ?? 0);&#xD;&#xA;decimal layingMaleOpen = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingMaleOpen&quot;) ?? 0);&#xD;&#xA;decimal layingFemaleConsFeed = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingFemaleConsFeed&quot;) ?? 0);&#xD;&#xA;decimal layingMaleConsFeed = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingMaleConsFeed&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Calculate totals&#xD;&#xA;decimal totalBirds = layingFemaleOpen + layingMaleOpen;&#xD;&#xA;decimal totalFeed = layingFemaleConsFeed + layingMaleConsFeed;&#xD;&#xA;&#xD;&#xA;if (totalBirds &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (Total Feed) / (Total Birds)&#xD;&#xA;    decimal result = totalFeed / totalBirds;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell237_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function to safely convert values&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Get values for {@RearingPlacedMales} calculation&#xD;&#xA;decimal rearingFemaleOpen = SafeConvert(GetCurrentColumnValue(&quot;RearingFemaleOpen&quot;));&#xD;&#xA;decimal fdoa = SafeConvert(GetCurrentColumnValue(&quot;FDOA&quot;));&#xD;&#xA;decimal fSampleToVet = SafeConvert(GetCurrentColumnValue(&quot;FSampleToVet&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingPlacedMales} = RearingFemaleOpen - FDOA - FSampleToVet&#xD;&#xA;decimal rearingPlacedMales = rearingFemaleOpen - fdoa - fSampleToVet;&#xD;&#xA;&#xD;&#xA;// Get male feed consumption values&#xD;&#xA;decimal rearingMaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;RearingMaleConsFeed&quot;));&#xD;&#xA;decimal layingMaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;LayingMaleConsFeed&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingMaleConsFeedTon} and {@LayingConsFeedMale}&#xD;&#xA;decimal rearingMaleConsFeedTon = rearingMaleConsFeed / 1000.0m;&#xD;&#xA;decimal layingConsFeedMale = layingMaleConsFeed / 1000.0m;&#xD;&#xA;&#xD;&#xA;// Calculate {@CycleMaleConsFeed} = rearingMaleConsFeedTon + layingConsFeedMale&#xD;&#xA;decimal cycleMaleConsFeed = rearingMaleConsFeedTon + layingConsFeedMale;&#xD;&#xA;&#xD;&#xA;if (rearingPlacedMales &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: ({@CycleMaleConsFeed} * 1000) / {@RearingPlacedMales}&#xD;&#xA;    // Note: cycleMaleConsFeed is in tons, multiplying by 1000 converts to kg&#xD;&#xA;    decimal result = (cycleMaleConsFeed * 1000.0m) / rearingPlacedMales;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell235_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function to safely convert values&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// ====================================================================&#xD;&#xA;// PART 1: Get all raw values from data source&#xD;&#xA;// ====================================================================&#xD;&#xA;&#xD;&#xA;// Female feed consumption (kg)&#xD;&#xA;decimal rearingFemaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;RearingFemaleConsFeed&quot;));&#xD;&#xA;decimal layingFemaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;LayingFemaleConsFeed&quot;));&#xD;&#xA;&#xD;&#xA;// Male feed consumption (kg)&#xD;&#xA;decimal rearingMaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;RearingMaleConsFeed&quot;));&#xD;&#xA;decimal layingMaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;LayingMaleConsFeed&quot;));&#xD;&#xA;&#xD;&#xA;// Values for {@RearingPlacedMales} calculation&#xD;&#xA;decimal rearingFemaleOpen = SafeConvert(GetCurrentColumnValue(&quot;RearingFemaleOpen&quot;));&#xD;&#xA;decimal fdoa = SafeConvert(GetCurrentColumnValue(&quot;FDOA&quot;));&#xD;&#xA;decimal fSampleToVet = SafeConvert(GetCurrentColumnValue(&quot;FSampleToVet&quot;));&#xD;&#xA;&#xD;&#xA;// ====================================================================&#xD;&#xA;// PART 2: Calculate female feed in tons&#xD;&#xA;// ====================================================================&#xD;&#xA;&#xD;&#xA;// {@RearingFemaleConsFeedTon} = RearingFemaleConsFeed / 1000&#xD;&#xA;decimal rearingFemaleConsFeedTon = rearingFemaleConsFeed / 1000.0m;&#xD;&#xA;&#xD;&#xA;// {@LayingConsFeedFemale} = LayingFemaleConsFeed / 1000&#xD;&#xA;decimal layingConsFeedFemale = layingFemaleConsFeed / 1000.0m;&#xD;&#xA;&#xD;&#xA;// {@CycleFemaleConsFeed} = rearingFemaleConsFeedTon + layingConsFeedFemale&#xD;&#xA;decimal cycleFemaleConsFeed = rearingFemaleConsFeedTon + layingConsFeedFemale;&#xD;&#xA;&#xD;&#xA;// ====================================================================&#xD;&#xA;// PART 3: Calculate male feed in tons&#xD;&#xA;// ====================================================================&#xD;&#xA;&#xD;&#xA;// {@RearingMaleConsFeedTon} = RearingMaleConsFeed / 1000&#xD;&#xA;decimal rearingMaleConsFeedTon = rearingMaleConsFeed / 1000.0m;&#xD;&#xA;&#xD;&#xA;// {@LayingConsFeedMale} = LayingMaleConsFeed / 1000&#xD;&#xA;decimal layingConsFeedMale = layingMaleConsFeed / 1000.0m;&#xD;&#xA;&#xD;&#xA;// {@CycleMaleConsFeed} (in tons) = rearingMaleConsFeedTon + layingConsFeedMale&#xD;&#xA;decimal cycleMaleConsFeedTons = rearingMaleConsFeedTon + layingConsFeedMale;&#xD;&#xA;&#xD;&#xA;// ====================================================================&#xD;&#xA;// PART 4: Calculate {@RearingPlacedMales}&#xD;&#xA;// ====================================================================&#xD;&#xA;&#xD;&#xA;// {@RearingPlacedMales} = RearingFemaleOpen - FDOA - FSampleToVet&#xD;&#xA;decimal rearingPlacedMales = rearingFemaleOpen - fdoa - fSampleToVet;&#xD;&#xA;&#xD;&#xA;// ====================================================================&#xD;&#xA;// PART 5: Calculate the final value&#xD;&#xA;// ====================================================================&#xD;&#xA;&#xD;&#xA;// The formula appears to be: {@CycleFemaleConsFeed} + (if(rearingPlacedMales&gt;0, cycleMaleConsFeedTons * 1000 / rearingPlacedMales, 0))&#xD;&#xA;// But this mixes tons and kg, so we need to be careful with units&#xD;&#xA;&#xD;&#xA;if (rearingPlacedMales &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // {@CycleMaleConsFeed} in the final expression seems to be the result of the calculation, not the tons value&#xD;&#xA;    // Based on your formula: if({@RearingPlacedMales} &gt; 0) then {@CycleMaleConsFeed} * 1000 / {@RearingPlacedMales}&#xD;&#xA;    // This suggests {@CycleMaleConsFeed} is in tons, and we're converting to kg per male&#xD;&#xA;    decimal cycleMaleResult = (cycleMaleConsFeedTons * 1000.0m) / rearingPlacedMales;&#xD;&#xA;    &#xD;&#xA;    // Final result: {@CycleFemaleConsFeed} + cycleMaleResult&#xD;&#xA;    // Note: This adds tons (female) + kg/male (male) - verify if this is correct for your needs&#xD;&#xA;    decimal result = cycleFemaleConsFeed + cycleMaleResult;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    // If no placed males, just show female feed&#xD;&#xA;    cell.Text = cycleFemaleConsFeed.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell233_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function to safely convert values&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Get raw values from data source&#xD;&#xA;decimal rearingFemaleOpen = SafeConvert(GetCurrentColumnValue(&quot;RearingFemaleOpen&quot;));&#xD;&#xA;decimal fdoa = SafeConvert(GetCurrentColumnValue(&quot;FDOA&quot;));&#xD;&#xA;decimal fSampleToVet = SafeConvert(GetCurrentColumnValue(&quot;FSampleToVet&quot;));&#xD;&#xA;decimal rearingFemaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;RearingFemaleConsFeed&quot;));&#xD;&#xA;decimal layingFemaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;LayingFemaleConsFeed&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingPlacedFemales}&#xD;&#xA;decimal rearingPlacedFemales = rearingFemaleOpen - fdoa - fSampleToVet;&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingFemaleConsFeedTon} (convert kg to tons)&#xD;&#xA;decimal rearingFemaleConsFeedTon = rearingFemaleConsFeed / 1000.0m;&#xD;&#xA;&#xD;&#xA;// Calculate {@LayingConsFeedFemale} (convert kg to tons)&#xD;&#xA;decimal layingConsFeedFemale = layingFemaleConsFeed / 1000.0m;&#xD;&#xA;&#xD;&#xA;// Calculate {@CycleFemaleConsFeed} (total female feed in tons)&#xD;&#xA;decimal cycleFemaleConsFeed = rearingFemaleConsFeedTon + layingConsFeedFemale;&#xD;&#xA;&#xD;&#xA;if (rearingPlacedFemales &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: ({@CycleFemaleConsFeed} * 1000) / {@RearingPlacedFemales}&#xD;&#xA;    // This gives kg per female (since cycleFemaleConsFeed is in tons, *1000 converts to kg)&#xD;&#xA;    decimal result = (cycleFemaleConsFeed * 1000.0m) / rearingPlacedFemales;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell231_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function to safely convert values&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Get raw values from data source&#xD;&#xA;decimal rearingMaleOpen = SafeConvert(GetCurrentColumnValue(&quot;RearingMaleOpen&quot;));&#xD;&#xA;decimal mdoa = SafeConvert(GetCurrentColumnValue(&quot;MDOA&quot;));&#xD;&#xA;decimal mSampleToVet = SafeConvert(GetCurrentColumnValue(&quot;MSampleToVet&quot;));&#xD;&#xA;decimal rearingMaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;RearingMaleConsFeed&quot;));&#xD;&#xA;decimal layingMaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;LayingMaleConsFeed&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingPlacedMales}&#xD;&#xA;decimal rearingPlacedMales = rearingMaleOpen - mdoa - mSampleToVet;&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingMaleConsFeedTon} (convert kg to tons)&#xD;&#xA;decimal rearingMaleConsFeedTon = rearingMaleConsFeed / 1000.0m;&#xD;&#xA;&#xD;&#xA;// Calculate {@LayingConsFeedMale} (convert kg to tons)&#xD;&#xA;decimal layingConsFeedMale = layingMaleConsFeed / 1000.0m;&#xD;&#xA;&#xD;&#xA;// Calculate {@CycleMaleConsFeed} (total male feed in tons)&#xD;&#xA;decimal cycleMaleConsFeed = rearingMaleConsFeedTon + layingConsFeedMale;&#xD;&#xA;&#xD;&#xA;if (rearingPlacedMales &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: ({@CycleMaleConsFeed} * 1000) / {@RearingPlacedMales}&#xD;&#xA;    // This gives kg per male (since cycleMaleConsFeed is in tons, *1000 converts to kg)&#xD;&#xA;    decimal result = (cycleMaleConsFeed * 1000.0m) / rearingPlacedMales;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell42_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function to safely convert values&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Get raw values from data source - Female&#xD;&#xA;decimal rearingFemaleOpen = SafeConvert(GetCurrentColumnValue(&quot;RearingFemaleOpen&quot;));&#xD;&#xA;decimal fdoa = SafeConvert(GetCurrentColumnValue(&quot;FDOA&quot;));&#xD;&#xA;decimal fSampleToVet = SafeConvert(GetCurrentColumnValue(&quot;FSampleToVet&quot;));&#xD;&#xA;decimal rearingFemaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;RearingFemaleConsFeed&quot;));&#xD;&#xA;decimal layingFemaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;LayingFemaleConsFeed&quot;));&#xD;&#xA;&#xD;&#xA;// Get raw values from data source - Male&#xD;&#xA;decimal rearingMaleOpen = SafeConvert(GetCurrentColumnValue(&quot;RearingMaleOpen&quot;));&#xD;&#xA;decimal mdoa = SafeConvert(GetCurrentColumnValue(&quot;MDOA&quot;));&#xD;&#xA;decimal mSampleToVet = SafeConvert(GetCurrentColumnValue(&quot;MSampleToVet&quot;));&#xD;&#xA;decimal rearingMaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;RearingMaleConsFeed&quot;));&#xD;&#xA;decimal layingMaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;LayingMaleConsFeed&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingPlacedFemales}&#xD;&#xA;decimal rearingPlacedFemales = rearingFemaleOpen - fdoa - fSampleToVet;&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingPlacedMales}&#xD;&#xA;decimal rearingPlacedMales = rearingMaleOpen - mdoa - mSampleToVet;&#xD;&#xA;&#xD;&#xA;// Calculate total placed birds&#xD;&#xA;decimal totalPlacedBirds = rearingPlacedFemales + rearingPlacedMales;&#xD;&#xA;&#xD;&#xA;// Calculate female feed in tons&#xD;&#xA;decimal rearingFemaleConsFeedTon = rearingFemaleConsFeed / 1000.0m;&#xD;&#xA;decimal layingConsFeedFemale = layingFemaleConsFeed / 1000.0m;&#xD;&#xA;decimal cycleFemaleConsFeed = rearingFemaleConsFeedTon + layingConsFeedFemale;&#xD;&#xA;&#xD;&#xA;// Calculate male feed in tons&#xD;&#xA;decimal rearingMaleConsFeedTon = rearingMaleConsFeed / 1000.0m;&#xD;&#xA;decimal layingConsFeedMale = layingMaleConsFeed / 1000.0m;&#xD;&#xA;decimal cycleMaleConsFeed = rearingMaleConsFeedTon + layingConsFeedMale;&#xD;&#xA;&#xD;&#xA;// Calculate total feed in tons&#xD;&#xA;decimal totalFeedTons = cycleFemaleConsFeed + cycleMaleConsFeed;&#xD;&#xA;&#xD;&#xA;if (totalPlacedBirds &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (Total Feed Tons * 1000) / Total Placed Birds&#xD;&#xA;    // This gives kg per bird (since total feed is in tons, *1000 converts to kg)&#xD;&#xA;    decimal result = (totalFeedTons * 1000.0m) / totalPlacedBirds;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell69_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function to safely convert values&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Get raw values from data source&#xD;&#xA;decimal rearingMaleOpen = SafeConvert(GetCurrentColumnValue(&quot;RearingMaleOpen&quot;));&#xD;&#xA;decimal mdoa = SafeConvert(GetCurrentColumnValue(&quot;MDOA&quot;));&#xD;&#xA;decimal mSampleToVet = SafeConvert(GetCurrentColumnValue(&quot;MSampleToVet&quot;));&#xD;&#xA;decimal layingFemaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;LayingFemaleConsFeed&quot;));&#xD;&#xA;decimal layingMaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;LayingMaleConsFeed&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingPlacedMales}&#xD;&#xA;decimal rearingPlacedMales = rearingMaleOpen - mdoa - mSampleToVet;&#xD;&#xA;&#xD;&#xA;// Calculate {@LayingConsFeedFemale} (convert kg to tons)&#xD;&#xA;decimal layingConsFeedFemale = layingFemaleConsFeed / 1000.0m;&#xD;&#xA;&#xD;&#xA;// Calculate {@LayingConsFeedMale} (convert kg to tons)&#xD;&#xA;decimal layingConsFeedMale = layingMaleConsFeed / 1000.0m;&#xD;&#xA;&#xD;&#xA;// Calculate {@LayingConsFeedTotal} (total laying feed in tons)&#xD;&#xA;decimal layingConsFeedTotal = layingConsFeedFemale + layingConsFeedMale;&#xD;&#xA;&#xD;&#xA;if (rearingPlacedMales &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: ({@LayingConsFeedTotal} * 1000) / {@RearingPlacedMales}&#xD;&#xA;    // This gives kg per male (since layingConsFeedTotal is in tons, *1000 converts to kg)&#xD;&#xA;    decimal result = (layingConsFeedTotal * 1000.0m) / rearingPlacedMales;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell31_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function to safely convert values&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Get raw values from data source - Female&#xD;&#xA;decimal rearingFemaleOpen = SafeConvert(GetCurrentColumnValue(&quot;RearingFemaleOpen&quot;));&#xD;&#xA;decimal fdoa = SafeConvert(GetCurrentColumnValue(&quot;FDOA&quot;));&#xD;&#xA;decimal fSampleToVet = SafeConvert(GetCurrentColumnValue(&quot;FSampleToVet&quot;));&#xD;&#xA;decimal rearingFemaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;RearingFemaleConsFeed&quot;));&#xD;&#xA;decimal layingFemaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;LayingFemaleConsFeed&quot;));&#xD;&#xA;&#xD;&#xA;// Get raw values from data source - Male&#xD;&#xA;decimal rearingMaleOpen = SafeConvert(GetCurrentColumnValue(&quot;RearingMaleOpen&quot;));&#xD;&#xA;decimal mdoa = SafeConvert(GetCurrentColumnValue(&quot;MDOA&quot;));&#xD;&#xA;decimal mSampleToVet = SafeConvert(GetCurrentColumnValue(&quot;MSampleToVet&quot;));&#xD;&#xA;decimal rearingMaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;RearingMaleConsFeed&quot;));&#xD;&#xA;decimal layingMaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;LayingMaleConsFeed&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingPlacedFemales}&#xD;&#xA;decimal rearingPlacedFemales = rearingFemaleOpen - fdoa - fSampleToVet;&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingPlacedMales}&#xD;&#xA;decimal rearingPlacedMales = rearingMaleOpen - mdoa - mSampleToVet;&#xD;&#xA;&#xD;&#xA;// Calculate total placed birds&#xD;&#xA;decimal totalPlacedBirds = rearingPlacedFemales + rearingPlacedMales;&#xD;&#xA;&#xD;&#xA;// Calculate female feed in tons&#xD;&#xA;decimal rearingFemaleConsFeedTon = rearingFemaleConsFeed / 1000.0m;&#xD;&#xA;decimal layingConsFeedFemale = layingFemaleConsFeed / 1000.0m;&#xD;&#xA;decimal cycleFemaleConsFeed = rearingFemaleConsFeedTon + layingConsFeedFemale;&#xD;&#xA;&#xD;&#xA;// Calculate male feed in tons&#xD;&#xA;decimal rearingMaleConsFeedTon = rearingMaleConsFeed / 1000.0m;&#xD;&#xA;decimal layingConsFeedMale = layingMaleConsFeed / 1000.0m;&#xD;&#xA;decimal cycleMaleConsFeed = rearingMaleConsFeedTon + layingConsFeedMale;&#xD;&#xA;&#xD;&#xA;// Calculate {@CycleBirdsConsFeed} (total cycle feed in tons)&#xD;&#xA;decimal cycleBirdsConsFeed = cycleFemaleConsFeed + cycleMaleConsFeed;&#xD;&#xA;&#xD;&#xA;if (totalPlacedBirds &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: ({@CycleBirdsConsFeed} * 1000) / totalPlacedBirds&#xD;&#xA;    // This gives kg per bird (since cycleBirdsConsFeed is in tons, *1000 converts to kg)&#xD;&#xA;    decimal result = (cycleBirdsConsFeed * 1000.0m) / totalPlacedBirds;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell247_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function to safely convert values&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Get raw values from data source&#xD;&#xA;decimal totalEggTill60Wk = SafeConvert(GetCurrentColumnValue(&quot;TotalEggTill60Wk&quot;));&#xD;&#xA;decimal totalEggFrom60ToEnd = SafeConvert(GetCurrentColumnValue(&quot;TotalEggFrom60ToEnd&quot;));&#xD;&#xA;decimal totalHatEggTill60Wk = SafeConvert(GetCurrentColumnValue(&quot;TotalHatEggTill60Wk&quot;));&#xD;&#xA;decimal totalHatEggFrom60ToEnd = SafeConvert(GetCurrentColumnValue(&quot;TotalHatEggFrom60ToEnd&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate {@ProductionTotalEgg}&#xD;&#xA;decimal productionTotalEgg = totalEggTill60Wk + totalEggFrom60ToEnd;&#xD;&#xA;&#xD;&#xA;// Calculate {@TotalHathedEgg}&#xD;&#xA;decimal totalHatchedEgg = totalHatEggTill60Wk + totalHatEggFrom60ToEnd;&#xD;&#xA;&#xD;&#xA;if (productionTotalEgg &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: ({@TotalHathedEgg} * 100) / {@ProductionTotalEgg}&#xD;&#xA;    decimal result = (totalHatchedEgg * 100.0m) / productionTotalEgg;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell251_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;// Note: Using the exact field name with typo as in your formula&#xD;&#xA;decimal layingFemaleOpen = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingFeamleOpen&quot;) ?? 0);&#xD;&#xA;decimal totalEggTill60Wk = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalEggTill60Wk&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (layingFemaleOpen &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: TotalEggTill60Wk / LayingFeamleOpen&#xD;&#xA;    decimal result = totalEggTill60Wk / layingFemaleOpen;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell253_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;// Note: Using the exact field name with typo as in your formula&#xD;&#xA;decimal layingFemaleOpen = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayingFeamleOpen&quot;) ?? 0);&#xD;&#xA;decimal totalHatEggTill60Wk = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalHatEggTill60Wk&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (layingFemaleOpen &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: TotalHatEggTill60Wk / LayingFeamleOpen&#xD;&#xA;    decimal result = totalHatEggTill60Wk / layingFemaleOpen;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell255_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function to safely convert values&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Get raw values from data source&#xD;&#xA;decimal totalEggTill60Wk = SafeConvert(GetCurrentColumnValue(&quot;TotalEggTill60Wk&quot;));&#xD;&#xA;decimal totalEggFrom60ToEnd = SafeConvert(GetCurrentColumnValue(&quot;TotalEggFrom60ToEnd&quot;));&#xD;&#xA;decimal layingFemaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;LayingFemaleConsFeed&quot;));&#xD;&#xA;decimal layingMaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;LayingMaleConsFeed&quot;));&#xD;&#xA;decimal rearingFemaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;RearingFemaleConsFeed&quot;));&#xD;&#xA;decimal rearingMaleConsFeed = SafeConvert(GetCurrentColumnValue(&quot;RearingMaleConsFeed&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate {@ProductionTotalEgg}&#xD;&#xA;decimal productionTotalEgg = totalEggTill60Wk + totalEggFrom60ToEnd;&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingFemaleConsFeedTon} (convert kg to tons)&#xD;&#xA;decimal rearingFemaleConsFeedTon = rearingFemaleConsFeed / 1000.0m;&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingMaleConsFeedTon} (convert kg to tons)&#xD;&#xA;decimal rearingMaleConsFeedTon = rearingMaleConsFeed / 1000.0m;&#xD;&#xA;&#xD;&#xA;// Calculate {@RearingTotalConsFeed} (total rearing feed in tons)&#xD;&#xA;decimal rearingTotalConsFeed = rearingFemaleConsFeedTon + rearingMaleConsFeedTon;&#xD;&#xA;&#xD;&#xA;// Calculate total laying feed in kg (not tons)&#xD;&#xA;decimal totalLayingFeedKg = layingFemaleConsFeed + layingMaleConsFeed;&#xD;&#xA;&#xD;&#xA;// Calculate total rearing feed in kg (convert tons back to kg)&#xD;&#xA;decimal totalRearingFeedKg = rearingTotalConsFeed * 1000.0m;&#xD;&#xA;&#xD;&#xA;// Calculate total feed in kg&#xD;&#xA;decimal totalFeedKg = totalLayingFeedKg + totalRearingFeedKg;&#xD;&#xA;&#xD;&#xA;if (productionTotalEgg &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (Total Feed Kg) * 1000 / Total Eggs&#xD;&#xA;    // This gives grams of feed per egg&#xD;&#xA;    decimal result = (totalFeedKg * 1000.0m) / productionTotalEgg;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); }&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;" PageWidthF="826.771667" PageHeightF="1169.29138" Version="26.1" DataMember="SR_BRD_EndFlock" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
