<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_BRD_RearPeriodResultOfFeed" ScriptsSource="decimal totalFeedRecF = 0;&#xD;&#xA;decimal totalFeedStockF = 0;&#xD;&#xA;decimal sumWeightedValues = 0;&#xD;&#xA;decimal sumWeights = 0;&#xD;&#xA;decimal sumWeightedValuesMale = 0;&#xD;&#xA;decimal sumWeightsMale = 0;&#xD;&#xA;decimal dailyWeightedFemale = 0;&#xD;&#xA;decimal dailyWeightsFemale = 0;&#xD;&#xA;decimal dailyWeightedMale = 0;&#xD;&#xA;decimal dailyWeightsMale = 0;&#xD;&#xA;&#xD;&#xA;private void xrTableCell56_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get values from fields&#xD;&#xA;    decimal startMaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartMaleBirds&quot;) ?? 0);&#xD;&#xA;    decimal startFemaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartFemaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate&#xD;&#xA;    if (startFemaleBirds != 0) {&#xD;&#xA;        decimal result = (startMaleBirds * 100) / startFemaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // 2 decimal places&#xD;&#xA;        // Or: cell.Text = result.ToString(&quot;N0&quot;); // whole number&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      // Accumulate values&#xD;&#xA;    object feedRecFObj = GetCurrentColumnValue(&quot;FeedRecF&quot;);&#xD;&#xA;    object feedStockFObj = GetCurrentColumnValue(&quot;FeedStockF&quot;);&#xD;&#xA;    &#xD;&#xA;    if (feedRecFObj != null &amp;&amp; feedRecFObj != DBNull.Value) {&#xD;&#xA;        decimal.TryParse(feedRecFObj.ToString(), out decimal feedRecF);&#xD;&#xA;        totalFeedRecF += feedRecF;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    if (feedStockFObj != null &amp;&amp; feedStockFObj != DBNull.Value) {&#xD;&#xA;        decimal.TryParse(feedStockFObj.ToString(), out decimal feedStockF);&#xD;&#xA;        totalFeedStockF += feedStockF;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    //Lgoic for FeedBirdsWeekF&#xD;&#xA;    // Get current row values&#xD;&#xA;    object feedBirdsWeekFObj = GetCurrentColumnValue(&quot;FeedBirdsWeekF&quot;);&#xD;&#xA;    object liveFemaleOpenObj = GetCurrentColumnValue(&quot;StartFemaleBirds&quot;);&#xD;&#xA;    &#xD;&#xA;    decimal feedBirdsWeekF = 0;&#xD;&#xA;    decimal liveFemaleOpen = 0;&#xD;&#xA;    &#xD;&#xA;    // Parse FeedBirdsWeekF&#xD;&#xA;    if (feedBirdsWeekFObj != null &amp;&amp; feedBirdsWeekFObj != DBNull.Value) {&#xD;&#xA;        decimal.TryParse(feedBirdsWeekFObj.ToString(), out feedBirdsWeekF);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Parse LiveFemaleOpen (weight)&#xD;&#xA;    if (liveFemaleOpenObj != null &amp;&amp; liveFemaleOpenObj != DBNull.Value) {&#xD;&#xA;        decimal.TryParse(liveFemaleOpenObj.ToString(), out liveFemaleOpen);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Calculate weighted sum: value * weight&#xD;&#xA;    sumWeightedValues += (feedBirdsWeekF * liveFemaleOpen);&#xD;&#xA;    &#xD;&#xA;    // Sum of weights&#xD;&#xA;    sumWeights += liveFemaleOpen;&#xD;&#xA;    &#xD;&#xA;    //Lgoic for FeedBirdsWeekM&#xD;&#xA;    object feedBirdsWeekMObj = GetCurrentColumnValue(&quot;FeedBirdsWeekM&quot;);&#xD;&#xA;    object liveMaleOpenObj = GetCurrentColumnValue(&quot;StartFemaleBirds&quot;);&#xD;&#xA;    &#xD;&#xA;    decimal feedBirdsWeekM = 0;&#xD;&#xA;    decimal liveMaleOpen = 0;&#xD;&#xA;    &#xD;&#xA;    if (feedBirdsWeekMObj != null &amp;&amp; feedBirdsWeekMObj != DBNull.Value) {&#xD;&#xA;        decimal.TryParse(feedBirdsWeekMObj.ToString(), out feedBirdsWeekM);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    if (liveMaleOpenObj != null &amp;&amp; liveMaleOpenObj != DBNull.Value) {&#xD;&#xA;        decimal.TryParse(liveMaleOpenObj.ToString(), out liveMaleOpen);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    sumWeightedValuesMale += (feedBirdsWeekM * liveMaleOpen);&#xD;&#xA;    sumWeightsMale += liveMaleOpen;&#xD;&#xA;    &#xD;&#xA;        // FEMALE: FeedBirdsDayF weighted by LiveFemaleOpen&#xD;&#xA;    object feedDayFObj = GetCurrentColumnValue(&quot;FeedBirdsDayF&quot;);&#xD;&#xA;    object liveFemaleObj = GetCurrentColumnValue(&quot;StartFemaleBirds&quot;);&#xD;&#xA;    &#xD;&#xA;    decimal feedDayF = 0;&#xD;&#xA;    decimal liveFemale = 0;&#xD;&#xA;    &#xD;&#xA;    if (feedDayFObj != null &amp;&amp; feedDayFObj != DBNull.Value) {&#xD;&#xA;        decimal.TryParse(feedDayFObj.ToString(), out feedDayF);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    if (liveFemaleObj != null &amp;&amp; liveFemaleObj != DBNull.Value) {&#xD;&#xA;        decimal.TryParse(liveFemaleObj.ToString(), out liveFemale);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    dailyWeightedFemale += (feedDayF * liveFemale);&#xD;&#xA;    dailyWeightsFemale += liveFemale;&#xD;&#xA;    &#xD;&#xA;    // MALE: FeedBirdsDayM weighted by LiveMaleOpen&#xD;&#xA;    object feedDayMObj = GetCurrentColumnValue(&quot;FeedBirdsDayM&quot;);&#xD;&#xA;    object liveMaleObj = GetCurrentColumnValue(&quot;StartMaleBirds&quot;);&#xD;&#xA;    &#xD;&#xA;    decimal feedDayM = 0;&#xD;&#xA;    decimal liveMale = 0;&#xD;&#xA;    &#xD;&#xA;    if (feedDayMObj != null &amp;&amp; feedDayMObj != DBNull.Value) {&#xD;&#xA;        decimal.TryParse(feedDayMObj.ToString(), out feedDayM);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    if (liveMaleObj != null &amp;&amp; liveMaleObj != DBNull.Value) {&#xD;&#xA;        decimal.TryParse(liveMaleObj.ToString(), out liveMale);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    dailyWeightedMale += (feedDayM * liveMale);&#xD;&#xA;    dailyWeightsMale += liveMale;&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell58_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Calculate sum of both&#xD;&#xA;    decimal total = totalFeedRecF ;&#xD;&#xA;    cell.Text = total.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell40_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Calculate weighted average: Σ(value * weight) / Σ(weights)&#xD;&#xA;    if (sumWeights &gt; 0) {&#xD;&#xA;        decimal weightedAvg = sumWeightedValues / sumWeights;&#xD;&#xA;        cell.Text = weightedAvg.ToString(&quot;N0&quot;); // 2 decimal places&#xD;&#xA;        // Or: cell.Text = weightedAvg.ToString(&quot;N3&quot;); // 3 decimal places&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0&quot;;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell41_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = sumWeightsMale ;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell42_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    decimal totalWeights = sumWeights + sumWeightsMale;&#xD;&#xA;    decimal totalWeightedValues = sumWeightedValues + sumWeightedValuesMale;&#xD;&#xA;    &#xD;&#xA;    cell.Text = totalWeights &gt; 0 ? &#xD;&#xA;        (totalWeightedValues / totalWeights).ToString(&quot;N0&quot;): &quot;0&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell43_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (dailyWeightsFemale &gt; 0) {&#xD;&#xA;        decimal weightedAvgFemale = dailyWeightedFemale / dailyWeightsFemale;&#xD;&#xA;        cell.Text = weightedAvgFemale.ToString(&quot;N0&quot;);&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell45_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (dailyWeightsMale &gt; 0) {&#xD;&#xA;        decimal weightedAvgMale = dailyWeightedMale / dailyWeightsMale;&#xD;&#xA;        cell.Text = weightedAvgMale.ToString(&quot;N0&quot;);&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0&quot;;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell46_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Calculate totals&#xD;&#xA;    decimal totalWeighted = dailyWeightedFemale + dailyWeightedMale;&#xD;&#xA;    decimal totalWeights = dailyWeightsFemale + dailyWeightsMale;&#xD;&#xA;    &#xD;&#xA;    if (totalWeights &gt; 0) {&#xD;&#xA;        decimal weightedAvgTotal = totalWeighted / totalWeights;&#xD;&#xA;        cell.Text = weightedAvgTotal.ToString(&quot;N0&quot;);&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1169.29138" PageHeightF="826.771667" Version="25.2" DataMember="SR_BRD_PeriodResultOfFeed" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
