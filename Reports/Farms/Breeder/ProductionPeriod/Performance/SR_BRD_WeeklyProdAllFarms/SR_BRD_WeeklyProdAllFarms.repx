<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_BRD_WeeklyProdAllFarms" ScriptsSource="&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartBalance and Mort values&#xD;&#xA;    decimal startBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartBalance&quot;) ?? 0);&#xD;&#xA;    decimal mort = Convert.ToDecimal(GetCurrentColumnValue(&quot;Mort&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startBalance != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate mortality percentage&#xD;&#xA;        decimal result = (mort / startBalance) * 100.0m;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell24_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get PlacedNo and CumMort values&#xD;&#xA;    decimal placedNo = Convert.ToDecimal(GetCurrentColumnValue(&quot;PlacedNo&quot;) ?? 0);&#xD;&#xA;    decimal cumMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumMort&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (placedNo != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate cumulative mortality percentage&#xD;&#xA;        decimal result = (cumMort / placedNo) * 100.0m;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell12_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get PlacedNo and CumCulls values&#xD;&#xA;    decimal placedNo = Convert.ToDecimal(GetCurrentColumnValue(&quot;PlacedNo&quot;) ?? 0);&#xD;&#xA;    decimal cumCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumCulls&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (placedNo != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate cumulative culls percentage&#xD;&#xA;        decimal result = (cumCulls * 100.0m) / placedNo;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell58_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartBalance and FeedConsKG values&#xD;&#xA;    decimal startBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartBalance&quot;) ?? 0);&#xD;&#xA;    decimal feedConsKG = Convert.ToDecimal(GetCurrentColumnValue(&quot;FeedConsKG&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startBalance != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate average daily feed consumption per bird in grams&#xD;&#xA;        // FeedConsKG * 1000 converts to grams&#xD;&#xA;        // Divide by startBalance gives grams per bird for the period&#xD;&#xA;        // Divide by 7.0 gives grams per bird per day&#xD;&#xA;        decimal result = (feedConsKG * 1000.0m) / startBalance / 7.0m;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" Version="25.2" DataMember="SR_BRD_WeeklyProdAllFarms" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
