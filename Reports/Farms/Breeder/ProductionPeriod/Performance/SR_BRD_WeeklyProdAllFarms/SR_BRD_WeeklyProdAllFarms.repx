    <Item6 Ref="246" ControlType="ReportFooterBand" Name="ReportFooter">
      <SubBands>
        <Item1 Ref="247" ControlType="SubBand" Name="SubBand5">
          <Controls>
            <Item1 Ref="248" ControlType="XRSubreport" Name="SR_BRD_WeeklyProdAllFarms_laying">
              <ReportSource Ref="250" ControlType="DevExpressReports.Reports.Farms.Breeder.ProductionPeriod.Performance.SR_BRD_WeeklyProdAllFarms_laying.SR_BRD_WeeklyProdAllFarms_laying, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartBalance and Mort values&#xD;&#xA;    decimal startBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartBalance&quot;) ?? 0);&#xD;&#xA;    decimal mort = Convert.ToDecimal(GetCurrentColumnValue(&quot;Mort&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startBalance != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate mortality percentage&#xD;&#xA;        decimal result = (mort / startBalance) * 100.0m;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell24_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get PlacedNo and CumMort values&#xD;&#xA;    decimal placedNo = Convert.ToDecimal(GetCurrentColumnValue(&quot;PlacedNo&quot;) ?? 0);&#xD;&#xA;    decimal cumMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumMort&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (placedNo != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate cumulative mortality percentage&#xD;&#xA;        decimal result = (cumMort / placedNo) * 100.0m;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell12_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get PlacedNo and CumCulls values&#xD;&#xA;    decimal placedNo = Convert.ToDecimal(GetCurrentColumnValue(&quot;PlacedNo&quot;) ?? 0);&#xD;&#xA;    decimal cumCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumCulls&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (placedNo != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate cumulative culls percentage&#xD;&#xA;        decimal result = (cumCulls * 100.0m) / placedNo;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell58_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal startBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartBalance&quot;) ?? 0);&#xD;&#xA;decimal hatchEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchEggs&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (startBalance != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: HatchEggs / StartBalance / 7 * 100&#xD;&#xA;    // This gives average daily hatch eggs per 100 birds&#xD;&#xA;    decimal result = (hatchEggs / startBalance / 7.0m) * 100.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell36_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal startBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartBalance&quot;) ?? 0);&#xD;&#xA;decimal totalEggsProd = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalEggsProd&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (startBalance != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: TotalEggsProd * 100 / StartBalance / 7&#xD;&#xA;    decimal result = (totalEggsProd * 100.0m) / startBalance / 7.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell55_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get current week values&#xD;&#xA;decimal startBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartBalance&quot;) ?? 0);&#xD;&#xA;decimal totalEggsProd = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalEggsProd&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Get previous week values&#xD;&#xA;decimal prevStartBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;PrevStartBalance&quot;) ?? 0);&#xD;&#xA;decimal prevTotalEggsProd = Convert.ToDecimal(GetCurrentColumnValue(&quot;PrevTotalEggsProd&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Calculate @ProdPerc (Current week production percentage)&#xD;&#xA;decimal prodPerc = 0;&#xD;&#xA;if (startBalance != 0)&#xD;&#xA;{&#xD;&#xA;    prodPerc = (totalEggsProd * 100.0m) / startBalance / 7.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Calculate @PrevProd (Previous week production percentage)&#xD;&#xA;decimal prevProd = 0;&#xD;&#xA;if (prevStartBalance != 0)&#xD;&#xA;{&#xD;&#xA;    prevProd = (prevTotalEggsProd * 100.0m) / prevStartBalance / 7.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Calculate the difference: @ProdPerc - @PrevProd&#xD;&#xA;decimal result = prodPerc - prevProd;&#xD;&#xA;&#xD;&#xA;// Format and display the result&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;); // Shows with 2 decimal places (e.g., 5.23 or -2.15)&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell4_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;) ?? 0);&#xD;&#xA;decimal cumHatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumHatEggs&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: CumHatEggs / POL&#xD;&#xA;    // This gives average hatch eggs per bird up to point of lay&#xD;&#xA;    decimal result = cumHatEggs / pol;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell6_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal startBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartBalance&quot;) ?? 0);&#xD;&#xA;decimal feedConsKG = Convert.ToDecimal(GetCurrentColumnValue(&quot;FeedConsKG&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (startBalance != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: FeedConsKG * 1000 / StartBalance / 7&#xD;&#xA;    // This gives average daily feed consumption in grams per bird&#xD;&#xA;    decimal result = (feedConsKG * 1000.0m) / startBalance / 7.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;); // Formats to whole number (grams)&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" Version="26.1" DataMember="SR_BRD_WeeklyProdAllFarmsLaying" DataSource="#Ref-249" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
