        <Item2 Ref="711" ControlType="SubBand" Name="SubBand6">
          <Controls>
            <Item1 Ref="712" ControlType="XRSubreport" Name="SR_BRD_WeeklyProdAllFarms_Eggs">
              <ReportSource Ref="714" ControlType="DevExpressReports.Reports.Farms.Breeder.ProductionPeriod.Performance.SR_BRD_WeeklyProdAllFarms_Eggs.SR_BRD_WeeklyProdAllFarms_Eggs, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="&#xD;&#xA;private void xrTableCell57_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get TotalEggs and HatchEggs values&#xD;&#xA;decimal totalEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalEggs&quot;) ?? 0);&#xD;&#xA;decimal hatchEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchEggs&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (totalEggs != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate hatch percentage&#xD;&#xA;    decimal result = (hatchEggs / totalEggs) * 100.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places (e.g., 45.67)&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell59_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get the raw values from the data source&#xD;&#xA;decimal totalEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalEggs&quot;) ?? 0);&#xD;&#xA;decimal hatchEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchEggs&quot;) ?? 0);&#xD;&#xA;decimal hatEggsPercStd = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatEggsPercStd&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Calculate HatchEggsPerc (@HatchEggsPerc)&#xD;&#xA;decimal hatchEggsPerc = 0;&#xD;&#xA;&#xD;&#xA;if (totalEggs != 0)&#xD;&#xA;{&#xD;&#xA;    hatchEggsPerc = (hatchEggs / totalEggs) * 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Now apply the main logic: if(@HatchEggsPerc &gt; 0) THEN @HatchEggsPerc - HatEggsPercStd&#xD;&#xA;if (hatchEggsPerc &gt; 0)&#xD;&#xA;{&#xD;&#xA;    decimal result = hatchEggsPerc - hatEggsPercStd;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Format to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;; &#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" Version="26.1" DataMember="SR_BRD_WeeklyProdAllFarms_eggs" DataSource="#Ref-713" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
