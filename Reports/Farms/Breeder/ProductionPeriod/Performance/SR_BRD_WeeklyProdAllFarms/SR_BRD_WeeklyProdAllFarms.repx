        <Item5 Ref="1194" ControlType="SubBand" Name="SubBand7">
          <Controls>
            <Item1 Ref="1195" ControlType="XRSubreport" Name="SR_BRD_WeeklyProdAllFarms_EggsCatigory">
              <ReportSource Ref="1197" ControlType="DevExpressReports.Reports.Farms.Breeder.ProductionPeriod.Performance.SR_BRD_WeeklyProdAllFarms_EggsCatigory.SR_BRD_WeeklyProdAllFarms_EggsCatigory, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="&#xD;&#xA;private void crossTabDataCell2_BeforePrint(object sender, DevExpress.XtraReports.UI.CrossTab.CrossTabCellPrintEventArgs e) {&#xD;&#xA;    // Get the current cell's value (CatValue) and the TotalEggs value&#xD;&#xA;object catValueObj = GetCellValue(&quot;CatValue&quot;); // The measure/field name&#xD;&#xA;object totalEggsObj = GetCellValue(&quot;TotalEggs&quot;); // The total eggs field&#xD;&#xA;&#xD;&#xA;if (catValueObj != null &amp;&amp; totalEggsObj != null)&#xD;&#xA;{&#xD;&#xA;    decimal catValue = Convert.ToDecimal(catValueObj);&#xD;&#xA;    decimal totalEggs = Convert.ToDecimal(totalEggsObj);&#xD;&#xA;    &#xD;&#xA;    if (totalEggs != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate percentage: (CatValue * 100) / TotalEggs&#xD;&#xA;        decimal result = (catValue * 100.0m) / totalEggs;&#xD;&#xA;        e.Value = result; // Set the cell value&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        e.Value = 0; // Or DBNull.Value if you prefer null&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    e.Value = 0;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" Version="25.2" DataMember="SR_BRD_WeeklyProdAllFarms_eggscategories" DataSource="#Ref-1196" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
