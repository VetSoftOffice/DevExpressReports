<XtraReportsLayoutSerializer SerializerVersion="26.1.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_BRD_RearPeriodResult" ScriptsSource="decimal sumFemaleCulls = 0;&#xD;&#xA;decimal sumFemaleCullsKill = 0;&#xD;&#xA;decimal sumFemaleSample = 0;&#xD;&#xA;decimal sumFemaleSexError = 0;&#xD;&#xA;decimal sumFemaleTrans = 0;&#xD;&#xA;decimal sumFemaleMort = 0;&#xD;&#xA;decimal sumMaleCulls = 0;&#xD;&#xA;decimal sumMaleCullsKill = 0;&#xD;&#xA;decimal sumMaleSample = 0;&#xD;&#xA;decimal sumMaleSexError = 0;&#xD;&#xA;decimal sumMaleTrans = 0;&#xD;&#xA;decimal sumMaleMort = 0;&#xD;&#xA;&#xD;&#xA;private void xrTableCell20_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get WC_LiveFemale value&#xD;&#xA;    decimal wcLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveFemale&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate total FemaleDepl from separate sums&#xD;&#xA;    decimal totalFemaleDepl = sumFemaleCulls + sumFemaleCullsKill + sumFemaleSample + &#xD;&#xA;                             sumFemaleSexError + sumFemaleTrans + sumFemaleMort;&#xD;&#xA;    &#xD;&#xA;    // Calculate denominator: WC_LiveFemale + totalFemaleDepl&#xD;&#xA;    decimal denominator = wcLiveFemale + totalFemaleDepl;&#xD;&#xA;    &#xD;&#xA;    // Calculate percentage if denominator &gt; 0&#xD;&#xA;    if (denominator &gt; 0) {&#xD;&#xA;        decimal result = (totalFemaleDepl * 100) / denominator;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // 1 decimal place&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      // Sum each field separately for current row&#xD;&#xA;    sumFemaleCulls += Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Culls&quot;) ?? 0);&#xD;&#xA;    sumFemaleCullsKill += Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_CullsKill&quot;) ?? 0);&#xD;&#xA;    sumFemaleSample += Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Sample&quot;) ?? 0);&#xD;&#xA;    sumFemaleSexError += Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_SexError&quot;) ?? 0);&#xD;&#xA;    sumFemaleTrans += Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Trans&quot;) ?? 0);&#xD;&#xA;    sumFemaleMort += Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleMort&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;     // Sum each MALE field separately for current row&#xD;&#xA;    sumMaleCulls += Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_Culls&quot;) ?? 0);&#xD;&#xA;    sumMaleCullsKill += Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_CullsKill&quot;) ?? 0);&#xD;&#xA;    sumMaleSample += Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_Sample&quot;) ?? 0);&#xD;&#xA;    sumMaleSexError += Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_SexError&quot;) ?? 0);&#xD;&#xA;    sumMaleTrans += Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_Trans&quot;) ?? 0);&#xD;&#xA;    sumMaleMort += Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleMort&quot;) ?? 0);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell21_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    // Calculate total FemaleDepl from separate sums&#xD;&#xA;    decimal totalFemaleDepl = sumFemaleCulls + sumFemaleCullsKill + sumFemaleSample + &#xD;&#xA;                             sumFemaleSexError + sumFemaleTrans + sumFemaleMort;&#xD;&#xA;&#xD;&#xA;    cell.Text = totalFemaleDepl.ToString(&quot;N0&quot;); // 1 decimal place&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell77_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get WC_LiveMALE value&#xD;&#xA;    decimal wcLiveMale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveMale&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate total MaleDepl from separate sums&#xD;&#xA;    decimal totalMaleDepl = sumMaleCulls + sumMaleCullsKill + sumMaleSample + &#xD;&#xA;                           sumMaleSexError + sumMaleTrans + sumMaleMort;&#xD;&#xA;    &#xD;&#xA;    // Calculate denominator: WC_LiveMale + totalMaleDepl&#xD;&#xA;    decimal denominator = wcLiveMale + totalMaleDepl;&#xD;&#xA;    &#xD;&#xA;    // Calculate percentage if denominator &gt; 0&#xD;&#xA;    if (denominator &gt; 0) {&#xD;&#xA;        decimal result = (totalMaleDepl * 100) / denominator;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ; // 1 decimal place&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell78_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;         XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    // Calculate total FemaleDepl from separate sums&#xD;&#xA;    decimal tota1MaleDepl = sumMaleCulls + sumMaleCullsKill + sumMaleSample + &#xD;&#xA;                           sumMaleSexError + sumMaleTrans + sumMaleMort;&#xD;&#xA;    cell.Text = tota1MaleDepl.ToString(&quot;N0&quot;); // 1 decimal place&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell79_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;         XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    // Calculate total FemaleDepl from separate sums&#xD;&#xA;   decimal tota1MaleDepl = sumMaleCulls + sumMaleCullsKill + sumMaleSample + &#xD;&#xA;                           sumMaleSexError + sumMaleTrans + sumMaleMort;&#xD;&#xA;    decimal StartMaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartMaleBirds&quot;) ?? 0);&#xD;&#xA;    decimal result = 0;&#xD;&#xA;    if(StartMaleBirds &gt; 0){&#xD;&#xA;        &#xD;&#xA;           result = (tota1MaleDepl * 100) / StartMaleBirds; &#xD;&#xA;        }&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // 1 decimal place&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    // Calculate total FemaleDepl from separate sums&#xD;&#xA;    decimal totalFemaleDepl = sumFemaleCulls + sumFemaleCullsKill + sumFemaleSample + &#xD;&#xA;                             sumFemaleSexError + sumFemaleTrans + sumFemaleMort;&#xD;&#xA;    decimal StartFemaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartFemaleBirds&quot;) ?? 0);&#xD;&#xA;    decimal result = 0;&#xD;&#xA;    if(StartFemaleBirds  &gt; 0){&#xD;&#xA;        &#xD;&#xA;           result = (totalFemaleDepl * 100) / StartFemaleBirds  ;&#xD;&#xA;        }&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // 1 decimal place&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell84_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;      decimal totalFemaleDepl = sumFemaleCulls + sumFemaleCullsKill + sumFemaleSample + &#xD;&#xA;                             sumFemaleSexError + sumFemaleTrans + sumFemaleMort;&#xD;&#xA;&#xD;&#xA;    // Get values from fields&#xD;&#xA;    decimal wcLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveFemale&quot;) ?? 0);&#xD;&#xA;    decimal femaleFeed = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleFeed&quot;) ?? 0);&#xD;&#xA;     if (wcLiveFemale &gt; 0) {&#xD;&#xA;        // Method 1: As per your formula order&#xD;&#xA;        decimal result = femaleFeed * 1000 / (wcLiveFemale + totalFemaleDepl )  / 7;&#xD;&#xA;        &#xD;&#xA;        // Method 2: More efficient&#xD;&#xA;        // decimal result = (maleFeed * 1000) / (wcLiveMale * 7);&#xD;&#xA;        &#xD;&#xA;        cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0&quot;;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    &#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;private void xrTableCell85_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    decimal tota1MaleDepl = sumMaleCulls + sumMaleCullsKill + sumMaleSample + &#xD;&#xA;                           sumMaleSexError + sumMaleTrans + sumMaleMort;&#xD;&#xA;    decimal wcLiveMale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveMale&quot;) ?? 0);&#xD;&#xA;    decimal maleFeed = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleFeed&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (wcLiveMale &gt; 0) {&#xD;&#xA;        // Method 1: As per your formula order&#xD;&#xA;        decimal result = maleFeed * 1000 / (wcLiveMale + tota1MaleDepl )  / 7;&#xD;&#xA;        &#xD;&#xA;        // Method 2: More efficient&#xD;&#xA;        // decimal result = (maleFeed * 1000) / (wcLiveMale * 7);&#xD;&#xA;        &#xD;&#xA;        cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell86_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;         XRTableCell cell = sender as XRTableCell;&#xD;&#xA;     decimal wcLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveFemale&quot;) ?? 0);&#xD;&#xA;    decimal wcLiveMale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveMale&quot;) ?? 0);&#xD;&#xA;     decimal rowRatio = 0;&#xD;&#xA;    if (wcLiveFemale &gt; 0) &#xD;&#xA;        rowRatio = (wcLiveMale * 100) / wcLiveFemale;&#xD;&#xA;    cell.Text = rowRatio.ToString(&quot;N1&quot;);&#xD;&#xA;&#xD;&#xA;   }&#xD;&#xA;&#xD;&#xA;private void xrTableCell68_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get values from fields&#xD;&#xA;    decimal startFemaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartFemaleBirds&quot;) ?? 0);&#xD;&#xA;    decimal startMaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartMaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate: (StartMaleBirds × 100) / StartFemaleBirds&#xD;&#xA;    if (startFemaleBirds &gt; 0) {&#xD;&#xA;        decimal result = (startMaleBirds * 100) / startFemaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // 1 decimal place with %&#xD;&#xA;        // Or without %: result.ToString(&quot;F1&quot;)&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or &quot;0&quot;&#xD;&#xA;    } &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;" Landscape="true" PageWidthF="1169.29138" PageHeightF="826.771667" Version="26.1" DataMember="SR_BRD_RearPeriodResult" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
