                  <Item8 Ref="399" Name="NoOfGroupsPerPage" />
                  <Item9 Ref="400" Visible="false" Name="DateFrom" />
                  <Item10 Ref="401" Visible="false" AllowNull="true" Name="DateTo" />
                  <Item11 Ref="402" Visible="false" AllowNull="true" Name="CycleFlkBatchCount" />
                  <Item12 Ref="403" Visible="false" AllowNull="true" Name="CycleFlkBatchNo" />
                  <Item13 Ref="404" Visible="false" AllowNull="true" Name="PlaceCode" />
                  <Item14 Ref="405" Visible="false" AllowNull="true" Name="SupPlacesCount" />
                  <Item15 Ref="406" Name="BookPerf" />
                  <Item16 Ref="407" Visible="false" Name="LineType" />
                  <Item17 Ref="408" Visible="false" Name="FarmCode" />
                  <Item18 Ref="409" Visible="false" Name="CropNo" />
                  <Item19 Ref="410" Visible="false" Name="Breed" />
                  <Item20 Ref="411" Visible="false" Name="Sitee" />
                  <Item21 Ref="412" Visible="false" Name="FarmNo" />
                  <Item22 Ref="413" Visible="false" Name="Flock" />
                  <Item23 Ref="414" Visible="false" Name="WCDate" />
                  <Item24 Ref="415" Visible="false" Name="FemaleArrivalDate" />
                  <Item25 Ref="416" Visible="false" Name="MaleArrivalDate" />
                  <Item26 Ref="417" Visible="false" ValueInfo="0" Name="FemaleReceived" Type="#Ref-29" />
                  <Item27 Ref="418" Visible="false" ValueInfo="0" Name="MaleReceived" Type="#Ref-29" />
                  <Item28 Ref="419" Visible="false" Name="LightOn" />
                  <Item29 Ref="420" Visible="false" Name="LightOff" />
                  <Item30 Ref="421" Visible="false" ValueInfo="0" Name="FemaleDOA" Type="#Ref-29" />
                  <Item31 Ref="422" Visible="false" ValueInfo="0" Name="MaleDOA" Type="#Ref-29" />
                  <Item32 Ref="423" Visible="false" Name="Hours" />
                  <Item33 Ref="424" Visible="false" Name="Lux" />
                  <Item34 Ref="425" Visible="false" ValueInfo="0" Name="FBW_STD" Type="#Ref-29" />
                  <Item35 Ref="426" Visible="false" ValueInfo="0" Name="MBW_STD" Type="#Ref-29" />
                  <Item36 Ref="427" Visible="false" ValueInfo="0" Name="FemalesLeft" Type="#Ref-29" />
                  <Item37 Ref="428" Visible="false" ValueInfo="0" Name="MalesLeft" Type="#Ref-29" />
                </Parameters>
                <CalculatedFields>
                  <Item1 Ref="429" Name="Result" Expression="Iif(IsNullOrEmpty([Sentdate]), 'F' , 'T' )" DataMember="SR_BRD_SampleSent" />
                  <Item2 Ref="430" Name="Age" Expression="ToStr([DayFrom]) + ' - ' + ToStr([DayTo])" DataMember="SR_PH_BRD_Vaccination" />
                  <Item3 Ref="431" Name="FromTo" Expression="[StartDate].ToString('d') + ' - ' + [EndDate].ToString('d')" DataMember="SR_PH_BRD_Vaccination" />
                  <Item4 Ref="432" Name="OpenF" Expression="Iif(IsNullOrEmpty([OpenFHTEggsF]), 0, [OpenFHTEggsF])&#xA;+&#xA;Iif(IsNullOrEmpty([OpenHTEggsF]), 0, [OpenHTEggsF])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item5 Ref="433" Name="Production" Expression="Iif(IsNullOrEmpty([ProdFHTEggsF]), 0, [ProdFHTEggsF]) +&#xA;Iif(IsNullOrEmpty([ProdHTEggsF]), 0, [ProdHTEggsF])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item6 Ref="434" Name="SendToHatF" Expression="Iif(IsNullOrEmpty([HatcheryFHTEggsF]), 0, [HatcheryFHTEggsF]) +&#xA;Iif(IsNullOrEmpty([HatcheryHTEggsF]), 0, [HatcheryHTEggsF])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item7 Ref="435" Name="SendToCEGS" Expression="Iif(IsNullOrEmpty([CEGSFHTEggsF]), 0, [CEGSFHTEggsF]) +&#xA;Iif(IsNullOrEmpty([CEGSHTEggsF]), 0, [CEGSHTEggsF])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item8 Ref="436" Name="CloseF" Expression="Iif(IsNullOrEmpty([CloseFHTEggsF]), 0, [CloseFHTEggsF]) +&#xA;Iif(IsNullOrEmpty([CloseHTEggsF]), 0, [CloseHTEggsF])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item9 Ref="437" Name="OpenC" Expression="Iif(IsNullOrEmpty([OpenFHTEggsC]), 0, [OpenFHTEggsC]) +&#xA;Iif(IsNullOrEmpty([OpenHTEggsC]), 0, [OpenHTEggsC])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item10 Ref="438" Name="Receive" Expression="Iif(IsNullOrEmpty([RecFHTEggsC]), 0, [RecFHTEggsC]) +&#xA;Iif(IsNullOrEmpty([RecHTEggsC]), 0, [RecHTEggsC])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item11 Ref="439" Name="SendToHatC" Expression="Iif(IsNullOrEmpty([HatcheryFHTEggsC]), 0, [HatcheryFHTEggsC]) +&#xA;Iif(IsNullOrEmpty([HatcheryHTEggsC]), 0, [HatcheryHTEggsC])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item12 Ref="440" Name="Close" Expression="Iif(IsNullOrEmpty([CloseFHTEggsC]), 0, [CloseFHTEggsC]) +&#xA;Iif(IsNullOrEmpty([CloseHTEggsC]), 0, [CloseHTEggsC])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item13 Ref="441" Name="TotalHE" Expression="Iif(IsNullOrEmpty([CloseFHTEggsC]), 0, [CloseFHTEggsC]) +&#xD;&#xA;Iif(IsNullOrEmpty([CloseFHTEggsF]), 0, [CloseFHTEggsF]) +&#xD;&#xA;Iif(IsNullOrEmpty([CloseHTEggsC]), 0, [CloseHTEggsC]) +&#xD;&#xA;Iif(IsNullOrEmpty([CloseHTEggsF]), 0, [CloseHTEggsF])&#xD;&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item14 Ref="442" Name="TotalFHE" Expression="Iif(IsNullOrEmpty([CloseFHTEggsC]),0 ,[CloseFHTEggsC]) + Iif(IsNullOrEmpty([CloseFHTEggsF]),0 ,[CloseHTEggsF])" DataMember="SR_BRD_HTEggsBalance" />
                  <Item15 Ref="443" Name="TotalEggs" Expression="[TotalHE] + [TotalFHE]" DataMember="SR_BRD_HTEggsBalance" />
                  <Item16 Ref="444" Name="SameDate" Expression="Iif(?DateFrom == ?DateTo, 1, 0)" DataMember="SR_BRD_HTEggsBalance" />
                  <Item17 Ref="445" Name="Age_weeks" Expression="Max([rf_WeeKNo])" DataMember="SR_BRD_WeeklyReport" />
                  <Item18 Ref="446" Name="BirdsLeftFemale" Expression="?FemaleReceived - ?FemaleDOA" DataMember="SR_BRD_WeeklyReport" />
                  <Item19 Ref="447" Name="FemalesPlaced" Expression="Sum([FemalePlaced])" DataMember="SR_BRD_WeeklyReport" />
                  <Item20 Ref="448" Name="BirdsLeftMale" Expression="?MaleReceived - ?MaleDOA" DataMember="SR_BRD_WeeklyReport" />
                  <Item21 Ref="449" Name="MalesPlaced" Expression="Sum([MalePlaced])" DataMember="SR_BRD_WeeklyReport" />
                  <Item22 Ref="450" Name="FeedKgs" Expression="Iif(IsNullOrEmpty([FemaleFeed]), 0, [FemaleFeed]) + Iif(IsNullOrEmpty([MaleFeed]), 0, [MaleFeed])&#xA;" DataMember="SR_BRD_WeeklyReport" />
                  <Item23 Ref="451" Name="TotalLayBalance" Expression="Iif(IsNullOrEmpty([LayFemaleBalance]), 0, [LayFemaleBalance]) +&#xA;Iif(IsNullOrEmpty([LayMaleBalance]), 0, [LayMaleBalance])&#xA;" DataMember="SR_BRD_DailySelling" />
                  <Item24 Ref="452" Name="TotalSaledBalance" Expression="Iif(IsNullOrEmpty([SellFemaleBalance]), 0, [SellFemaleBalance]) +&#xA;Iif(IsNullOrEmpty([SellMaleBalance]), 0, [SellMaleBalance])&#xA;" DataMember="SR_BRD_DailySelling" />
                  <Item25 Ref="453" Name="SellValue" Expression="Iif(IsNullOrEmpty([SellingPrice]), 0, [SellingPrice]) +&#xA;Iif(IsNullOrEmpty([SellWt]), 0, [SellWt])&#xA;" DataMember="SR_BRD_DailySelling" />
                  <Item26 Ref="454" Name="EggsValue" Expression="Iif(IsNullOrEmpty([SellingEggs]), 0, [SellingEggs]) *&#xA;Iif(IsNullOrEmpty([SellingEggsPrice]), 0, [SellingEggsPrice])&#xA;" DataMember="SR_BRD_DailySelling" />
                  <Item27 Ref="455" Name="TotalLayFarm" Expression="IIF(!IsNullOrEmpty([LayFemaleBalance]), [LayFemaleBalance], 0) + IIF(!IsNullOrEmpty([LayMaleBalance]), [LayMaleBalance], 0)" DataMember="SR_BRD_DailySelling_Sub1" />
                  <Item28 Ref="456" Name="TotalSellingFarm" Expression="IIF(!IsNullOrEmpty([SellMaleBalance]), [SellMaleBalance], 0) + IIF(!IsNullOrEmpty([SellFemaleBalance]), [SellFemaleBalance], 0)" DataMember="SR_BRD_DailySelling_Sub1" />
