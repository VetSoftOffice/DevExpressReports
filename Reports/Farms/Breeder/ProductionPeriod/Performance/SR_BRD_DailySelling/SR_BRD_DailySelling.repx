        <Item3 Ref="388" ControlType="SubBand" Name="SubBand8">
          <Controls>
            <Item1 Ref="389" ControlType="XRSubreport" Name="SR_BRD_DailySelling_Sub1">
              <ReportSource Ref="391" ControlType="DevExpressReports.Reports.Farms.Breeder.ProductionPeriod.Performance.SR_BRD_DailySelling_Sub1.SR_BRD_DailySelling_Sub1, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" PageWidthF="1169.29138" PageHeightF="1653.54333" Version="25.2" DataMember="SR_BRD_DailySelling_Sub1" DataSource="#Ref-390" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
                <Parameters>
                  <Item1 Ref="392" Visible="false" ValueInfo="False" Name="IsRTL" Type="#Ref-2" />
                  <Item2 Ref="393" Visible="false" ValueInfo="False" Name="IsCustomReportHeader" Type="#Ref-2" />
                  <Item3 Ref="394" Visible="false" ValueInfo="False" Name="IsCustomReportFooter" Type="#Ref-2" />
                  <Item4 Ref="395" ValueInfo="False" Name="ShowSignature" Type="#Ref-2" />
