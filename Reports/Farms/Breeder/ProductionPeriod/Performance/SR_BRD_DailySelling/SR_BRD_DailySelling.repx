+= sellWt / totalBalance;&#xD;&#xA;        totalRatioCount++;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    double femaleBalance = Convert.ToDouble(GetCurrentColumnValue(&quot;LayFemaleBalance&quot;));&#xD;&#xA;    double maleBalance   = Convert.ToDouble(GetCurrentColumnValue(&quot;LayMaleBalance&quot;));&#xD;&#xA;    double layWt         = Convert.ToDouble(GetCurrentColumnValue(&quot;LayWt&quot;));&#xD;&#xA;&#xD;&#xA;    double totalBalance = femaleBalance + maleBalance;&#xD;&#xA;&#xD;&#xA;    if (totalBalance &gt; 0)&#xD;&#xA;    {&#xD;&#xA;         avgSum += layWt / totalBalance;&#xD;&#xA;        avgCount++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    TotalLayFemaleBalance += femaleBalance ;&#xD;&#xA;    TotalLayMaleBalance += maleBalance   ;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell42_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    if (cell == null)&#xD;&#xA;        return;&#xD;&#xA;&#xD;&#xA;    if (avgCount &gt; 0)&#xD;&#xA;        cell.Text = (avgSum / avgCount).ToString(&quot;N2&quot;);&#xD;&#xA;    else&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell25_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    if (cell == null)&#xD;&#xA;        return;&#xD;&#xA;&#xD;&#xA;    double sellFemaleBalance = Convert.ToDouble(GetCurrentColumnValue(&quot;SellFemaleBalance&quot;));&#xD;&#xA;    double sellMaleBalance   = Convert.ToDouble(GetCurrentColumnValue(&quot;SellMaleBalance&quot;));&#xD;&#xA;    double sellWt            = Convert.ToDouble(GetCurrentColumnValue(&quot;SellWt&quot;));&#xD;&#xA;&#xD;&#xA;    double totalSaledBalance = sellFemaleBalance + sellMaleBalance;&#xD;&#xA;&#xD;&#xA;    if (totalSaledBalance &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        double result = sellWt / totalSaledBalance;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell48_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;if (cell == null)&#xD;&#xA;    return;&#xD;&#xA;&#xD;&#xA;// Optionally, check if this is the last row in the group/report&#xD;&#xA;&#xD;&#xA;    if (totalRatioCount &gt; 0)&#xD;&#xA;        cell.Text = (totalRatioSum / totalRatioCount).ToString(&quot;N2&quot;);&#xD;&#xA;    else&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell29_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;if (cell == null)&#xD;&#xA;    return;&#xD;&#xA;&#xD;&#xA;// Get current row value&#xD;&#xA;double femaleSell = Convert.ToDouble(GetCurrentColumnValue(&quot;FemaleSell&quot;));&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// Apply condition&#xD;&#xA;if (TotalLayFemaleBalance != 0)&#xD;&#xA;    cell.Text = (femaleSell * 100.0 / TotalLayFemaleBalance).ToString(&quot;N2&quot;);&#xD;&#xA;else&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell30_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;if (cell == null)&#xD;&#xA;    return;&#xD;&#xA;&#xD;&#xA;// Get values&#xD;&#xA;double maleSell = Convert.ToDouble(GetCurrentColumnValue(&quot;MaleSell&quot;));&#xD;&#xA;&#xD;&#xA;// Apply condition&#xD;&#xA;if (TotalLayMaleBalance  != 0)&#xD;&#xA;    cell.Text = (maleSell * 100.0 / TotalLayMaleBalance).ToString(&quot;N2&quot;);&#xD;&#xA;else&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell32_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;if (cell == null)&#xD;&#xA;    return;&#xD;&#xA;&#xD;&#xA;// Get values&#xD;&#xA;double femaleSellCulls = Convert.ToDouble(GetCurrentColumnValue(&quot;FemaleSellCulls&quot;));&#xD;&#xA;&#xD;&#xA;// Apply condition&#xD;&#xA;if (TotalLayFemaleBalance != 0)&#xD;&#xA;    cell.Text = (femaleSellCulls * 100.0 / TotalLayFemaleBalance ).ToString(&quot;N2&quot;);&#xD;&#xA;else&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell33_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;if (cell == null)&#xD;&#xA;    return;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;double maleSellCulls = Convert.ToDouble(GetCurrentColumnValue(&quot;MaleSellCulls&quot;));&#xD;&#xA;&#xD;&#xA;// Apply condition&#xD;&#xA;if (TotalLayMaleBalance  != 0)&#xD;&#xA;    cell.Text = (maleSellCulls * 100.0 / TotalLayMaleBalance  ).ToString(&quot;N2&quot;);&#xD;&#xA;else&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell35_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;if (cell == null)&#xD;&#xA;    return;&#xD;&#xA;&#xD;&#xA;// Get required values&#xD;&#xA;&#xD;&#xA;double femaleSell = Convert.ToDouble(GetCurrentColumnValue(&quot;FemaleSell&quot;));&#xD;&#xA;double femaleSellCulls = Convert.ToDouble(GetCurrentColumnValue(&quot;FemaleSellCulls&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate DeplationF&#xD;&#xA;double deplationF = TotalLayFemaleBalance - (femaleSell + femaleSellCulls);&#xD;&#xA;&#xD;&#xA;// Apply percentage logic&#xD;&#xA;if (femaleLayRTotal != 0)&#xD;&#xA;    cell.Text = (deplationF * 100.0 / TotalLayFemaleBalance ).ToString(&quot;N2&quot;);&#xD;&#xA;else&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell36_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;if (cell == null)&#xD;&#xA;    return;&#xD;&#xA;&#xD;&#xA;// Get required values&#xD;&#xA;&#xD;&#xA;double maleSell = Convert.ToDouble(GetCurrentColumnValue(&quot;MaleSell&quot;));&#xD;&#xA;double maleSellCulls = Convert.ToDouble(GetCurrentColumnValue(&quot;MaleSellCulls&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate DeplationM&#xD;&#xA;double deplationM = TotalLayMaleBalance  - (maleSell + maleSellCulls);&#xD;&#xA;&#xD;&#xA;// Apply percentage logic&#xD;&#xA;if (maleLayRTotal != 0)&#xD;&#xA;    cell.Text = (deplationM * 100.0 / TotalLayMaleBalance  ).ToString(&quot;N2&quot;);&#xD;&#xA;else&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;" PageWidthF="1169.29138" PageHeightF="1653.54333" Version="25.2" DataMember="SR_BRD_DailySelling" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
