                <CalculatedFields>
                  <Item1 Ref="154" Name="Abs_OpenBal" Expression="Abs([OpenBalance])" DataMember="SR_FC_CustSuppSheet" />
                  <Item2 Ref="155" Name="DebitCreditOpenBalRes" Expression="Iif([OpenBalance] &gt; 0,[Debit_Str] , Iif([OpenBalance] &lt; 0, [Credit_Str], ''))" DataMember="SR_FC_CustSuppSheet" />
                  <Item3 Ref="156" Name="Debit_Str" Expression="Iif(?IsRTL == true,'(مدين)' , '(Debit)')" DataMember="SR_FC_CustSuppSheet" />
                  <Item4 Ref="157" Name="Credit_Str" Expression="Iif(?IsRTL == true,'(دائن)' , '(Credit)')" DataMember="SR_FC_CustSuppSheet" />
                  <Item5 Ref="158" Name="OpenDebit" Expression="Iif([OpenBalance] &gt; 0, [OpenBalance], NULL)" DataMember="SR_FC_CustSuppSheet" />
                  <Item6 Ref="159" Name="OpenCredit" Expression="Iif([OpenBalance] &lt; 0, Abs([OpenBalance]), NULL)&#xA;" DataMember="SR_FC_CustSuppSheet" />
                  <Item7 Ref="160" Name="Result" Expression="[Debit] - [Credit]" DataMember="SR_FC_CustSuppSheet" />
                  <Item8 Ref="161" Name="CloseDebit" Expression="Iif([CloseBalance] &gt; 0, [CloseBalance], 0)" DataMember="SR_FC_CustSuppSheet" />
                  <Item9 Ref="162" Name="Open_Balance_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([OpenBalance])/[FormulaOperand_Prod] ,0 )" DataMember="SR_FC_FM_StockMovement" />
                  <Item10 Ref="163" Name="Inputs_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([InputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item11 Ref="164" Name="Consumed_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([Consumed])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item12 Ref="165" Name="Outputs_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([SoldTransferOut])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item13 Ref="166" Name="Other_Output_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([OtherOutputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item14 Ref="167" Name="Close_Balance_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([CloseBalance])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item15 Ref="168" Name="CondLoss_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([CondLoss])/[FormulaOperand_Prod] ,0 )&#xA;&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item16 Ref="169" Name="Deviation_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([Deviation])/[FormulaOperand_Prod] ,0 )&#xA;&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item17 Ref="170" Name="ProdType_Prod" Expression="[ProdType]+'_'+[Product]" DataMember="SR_FC_FM_StockMovement" />
                  <Item18 Ref="171" Name="Produced" Expression="IsNull([TotalSelleable],0 )+IsNull([HouseEggsReject],0 )+IsNull([MOBA],0 )" DataMember="SR_LAY_ProdWeeklyDepl" />
                  <Item19 Ref="172" Name="Rejected" Expression="IsNull([HouseEggsReject],0 )+IsNull([MOBA],0 )" DataMember="SR_LAY_ProdWeeklyDepl" />
                  <Item20 Ref="173" Name="CopyRight" Expression="Iif(?IsRTL, 'حقوق النسخ 2003-2025 فيت سوفت - جميع الحقوق محفوظة', 'Copyright @ 2003-2025 VetSoft Office, All rights reserved')&#xA;" DataMember="SR_FM_RationResult" />
                  <Item21 Ref="174" Name="MonthName" Expression="IIf(&#xA;    ?IsRTL, &#xA;    IIf([DateMonthNo] == 1, 'يناير',&#xA;        IIf([DateMonthNo] == 2, 'فبراير',&#xA;            IIf([DateMonthNo] == 3, 'مارس',&#xA;                IIf([DateMonthNo] == 4, 'أبريل',&#xA;                    IIf([DateMonthNo] == 5, 'مايو',&#xA;                        IIf([DateMonthNo] == 6, 'يونيو',&#xA;                            IIf([DateMonthNo] == 7, 'يوليو',&#xA;                                IIf([DateMonthNo] == 8, 'أغسطس',&#xA;                                    IIf([DateMonthNo] == 9, 'سبتمبر',&#xA;                                        IIf([DateMonthNo] == 10, 'أكتوبر',&#xA;                                            IIf([DateMonthNo] == 11, 'نوفمبر',&#xA;                                                'ديسمبر'&#xA;                                            )&#xA;                                        )&#xA;                                    )&#xA;                                )&#xA;                            )&#xA;                        )&#xA;                    )&#xA;                )&#xA;            )&#xA;        )&#xA;    ),&#xA;    IIf([DateMonthNo] == 1, 'Jan',&#xA;        IIf([DateMonthNo] == 2, 'Feb',&#xA;            IIf([DateMonthNo] == 3, 'Mar',&#xA;                IIf([DateMonthNo] == 4, 'Apr',&#xA;                    IIf([DateMonthNo] == 5, 'May',&#xA;                        IIf([DateMonthNo] == 6, 'Jun',&#xA;                            IIf([DateMonthNo] == 7, 'Jul',&#xA;                                IIf([DateMonthNo] == 8, 'Aug',&#xA;                                    IIf([DateMonthNo] == 9, 'Sep',&#xA;                                        IIf([DateMonthNo] == 10, 'Oct',&#xA;                                            IIf([DateMonthNo] == 11, 'Nov',&#xA;                                                'Dec'&#xA;                                            )&#xA;                                        )&#xA;                                    )&#xA;                                )&#xA;                            )&#xA;                        )&#xA;                    )&#xA;                )&#xA;            )&#xA;        )&#xA;    )&#xA;)" DataMember="SR_BRD_FlocksActProd" />
                  <Item22 Ref="175" Name="MonthName_HatEggs" Expression="IIf(&#xA;    ?IsRTL, &#xA;    IIf([DateMonthNo] == 1, 'يناير',&#xA;        IIf([DateMonthNo] == 2, 'فبراير',&#xA;            IIf([DateMonthNo] == 3, 'مارس',&#xA;                IIf([DateMonthNo] == 4, 'أبريل',&#xA;                    IIf([DateMonthNo] == 5, 'مايو',&#xA;                        IIf([DateMonthNo] == 6, 'يونيو',&#xA;                            IIf([DateMonthNo] == 7, 'يوليو',&#xA;                                IIf([DateMonthNo] == 8, 'أغسطس',&#xA;                                    IIf([DateMonthNo] == 9, 'سبتمبر',&#xA;                                        IIf([DateMonthNo] == 10, 'أكتوبر',&#xA;                                            IIf([DateMonthNo] == 11, 'نوفمبر',&#xA;                                                'ديسمبر'&#xA;                                            )&#xA;                                        )&#xA;                                    )&#xA;                                )&#xA;                            )&#xA;                        )&#xA;                    )&#xA;                )&#xA;            )&#xA;        )&#xA;    ),&#xA;    IIf([DateMonthNo] == 1, 'Jan',&#xA;        IIf([DateMonthNo] == 2, 'Feb',&#xA;            IIf([DateMonthNo] == 3, 'Mar',&#xA;                IIf([DateMonthNo] == 4, 'Apr',&#xA;                    IIf([DateMonthNo] == 5, 'May',&#xA;                        IIf([DateMonthNo] == 6, 'Jun',&#xA;                            IIf([DateMonthNo] == 7, 'Jul',&#xA;                                IIf([DateMonthNo] == 8, 'Aug',&#xA;                                    IIf([DateMonthNo] == 9, 'Sep',&#xA;                                        IIf([DateMonthNo] == 10, 'Oct',&#xA;                                            IIf([DateMonthNo] == 11, 'Nov',&#xA;                                                'Dec'&#xA;                                            )&#xA;                                        )&#xA;                                    )&#xA;                                )&#xA;                            )&#xA;                        )&#xA;                    )&#xA;                )&#xA;            )&#xA;        )&#xA;    )&#xA;)" DataMember="SR_BRD_FlocksActProd_HatEggs" />
