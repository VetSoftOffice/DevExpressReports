<XtraReportsLayoutSerializer SerializerVersion="26.1.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_BRD_FinishedFlkData" ScriptsSource="private void xrTableCell75_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get RearFemBalance and RearFemMort values&#xD;&#xA;    decimal rearFemBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;RearFemBalance&quot;) ?? 0);&#xD;&#xA;    decimal rearFemMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;RearFemMort&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (rearFemBalance != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate rear female mortality percentage&#xD;&#xA;        decimal result = (rearFemMort * 100) / rearFemBalance;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell76_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get RearMaleBalance and RearMaleMort values&#xD;&#xA;    decimal rearMaleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;RearMaleBalance&quot;) ?? 0);&#xD;&#xA;    decimal rearMaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;RearMaleMort&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (rearMaleBalance != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate rear male mortality percentage&#xD;&#xA;        decimal result = (rearMaleMort * 100) / rearMaleBalance;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell77_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Calculate TotalRearBalance (RearFemBalance + RearMaleBalance)&#xD;&#xA;    decimal rearFemBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;RearFemBalance&quot;) ?? 0);&#xD;&#xA;    decimal rearMaleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;RearMaleBalance&quot;) ?? 0);&#xD;&#xA;    decimal totalRearBalance = rearFemBalance + rearMaleBalance;&#xD;&#xA;    &#xD;&#xA;    // Calculate TotalRearingMort (RearFemMort + RearMaleMort)&#xD;&#xA;    decimal rearFemMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;RearFemMort&quot;) ?? 0);&#xD;&#xA;    decimal rearMaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;RearMaleMort&quot;) ?? 0);&#xD;&#xA;    decimal totalRearingMort = rearFemMort + rearMaleMort;&#xD;&#xA;    &#xD;&#xA;    if (totalRearBalance != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate total rearing mortality percentage&#xD;&#xA;        decimal result = (totalRearingMort * 100) / totalRearBalance;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell97_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get LayStartFemBalance and LayFemCulls values&#xD;&#xA;    decimal layStartFemBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayStartFemBalance&quot;) ?? 0);&#xD;&#xA;    decimal layFemCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayFemCulls&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (layStartFemBalance != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate lay female culls percentage&#xD;&#xA;        decimal result = (layFemCulls * 100) / layStartFemBalance;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell105_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get LayStartFemBalance and LayFemMort values&#xD;&#xA;    decimal layStartFemBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayStartFemBalance&quot;) ?? 0);&#xD;&#xA;    decimal layFemMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayFemMort&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (layStartFemBalance != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate lay female mortality percentage&#xD;&#xA;        decimal result = (layFemMort * 100) / layStartFemBalance;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell117_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get LayStartFemBalance&#xD;&#xA;    decimal layStartFemBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayStartFemBalance&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate TotalLayingFemExcluded (LayFemMort + LayFemCulls)&#xD;&#xA;    decimal layFemMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayFemMort&quot;) ?? 0);&#xD;&#xA;    decimal layFemCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayFemCulls&quot;) ?? 0);&#xD;&#xA;    decimal totalLayingFemExcluded = layFemMort + layFemCulls;&#xD;&#xA;    &#xD;&#xA;    if (layStartFemBalance != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate total laying female exclusion percentage&#xD;&#xA;        decimal result = (totalLayingFemExcluded * 100) / layStartFemBalance;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell98_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get LayStartMaleBalance and LayMaleCulls values&#xD;&#xA;    decimal layStartMaleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayStartMaleBalance&quot;) ?? 0);&#xD;&#xA;    decimal layMaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayMaleCulls&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (layStartMaleBalance != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate lay male culls percentage&#xD;&#xA;        decimal result = (layMaleCulls * 100) / layStartMaleBalance;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell106_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get LayStartMaleBalance and LayMaleMort values&#xD;&#xA;    decimal layStartMaleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayStartMaleBalance&quot;) ?? 0);&#xD;&#xA;    decimal layMaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayMaleMort&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (layStartMaleBalance != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate lay male mortality percentage&#xD;&#xA;        decimal result = (layMaleMort * 100) / layStartMaleBalance;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell118_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get LayStartMaleBalance&#xD;&#xA;    decimal layStartMaleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayStartMaleBalance&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate TotalLayingMaleExcluded (LayMaleMort + LayMaleCulls + LayMaleSpiking)&#xD;&#xA;    decimal layMaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayMaleMort&quot;) ?? 0);&#xD;&#xA;    decimal layMaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayMaleCulls&quot;) ?? 0);&#xD;&#xA;    decimal layMaleSpiking = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayMaleSpiking&quot;) ?? 0);&#xD;&#xA;    decimal totalLayingMaleExcluded = layMaleMort + layMaleCulls + layMaleSpiking;&#xD;&#xA;    &#xD;&#xA;    if (layStartMaleBalance != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate total laying male exclusion percentage&#xD;&#xA;        decimal result = (totalLayingMaleExcluded * 100) / layStartMaleBalance;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell99_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;            XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;        decimal layingFemCullsPer = 0;&#xD;&#xA;        decimal layingMaleMortPre = 0;&#xD;&#xA;        decimal totalPercentage = 0;&#xD;&#xA;&#xD;&#xA;            // Get values for calculations&#xD;&#xA;        decimal layStartFemBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayStartFemBalance&quot;) ?? 0);&#xD;&#xA;        decimal layFemCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayFemCulls&quot;) ?? 0);&#xD;&#xA;        decimal layFemMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayFemMort&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        // Calculate {@LayingFemCullsPer}&#xD;&#xA;        if (layStartFemBalance != 0)&#xD;&#xA;        {&#xD;&#xA;            layingFemCullsPer = (layFemCulls * 100) / layStartFemBalance;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            layingFemCullsPer = 0;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // Calculate {@LayingmaleMortPre}&#xD;&#xA;        if (layStartFemBalance != 0)&#xD;&#xA;        {&#xD;&#xA;            layingMaleMortPre = (layFemMort * 100) / layStartFemBalance;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            layingMaleMortPre = 0;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // Calculate total&#xD;&#xA;        totalPercentage = layingFemCullsPer + layingMaleMortPre;&#xD;&#xA;        cell.Text = totalPercentage.ToString(&quot;N2&quot;) ;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell107_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;             XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;        decimal layingFemMortPre = 0;&#xD;&#xA;        decimal layingMaleMortPre = 0;&#xD;&#xA;        decimal totalMortalityPercentage = 0;&#xD;&#xA;            decimal layStartFemBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayStartFemBalance&quot;) ?? 0);&#xD;&#xA;        decimal layFemMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayFemMort&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        // Get values for male calculation&#xD;&#xA;        decimal layStartMaleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayStartMaleBalance&quot;) ?? 0);&#xD;&#xA;        decimal layMaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayMaleMort&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        // Calculate {@LayingFemMortPre} - Female mortality percentage&#xD;&#xA;        if (layStartFemBalance != 0)&#xD;&#xA;        {&#xD;&#xA;            layingFemMortPre = (layFemMort * 100) / layStartFemBalance;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            layingFemMortPre = 0;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // Calculate {@LayingmaleMortPre} - Male mortality percentage&#xD;&#xA;        if (layStartMaleBalance != 0)&#xD;&#xA;        {&#xD;&#xA;            layingMaleMortPre = (layMaleMort * 100) / layStartMaleBalance;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            layingMaleMortPre = 0;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // Calculate total (sum of both percentages)&#xD;&#xA;        totalMortalityPercentage = layingFemMortPre + layingMaleMortPre;&#xD;&#xA;        &#xD;&#xA;        cell.Text = totalMortalityPercentage.ToString(&quot;N2&quot;) ;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell119_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;             XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;        decimal totalLayingFemExcluded = 0;&#xD;&#xA;        decimal totalLayingMaleExcluded = 0;&#xD;&#xA;        decimal layingPeriodFemExcludedPer = 0;&#xD;&#xA;        decimal layingPeriodMaleExcludedPer = 0;&#xD;&#xA;        decimal totalExcludedPercentage = 0;&#xD;&#xA;                // Get values for female calculations&#xD;&#xA;        decimal layStartFemBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayStartFemBalance&quot;) ?? 0);&#xD;&#xA;        decimal layFemMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayFemMort&quot;) ?? 0);&#xD;&#xA;        decimal layFemCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayFemCulls&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        // Get values for male calculations&#xD;&#xA;        decimal layStartMaleBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayStartMaleBalance&quot;) ?? 0);&#xD;&#xA;        decimal layMaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayMaleMort&quot;) ?? 0);&#xD;&#xA;        decimal layMaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayMaleCulls&quot;) ?? 0);&#xD;&#xA;        decimal layMaleSpiking = Convert.ToDecimal(GetCurrentColumnValue(&quot;LayMaleSpiking&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        // Calculate {@TotalLayingFemExcluded}&#xD;&#xA;        totalLayingFemExcluded = layFemMort + layFemCulls;&#xD;&#xA;        &#xD;&#xA;        // Calculate {@TotalLayingMaleExcluded}&#xD;&#xA;        totalLayingMaleExcluded = layMaleMort + layMaleCulls + layMaleSpiking;&#xD;&#xA;        &#xD;&#xA;        // Calculate {@LayingPeriodFemExcludedPer}&#xD;&#xA;        if (layStartFemBalance != 0)&#xD;&#xA;        {&#xD;&#xA;            layingPeriodFemExcludedPer = (totalLayingFemExcluded * 100) / layStartFemBalance;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            layingPeriodFemExcludedPer = 0;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // Calculate {@LayingPeriodMaleExcludedPer}&#xD;&#xA;        if (layStartMaleBalance != 0)&#xD;&#xA;        {&#xD;&#xA;            layingPeriodMaleExcludedPer = (totalLayingMaleExcluded * 100) / layStartMaleBalance;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            layingPeriodMaleExcludedPer = 0;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // Calculate total (sum of both percentages)&#xD;&#xA;        totalExcludedPercentage = layingPeriodFemExcludedPer + layingPeriodMaleExcludedPer;&#xD;&#xA;        cell.Text = totalExcludedPercentage.ToString(&quot;N2&quot;) ;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell29_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get FemalePOL and TotalEggs values&#xD;&#xA;    decimal femalePOL = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemalePOL&quot;) ?? 0);&#xD;&#xA;    decimal totalEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalEggs&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (femalePOL != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate eggs per female at POL&#xD;&#xA;        decimal result = totalEggs / femalePOL;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell35_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get TotalEggs and HatEggs values&#xD;&#xA;    decimal totalEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalEggs&quot;) ?? 0);&#xD;&#xA;    decimal hatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatEggs&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (totalEggs != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate hatching eggs percentage&#xD;&#xA;        decimal result = (hatEggs * 100) / totalEggs;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell60_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get FemalePOL and HatEggs values&#xD;&#xA;    decimal femalePOL = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemalePOL&quot;) ?? 0);&#xD;&#xA;    decimal hatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatEggs&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (femalePOL != 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate hatching eggs per female at POL&#xD;&#xA;        decimal result = hatEggs / femalePOL;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" PageWidthF="1169.29138" PageHeightF="1653.54333" Version="26.1" DataMember="SR_BRD_FinishedFlkData" DataSource="