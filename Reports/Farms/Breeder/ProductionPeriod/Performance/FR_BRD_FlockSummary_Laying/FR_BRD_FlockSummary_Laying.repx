<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="FR_BRD_FlockSummary_Laying" ScriptsSource="&#xD;&#xA;private void xrTableCell48_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    decimal fLive_20 = Convert.ToDecimal(GetCurrentColumnValue(&quot;FLive_20&quot;) ?? 0);&#xD;&#xA;    decimal femaleQtyKg = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleQtyKg&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (fLive_20 &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = femaleQtyKg / fLive_20;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) + &quot; ♀&quot;;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00 ♀&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell50_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    decimal mLive_20 = Convert.ToDecimal(GetCurrentColumnValue(&quot;MLive_20&quot;) ?? 0);&#xD;&#xA;    decimal maleQtyKg = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleQtyKg&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (mLive_20 &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = maleQtyKg / mLive_20;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) + &quot; ♂&quot;;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00 ♂&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell1_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get MLive_20 (male live at 20 weeks)&#xD;&#xA;    decimal mLive_20 = Convert.ToDecimal(GetCurrentColumnValue(&quot;MLive_20&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Get FMTotal components (Female Mort + Female Culls)&#xD;&#xA;    decimal femaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Mort&quot;) ?? 0);&#xD;&#xA;    decimal femaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Culls&quot;) ?? 0);&#xD;&#xA;    decimal fmTotal = femaleMort + femaleCulls;&#xD;&#xA;    &#xD;&#xA;    // Get FLive_20 (female live at 20 weeks)&#xD;&#xA;    decimal fLive_20 = Convert.ToDecimal(GetCurrentColumnValue(&quot;FLive_20&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate if condition met&#xD;&#xA;    if (mLive_20 &gt; 0 &amp;&amp; fLive_20 &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (fmTotal / fLive_20) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) + &quot; %&quot;;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00 %&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell2_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get MLive_20 (male live at 20 weeks)&#xD;&#xA;    decimal mLive_20 = Convert.ToDecimal(GetCurrentColumnValue(&quot;MLive_20&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Get MMTotal components (Male Mort + Male Culls)&#xD;&#xA;    decimal maleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_Mort&quot;) ?? 0);&#xD;&#xA;    decimal maleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_Culls&quot;) ?? 0);&#xD;&#xA;    decimal mmTotal = maleMort + maleCulls;&#xD;&#xA;    &#xD;&#xA;    // Calculate if condition met&#xD;&#xA;    if (mLive_20 &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (mmTotal / mLive_20) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) + &quot; %&quot;;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00 %&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell3_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    decimal fLive_POL = Convert.ToDecimal(GetCurrentColumnValue(&quot;FLive_POL&quot;) ?? 0);&#xD;&#xA;    decimal totalEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalEggs&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (fLive_POL &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = totalEggs / fLive_POL;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell64_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    decimal fLive_POL = Convert.ToDecimal(GetCurrentColumnValue(&quot;FLive_POL&quot;) ?? 0);&#xD;&#xA;    decimal hatchingEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchingEggs&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (fLive_POL &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = hatchingEggs / fLive_POL;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell69_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    decimal fLive_POL = Convert.ToDecimal(GetCurrentColumnValue(&quot;FLive_POL&quot;) ?? 0);&#xD;&#xA;    decimal rejectedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejectedEggs&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (fLive_POL &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = rejectedEggs / fLive_POL;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell13_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get TotalEggs&#xD;&#xA;    decimal totalEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalEggs&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Get TotalFeed components (FemaleQtyKg + MaleQtyKg)&#xD;&#xA;    decimal femaleQtyKg = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleQtyKg&quot;) ?? 0);&#xD;&#xA;    decimal maleQtyKg = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleQtyKg&quot;) ?? 0);&#xD;&#xA;    decimal totalFeed = femaleQtyKg + maleQtyKg;&#xD;&#xA;    &#xD;&#xA;    if (totalEggs &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate feed per 1000 eggs&#xD;&#xA;        decimal result = (totalFeed / totalEggs) * 1000;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrLabel6_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRLabel label = sender as XRLabel;&#xD;&#xA;    &#xD;&#xA;// Get HatchingEggs&#xD;&#xA;decimal hatchingEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchingEggs&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Get TotalFeed components (FemaleQtyKg + MaleQtyKg)&#xD;&#xA;decimal femaleQtyKg = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleQtyKg&quot;) ?? 0);&#xD;&#xA;decimal maleQtyKg = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleQtyKg&quot;) ?? 0);&#xD;&#xA;decimal totalFeed = femaleQtyKg + maleQtyKg;&#xD;&#xA;&#xD;&#xA;if (hatchingEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate feed per 1000 hatching eggs&#xD;&#xA;    decimal result = (totalFeed / hatchingEggs) * 1000;&#xD;&#xA;    label.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    label.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrLabel8_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRLabel label = sender as XRLabel;&#xD;&#xA;    &#xD;&#xA;    // Get FloorArea&#xD;&#xA;    decimal floorArea = Convert.ToDecimal(GetCurrentColumnValue(&quot;FloorArea&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Get live birds at 20 weeks (FLive_20 + MLive_20)&#xD;&#xA;    decimal fLive_20 = Convert.ToDecimal(GetCurrentColumnValue(&quot;FLive_20&quot;) ?? 0);&#xD;&#xA;    decimal mLive_20 = Convert.ToDecimal(GetCurrentColumnValue(&quot;MLive_20&quot;) ?? 0);&#xD;&#xA;    decimal totalLive = fLive_20 + mLive_20;&#xD;&#xA;    &#xD;&#xA;    if (floorArea &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate birds per square meter&#xD;&#xA;        decimal result = totalLive / floorArea;&#xD;&#xA;        label.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        label.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrLabel11_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRLabel label = sender as XRLabel;&#xD;&#xA;    &#xD;&#xA;// Get FLive_20 (female live at 20 weeks)&#xD;&#xA;decimal fLive_20 = Convert.ToDecimal(GetCurrentColumnValue(&quot;FLive_20&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Get FFedSpace (female feeder space)&#xD;&#xA;decimal fFedSpace = Convert.ToDecimal(GetCurrentColumnValue(&quot;FFedSpace&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (fLive_20 &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate feeder space per female bird&#xD;&#xA;    decimal result = fFedSpace / fLive_20;&#xD;&#xA;    label.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    label.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell35_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get WaterSpace&#xD;&#xA;    decimal waterSpace = Convert.ToDecimal(GetCurrentColumnValue(&quot;WaterSpace&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Get live birds at 20 weeks (FLive_20 + MLive_20)&#xD;&#xA;    decimal fLive_20 = Convert.ToDecimal(GetCurrentColumnValue(&quot;FLive_20&quot;) ?? 0);&#xD;&#xA;    decimal mLive_20 = Convert.ToDecimal(GetCurrentColumnValue(&quot;MLive_20&quot;) ?? 0);&#xD;&#xA;    decimal totalLive = fLive_20 + mLive_20;&#xD;&#xA;    &#xD;&#xA;    if (waterSpace &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate birds per water space unit&#xD;&#xA;        decimal result = totalLive / waterSpace;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell75_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get SettingEggs&#xD;&#xA;    decimal settingEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettingEggs&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Get total chicks (DeadChicks + Culls + Broiler)&#xD;&#xA;    decimal deadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;) ?? 0);&#xD;&#xA;    decimal culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;) ?? 0);&#xD;&#xA;    decimal broiler = Convert.ToDecimal(GetCurrentColumnValue(&quot;Broiler&quot;) ?? 0);&#xD;&#xA;    decimal totalChicks = deadChicks + culls + broiler;&#xD;&#xA;    &#xD;&#xA;    if (settingEggs &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate hatchability percentage&#xD;&#xA;        decimal result = (totalChicks / settingEggs) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell80_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get FLive_POL (female live at peak production)&#xD;&#xA;    decimal fLive_POL = Convert.ToDecimal(GetCurrentColumnValue(&quot;FLive_POL&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Get total chicks (DeadChicks + Culls + Broiler)&#xD;&#xA;    decimal deadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;) ?? 0);&#xD;&#xA;    decimal culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;) ?? 0);&#xD;&#xA;    decimal broiler = Convert.ToDecimal(GetCurrentColumnValue(&quot;Broiler&quot;) ?? 0);&#xD;&#xA;    decimal totalChicks = deadChicks + culls + broiler;&#xD;&#xA;    &#xD;&#xA;    if (fLive_POL &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        // Calculate chicks per hen at POL&#xD;&#xA;        decimal result = totalChicks / fLive_POL;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" PageWidthF="1169.29138" PageHeightF="1653.54333" Version="25.2" DataMember="SR_BRD_FlockSummary_Laying" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
