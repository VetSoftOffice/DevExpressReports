                  <Item16 Ref="286" Visible="false" Name="LineType" />
                  <Item17 Ref="287" Visible="false" Name="FarmCode" />
                  <Item18 Ref="288" Visible="false" Name="CropNo" />
                  <Item19 Ref="289" Visible="false" Name="Breed" />
                  <Item20 Ref="290" Visible="false" Name="Sitee" />
                  <Item21 Ref="291" Visible="false" Name="FarmNo" />
                  <Item22 Ref="292" Visible="false" Name="Flock" />
                  <Item23 Ref="293" Visible="false" Name="AgeWeekNo" />
                  <Item24 Ref="294" Visible="false" Name="AgeProdWeekNo" />
                </Parameters>
                <CalculatedFields>
                  <Item1 Ref="295" Name="Result" Expression="Iif(IsNullOrEmpty([Sentdate]), 'F' , 'T' )" DataMember="SR_BRD_SampleSent" />
                  <Item2 Ref="296" Name="Age" Expression="ToStr([DayFrom]) + ' - ' + ToStr([DayTo])" DataMember="SR_PH_BRD_Vaccination" />
                  <Item3 Ref="297" Name="FromTo" Expression="[StartDate].ToString('d') + ' - ' + [EndDate].ToString('d')" DataMember="SR_PH_BRD_Vaccination" />
                  <Item4 Ref="298" Name="OpenF" Expression="Iif(IsNullOrEmpty([OpenFHTEggsF]), 0, [OpenFHTEggsF])&#xA;+&#xA;Iif(IsNullOrEmpty([OpenHTEggsF]), 0, [OpenHTEggsF])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item5 Ref="299" Name="Production" Expression="Iif(IsNullOrEmpty([ProdFHTEggsF]), 0, [ProdFHTEggsF]) +&#xA;Iif(IsNullOrEmpty([ProdHTEggsF]), 0, [ProdHTEggsF])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item6 Ref="300" Name="SendToHatF" Expression="Iif(IsNullOrEmpty([HatcheryFHTEggsF]), 0, [HatcheryFHTEggsF]) +&#xA;Iif(IsNullOrEmpty([HatcheryHTEggsF]), 0, [HatcheryHTEggsF])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item7 Ref="301" Name="SendToCEGS" Expression="Iif(IsNullOrEmpty([CEGSFHTEggsF]), 0, [CEGSFHTEggsF]) +&#xA;Iif(IsNullOrEmpty([CEGSHTEggsF]), 0, [CEGSHTEggsF])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item8 Ref="302" Name="CloseF" Expression="Iif(IsNullOrEmpty([CloseFHTEggsF]), 0, [CloseFHTEggsF]) +&#xA;Iif(IsNullOrEmpty([CloseHTEggsF]), 0, [CloseHTEggsF])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item9 Ref="303" Name="OpenC" Expression="Iif(IsNullOrEmpty([OpenFHTEggsC]), 0, [OpenFHTEggsC]) +&#xA;Iif(IsNullOrEmpty([OpenHTEggsC]), 0, [OpenHTEggsC])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item10 Ref="304" Name="Receive" Expression="Iif(IsNullOrEmpty([RecFHTEggsC]), 0, [RecFHTEggsC]) +&#xA;Iif(IsNullOrEmpty([RecHTEggsC]), 0, [RecHTEggsC])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item11 Ref="305" Name="SendToHatC" Expression="Iif(IsNullOrEmpty([HatcheryFHTEggsC]), 0, [HatcheryFHTEggsC]) +&#xA;Iif(IsNullOrEmpty([HatcheryHTEggsC]), 0, [HatcheryHTEggsC])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item12 Ref="306" Name="Close" Expression="Iif(IsNullOrEmpty([CloseFHTEggsC]), 0, [CloseFHTEggsC]) +&#xA;Iif(IsNullOrEmpty([CloseHTEggsC]), 0, [CloseHTEggsC])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item13 Ref="307" Name="TotalEggss" Expression="Iif(IsNullOrEmpty([CloseFHTEggsC]), 0, [CloseFHTEggsC]) +&#xD;&#xA;Iif(IsNullOrEmpty([CloseFHTEggsF]), 0, [CloseFHTEggsF]) +&#xD;&#xA;Iif(IsNullOrEmpty([CloseHTEggsC]), 0, [CloseHTEggsC]) +&#xD;&#xA;Iif(IsNullOrEmpty([CloseHTEggsF]), 0, [CloseHTEggsF])&#xD;&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item14 Ref="308" Name="SameDate" Expression="Iif(?DateFrom == ?DateTo, 1, 0)&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item15 Ref="309" Name="EGGS" Expression="IIF([POL] &gt; 0, ([FloorEggs] + [NestedEggs]) / [POL], 0)" DataMember="SR_BRD_BreedPerf" />
                  <Item16 Ref="310" Name="HE" Expression="IIF([POL] &gt; 0, ([HatchingEggs] + [HatchingFloorG_A] + [HatchingFloorG_B]) / [POL], 0)" DataMember="SR_BRD_BreedPerf" />
                  <Item17 Ref="311" Name="AVGHATCH" Expression="IIF([SettingEggs] &gt; 0, (([DeadChicks] + [Culls] + [Chicks]) / [SettingEggs]) * 100, 0)" DataMember="SR_BRD_BreedPerf" />
                  <Item18 Ref="312" Name="CHICKS" Expression="IIF([POL] &gt; 0, ([DeadChicks] + [Culls] + [Chicks]) / [POL], 0)" DataMember="SR_BRD_BreedPerf" />
                  <Item19 Ref="313" Name="CUMMORT" Expression="IIF([Female_Started] &gt; 0, (([Female_Mort] + [Female_CK] + [Female_CS]) / [Female_Started]) * 100, 0)" DataMember="SR_BRD_BreedPerf" />
                </CalculatedFields>
