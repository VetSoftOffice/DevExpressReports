                  <Item12 Ref="676" Name="Close" Expression="Iif(IsNullOrEmpty([CloseFHTEggsC]), 0, [CloseFHTEggsC]) +&#xA;Iif(IsNullOrEmpty([CloseHTEggsC]), 0, [CloseHTEggsC])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item13 Ref="677" Name="TotalEggss" Expression="Iif(IsNullOrEmpty([CloseFHTEggsC]), 0, [CloseFHTEggsC]) +&#xD;&#xA;Iif(IsNullOrEmpty([CloseFHTEggsF]), 0, [CloseFHTEggsF]) +&#xD;&#xA;Iif(IsNullOrEmpty([CloseHTEggsC]), 0, [CloseHTEggsC]) +&#xD;&#xA;Iif(IsNullOrEmpty([CloseHTEggsF]), 0, [CloseHTEggsF])&#xD;&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item14 Ref="678" Name="SameDate" Expression="Iif(?DateFrom == ?DateTo, 1, 0)&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item15 Ref="679" Name="EGGS" Expression="IIF([POL] &gt; 0, ([FloorEggs] + [NestedEggs]) / [POL], 0)" DataMember="SR_BRD_BreedPerf" />
                  <Item16 Ref="680" Name="HE" Expression="IIF([POL] &gt; 0, ([HatchingEggs] + [HatchingFloorG_A] + [HatchingFloorG_B]) / [POL], 0)" DataMember="SR_BRD_BreedPerf" />
                  <Item17 Ref="681" Name="AVGHATCH" Expression="IIF([SettingEggs] &gt; 0, (([DeadChicks] + [Culls] + [Chicks]) / [SettingEggs]) * 100, 0)" DataMember="SR_BRD_BreedPerf" />
                  <Item18 Ref="682" Name="CHICKS" Expression="IIF([POL] &gt; 0, ([DeadChicks] + [Culls] + [Chicks]) / [POL], 0)" DataMember="SR_BRD_BreedPerf" />
                  <Item19 Ref="683" Name="CUMMORT" Expression="IIF([Female_Started] &gt; 0, (([Female_Mort] + [Female_CK] + [Female_CS]) / [Female_Started]) * 100, 0)" DataMember="SR_BRD_BreedPerf" />
                </CalculatedFields>
