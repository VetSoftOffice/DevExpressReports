            <Item1 Ref="268" ControlType="XRSubreport" Name="BreedPerf1">
              <ReportSource Ref="270" ControlType="DevExpressReports.Reports.Farms.Breeder.ProductionPeriod.Performance.BreedPerf1.BreedPerf1, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource=" decimal totalRatio = 0;&#xD;&#xA; int validRowCount = 0;&#xD;&#xA;// Variables for second ratio&#xD;&#xA;decimal totalRatio2 = 0;&#xD;&#xA;int validRowCount2 = 0;&#xD;&#xA;decimal totalRatio3 = 0;  &#xD;&#xA;int validRowCount3 = 0;&#xD;&#xA;decimal totalRatio4 = 0;  // ((DeadChicks + Culls + Chicks) / SettingEggs) * 100&#xD;&#xA;int validRowCount4 = 0;&#xD;&#xA;decimal totalRatio5 = 0;  // (DeadChicks + Culls + Chicks) / POL&#xD;&#xA;int validRowCount5 = 0;&#xD;&#xA;int recordCount = 0;&#xD;&#xA;decimal sumOfAverages = 0;&#xD;&#xA;private void xrTableCell44_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get current row values&#xD;&#xA;decimal pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;));&#xD;&#xA;decimal countFlock = Convert.ToDecimal(GetCurrentColumnValue(&quot;CountFlock&quot;));&#xD;&#xA;&#xD;&#xA;if (countFlock &gt; 0)&#xD;&#xA;{&#xD;&#xA;    cell.Text = (pol / countFlock).ToString(&quot;0.##&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell15_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Read current row values safely&#xD;&#xA;decimal pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;));&#xD;&#xA;decimal floorEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;FloorEggs&quot;));&#xD;&#xA;decimal nestedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;NestedEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (pol &gt; 0)&#xD;&#xA;{&#xD;&#xA;    cell.Text = ((floorEggs + nestedEggs) / pol).ToString(&quot;0.##&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell18_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA; XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal femaleStarted = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Started&quot;) ?? 0);&#xD;&#xA;decimal femaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Mort&quot;) ?? 0);&#xD;&#xA;decimal femaleCK = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_CK&quot;) ?? 0);&#xD;&#xA;decimal femaleCS = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_CS&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (femaleStarted &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (Female_Mort + Female_CK + Female_CS) / Female_Started * 100&#xD;&#xA;    decimal totalRemovals = femaleMort + femaleCK + femaleCS;&#xD;&#xA;    decimal result = (totalRemovals / femaleStarted) * 100.0m;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell20_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Read values safely&#xD;&#xA;decimal femaleStarted = GetCurrentColumnValue(&quot;Female_Started&quot;) == null&#xD;&#xA;    ? 0&#xD;&#xA;    : Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Started&quot;));&#xD;&#xA;&#xD;&#xA;decimal femaleMort = GetCurrentColumnValue(&quot;Female_Mort&quot;) == null&#xD;&#xA;    ? 0&#xD;&#xA;    : Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Mort&quot;));&#xD;&#xA;&#xD;&#xA;decimal femaleCK = GetCurrentColumnValue(&quot;Female_CK&quot;) == null&#xD;&#xA;    ? 0&#xD;&#xA;    : Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_CK&quot;));&#xD;&#xA;&#xD;&#xA;decimal femaleCS = GetCurrentColumnValue(&quot;Female_CS&quot;) == null&#xD;&#xA;    ? 0&#xD;&#xA;    : Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_CS&quot;));&#xD;&#xA;&#xD;&#xA;if (femaleStarted &gt; 0)&#xD;&#xA;{&#xD;&#xA;    cell.Text = (((femaleMort + femaleCK + femaleCS) / femaleStarted) * 100)&#xD;&#xA;        .ToString(&quot;0.##&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Read values safely&#xD;&#xA;decimal settingEggs = GetCurrentColumnValue(&quot;SettingEggs&quot;) == null&#xD;&#xA;    ? 0&#xD;&#xA;    : Convert.ToDecimal(GetCurrentColumnValue(&quot;SettingEggs&quot;));&#xD;&#xA;&#xD;&#xA;decimal deadChicks = GetCurrentColumnValue(&quot;DeadChicks&quot;) == null&#xD;&#xA;    ? 0&#xD;&#xA;    : Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;&#xD;&#xA;decimal culls = GetCurrentColumnValue(&quot;Culls&quot;) == null&#xD;&#xA;    ? 0&#xD;&#xA;    : Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;&#xD;&#xA;decimal chicks = GetCurrentColumnValue(&quot;Chicks&quot;) == null&#xD;&#xA;    ? 0&#xD;&#xA;    : Convert.ToDecimal(GetCurrentColumnValue(&quot;Chicks&quot;));&#xD;&#xA;&#xD;&#xA;if (settingEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    cell.Text = (((deadChicks + culls + chicks) / settingEggs) * 100)&#xD;&#xA;        .ToString(&quot;0.##&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell24_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Read values safely&#xD;&#xA;decimal pol = GetCurrentColumnValue(&quot;POL&quot;) == null&#xD;&#xA;    ? 0&#xD;&#xA;    : Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;));&#xD;&#xA;&#xD;&#xA;decimal deadChicks = GetCurrentColumnValue(&quot;DeadChicks&quot;) == null&#xD;&#xA;    ? 0&#xD;&#xA;    : Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;&#xD;&#xA;decimal culls = GetCurrentColumnValue(&quot;Culls&quot;) == null&#xD;&#xA;    ? 0&#xD;&#xA;    : Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;&#xD;&#xA;decimal chicks = GetCurrentColumnValue(&quot;Chicks&quot;) == null&#xD;&#xA;    ? 0&#xD;&#xA;    : Convert.ToDecimal(GetCurrentColumnValue(&quot;Chicks&quot;));&#xD;&#xA;&#xD;&#xA;if (pol &gt; 0)&#xD;&#xA;{&#xD;&#xA;    cell.Text = ((deadChicks + culls + chicks) / pol)&#xD;&#xA;        .ToString(&quot;0.##&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell35_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (validRowCount &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal avgRatio = totalRatio / validRowCount;&#xD;&#xA;            cell.Text = avgRatio.ToString(&quot;N2&quot;); // 3 decimal places&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;   }&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     decimal pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;) ?? 0);&#xD;&#xA;        decimal floorEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;FloorEggs&quot;) ?? 0);&#xD;&#xA;        decimal nestedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;NestedEggs&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        if (pol &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal ratio = (floorEggs + nestedEggs) / pol;&#xD;&#xA;            totalRatio += ratio;&#xD;&#xA;            validRowCount++;&#xD;&#xA;        }&#xD;&#xA;    // Calculate Ratio 2: (HatchingEggs + HatchingFloorG_A + HatchingFloorG_B) / POL&#xD;&#xA;        if (pol &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal hatchingEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchingEggs&quot;) ?? 0);&#xD;&#xA;            decimal hatchingFloorG_A = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchingFloorG_A&quot;) ?? 0);&#xD;&#xA;            decimal hatchingFloorG_B = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchingFloorG_B&quot;) ?? 0);&#xD;&#xA;            &#xD;&#xA;            decimal ratio2 = (hatchingEggs + hatchingFloorG_A + hatchingFloorG_B) / pol;&#xD;&#xA;            totalRatio2 += ratio2;&#xD;&#xA;            validRowCount2++;&#xD;&#xA;        }&#xD;&#xA;         // --- Ratio 3: ((Female_Mort + Female_CK + Female_CS) / Female_Started) * 100 ---&#xD;&#xA;        if (femaleStarted &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal femaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Mort&quot;) ?? 0);&#xD;&#xA;            decimal femaleCK = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_CK&quot;) ?? 0);&#xD;&#xA;            decimal femaleCS = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_CS&quot;) ?? 0);&#xD;&#xA;            &#xD;&#xA;            decimal ratio3 = ((femaleMort + femaleCK + femaleCS) / femaleStarted) * 100;&#xD;&#xA;            totalRatio3 += ratio3;&#xD;&#xA;            validRowCount3++;&#xD;&#xA;        }&#xD;&#xA;        // --- Ratio 4: ((DeadChicks + Culls + Chicks) / SettingEggs) * 100 ---&#xD;&#xA;        if (settingEggs &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal deadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;) ?? 0);&#xD;&#xA;            decimal culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;) ?? 0);&#xD;&#xA;            decimal chicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;Chicks&quot;) ?? 0);&#xD;&#xA;            &#xD;&#xA;            decimal ratio4 = ((deadChicks + culls + chicks) / settingEggs) * 100;&#xD;&#xA;            totalRatio4 += ratio4;&#xD;&#xA;            validRowCount4++;&#xD;&#xA;        }&#xD;&#xA;        // --- Ratio 5: (DeadChicks + Culls + Chicks) / POL ---&#xD;&#xA;        if (pol &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal deadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;) ?? 0);&#xD;&#xA;            decimal culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;) ?? 0);&#xD;&#xA;            decimal chicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;Chicks&quot;) ?? 0);&#xD;&#xA;            &#xD;&#xA;            decimal ratio5 = (deadChicks + culls + chicks) / pol;&#xD;&#xA;            totalRatio5 += ratio5;&#xD;&#xA;            validRowCount5++;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell38_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (validRowCount3 &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal avgRatio = totalRatio3 / validRowCount3;&#xD;&#xA;            cell.Text = avgRatio.ToString(&quot;N2&quot;); // Adjust decimal places as needed&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell40_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        if (validRowCount3 &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal avgMortalityPercent = totalRatio3 / validRowCount3;&#xD;&#xA;            cell.Text = avgMortalityPercent.ToString(&quot;N2&quot;) ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&