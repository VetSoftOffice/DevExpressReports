late mortality percentage for this row&#xD;&#xA;    if (openFemale &gt; 0) {&#xD;&#xA;        decimal rowMortPercent = (totalFemaleMort * 100) / openFemale;&#xD;&#xA;        sumFemaleMortPercent += rowMortPercent;&#xD;&#xA;        countFemaleMortPercent++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;     // Get values for current row&#xD;&#xA;    decimal openMale = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenMale&quot;) ?? 0);&#xD;&#xA;    decimal totalMaleDepl = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalMaleDepl&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate deployment percentage for this row&#xD;&#xA;    if (openMale &gt; 0) {&#xD;&#xA;        decimal rowDeplPercent = (totalMaleDepl * 100) / openMale;&#xD;&#xA;        sumMaleDeplPercent += rowDeplPercent;&#xD;&#xA;        countMaleDeplPercent++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;      // Get values for current row&#xD;&#xA;    decimal openFemaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenFemale&quot;) ?? 0);&#xD;&#xA;    decimal totalFemaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalFemaleCulls&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate culls percentage for this row&#xD;&#xA;    if (openFemale &gt; 0) {&#xD;&#xA;        decimal rowCullsPercent = (totalFemaleCulls * 100) / openFemaleCulls ;&#xD;&#xA;        sumFemaleCullsPercent += rowCullsPercent;&#xD;&#xA;        countFemaleCullsPercent++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Get values for current row&#xD;&#xA;    decimal openMaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenMale&quot;) ?? 0);&#xD;&#xA;    decimal totalMaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalMaleCulls&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate culls percentage for this row&#xD;&#xA;    if (openMale &gt; 0) {&#xD;&#xA;        decimal rowCullsPercent = (totalMaleCulls * 100) / openMaleCulls ;&#xD;&#xA;        sumMaleCullsPercent += rowCullsPercent;&#xD;&#xA;        countMaleCullsPercent++;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Get values for current row&#xD;&#xA;    decimal openFemaleHat = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenFemale&quot;) ?? 0);&#xD;&#xA;    decimal totalHatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalHatEggs&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate eggs per female for this row&#xD;&#xA;    if (openFemale &gt; 0) {&#xD;&#xA;        decimal rowEggsPerFemale = totalHatEggs / openFemaleHat ;&#xD;&#xA;        sumEggsPerFemale += rowEggsPerFemale;&#xD;&#xA;        countEggsPerFemale++;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell43_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (countFemaleMortPercent &gt; 0) {&#xD;&#xA;        decimal avgMortPercent = sumFemaleMortPercent / countFemaleMortPercent;&#xD;&#xA;        cell.Text = avgMortPercent.ToString(&quot;N2&quot;);&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell20_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get values from fields&#xD;&#xA;    decimal openMale = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenMale&quot;) ?? 0);&#xD;&#xA;    decimal totalMaleDepl = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalMaleDepl&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate: (TotalMaleDepl × 100) / OpenMale&#xD;&#xA;    if (openMale &gt; 0) {&#xD;&#xA;        decimal result = (totalMaleDepl * 100) / openMale;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // 2 decimal places with %&#xD;&#xA;        // Or without %: result.ToString(&quot;F2&quot;)&#xD;&#xA;        // Or whole number: result.ToString(&quot;N0&quot;) + &quot;%&quot;&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0