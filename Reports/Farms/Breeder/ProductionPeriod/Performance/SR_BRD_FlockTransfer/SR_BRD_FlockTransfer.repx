<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="26.1.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_BRD_FlockTransfer" ScriptsSource="decimal sumFemaleTransfer = 0;&#xD;&#xA;decimal sumFemaleMort = 0;&#xD;&#xA;decimal sumFemaleCulls = 0;&#xD;&#xA;decimal sumFemaleError = 0;&#xD;&#xA;decimal sumMaleMort = 0;&#xD;&#xA;decimal sumMaleSelection = 0;&#xD;&#xA;decimal sumMaleCulls = 0;&#xD;&#xA;decimal sumMaleError = 0;&#xD;&#xA;decimal sumMaleTransfer = 0;&#xD;&#xA;decimal totalLayFemaleTransfer = 0;&#xD;&#xA;decimal totalLayMaleMort = 0;&#xD;&#xA;decimal totalLayMaleTransfer = 0;&#xD;&#xA;decimal totalLayFemaleMort = 0;&#xD;&#xA;decimal totalRearFemaleCulls = 0;&#xD;&#xA;decimal totalRearFemaleError = 0;&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Accumulate values&#xD;&#xA;    sumFemaleMort += Convert.ToDecimal(GetCurrentColumnValue(&quot;RearFemaleMort&quot;) ?? 0);&#xD;&#xA;    sumFemaleCulls += Convert.ToDecimal(GetCurrentColumnValue(&quot;RearFemaleCulls&quot;) ?? 0);&#xD;&#xA;    sumFemaleError += Convert.ToDecimal(GetCurrentColumnValue(&quot;RearFemaleError&quot;) ?? 0);&#xD;&#xA;    sumFemaleTransfer += Convert.ToDecimal(GetCurrentColumnValue(&quot;RearFemaleTransfer&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Accumulate male values&#xD;&#xA;    sumMaleMort += Convert.ToDecimal(GetCurrentColumnValue(&quot;RearMaleMort&quot;) ?? 0);&#xD;&#xA;    sumMaleSelection += Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleSelection&quot;) ?? 0);&#xD;&#xA;    sumMaleCulls += Convert.ToDecimal(GetCurrentColumnValue(&quot;RearMaleCulls&quot;) ?? 0);&#xD;&#xA;    sumMaleError += Convert.ToDecimal(GetCurrentColumnValue(&quot;RearMaleError&quot;) ?? 0);&#xD;&#xA;    sumMaleTransfer += Convert.ToDecimal(GetCurrentColumnValue(&quot;RearMaleTransfer&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Accumulate sums from each detail row&#xD;&#xA;    totalLayFemaleTransfer += Convert.ToDecimal(GetCurrentColumnValue(&quot;LayFemaleTransfer&quot;) ?? 0);&#xD;&#xA;    totalLayFemaleMort += Convert.ToDecimal(GetCurrentColumnValue(&quot;LayFemaleMort&quot;) ?? 0);&#xD;&#xA;    totalLayMaleMort += Convert.ToDecimal(GetCurrentColumnValue(&quot;LayMaleMort&quot;) ?? 0);&#xD;&#xA;    totalLayMaleTransfer += Convert.ToDecimal(GetCurrentColumnValue(&quot;LayMaleTransfer&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    totalRearFemaleCulls += Convert.ToDecimal(GetCurrentColumnValue(&quot;RearFemaleCulls&quot;) ?? 0);&#xD;&#xA;    totalRearFemaleError += Convert.ToDecimal(GetCurrentColumnValue(&quot;RearFemaleError&quot;) ?? 0);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell56_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get current FemaleTransBalance (should be total/group value)&#xD;&#xA;    decimal femaleTransBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleTransBalance&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate result&#xD;&#xA;    decimal totalDeductions = sumFemaleMort + sumFemaleCulls + sumFemaleError + sumFemaleTransfer;&#xD;&#xA;    decimal result = femaleTransBalance - totalDeductions;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell57_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get current MaleTransBalance (should be total/group value)&#xD;&#xA;    decimal maleTransBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleTransBalance&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate result&#xD;&#xA;    decimal totalDeductions = sumMaleMort + sumMaleSelection + sumMaleCulls + sumMaleError + sumMaleTransfer;&#xD;&#xA;    decimal result = maleTransBalance - totalDeductions;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell58_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Apply equation to the SUMS: Σ(LayFemaleTransfer) - Σ(LayMaleMort)&#xD;&#xA;    decimal result = totalLayFemaleTransfer - totalLayMaleMort;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;); // Whole number format&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;private void xrTableCell60_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Apply equation to the SUMS: Σ(LayMaleTransfer) - Σ(LayMaleMort)&#xD;&#xA;    decimal result = totalLayMaleTransfer - totalLayMaleMort;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;); // Whole number format&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell62_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Calculate total: Σ(RearFemaleMort) + Σ(LayFemaleMort)&#xD;&#xA;    decimal totalFemaleMort = sumFemaleMort + totalLayFemaleMort;&#xD;&#xA;    &#xD;&#xA;    cell.Text = totalFemaleMort.ToString(&quot;N0&quot;); // Whole number format&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell63_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Display the total sum&#xD;&#xA;    cell.Text = totalRearFemaleCulls.ToString(&quot;N0&quot;); // Whole number format&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell64_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Display the total sum&#xD;&#xA;    cell.Text = totalRearFemaleError.ToString(&quot;N0&quot;); // Whole number format&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell65_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get FemaleTransBalance value&#xD;&#xA;    decimal femaleTransBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleTransBalance&quot;) ?? 0);&#xD;&#xA;     // Apply formula: FemaleTransBalance - (TotalErrorFemale + TotalFemaleCulls + TotalMortFemale)&#xD;&#xA;    decimal totalDeductions = sumFemaleError + sumFemaleCulls + sumFemaleMort ;&#xD;&#xA;    decimal result = femaleTransBalance - totalDeductions;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell66_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    decimal result = sumMaleMort + totalLayMaleMort;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell67_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;           XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    decimal result = sumMaleCulls ;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell68_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;               XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    decimal result = sumMaleError ;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell70_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    decimal MaleTransBalance = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleTransBalance&quot;) ?? 0);&#xD;&#xA;    decimal result = MaleTransBalance - (sumMaleCulls  + sumMaleError + sumMaleMort  + totalLayMaleMort ) ;&#xD;&#xA;    &#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;" Landscape="true" PageWidthF="1169.29138" PageHeightF="826.771667" Version="26.1" DataMember="SR_BRD_FlockTransfer" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
