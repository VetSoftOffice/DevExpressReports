        decimal femaleQtyKg = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleQtyKg&quot;) ?? 0);&#xD;&#xA;        totalFemaleQtyKg += femaleQtyKg;&#xD;&#xA;        decimal maleQtyKg = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleQtyKg&quot;) ?? 0);&#xD;&#xA;        totalMaleQtyKg += maleQtyKg;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell2_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        decimal females = Convert.ToDecimal(GetCurrentColumnValue(&quot;Females&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        if (females &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            // This uses the current row's females count with accumulated total feed&#xD;&#xA;            decimal feedPerFemale = totalFemaleQtyKg / females;&#xD;&#xA;            cell.Text = feedPerFemale.ToString(&quot;N2&quot;) + &quot;  Kgs&quot;;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell4_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        decimal males = Convert.ToDecimal(GetCurrentColumnValue(&quot;Males&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        if (males &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal feedPerMale = totalMaleQtyKg / males;&#xD;&#xA;            cell.Text = feedPerMale.ToString(&quot;N2&quot;) + &quot;  Kgs&quot;;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;" PageWidthF="826.771667" PageHeightF="1169.29138" Version="25.2" DataMember="SR_FR_FeedByCrop" DataSource="#Ref-847" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
