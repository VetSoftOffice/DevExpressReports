        <Item2 Ref="178" ControlType="SubBand" Name="SubBand6">
          <Controls>
            <Item1 Ref="179" ControlType="XRSubreport" Name="FR_BRD_FlockSummary_3">
              <ReportSource Ref="181" ControlType="DevExpressReports.Reports.Farms.Breeder.RearingPeriod.Performance.FR_BRD_FlockSummary_3.FR_BRD_FlockSummary_3, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="&#xD;&#xA;private void xrTableCell7_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    object fObj = GetCurrentColumnValue(&quot;FChickRecived&quot;);&#xD;&#xA;    object mObj = GetCurrentColumnValue(&quot;MChickRecived&quot;);&#xD;&#xA;&#xD;&#xA;    decimal f = 0;&#xD;&#xA;    decimal m = 0;&#xD;&#xA;&#xD;&#xA;    if (fObj != null &amp;&amp; fObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(fObj.ToString(), out f);&#xD;&#xA;&#xD;&#xA;    if (mObj != null &amp;&amp; mObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(mObj.ToString(), out m);&#xD;&#xA;&#xD;&#xA;    if (f &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (m / f) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) + &quot;%&quot;;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; &#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell12_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    object fChicksObj = GetCurrentColumnValue(&quot;FChickRecived&quot;);&#xD;&#xA;    object fDoaObj    = GetCurrentColumnValue(&quot;FDOA&quot;);&#xD;&#xA;&#xD;&#xA;    decimal fChicks = 0;&#xD;&#xA;    decimal fDoa = 0;&#xD;&#xA;&#xD;&#xA;    if (fChicksObj != null &amp;&amp; fChicksObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(fChicksObj.ToString(), out fChicks);&#xD;&#xA;&#xD;&#xA;    if (fDoaObj != null &amp;&amp; fDoaObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(fDoaObj.ToString(), out fDoa);&#xD;&#xA;&#xD;&#xA;    if (fChicks &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        d