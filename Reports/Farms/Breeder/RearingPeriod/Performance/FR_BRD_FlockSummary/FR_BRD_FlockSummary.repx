&#xD;&#xA;        cell.Text = percent.ToString(&quot;0.00&quot;) + &quot;%&quot;; // 2 decimals + %&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or &quot;&quot; if you prefer blank&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell55_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get current row values as decimals&#xD;&#xA;    decimal liveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveFemale&quot;));&#xD;&#xA;    decimal liveMale = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveMale&quot;));&#xD;&#xA;&#xD;&#xA;    // Calculate percentage safely&#xD;&#xA;    if (liveFemale &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percent = (liveMale / liveFemale) * 100;&#xD;&#xA;        cell.Text = percent.ToString(&quot;0.00&quot;) + &quot;%&quot;; // 2 decimals + %&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or &quot;&quot; if you prefer blank&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" PageWidthF="826.771667" PageHeightF="1169.29138" Version="25.2" DataMember="SR_BRD_FlockSummary" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
