            <Item1 Ref="297" ControlType="XRSubreport" Name="FR_BRD_FlockSummary_3">
              <ReportSource Ref="299" ControlType="DevExpressReports.Reports.Farms.Breeder.RearingPeriod.Performance.FR_BRD_FlockSummary_3.FR_BRD_FlockSummary_3, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="&#xD;&#xA;private void xrTableCell7_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    object fObj = GetCurrentColumnValue(&quot;FChickRecived&quot;);&#xD;&#xA;    object mObj = GetCurrentColumnValue(&quot;MChickRecived&quot;);&#xD;&#xA;&#xD;&#xA;    decimal f = 0;&#xD;&#xA;    decimal m = 0;&#xD;&#xA;&#xD;&#xA;    if (fObj != null &amp;&amp; fObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(fObj.ToString(), out f);&#xD;&#xA;&#xD;&#xA;    if (mObj != null &amp;&amp; mObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(mObj.ToString(), out m);&#xD;&#xA;&#xD;&#xA;    if (f &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (m / f) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) + &quot;%&quot;;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; &#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell12_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    object fChicksObj = GetCurrentColumnValue(&quot;FChickRecived&quot;);&#xD;&#xA;    object fDoaObj    = GetCurrentColumnValue(&quot;FDOA&quot;);&#xD;&#xA;&#xD;&#xA;    decimal fChicks = 0;&#xD;&#xA;    decimal fDoa = 0;&#xD;&#xA;&#xD;&#xA;    if (fChicksObj != null &amp;&amp; fChicksObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(fChicksObj.ToString(), out fChicks);&#xD;&#xA;&#xD;&#xA;    if (fDoaObj != null &amp;&amp; fDoaObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(fDoaObj.ToString(), out fDoa);&#xD;&#xA;&#xD;&#xA;    if (fChicks &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (fDoa / fChicks) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;)  + &quot;%&quot;; &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell13_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    object mChicksObj = GetCurrentColumnValue(&quot;MChickRecived&quot;);&#xD;&#xA;    object mDoaObj    = GetCurrentColumnValue(&quot;MDOA&quot;);&#xD;&#xA;&#xD;&#xA;    decimal mChicks = 0;&#xD;&#xA;    decimal mDoa = 0;&#xD;&#xA;&#xD;&#xA;    if (mChicksObj != null &amp;&amp; mChicksObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(mChicksObj.ToString(), out mChicks);&#xD;&#xA;&#xD;&#xA;    if (mDoaObj != null &amp;&amp; mDoaObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(mDoaObj.ToString(), out mDoa);&#xD;&#xA;&#xD;&#xA;    if (mChicks &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (mDoa / mChicks) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) + &quot;%&quot;; &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell20_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    object fChicksObj = GetCurrentColumnValue(&quot;FChickRecived&quot;);&#xD;&#xA;    object toVetObj   = GetCurrentColumnValue(&quot;FemaleToVetAndMinAgr&quot;);&#xD;&#xA;&#xD;&#xA;    decimal fChicks = 0;&#xD;&#xA;    decimal toVet = 0;&#xD;&#xA;&#xD;&#xA;    if (fChicksObj != null &amp;&amp; fChicksObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(fChicksObj.ToString(), out fChicks);&#xD;&#xA;&#xD;&#xA;    if (toVetObj != null &amp;&amp; toVetObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(toVetObj.ToString(), out toVet);&#xD;&#xA;&#xD;&#xA;    if (fChicks &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (toVet / fChicks) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) + &quot;%&quot;; &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    object mChicksObj = GetCurrentColumnValue(&quot;MChickRecived&quot;);&#xD;&#xA;    object toVetObj   = GetCurrentColumnValue(&quot;MaleToVetAndMinAgr&quot;);&#xD;&#xA;&#xD;&#xA;    decimal mChicks = 0;&#xD;&#xA;    decimal toVet = 0;&#xD;&#xA;&#xD;&#xA;    if (mChicksObj != null &amp;&amp; mChicksObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(mChicksObj.ToString(), out mChicks);&#xD;&#xA;&#xD;&#xA;    if (toVetObj != null &amp;&amp; toVetObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(toVetObj.ToString(), out toVet);&#xD;&#xA;&#xD;&#xA;    if (mChicks &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (toVet / mChicks) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) + &quot;%&quot;; &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell25_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get the current row values as decimals&#xD;&#xA;    decimal chicksReceived = Convert.ToDecimal(GetCurrentColumnValue(&quot;FChickRecived&quot;));&#xD;&#xA;    decimal femaleMortWeek = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Mort_Week&quot;));&#xD;&#xA;&#xD;&#xA;    // Calculate percentage safely&#xD;&#xA;    if (chicksReceived &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percent = (femaleMortWeek / chicksReceived) * 100;&#xD;&#xA;        cell.Text = percent.ToString(&quot;0.00&quot;) + &quot;%&quot;; // format with 2 decimals&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or use &quot;&quot; if you want it blank&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell27_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get the current row values as decimals&#xD;&#xA;    decimal chicksReceived = Convert.ToDecimal(GetCurrentColumnValue(&quot;MChickRecived&quot;));&#xD;&#xA;    decimal maleMortWeek = Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_Mort_Week&quot;));&#xD;&#xA;&#xD;&#xA;    // Calculate percentage safely&#xD;&#xA;    if (chicksReceived &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percent = (maleMortWeek / chicksReceived) * 100;&#xD;&#xA;        cell.Text = percent.ToString(&quot;N2&quot;) + &quot;%&quot;; // formatted with 2 decimals&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or &quot;&quot; if you want it blank&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell33_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get current row values as decimals&#xD;&#xA;    decimal chicksReceived = Convert.ToDecimal(GetCurrentColumnValue(&quot;FChickRecived&quot;));&#xD;&#xA;    decimal femaleSexError = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_SexError&quot;));&#xD;&#xA;&#xD;&#xA;    // Calculate percentage safely&#xD;&#xA;    if (chicksReceived &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percent = (femaleSexError / chicksReceived) * 100;&#xD;&#xA;        cell.Text = percent.ToString(&quot;0.00&quot;) + &quot;%&quot;; // format with 2 decimals&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or &quot;&quot; if you want it blank&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell35_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get current row values as decimals&#xD;&#xA;    decimal chicksReceived = Convert.ToDecimal(GetCurrentColumnValue(&quot;MChickRecived&quot;));&#xD;&#xA;    decimal maleSexError = Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_SexError&quot;));&#xD;&#xA;&#xD;&#xA;    // Calculate percentage safely&#xD;&#xA;    if (chicksReceived &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percent = (maleSexError / chicksReceived) * 100;&#xD;&#xA;        cell.Text = percent.ToString(&quot;0.00&quot;) + &quot;%&quot;; // format with 2 decimals&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or &quot;&quot; if you prefer blank&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell38_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get current row values as decimals&#xD;&#xA;    decimal chicksReceived = Convert.ToDecimal(GetCurrentColumnValue(&quot;FChickRecived&quot;));&#xD;&#xA;    decimal femaleSelling = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleSelling&quot;));&#xD;&#xA;&#xD;&#xA;    // Calculate percentage safely&#xD;&#xA;    if (chicksReceived &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percent = (femaleSelling / chicksReceived) * 100;&#xD;&#xA;        cell.Text = percent.ToString(&quot;0.00&quot;)+ &quot;%&quot;; // format with 2 decimals&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or &quot;&quot; if you prefer blank&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell40_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get current row values as decimals&#xD;&#xA;    decimal chicksReceived = Convert.ToDecimal(GetCurrentColumnValue(&quot;MChickRecived&quot;));&#xD;&#xA;    decimal maleSelling = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleSelling&quot;));&#xD;&#xA;&#xD;&#xA;    // Calculate percentage safely&#xD;&#xA;    if (chicksReceived &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percent = (maleSelling / chicksReceived) * 100;&#xD;&#xA;        cell.Text = percent.ToString(&quot;0.00&quot;) + &quot;%&quot;; // format with 2 decimals&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or &quot;&quot; if you prefer blank&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell43_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get current row values as decimals&#xD;&#xA;    decimal chicksReceived = Convert.ToDecimal(GetCurrentColumnValue(&quot;FChickRecived&quot;));&#xD;&#xA;    decimal totalFemaleSamples = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalFemaleSamples&quot;));&#xD;&#xA;&#xD;&#xA;    // Calculate percentage safely&#xD;&#xA;    if (chicksReceived &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percent = (totalFemaleSamples / chicksReceived) * 100;&#xD;&#xA;        cell.Text = percent.ToString(&quot;0.00&quot;) + &quot;%&quot;;     }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; &#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell45_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get current row values as decimals&#xD;&#xA;    decimal chicksReceived = Convert.ToDecimal(GetCurrentColumnValue(&quot;MChickRecived&quot;));&#xD;&#xA;    decimal totalMaleSamples = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalMaleSamples&quot;));&#xD;&#xA;&#xD;&#xA;    // Calculate percentage safely&#xD;&#xA;    if (chicksReceived &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percent = (totalMaleSamples / chicksReceived) * 100;&#xD;&#xA;        cell.Text = percent.ToString(&quot;0.00&quot;) + &quot;%&quot;; &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell48_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get current row values as decimals&#xD;&#xA;    decimal chicksReceived = Convert.ToDecimal(GetCurrentColumnValue(&quot;FChickRecived&quot;));&#xD;&#xA;    decimal femaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Mort&quot;));&#xD;&#xA;&#xD;&#xA;    // Calculate percentage safely&#xD;&#xA;    if (chicksReceived &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percent = (femaleMort / chicksReceived) * 100;&#xD;&#xA;        cell.Text = percent.ToString(&quot;0.00&quot;) + &quot;%&quot;; // add &quot;%&quot; and 2 decimals&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or &quot;&quot; if you prefer blank&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell50_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get current row values as decimals&#xD;&#xA;    decimal chicksReceived = Convert.ToDecimal(GetCurrentColumnValue(&quot;MChickRecived&quot;));&#xD;&#xA;    decimal maleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_Mort&quot;));&#xD;&#xA;&#xD;&#xA;    // Calculate percentage safely&#xD;&#xA;    if (chicksReceived &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percent = (maleMort / chicksReceived) * 100;&#xD;&#xA;        cell.Text = percent.ToString(&quot;0.00&quot;) + &quot;%&quot;; // 2 decimals + %&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or &quot;&quot; if you prefer blank&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell55_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get current row values as decimals&#xD;&#xA;    decimal liveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveFemale&quot;));&#xD;&#xA;    decimal liveMale = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveMale&quot;));&#xD;&#xA;&#xD;&#xA;    // Calculate percentage safely&#xD;&#xA;    if (liveFemale &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percent = (liveMale / liveFemale) * 100;&#xD;&#xA;        cell.Text = percent.ToString(&quot;0.00&quot;) + &quot;%&quot;; // 2 decimals + %&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or &quot;&quot; if you prefer blank&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" PageWidthF="826.771667" PageHeightF="1169.29138" Version="25.2" DataMember="SR_BRD_FlockSummary_2" DataSource="#Ref-298" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
