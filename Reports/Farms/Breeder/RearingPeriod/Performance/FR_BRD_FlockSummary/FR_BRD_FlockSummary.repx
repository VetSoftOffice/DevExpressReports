        <Item4 Ref="374" ControlType="SubBand" Name="SubBand9">
          <Controls>
            <Item1 Ref="375" ControlType="XRSubreport" Name="FR_BRD_FlockSummary_1">
              <ReportSource Ref="377" ControlType="DevExpressReports.Reports.Farms.Breeder.RearingPeriod.Performance.FR_BRD_FlockSummary_1.FR_BRD_FlockSummary_1, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="&#xD;&#xA;private void xrTableCell7_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    object fObj = GetCurrentColumnValue(&quot;FChickRecived&quot;);&#xD;&#xA;    object mObj = GetCurrentColumnValue(&quot;MChickRecived&quot;);&#xD;&#xA;&#xD;&#xA;    decimal f = 0;&#xD;&#xA;    decimal m = 0;&#xD;&#xA;&#xD;&#xA;    if (fObj != null &amp;&amp; fObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(fObj.ToString(), out f);&#xD;&#xA;&#xD;&#xA;    if (mObj != null &amp;&amp; mObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(mObj.ToString(), out m);&#xD;&#xA;&#xD;&#xA;    if (f &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (m / f) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) + &quot;%&quot;;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; &#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell12_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    object fChicksObj = GetCurrentColumnValue(&quot;FChickRecived&quot;);&#xD;&#xA;    object fDoaObj    = GetCurrentColumnValue(&quot;FDOA&quot;);&#xD;&#xA;&#xD;&#xA;    decimal fChicks = 0;&#xD;&#xA;    decimal fDoa = 0;&#xD;&#xA;&#xD;&#xA;    if (fChicksObj != null &amp;&amp; fChicksObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(fChicksObj.ToString(), out fChicks);&#xD;&#xA;&#xD;&#xA;    if (fDoaObj != null &amp;&amp; fDoaObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(fDoaObj.ToString(), out fDoa);&#xD;&#xA;&#xD;&#xA;    if (fChicks &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (fDoa / fChicks) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;)  + &quot;%&quot;; &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell13_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    object mChicksObj = GetCurrentColumnValue(&quot;MChickRecived&quot;);&#xD;&#xA;    object mDoaObj    = GetCurrentColumnValue(&quot;MDOA&quot;);&#xD;&#xA;&#xD;&#xA;    decimal mChicks = 0;&#xD;&#xA;    decimal mDoa = 0;&#xD;&#xA;&#xD;&#xA;    if (mChicksObj != null &amp;&amp; mChicksObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(mChicksObj.ToString(), out mChicks);&#xD;&#xA;&#xD;&#xA;    if (mDoaObj != null &amp;&amp; mDoaObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(mDoaObj.ToString(), out mDoa);&#xD;&#xA;&#xD;&#xA;    if (mChicks &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (mDoa / mChicks) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) + &quot;%&quot;; &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell20_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    object fChicksObj = GetCurrentColumnValue(&quot;FChickRecived&quot;);&#xD;&#xA;    object toVetObj   = GetCurrentColumnValue(&quot;FemaleToVetAndMinAgr&quot;);&#xD;&#xA;&#xD;&#xA;    decimal fChicks = 0;&#xD;&#xA;    decimal toVet = 0;&#xD;&#xA;&#xD;&#xA;    if (fChicksObj != null &amp;&amp; fChicksObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(fChicksObj.ToString(), out fChicks);&#xD;&#xA;&#xD;&#xA;    if (toVetObj != null &amp;&amp; toVetObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(toVetObj.ToString(), out toVet);&#xD;&#xA;&#xD;&#xA;    if (fChicks &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (toVet / fChicks) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) + &quot;%&quot;; &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    object mChicksObj = GetCurrentColumnValue(&quot;MChickRecived&quot;);&#xD;&#xA;    object toVetObj   = GetCurrentColumnValue(&quot;MaleToVetAndMinAgr&quot;);&#xD;&#xA;&#xD;&#xA;    decimal mChicks = 0;&#xD;&#xA;    decimal toVet = 0;&#xD;&#xA;&#xD;&#xA;    if (mChicksObj != null &amp;&amp; mChicksObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(mChicksObj.ToString(), out mChicks);&#xD;&#xA;&#xD;&#xA;    if (toVetObj != null &amp;&amp; toVetObj != DBNull.Value)&#xD;&#xA;        decimal.TryParse(toVetObj.ToString(), out toVet);&#xD;&#xA;&#xD;&#xA;    if (mChicks &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = (toVet / mChicks) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) + &quot;%&quot;; &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell25_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get the current row values as decimals&#xD;&#xA;    decimal chicksReceived = Convert.ToDecimal(GetCurrentColumnValue(&quot;FChickRecived&quot;));&#xD;&#xA;    decimal femaleMortWeek = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Mort_Week&quot;));&#xD;&#xA;&#xD;&#xA;    // Calculate percentage safely&#xD;&#xA;    if (chicksReceived &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percent = (femaleMortWeek / chicksReceived) * 100;&#xD;&#xA;        cell.Text = percent.ToString(&quot;0.00&quot;) + &quot;%&quot;; // format with 2 decimals&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or use &quot;&quot; if you want it blank&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell27_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get the current row values as decimals&#xD;&#xA;    decimal chicksReceived = Convert.ToDecimal(GetCurrentColumnValue(&quot;MChickRecived&quot;));&#xD;&#xA;    decimal maleMortWeek = Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_Mort_Week&quot;));&#xD;&#xA;&#xD;&#xA;    // Calculate percentage safely&#xD;&#xA;    if (chicksReceived &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percent = (maleMortWeek / chicksReceived) * 100;&#xD;&#xA;        cell.Text = percent.ToString(&quot;N2&quot;) + &quot;%&quot;; // formatted with 2 decimals&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;; // or &quot;&quot; if you want it blank&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell33_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get current row values as decimals&#xD;&#xA;    decimal chicksReceived = Convert.ToDecimal(GetCurrentColumnValue(&quot;FChickRecived&quot;));&#xD;&#xA;    decimal femaleSexError = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_SexError&quot;));&#xD;&#xA;&#xD;&#xA;    // Calculate percentage safely&#xD;&#xA;    if (chicksReceived &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal percent = (femaleSexError / chicksReceived) * 100;&#xD;&#xA;        cell.Text = percent.ToString(&quot;0.00&quot;) + &quot;%&quot;; // format with 2 decimals&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA