        <Item6 Ref="860" ControlType="SubBand" Name="SubBand8">
          <Controls>
            <Item1 Ref="861" ControlType="XRSubreport" Name="FR_BRD_FlockSummary4">
              <ReportSource Ref="863" ControlType="DevExpressReports.Reports.Farms.Breeder.RearingPeriod.Performance.FR_BRD_FlockSummary4.FR_BRD_FlockSummary4, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" Dpi="1" ScriptsSource="decimal totalFemaleQtyKg = 0;&#xD;&#xA;decimal totalMaleQtyKg = 0;&#xD;&#xA;&#xD;&#xA;private void xrTableCell2_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    decimal fChicks = Convert.ToDecimal(Parameters[&quot;FChicks&quot;]?.Value ?? 0);&#xD;&#xA;    decimal femaleQtyKg = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleQtyKg&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (fChicks &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = femaleQtyKg / fChicks;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) + (&quot;Kgs&quot;); // Format to 3 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell3_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        decimal mChicks = Convert.ToDecimal(Parameters[&quot;MChicks&quot;]?.Value ?? 0);&#xD;&#xA;        decimal maleQtyKg = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleQtyKg&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        if (mChicks &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal result = maleQtyKg / mChicks;&#xD;&#xA;            cell.Text = result.ToString(&quot;N2&quot;)+ (&quot;Kgs&quot;); // Format to 3 decimal places&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA; // Accumulate total female feed&#xD;&#xA;        decimal femaleQtyKg = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleQtyKg&quot;) ?? 0);&#xD;&#xA;        totalFemaleQtyKg += femaleQtyKg;&#xD;&#xA;        decimal maleQtyKg = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleQtyKg&quot;) ?? 0);&#xD;&#xA;        totalMaleQtyKg += maleQtyKg;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell8_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        decimal females = Convert.ToDecimal(GetCurrentColumnValue(&quot;Females&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        if (females &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            // This uses the current row's females count with accumulated total feed&#xD;&#xA;            decimal feedPerFemale = totalFemaleQtyKg / females;&#xD;&#xA;            cell.Text = feedPerFemale.ToString(&quot;N2&quot;) + &quot;Kgs&quot;;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell9_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;        &#xD;&#xA;        decimal males = Convert.ToDecimal(GetCurrentColumnValue(&quot;Males&quot;) ?? 0);&#xD;&#xA;        &#xD;&#xA;        if (males &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            decimal feedPerMale = totalMaleQtyKg / males;&#xD;&#xA;            cell.Text = feedPerMale.ToString(&quot;N2&quot;) + &quot;Kgs&quot;;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            cell.Text = &quot;0.00&quot;;&#xD;&#xA;        }&#xD;&#xA;}&#xD;&#xA;" SnapGridSize="0.125" ReportUnit="Inches" PageWidthF="8.5" PageHeightF="11" Version="25.2" DataMember="SR_FR_FeedByCrop" DataSource="#Ref-862">
