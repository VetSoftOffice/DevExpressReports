<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="WeeklyReport" ScriptsSource="decimal sumRfLiveFemale = 0;&#xD;&#xA;decimal sumFemaleFeed = 0;&#xD;&#xA;decimal sumRfLiveMale = 0;&#xD;&#xA;decimal sumMaleFeed = 0;&#xD;&#xA;decimal sumFemaleMort = 0;&#xD;&#xA;decimal sumCullsFemale = 0;&#xD;&#xA;decimal sumMaleMort = 0;&#xD;&#xA;decimal sumMaleCulls = 0;&#xD;&#xA;&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get values from fields&#xD;&#xA;    decimal rfLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_LiveFemale&quot;) ?? 0);&#xD;&#xA;    decimal femaleFeed = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleFeed&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate: (FemaleFeed / 7 / rf_LiveFemale) * 1000&#xD;&#xA;    if (rfLiveFemale &gt; 0) {&#xD;&#xA;        decimal result = (femaleFeed / 7 / rfLiveFemale) * 1000;&#xD;&#xA;        cell.Text = result.ToString(&quot;N1&quot;) ; // 1 decimal place with unit&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.0&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell23_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get values from fields&#xD;&#xA;    decimal rfLiveMale = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_LiveMale&quot;) ?? 0);&#xD;&#xA;    decimal maleFeed = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleFeed&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    // Calculate: (MaleFeed / 7 / rf_LiveMale) * 1000&#xD;&#xA;    if (rfLiveMale &gt; 0) {&#xD;&#xA;        decimal result = (maleFeed / 7 / rfLiveMale) * 1000;&#xD;&#xA;        cell.Text = result.ToString(&quot;N1&quot;) ; // 1 decimal place with unit&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.0&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;decimal rfLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_LiveFemale&quot;) ?? 0);&#xD;&#xA;    decimal femaleFeed = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleFeed&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    sumRfLiveFemale += rfLiveFemale;&#xD;&#xA;    sumFemaleFeed += femaleFeed;&#xD;&#xA;    &#xD;&#xA;     // Accumulate male sums from each detail row&#xD;&#xA;    sumRfLiveMale += Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_LiveMale&quot;) ?? 0);&#xD;&#xA;    sumMaleFeed += Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleFeed&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;     // Accumulate FemaleMort from each row&#xD;&#xA;    sumFemaleMort += Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleMort&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;     // --- Accumulate CullsFemale ---&#xD;&#xA;    object v = GetCurrentColumnValue(&quot;CullsFemale&quot;);&#xD;&#xA;    if (v != null &amp;&amp; v != DBNull.Value)&#xD;&#xA;    {&#xD;&#xA;        decimal.TryParse(v.ToString(), out decimal culls);&#xD;&#xA;        sumCullsFemale += culls;&#xD;&#xA;    }&#xD;&#xA;    v = GetCurrentColumnValue(&quot;MaleMort&quot;);&#xD;&#xA;    if (v != null &amp;&amp; v != DBNull.Value)&#xD;&#xA;    {&#xD;&#xA;        decimal.TryParse(v.ToString(), out decimal mort);&#xD;&#xA;        sumMaleMort += mort;&#xD;&#xA;    }&#xD;&#xA;    v = GetCurrentColumnValue(&quot;MaleCulls&quot;);&#xD;&#xA;    if (v != null &amp;&amp; v != DBNull.Value)&#xD;&#xA;    {&#xD;&#xA;        decimal.TryParse(v.ToString(), out decimal culls);&#xD;&#xA;        sumMaleCulls += culls;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;private void xrTableCell45_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    decimal days = 7;&#xD;&#xA;        &#xD;&#xA;    if (sumRfLiveFemale &gt; 0 &amp;&amp; days &gt; 0) {&#xD;&#xA;        decimal result = (sumFemaleFeed / days / sumRfLiveFemale) * 1000;&#xD;&#xA;        cell.Text = result.ToString(&quot;N1&quot;);&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.0&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell46_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get days from parameter or default to 7&#xD;&#xA;    decimal days = 7;&#xD;&#xA;        &#xD;&#xA;    // Apply equation to the ACCUMULATED SUMS: (TotalMaleFeed / days / TotalRfLiveMale) * 1000&#xD;&#xA;    if (sumRfLiveMale &gt; 0 &amp;&amp; days &gt; 0) {&#xD;&#xA;        decimal result = (sumMaleFeed / days / sumRfLiveMale) * 1000;&#xD;&#xA;        cell.Text = result.ToString(&quot;N1&quot;);&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0.0&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell51_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;       decimal femaleReceived = 0;&#xD;&#xA;       decimal femaleDOA = 0;&#xD;&#xA;&#xD;&#xA;    // --- FemaleReceived (parameter) ---&#xD;&#xA;    if (this.Report.Parameters[&quot;FemaleReceived&quot;] != null &amp;&amp;&#xD;&#xA;        this.Report.Parameters[&quot;FemaleReceived&quot;].Value != null)&#xD;&#xA;    {&#xD;&#xA;        decimal.TryParse(this.Report.Parameters[&quot;FemaleReceived&quot;].Value.ToString(), out femaleReceived);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- FemaleDOA (parameter) ---&#xD;&#xA;    if (Parameters[&quot;FemaleDOA&quot;] != null &amp;&amp;&#xD;&#xA;        Parameters[&quot;FemaleDOA&quot;].Value != null)&#xD;&#xA;    {&#xD;&#xA;        decimal.TryParse(Parameters[&quot;FemaleDOA&quot;].Value.ToString(), out femaleDOA);&#xD;&#xA;    }&#xD;&#xA;        // Calculate BirdsLeftFemale&#xD;&#xA;    decimal birdsLeftFemale = femaleReceived - femaleDOA;&#xD;&#xA;    &#xD;&#xA;    // Calculate percentage using accumulated sum&#xD;&#xA;    decimal denominator = birdsLeftFemale + femaleDOA;&#xD;&#xA;    &#xD;&#xA;    if (denominator &gt; 0) {&#xD;&#xA;        decimal result = (sumFemaleMort / denominator) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N0&quot;) ;&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell52_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal femaleReceived = 0;&#xD;&#xA;decimal femaleDOA = 0;&#xD;&#xA;decimal birdsLeftFemale = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;// --- FemaleReceived (parameter) ---&#xD;&#xA;if (Parameters[&quot;FemaleReceived&quot;] != null &amp;&amp;&#xD;&#xA;    Parameters[&quot;FemaleReceived&quot;].Value != null)&#xD;&#xA;{&#xD;&#xA;    decimal.TryParse(Parameters[&quot;FemaleReceived&quot;].Value.ToString(), out femaleReceived);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- FemaleDOA (parameter) ---&#xD;&#xA;if (Parameters[&quot;FemaleDOA&quot;] != null &amp;&amp;&#xD;&#xA;    Parameters[&quot;FemaleDOA&quot;].Value != null)&#xD;&#xA;{&#xD;&#xA;    decimal.TryParse(Parameters[&quot;FemaleDOA&quot;].Value.ToString(), out femaleDOA);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- BirdsLeftFemale ---&#xD;&#xA;birdsLeftFemale = femaleReceived - femaleDOA;&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;if (birdsLeftFemale &gt; 0)&#xD;&#xA;    result = (sumCullsFemale / (birdsLeftFemale + femaleDOA)) * 100m;&#xD;&#xA;&#xD;&#xA;// --- Assign result ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell53_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal maleReceived = 0;&#xD;&#xA;decimal maleDOA = 0;&#xD;&#xA;decimal birdsLeftMale = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;// --- MaleReceived (parameter) ---&#xD;&#xA;if (this.Report.Parameters[&quot;MaleReceived&quot;] != null &amp;&amp;&#xD;&#xA;    this.Report.Parameters[&quot;MaleReceived&quot;].Value != null)&#xD;&#xA;{&#xD;&#xA;    decimal.TryParse(this.Report.Parameters[&quot;MaleReceived&quot;].Value.ToString(), out maleReceived);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- MaleDOA (parameter) ---&#xD;&#xA;if (Parameters[&quot;MaleDOA&quot;] != null &amp;&amp;&#xD;&#xA;    Parameters[&quot;MaleDOA&quot;].Value != null)&#xD;&#xA;{&#xD;&#xA;    decimal.TryParse(Parameters[&quot;MaleDOA&quot;].Value.ToString(), out maleDOA);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- BirdsLeftMale ---&#xD;&#xA;birdsLeftMale = maleReceived - maleDOA;&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;if (birdsLeftMale &gt; 0)&#xD;&#xA;    result = (sumMaleMort / (birdsLeftMale + maleDOA)) * 100m;&#xD;&#xA;&#xD;&#xA;// --- Assign result ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell54_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal maleReceived = 0;&#xD;&#xA;decimal maleDOA = 0;&#xD;&#xA;decimal birdsLeftMale = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;// --- MaleReceived ---&#xD;&#xA;if (this.Report.Parameters[&quot;MaleReceived&quot;] != null &amp;&amp;&#xD;&#xA;    this.Report.Parameters[&quot;MaleReceived&quot;].Value != null)&#xD;&#xA;{&#xD;&#xA;    decimal.TryParse(this.Report.Parameters[&quot;MaleReceived&quot;].Value.ToString(), out maleReceived);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- MaleDOA ---&#xD;&#xA;if (this.Report.Parameters[&quot;MaleDOA&quot;] != null &amp;&amp;&#xD;&#xA;    this.Report.Parameters[&quot;MaleDOA&quot;].Value != null)&#xD;&#xA;{&#xD;&#xA;    decimal.TryParse(this.Report.Parameters[&quot;MaleDOA&quot;].Value.ToString(), out maleDOA);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- BirdsLeftMale ---&#xD;&#xA;birdsLeftMale = maleReceived - maleDOA;&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;if (birdsLeftMale &gt; 0)&#xD;&#xA;    result = (sumMaleCulls / (birdsLeftMale + maleDOA)) * 100m;&#xD;&#xA;&#xD;&#xA;// --- Output ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;" PageWidthF="1169.29138" PageHeightF="1653.54333" Version="25.2" DataMember="SR_BRD_WeeklyReport" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="All" BorderWidth="0.5">
