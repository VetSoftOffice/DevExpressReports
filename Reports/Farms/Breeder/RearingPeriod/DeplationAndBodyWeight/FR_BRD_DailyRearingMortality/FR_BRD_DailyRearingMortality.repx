;N0&quot;) ;&#xD;&#xA;    } else {&#xD;&#xA;        resultCell.Text = &quot;0&quot;;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell29_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell resultCell = sender as XRTableCell;// Your result cell&#xD;&#xA;    &#xD;&#xA;    if (totalLiveFemale &gt; 0) {&#xD;&#xA;        decimal result = ((totalCullsFemale + totalFemaleMort) / totalLiveFemale) * 100;&#xD;&#xA;        resultCell.Text = result.ToString(&quot;N0&quot;) ;&#xD;&#xA;    } else {&#xD;&#xA;        resultCell.Text = &quot;0&quot;;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell32_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     // Calculate Male Mortality percentage&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (totalLiveMale &gt; 0) {&#xD;&#xA;        decimal result = (totalMaleMort / totalLiveMale) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell33_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     // Calculate Male Culls percentage&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (totalLiveMale &gt; 0) {&#xD;&#xA;        decimal result = (totalCullsMale / totalLiveMale) * 100;&#xD;&#xA;        cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;    } else {&#xD;&#xA;        cell.Text = &quot;0&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell34_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      // Calculate Male Total Loss percentage (Mortality + Culls)&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (totalLiveMale &gt; 0) {&#xD;&#xA;        decimal result = ((tot