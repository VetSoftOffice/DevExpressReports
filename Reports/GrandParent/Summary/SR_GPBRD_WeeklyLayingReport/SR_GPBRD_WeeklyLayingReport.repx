e = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Sample&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (wcLiveFemale != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (Female_Sample * 100) / WC_LiveFemale&#xD;&#xA;    // This gives sample percentage based on live female count&#xD;&#xA;    decimal result = (femaleSample * 100.0m) / wcLiveFemale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell108_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartFemaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startFemaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartFemaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startFemaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_FemaleSample is the sum of Female_Sample&#xD;&#xA;        decimal rtFemaleSample = totalFemaleSample;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum Female_Sample * 100) / StartFemaleBirds&#xD;&#xA;        decimal result = (rtFemaleSample * 100.0m) / startFemaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell5_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal wcLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveFemale&quot;) ?? 0);&#xD;&#xA;decimal femaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Culls&quot;) ?? 0);&#xD;&#xA;decimal femaleCullsKill = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_CullsKill&quot;) ?? 0);&#xD;&#xA;decimal femaleSample = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Sample&quot;) ?? 0);&#xD;&#xA;decimal femaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleMort&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Calculate @FemaleDepl = Female_Culls + Female_CullsKill + Female_Sample + FemaleMort&#xD;&#xA;decimal femaleDepl = femaleCulls + femaleCullsKill + femaleSample + femaleMort;&#xD;&#xA;&#xD;&#xA;if (wcLiveFemale != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (@FemaleDepl * 100) / WC_LiveFemale&#xD;&#xA;    decimal result = (femaleDepl * 100.0m) / wcLiveFemale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell7_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartFemaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startFemaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartFemaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startFemaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_FemaleDepla is the sum of all female depletion fields&#xD;&#xA;        decimal rtFemaleDepla = totalFemaleCulls + totalFemaleCullsKill + totalFemaleSample + totalFemaleMort;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum of all female depletion * 100) / StartFemaleBirds&#xD;&#xA;        decimal result = (rtFemaleDepla * 100.0m) / startFemaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell9_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal wcLiveMale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveMale&quot;) ?? 0);&#xD;&#xA;decimal maleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleMort&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (wcLiveMale != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (MaleMort * 100) / WC_LiveMale&#xD;&#xA;    // This gives male mortality percentage based on live male count&#xD;&#xA;    decimal result = (maleMort * 100.0m) / wcLiveMale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell11_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartMaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startMaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartMaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startMaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_MaleMort is the sum of MaleMort&#xD;&#xA;        decimal rtMaleMort = totalMaleMort;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum MaleMort * 100) / StartMaleBirds&#xD;&#xA;        decimal result = (rtMaleMort * 100.0m) / startMaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell17_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal wcLiveMale = Convert