                  <Item4 Ref="225" Name="OpenF" Expression="Iif(IsNullOrEmpty([OpenFHTEggsF]), 0, [OpenFHTEggsF])&#xA;+&#xA;Iif(IsNullOrEmpty([OpenHTEggsF]), 0, [OpenHTEggsF])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item5 Ref="226" Name="Production" Expression="Iif(IsNullOrEmpty([ProdFHTEggsF]), 0, [ProdFHTEggsF]) +&#xA;Iif(IsNullOrEmpty([ProdHTEggsF]), 0, [ProdHTEggsF])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item6 Ref="227" Name="SendToHatF" Expression="Iif(IsNullOrEmpty([HatcheryFHTEggsF]), 0, [HatcheryFHTEggsF]) +&#xA;Iif(IsNullOrEmpty([HatcheryHTEggsF]), 0, [HatcheryHTEggsF])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item7 Ref="228" Name="SendToCEGS" Expression="Iif(IsNullOrEmpty([CEGSFHTEggsF]), 0, [CEGSFHTEggsF]) +&#xA;Iif(IsNullOrEmpty([CEGSHTEggsF]), 0, [CEGSHTEggsF])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item8 Ref="229" Name="CloseF" Expression="Iif(IsNullOrEmpty([CloseFHTEggsF]), 0, [CloseFHTEggsF]) +&#xA;Iif(IsNullOrEmpty([CloseHTEggsF]), 0, [CloseHTEggsF])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item9 Ref="230" Name="OpenC" Expression="Iif(IsNullOrEmpty([OpenFHTEggsC]), 0, [OpenFHTEggsC]) +&#xA;Iif(IsNullOrEmpty([OpenHTEggsC]), 0, [OpenHTEggsC])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item10 Ref="231" Name="Receive" Expression="Iif(IsNullOrEmpty([RecFHTEggsC]), 0, [RecFHTEggsC]) +&#xA;Iif(IsNullOrEmpty([RecHTEggsC]), 0, [RecHTEggsC])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item11 Ref="232" Name="SendToHatC" Expression="Iif(IsNullOrEmpty([HatcheryFHTEggsC]), 0, [HatcheryFHTEggsC]) +&#xA;Iif(IsNullOrEmpty([HatcheryHTEggsC]), 0, [HatcheryHTEggsC])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item12 Ref="233" Name="Close" Expression="Iif(IsNullOrEmpty([CloseFHTEggsC]), 0, [CloseFHTEggsC]) +&#xA;Iif(IsNullOrEmpty([CloseHTEggsC]), 0, [CloseHTEggsC])&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item13 Ref="234" Name="TotalHE" Expression="Iif(IsNullOrEmpty([CloseFHTEggsC]), 0, [CloseFHTEggsC]) +&#xD;&#xA;Iif(IsNullOrEmpty([CloseFHTEggsF]), 0, [CloseFHTEggsF]) +&#xD;&#xA;Iif(IsNullOrEmpty([CloseHTEggsC]), 0, [CloseHTEggsC]) +&#xD;&#xA;Iif(IsNullOrEmpty([CloseHTEggsF]), 0, [CloseHTEggsF])&#xD;&#xA;" DataMember="SR_BRD_HTEggsBalance" />
                  <Item14 Ref="235" Name="TotalDepl" Expression="IIF(!IsNullOrEmpty([TotalMort]), [TotalMort], 0) + &#xA;IIF(!IsNullOrEmpty([TotalCulls]), [TotalCulls], 0) + &#xA;IIF(!IsNullOrEmpty([Cocks]), [Cocks], 0)" DataMember="SR_LAY_WeeklyBodyWeight" />
                  <Item15 Ref="236" Name="FirstWeekMort" Expression="IIF(!IsNullOrEmpty([TotalMort]), [TotalMort], 0) + &#xA;IIF(!IsNullOrEmpty([TotalCulls]), [TotalCulls], 0) + &#xA;IIF(!IsNullOrEmpty([Cocks]), [Cocks], 0)" DataMember="SR_LAY_WeeklyBodyWeight" />
                  <Item16 Ref="237" Name="Type1_Weekly" Expression="IIF([Type1] = 1, ?Age, &#xA;IIF([Type1] = 2, ?FemaleBodyWt, &#xA;IIF([Type1] = 3, ?FemaleFeed, &#xA;IIF([Type1] = 4, ?FemaleMort, &#xA;IIF([Type1] = 5, ?MaleBodyWt, &#xA;IIF([Type1] = 6, ?MaleFeed, &#xA;IIF([Type1] = 7, ?MaleMort, &#xA;IIF([Type1] = 8, ?Env, NULL))))))))" DataMember="SR_BRD_WeeklyRearingReport" />
                  <Item17 Ref="238" Name="Type2_Weekly" Expression="IIF([Type2] = 1, ?Days, &#xA;IIF([Type2] = 2, ?Target, &#xA;IIF([Type2] = 3, ?Actual, &#xA;IIF([Type2] = 4, ?WeeklyGain, &#xA;IIF([Type2] = 5, ?Uniformity, &#xA;IIF([Type2] = 6, ?Target, &#xA;IIF([Type2] = 7, ?Actual, &#xA;IIF([Type2] = 8, ?FeedEnergy, &#xA;IIF([Type2] = 9, ?FeedType, &#xA;IIF([Type2] = 10, ?Birds, &#xA;IIF([Type2] = 11, ?WeeklyPerc, &#xA;IIF([Type2] = 12, ?CumPerc, &#xA;IIF([Type2] = 13, ?Light, &#xA;IIF([Type2] = 14, ?WaterConsumption, &#xA;IIF([Type2] = 15, ?Temperature, NULL)))))))))))))))" DataMember="SR_BRD_WeeklyRearingReport" />
