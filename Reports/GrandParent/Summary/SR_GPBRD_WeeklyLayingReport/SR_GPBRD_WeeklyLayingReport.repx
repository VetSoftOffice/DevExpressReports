is gives male sample percentage based on live male count&#xD;&#xA;    decimal result = (maleSample * 100.0m) / wcLiveMale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell41_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartMaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startMaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartMaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startMaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_MaleSample is the sum of Male_Sample&#xD;&#xA;        decimal rtMaleSample = totalMaleSample;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum Male_Sample * 100) / StartMaleBirds&#xD;&#xA;        decimal result = (rtMaleSample * 100.0m) / startMaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell43_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function to safely convert values&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Get values from the data source with safe conversion&#xD;&#xA;decimal wcLiveMale = SafeConvert(GetCurrentColumnValue(&quot;WC_LiveMale&quot;));&#xD;&#xA;decimal maleCulls = SafeConvert(GetCurrentColumnValue(&quot;Male_Culls&quot;));&#xD;&#xA;decimal maleCullsKill = SafeConvert(GetCurrentColumnValue(&quot;Male_CullsKill&quot;));&#xD;&#xA;decimal maleSample = SafeConvert(GetCurrentColumnValue(&quot;Male_Sample&quot;));&#xD;&#xA;decimal maleMort = SafeConvert(GetCurrentColumnValue(&quot;MaleMort&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate @MaleDepl = Male_Culls + Male_CullsKill + Male_Sample + MaleMort&#xD;&#xA;decimal maleDepl = maleCulls + maleCullsKill + maleSample + maleMort;&#xD;&#xA;&#xD;&#xA;if (wcLiveMale != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (@MaleDepl * 100) / WC_LiveMale&#xD;&#xA;    decimal result = (maleDepl * 100.0m) / wcLiveMale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell46_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartMaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startMaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartMaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startMaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_MaleDepl is the sum of all male depletion fields&#xD;&#xA;        decimal rtMaleDepl = totalMaleCulls + totalMaleCullsKill + totalMaleSample + totalMaleMort;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum of all male depletion * 100) / StartMaleBirds&#xD;&#xA;        decimal result = (rtMaleDepl * 100.0m) / startMaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" PageWidthF="1169.29138" PageHeightF="1653.54333" Version="25.2" DataMember="SR_GPBRD_WeeklyLayingReport" DataSource="#Ref-