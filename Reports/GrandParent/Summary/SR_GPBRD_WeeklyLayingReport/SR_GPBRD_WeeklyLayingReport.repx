<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_GPBRD_WeeklyLayingReport" ScriptsSource="decimal totalFemaleMort = 0;&#xD;&#xA;decimal totalFemaleKill = 0;&#xD;&#xA;decimal totalFemaleCullsKill = 0;&#xD;&#xA;decimal totalFemaleSample = 0;&#xD;&#xA;decimal totalMaleMort = 0;&#xD;&#xA;decimal totalMaleKills = 0;&#xD;&#xA;decimal totalMaleCulls = 0;&#xD;&#xA;decimal totalMaleSample = 0;&#xD;&#xA;private void xrTableCell91_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal wcLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveFemale&quot;) ?? 0);&#xD;&#xA;decimal femaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleMort&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (wcLiveFemale != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (FemaleMort * 100) / WC_LiveFemale&#xD;&#xA;    // This gives mortality percentage based on live female count&#xD;&#xA;    decimal result = (femaleMort * 100.0m) / wcLiveFemale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void detailBand1_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        decimal femaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleMort&quot;) ?? 0);&#xD;&#xA;    totalFemaleMort += femaleMort;&#xD;&#xA;    decimal femaleCullsKill = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_CullsKill&quot;) ?? 0);&#xD;&#xA;    totalFemaleKill += femaleCullsKill;&#xD;&#xA;        decimal femaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Culls&quot;) ?? 0);&#xD;&#xA;    totalFemaleCulls += femaleCulls;&#xD;&#xA;     decimal femaleSample = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Sample&quot;) ?? 0);&#xD;&#xA;    totalFemaleSample += femaleSample;&#xD;&#xA;    totalFemaleMort += SafeConvert(GetCurrentColumnValue(&quot;FemaleMort&quot;));&#xD;&#xA;        decimal maleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleMort&quot;) ?? 0);&#xD;&#xA;    totalMaleMort += maleMort;&#xD;&#xA;        decimal maleCullsKill = Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_CullsKill&quot;) ?? 0);&#xD;&#xA;    totalMaleKills += maleCullsKill;&#xD;&#xA;    decimal maleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_Culls&quot;) ?? 0);&#xD;&#xA;    totalMaleCulls += maleCulls;&#xD;&#xA;        decimal maleSample = Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_Sample&quot;) ?? 0);&#xD;&#xA;    totalMaleSample += maleSample;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell96_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartFemaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startFemaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartFemaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startFemaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_FemaleMort is the sum of FemaleMort&#xD;&#xA;        decimal rtFemaleMort = totalFemaleMort;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum FemaleMort * 100) / StartFemaleBirds&#xD;&#xA;        decimal result = (rtFemaleMort * 100.0m) / startFemaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell98_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;   XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal wcLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveFemale&quot;) ?? 0);&#xD;&#xA;decimal femaleCullsKill = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_CullsKill&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (wcLiveFemale != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (Female_CullsKill * 100) / WC_LiveFemale&#xD;&#xA;    // This gives cull kill percentage based on live female count&#xD;&#xA;    decimal result = (femaleCullsKill * 100.0m) / wcLiveFemale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell100_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartFemaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startFemaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartFemaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startFemaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_FemaleKill is the sum of Female_CullsKill&#xD;&#xA;        decimal rtFemaleKill = totalFemaleKill;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum Female_CullsKill * 100) / StartFemaleBirds&#xD;&#xA;        decimal result = (rtFemaleKill * 100.0m) / startFemaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell102_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#