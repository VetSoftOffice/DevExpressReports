    <Item23 Ref="73" Name="PinCode_CF" Expression="IIF([PinCode] = 'Total', ?Total, [PinCode])" DataMember="SR_GP_ProductDailyReport" />
    <Item24 Ref="74" Name="Type1_CF" Expression="IIF([Type1] = 1, ?BirdType,&#xA;IIF([Type1] = 2, ?Female,&#xA;IIF([Type1] = 3, ?Male,&#xA;IIF([Type1] = 4, ?Feed,&#xA;IIF([Type1] = 5, ?Water,&#xA;IIF([Type1] = 6, ?Heat,&#xA;IIF([Type1] = 9, ?HummidityHouse,&#xA;IIF([Type1] = 7, ?EggsStore,&#xA;IIF([Type1] = 8, ?LightTime,&#xA;[Type1]&#xA;)))))))))" DataMember="SR_GP_ProductDailyReport" />
