    <Item21 Ref="71" Name="TypeValue" Expression="IIF(&#xA;    !IsNullOrEmpty([ItemText]), [ItemText],&#xA;    IIF([Type] = 1000000001, ?Total,&#xA;    IIF([Type] = 1000000002, ?ProdPrec,&#xA;    IIF([Type] = 1000000003, ?HatPerc,&#xA;    IIF([Type] = 1000000004, ?StoreBalance, ''))))&#xA;)" DataMember="SR_GP_DailyEggsProd" />
