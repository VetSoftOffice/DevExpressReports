<XtraReportsLayoutSerializer SerializerVersion="26.1.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_BRD_WeeklyRearingReport" ScriptsSource="decimal totalFemaleMort = 0;&#xD;&#xA;decimal totalFemaleKill = 0;&#xD;&#xA;decimal totalFemaleCullsKill = 0;&#xD;&#xA;decimal totalFemaleSample = 0;&#xD;&#xA;decimal totalFemaleCulls  = 0;&#xD;&#xA;decimal totalMaleMort = 0;&#xD;&#xA;decimal totalMaleKills = 0;&#xD;&#xA;decimal totalMaleCulls = 0;&#xD;&#xA;decimal totalMaleSample = 0;&#xD;&#xA;private void xrTableCell91_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal wcLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveFemale&quot;) ?? 0);&#xD;&#xA;decimal femaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleMort&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (wcLiveFemale != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (FemaleMort * 100) / WC_LiveFemale&#xD;&#xA;    // This gives mortality percentage based on live female count&#xD;&#xA;    decimal result = (femaleMort * 100.0m) / wcLiveFemale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void detailBand1_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        decimal femaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleMort&quot;) ?? 0);&#xD;&#xA;    totalFemaleMort += femaleMort;&#xD;&#xA;    decimal femaleCullsKill = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_CullsKill&quot;) ?? 0);&#xD;&#xA;    totalFemaleKill += femaleCullsKill;&#xD;&#xA;        decimal femaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Culls&quot;) ?? 0);&#xD;&#xA;    totalFemaleCulls += femaleCulls;&#xD;&#xA;     decimal femaleSample = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Sample&quot;) ?? 0);&#xD;&#xA;    totalFemaleSample += femaleSample;&#xD;&#xA;    totalFemaleMort += Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleMort&quot;));&#xD;&#xA;        decimal maleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleMort&quot;) ?? 0);&#xD;&#xA;    totalMaleMort += maleMort;&#xD;&#xA;        decimal maleCullsKill = Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_CullsKill&quot;) ?? 0);&#xD;&#xA;    totalMaleKills += maleCullsKill;&#xD;&#xA;    decimal maleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_Culls&quot;) ?? 0);&#xD;&#xA;    totalMaleCulls += maleCulls;&#xD;&#xA;        decimal maleSample = Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_Sample&quot;) ?? 0);&#xD;&#xA;    totalMaleSample += maleSample;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell96_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartFemaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startFemaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartFemaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startFemaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_FemaleMort is the sum of FemaleMort&#xD;&#xA;        decimal rtFemaleMort = totalFemaleMort;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum FemaleMort * 100) / StartFemaleBirds&#xD;&#xA;        decimal result = (rtFemaleMort * 100.0m) / startFemaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell98_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;   XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal wcLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveFemale&quot;) ?? 0);&#xD;&#xA;decimal femaleCullsKill = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_CullsKill&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (wcLiveFemale != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (Female_CullsKill * 100) / WC_LiveFemale&#xD;&#xA;    // This gives cull kill percentage based on live female count&#xD;&#xA;    decimal result = (femaleCullsKill * 100.0m) / wcLiveFemale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell100_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartFemaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startFemaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartFemaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startFemaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_FemaleKill is the sum of Female_CullsKill&#xD;&#xA;        decimal rtFemaleKill = totalFemaleKill;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum Female_CullsKill * 100) / StartFemaleBirds&#xD;&#xA;        decimal result = (rtFemaleKill * 100.0m) / startFemaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell102_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal wcLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveFemale&quot;) ?? 0);&#xD;&#xA;decimal femaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Culls&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (wcLiveFemale != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (Female_Culls * 100) / WC_LiveFemale&#xD;&#xA;    // This gives cull percentage based on live female count&#xD;&#xA;    decimal result = (femaleCulls * 100.0m) / wcLiveFemale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell104_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartFemaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startFemaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartFemaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startFemaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_FemaleCulls is the sum of Female_Culls&#xD;&#xA;        decimal rtFemaleCulls = totalFemaleCulls;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum Female_Culls * 100) / StartFemaleBirds&#xD;&#xA;        decimal result = (rtFemaleCulls * 100.0m) / startFemaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell106_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal wcLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveFemale&quot;) ?? 0);&#xD;&#xA;decimal femaleSample = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Sample&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (wcLiveFemale != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (Female_Sample * 100) / WC_LiveFemale&#xD;&#xA;    // This gives sample percentage based on live female count&#xD;&#xA;    decimal result = (femaleSample * 100.0m) / wcLiveFemale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell108_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartFemaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startFemaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartFemaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startFemaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_FemaleSample is the sum of Female_Sample&#xD;&#xA;        decimal rtFemaleSample = totalFemaleSample;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum Female_Sample * 100) / StartFemaleBirds&#xD;&#xA;        decimal result = (rtFemaleSample * 100.0m) / startFemaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell5_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal wcLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveFemale&quot;) ?? 0);&#xD;&#xA;decimal femaleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Culls&quot;) ?? 0);&#xD;&#xA;decimal femaleCullsKill = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_CullsKill&quot;) ?? 0);&#xD;&#xA;decimal femaleSample = Convert.ToDecimal(GetCurrentColumnValue(&quot;Female_Sample&quot;) ?? 0);&#xD;&#xA;decimal femaleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemaleMort&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Calculate @FemaleDepl = Female_Culls + Female_CullsKill + Female_Sample + FemaleMort&#xD;&#xA;decimal femaleDepl = femaleCulls + femaleCullsKill + femaleSample + femaleMort;&#xD;&#xA;&#xD;&#xA;if (wcLiveFemale != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (@FemaleDepl * 100) / WC_LiveFemale&#xD;&#xA;    decimal result = (femaleDepl * 100.0m) / wcLiveFemale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell7_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartFemaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startFemaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartFemaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startFemaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_FemaleDepla is the sum of all female depletion fields&#xD;&#xA;        decimal rtFemaleDepla = totalFemaleCulls + totalFemaleCullsKill + totalFemaleSample + totalFemaleMort;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum of all female depletion * 100) / StartFemaleBirds&#xD;&#xA;        decimal result = (rtFemaleDepla * 100.0m) / startFemaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell9_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal wcLiveMale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveMale&quot;) ?? 0);&#xD;&#xA;decimal maleMort = Convert.ToDecimal(GetCurrentColumnValue(&quot;MaleMort&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (wcLiveMale != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (MaleMort * 100) / WC_LiveMale&#xD;&#xA;    // This gives male mortality percentage based on live male count&#xD;&#xA;    decimal result = (maleMort * 100.0m) / wcLiveMale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell11_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartMaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startMaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartMaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startMaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_MaleMort is the sum of MaleMort&#xD;&#xA;        decimal rtMaleMort = totalMaleMort;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum MaleMort * 100) / StartMaleBirds&#xD;&#xA;        decimal result = (rtMaleMort * 100.0m) / startMaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell17_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal wcLiveMale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveMale&quot;) ?? 0);&#xD;&#xA;decimal maleCullsKill = Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_CullsKill&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (wcLiveMale != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (Male_CullsKill * 100) / WC_LiveMale&#xD;&#xA;    // This gives male cull kill percentage based on live male count&#xD;&#xA;    decimal result = (maleCullsKill * 100.0m) / wcLiveMale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell27_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartMaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startMaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartMaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startMaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_MaleKills is the sum of Male_CullsKill&#xD;&#xA;        decimal rtMaleKills = totalMaleKills;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum Male_CullsKill * 100) / StartMaleBirds&#xD;&#xA;        decimal result = (rtMaleKills * 100.0m) / startMaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell29_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;   XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal wcLiveMale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveMale&quot;) ?? 0);&#xD;&#xA;decimal maleCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_Culls&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (wcLiveMale != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (Male_Culls * 100) / WC_LiveMale&#xD;&#xA;    // This gives male cull percentage based on live male count&#xD;&#xA;    decimal result = (maleCulls * 100.0m) / wcLiveMale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;} &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell33_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartMaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startMaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartMaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startMaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_MaleCulls is the sum of Male_Culls&#xD;&#xA;        decimal rtMaleCulls = totalMaleCulls;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum Male_Culls * 100) / StartMaleBirds&#xD;&#xA;        decimal result = (rtMaleCulls * 100.0m) / startMaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell39_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal wcLiveMale = Convert.ToDecimal(GetCurrentColumnValue(&quot;WC_LiveMale&quot;) ?? 0);&#xD;&#xA;decimal maleSample = Convert.ToDecimal(GetCurrentColumnValue(&quot;Male_Sample&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (wcLiveMale != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (Male_Sample * 100) / WC_LiveMale&#xD;&#xA;    // This gives male sample percentage based on live male count&#xD;&#xA;    decimal result = (maleSample * 100.0m) / wcLiveMale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell41_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartMaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startMaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartMaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startMaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_MaleSample is the sum of Male_Sample&#xD;&#xA;        decimal rtMaleSample = totalMaleSample;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum Male_Sample * 100) / StartMaleBirds&#xD;&#xA;        decimal result = (rtMaleSample * 100.0m) / startMaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell43_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function to safely convert values&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Get values from the data source with safe conversion&#xD;&#xA;decimal wcLiveMale = SafeConvert(GetCurrentColumnValue(&quot;WC_LiveMale&quot;));&#xD;&#xA;decimal maleCulls = SafeConvert(GetCurrentColumnValue(&quot;Male_Culls&quot;));&#xD;&#xA;decimal maleCullsKill = SafeConvert(GetCurrentColumnValue(&quot;Male_CullsKill&quot;));&#xD;&#xA;decimal maleSample = SafeConvert(GetCurrentColumnValue(&quot;Male_Sample&quot;));&#xD;&#xA;decimal maleMort = SafeConvert(GetCurrentColumnValue(&quot;MaleMort&quot;));&#xD;&#xA;&#xD;&#xA;// Calculate @MaleDepl = Male_Culls + Male_CullsKill + Male_Sample + MaleMort&#xD;&#xA;decimal maleDepl = maleCulls + maleCullsKill + maleSample + maleMort;&#xD;&#xA;&#xD;&#xA;if (wcLiveMale != 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: (@MaleDepl * 100) / WC_LiveMale&#xD;&#xA;    decimal result = (maleDepl * 100.0m) / wcLiveMale;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell46_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    // Get StartMaleBirds from the current row (assuming it's the same for all rows in the group)&#xD;&#xA;    decimal startMaleBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;StartMaleBirds&quot;) ?? 0);&#xD;&#xA;    &#xD;&#xA;    if (startMaleBirds != 0)&#xD;&#xA;    {&#xD;&#xA;        // #RT_MaleDepl is the sum of all male depletion fields&#xD;&#xA;        decimal rtMaleDepl = totalMaleCulls + totalMaleKills + totalMaleSample + totalMaleMort;&#xD;&#xA;        &#xD;&#xA;        // Calculate: (Sum of all male depletion * 100) / StartMaleBirds&#xD;&#xA;        decimal result = (rtMaleDepl * 100.0m) / startMaleBirds;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;); // Formats to 2 decimal places&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" Version="26.1" 