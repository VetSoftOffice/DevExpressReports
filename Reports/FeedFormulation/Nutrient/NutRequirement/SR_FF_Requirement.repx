<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="26.1.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_FF_Requirement" ScriptsSource="using System.Text.RegularExpressions;&#xD;&#xA;&#xD;&#xA;private void xrTableCell5_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    string raw = GetCurrentColumnValue(&quot;NutrientName&quot;).ToString();&#xD;&#xA;    // Check report parameter value (assumes it's a boolean parameter named &quot;IsRTL&quot;)&#xD;&#xA;        bool isRTL = Convert.ToBoolean(Parameters[&quot;IsRTL&quot;].Value);&#xD;&#xA;&#xD;&#xA;        if (isRTL)&#xD;&#xA;        {&#xD;&#xA;            // Keep Arabic + English + numbers + spaces&#xD;&#xA;            xrTableCell5.Text = Regex.Replace(raw, @&quot;[^\u0600-\u06FFa-zA-Z0-9\s]&quot;, &quot;&quot;);&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            // Keep only English + numbers + spaces&#xD;&#xA;            xrTableCell5.Text = Regex.Replace(raw, @&quot;[^a-zA-Z0-9\s]&quot;, &quot;&quot;);&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;" PageWidthF="826.771667" PageHeightF="1169.29138" Version="26.1" DataMember="SR_FF_Requirement" DataSource="#Ref-0" BorderColor="BlanchedAlmond">
