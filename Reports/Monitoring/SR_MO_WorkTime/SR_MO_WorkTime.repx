  <CalculatedFields>
    <Item1 Ref="22" Name="TotalWorkHours" Expression="((Sum([UserHour])) + (Sum([UserMinute])) / 60)" DataMember="SR_MO_WorkTime" />
    <Item2 Ref="23" Name="TotalWorkMinutes" Expression="(Sum([UserMinute])) % 60" DataMember="SR_MO_WorkTime" />
    <Item3 Ref="24" Name="TotalWorkHoursForSupport" Expression="sum([UserSupportHour]) + (sum([UserSupportMinute]) / 60)&#xA;" DataMember="SR_MO_WorkTime" />
    <Item4 Ref="25" Name="TotalWorkMinutesForSupport" Expression="sum([UserSupportMinute]) % 60&#xA;" DataMember="SR_MO_WorkTime" />
    <Item5 Ref="26" Name="SupportPerc" Expression="ToFloat([numerator]) / ToFloat([denominator]) &#xA;" DataMember="SR_MO_WorkTime" />
    <Item6 Ref="27" Name="numerator" Expression="(Sum([TotalWorkHoursForSupport]) * 60) + Sum([TotalWorkMinutesForSupport]) &#xA;" DataMember="SR_MO_WorkTime" />
    <Item7 Ref="28" Name="denominator" Expression="(Sum([TotalWorkHours]) * 60) + Sum([TotalWorkMinutes]) + &#xA;            (Sum([TotalWorkHoursForSupport]) * 60) + Sum([TotalWorkMinutesForSupport])&#xA;" DataMember="SR_MO_WorkTime" />
