    <Item20 Ref="47" Name="ChicksPerc" Expression="Iif([SR_HT_BreakOut.SampleEggs] != 0, [SR_HT_BreakOut.Chicks] * 100 / [SR_HT_BreakOut.SampleEggs], 0)&#xA;" DataMember="SR_HT_BreakOut" />
