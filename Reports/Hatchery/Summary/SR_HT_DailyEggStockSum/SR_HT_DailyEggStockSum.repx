<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_DailyEggStockSum" ScriptsSource="decimal TotalRec = 0;&#xD;&#xA;decimal ToalRecGroup  = 0;&#xD;&#xA;decimal TotalStock  = 0;&#xD;&#xA;decimal TotalStockGroup = 0;&#xD;&#xA;private void xrTableCell65_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal FarmIntake= 0;&#xD;&#xA;    decimal HatcheryIntake= 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FarmIntake&quot;) != null)&#xD;&#xA;        FarmIntake= Convert.ToDecimal(GetCurrentColumnValue(&quot;FarmIntake&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;HatcheryIntake&quot;) != null)&#xD;&#xA;        HatcheryIntake= Convert.ToDecimal(GetCurrentColumnValue(&quot;HatcheryIntake&quot;));&#xD;&#xA;&#xD;&#xA;    decimal result = FarmIntake + HatcheryIntake;&#xD;&#xA;    TotalRec+= result; &#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;0&quot;); // no decimals, adjust format if needed&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal FarmIntake= 0;&#xD;&#xA;    decimal HatcheryIntake= 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FarmIntake&quot;) != null)&#xD;&#xA;        FarmIntake= Convert.ToDecimal(GetCurrentColumnValue(&quot;FarmIntake&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;HatcheryIntake&quot;) != null)&#xD;&#xA;        HatcheryIntake= Convert.ToDecimal(GetCurrentColumnValue(&quot;HatcheryIntake&quot;));&#xD;&#xA;    &#xD;&#xA;    ToalRecGroup += (FarmIntake+ HatcheryIntake);&#xD;&#xA;    //-- new logic for Total Stock&#xD;&#xA;    decimal OpenStockReceivingHall = 0;&#xD;&#xA;    decimal RejCracks = 0;&#xD;&#xA;    decimal RejWhole = 0;&#xD;&#xA;    decimal RejBroken = 0;&#xD;&#xA;    decimal RejOther = 0;&#xD;&#xA;    decimal SellToLogistic = 0;&#xD;&#xA;    decimal SellOfHatEggs = 0;&#xD;&#xA;    decimal EggsToCollage = 0;&#xD;&#xA;    decimal TransToHatchery = 0;&#xD;&#xA;    decimal SettedEggs = 0;&#xD;&#xA;    decimal St_RejCrack = 0;&#xD;&#xA;    decimal St_RejWhole = 0;&#xD;&#xA;    decimal St_RejBroken = 0;&#xD;&#xA;    decimal St_RejOther = 0;&#xD;&#xA;    decimal EggsToOffal = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;OpenStockReceivingHall&quot;) != null)&#xD;&#xA;        OpenStockReceivingHall = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenStockReceivingHall&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FarmIntake&quot;) != null)&#xD;&#xA;        FarmIntake = Convert.ToDecimal(GetCurrentColumnValue(&quot;FarmIntake&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;HatcheryIntake&quot;) != null)&#xD;&#xA;        HatcheryIntake = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatcheryIntake&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;RejCracks&quot;) != null)&#xD;&#xA;        RejCracks = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejCracks&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;RejWhole&quot;) != null)&#xD;&#xA;        RejWhole = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejWhole&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;RejBroken&quot;) != null)&#xD;&#xA;        RejBroken = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejBroken&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;RejOther&quot;) != null)&#xD;&#xA;        RejOther = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejOther&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SellToLogistic&quot;) != null)&#xD;&#xA;        SellToLogistic = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellToLogistic&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SellOfHatEggs&quot;) != null)&#xD;&#xA;        SellOfHatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellOfHatEggs&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;EggsToCollage&quot;) != null)&#xD;&#xA;        EggsToCollage = Convert.ToDecimal(GetCurrentColumnValue(&quot;EggsToCollage&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;TransToHatchery&quot;) != null)&#xD;&#xA;        TransToHatchery = Convert.ToDecimal(GetCurrentColumnValue(&quot;TransToHatchery&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        SettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;St_RejCrack&quot;) != null)&#xD;&#xA;        St_RejCrack = Convert.ToDecimal(GetCurrentColumnValue(&quot;St_RejCrack&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;St_RejWhole&quot;) != null)&#xD;&#xA;        St_RejWhole = Convert.ToDecimal(GetCurrentColumnValue(&quot;St_RejWhole&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;St_RejBroken&quot;) != null)&#xD;&#xA;        St_RejBroken = Convert.ToDecimal(GetCurrentColumnValue(&quot;St_RejBroken&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;St_RejOther&quot;) != null)&#xD;&#xA;        St_RejOther = Convert.ToDecimal(GetCurrentColumnValue(&quot;St_RejOther&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;EggsToOffal&quot;) != null)&#xD;&#xA;        EggsToOffal = Convert.ToDecimal(GetCurrentColumnValue(&quot;EggsToOffal&quot;));&#xD;&#xA;    TotalStockGroup +=&#xD;&#xA;        OpenStockReceivingHall +&#xD;&#xA;        FarmIntake +&#xD;&#xA;        HatcheryIntake -&#xD;&#xA;        RejCracks -&#xD;&#xA;        RejWhole -&#xD;&#xA;        RejBroken -&#xD;&#xA;        RejOther -&#xD;&#xA;        SellToLogistic -&#xD;&#xA;        SellOfHatEggs -&#xD;&#xA;        EggsToCollage -&#xD;&#xA;        TransToHatchery -&#xD;&#xA;        SettedEggs -&#xD;&#xA;        St_RejCrack -&#xD;&#xA;        St_RejWhole -&#xD;&#xA;        St_RejBroken -&#xD;&#xA;        St_RejOther -&#xD;&#xA;        EggsToOffal;&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell69_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell69.Text = ToalRecGroup.ToString(&quot;0&quot;);&#xD;&#xA;      ToalRecGroup = 0; // reset for next group&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell45_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell45.Text = TotalRec.ToString(&quot;0&quot;);&#xD;&#xA;      TotalRec = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell44_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     decimal OpenStockReceivingHall = 0;&#xD;&#xA;    decimal FarmIntake = 0;&#xD;&#xA;    decimal HatcheryIntake = 0;&#xD;&#xA;    decimal RejCracks = 0;&#xD;&#xA;    decimal RejWhole = 0;&#xD;&#xA;    decimal RejBroken = 0;&#xD;&#xA;    decimal RejOther = 0;&#xD;&#xA;    decimal SellToLogistic = 0;&#xD;&#xA;    decimal SellOfHatEggs = 0;&#xD;&#xA;    decimal EggsToCollage = 0;&#xD;&#xA;    decimal TransToHatchery = 0;&#xD;&#xA;    decimal SettedEggs = 0;&#xD;&#xA;    decimal St_RejCrack = 0;&#xD;&#xA;    decimal St_RejWhole = 0;&#xD;&#xA;    decimal St_RejBroken = 0;&#xD;&#xA;    decimal St_RejOther = 0;&#xD;&#xA;    decimal EggsToOffal = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;OpenStockReceivingHall&quot;) != null)&#xD;&#xA;        OpenStockReceivingHall = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenStockReceivingHall&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FarmIntake&quot;) != null)&#xD;&#xA;        FarmIntake = Convert.ToDecimal(GetCurrentColumnValue(&quot;FarmIntake&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;HatcheryIntake&quot;) != null)&#xD;&#xA;        HatcheryIntake = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatcheryIntake&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;RejCracks&quot;) != null)&#xD;&#xA;        RejCracks = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejCracks&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;RejWhole&quot;) != null)&#xD;&#xA;        RejWhole = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejWhole&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;RejBroken&quot;) != null)&#xD;&#xA;        RejBroken = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejBroken&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;RejOther&quot;) != null)&#xD;&#xA;        RejOther = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejOther&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SellToLogistic&quot;) != null)&#xD;&#xA;        SellToLogistic = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellToLogistic&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SellOfHatEggs&quot;) != null)&#xD;&#xA;        SellOfHatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellOfHatEggs&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;EggsToCollage&quot;) != null)&#xD;&#xA;        EggsToCollage = Convert.ToDecimal(GetCurrentColumnValue(&quot;EggsToCollage&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;TransToHatchery&quot;) != null)&#xD;&#xA;        TransToHatchery = Convert.ToDecimal(GetCurrentColumnValue(&quot;TransToHatchery&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        SettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;St_RejCrack&quot;) != null)&#xD;&#xA;        St_RejCrack = Convert.ToDecimal(GetCurrentColumnValue(&quot;St_RejCrack&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;St_RejWhole&quot;) != null)&#xD;&#xA;        St_RejWhole = Convert.ToDecimal(GetCurrentColumnValue(&quot;St_RejWhole&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;St_RejBroken&quot;) != null)&#xD;&#xA;        St_RejBroken = Convert.ToDecimal(GetCurrentColumnValue(&quot;St_RejBroken&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;St_RejOther&quot;) != null)&#xD;&#xA;        St_RejOther = Convert.ToDecimal(GetCurrentColumnValue(&quot;St_RejOther&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;EggsToOffal&quot;) != null)&#xD;&#xA;        EggsToOffal = Convert.ToDecimal(GetCurrentColumnValue(&quot;EggsToOffal&quot;));&#xD;&#xA;&#xD;&#xA;    // Apply the equation&#xD;&#xA;    decimal result =&#xD;&#xA;        OpenStockReceivingHall +&#xD;&#xA;        FarmIntake +&#xD;&#xA;        HatcheryIntake -&#xD;&#xA;        RejCracks -&#xD;&#xA;        RejWhole -&#xD;&#xA;        RejBroken -&#xD;&#xA;        RejOther -&#xD;&#xA;        SellToLogistic -&#xD;&#xA;        SellOfHatEggs -&#xD;&#xA;        EggsToCollage -&#xD;&#xA;        TransToHatchery -&#xD;&#xA;        SettedEggs -&#xD;&#xA;        St_RejCrack -&#xD;&#xA;        St_RejWhole -&#xD;&#xA;        St_RejBroken -&#xD;&#xA;        St_RejOther -&#xD;&#xA;        EggsToOffal;&#xD;&#xA;&#xD;&#xA;    // If you want to accumulate for totals later:&#xD;&#xA;    TotalStock += result;&#xD;&#xA;&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;0&quot;); // no decimals, adjust as needed&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell84_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell84.Text = TotalStock.ToString(&quot;0&quot;);&#xD;&#xA;      TotalStock = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell68_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    xrTableCell68.Text = TotalStockGroup.ToString(&quot;0&quot;);&#xD;&#xA;    TotalStockGroup = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}" PageWidth="1169" PageHeight="1654" Version="24.2" DataMember="SR_HT_DailyEggStockSum" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
