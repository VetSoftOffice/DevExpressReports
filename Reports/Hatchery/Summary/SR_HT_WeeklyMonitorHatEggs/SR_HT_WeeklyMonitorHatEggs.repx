e(&quot;SampleQty&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---  &#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (sampleQty &gt; 0)&#xD;&#xA;    percentage = (bodyCheck * 100m) / sampleQty;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---  &#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;// --- Accumulate totals for weighted and simple average ---&#xD;&#xA;TotalBodyCheck += bodyCheck;&#xD;&#xA;TotalBodyCheckSampleQty += sampleQty;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell57_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Weighted BodyCheck % ---&#xD;&#xA;if (TotalBodyCheckSampleQty &gt; 0)&#xD;&#xA;    PercentageBodyCheck = (TotalBodyCheck / TotalBodyCheckSampleQty) * 100m;&#xD;&#xA;&#xD;&#xA;// --- Simple average of row percentages ---&#xD;&#xA;if (countRows  &gt; 0)&#xD;&#xA;    avgPercentageBodyCheck = PercentageBodyCheck / countRows;&#xD;&#xA;    &#xD;&#xA; xrTableCell57.Text = avgPercentageBodyCheck.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell28_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---  &#xD;&#xA;decimal wrinkled = 0;&#xD;&#xA;decimal sampleQty = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---  &#xD;&#xA;if (GetCurrentColumnValue(&quot;Wrinkled&quot;) != null)&#xD;&#xA;    wrinkled = Convert.ToDecimal(GetCurrentColumnValue(&quot;Wrinkled&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SampleQty&quot;) != null)&#xD;&#xA;    sampleQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;SampleQty&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---  &#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (sampleQty &gt; 0)&#xD;&#xA;    percentage = (wrinkled * 100m) / sampleQty;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---  &#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#