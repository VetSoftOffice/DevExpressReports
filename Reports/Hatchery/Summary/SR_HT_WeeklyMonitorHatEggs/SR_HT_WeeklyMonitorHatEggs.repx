xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;UpsideDown&quot;) != null)&#xD;&#xA;    upsideDown = Convert.ToDecimal(GetCurrentColumnValue(&quot;UpsideDown&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SampleQty&quot;) != null)&#xD;&#xA;    sampleQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;SampleQty&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (sampleQty &gt; 0)&#xD;&#xA;    percentage = (upsideDown * 100m) / sampleQty;&#xD;&#xA;&#xD;&#xA;// --- Add to report totals (for average) ---&#xD;&#xA;decimal UpsideDownPercReportSum = 0;&#xD;&#xA;int UpsideDownPercReportCount = 0;&#xD;&#xA;UpsideDownPercReportSum += percentage;   // keep sum of percentages&#xD;&#xA;UpsideDownPercReportCount++;             // count how many percentages added&#xD;&#xA;&#xD;&#xA;// --- Compute running average ---&#xD;&#xA;if (UpsideDownPercReportCount &gt; 0)&#xD;&#xA;    avgPercentageUpsideDown = UpsideDownPercReportSum / UpsideDownPercReportCount;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;private void xrTableCell65_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       xrTableCell65.Text = avgPercentageUpsideDown.ToString(&quot;N2&quot;);&#xD;&#xA;      avgPercentageUpsideDown = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;" PageWidth="2121" PageHeight="1169" Version="24.2" DataMember="SR_HT_WeeklyMonitorHatEggs" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
