omponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---  &#xD;&#xA;decimal wrinkled = 0;&#xD;&#xA;decimal sampleQty = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---  &#xD;&#xA;if (GetCurrentColumnValue(&quot;Wrinkled&quot;) != null)&#xD;&#xA;    wrinkled = Convert.ToDecimal(GetCurrentColumnValue(&quot;Wrinkled&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SampleQty&quot;) != null)&#xD;&#xA;    sampleQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;SampleQty&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---  &#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (sampleQty &gt; 0)&#xD;&#xA;    percentage = (wrinkled * 100m) / sampleQty;&#xD;&#xA;&#xD;&#xA;// --- Add to report totals (for average) ---  &#xD;&#xA;decimal WrinkledPercReportSum = 0;&#xD;&#xA;int WrinkledPercReportCount = 0;&#xD;&#xA;WrinkledPercReportSum += percentage;   // keep sum of percentages  &#xD;&#xA;WrinkledPercReportCount++;             // count how many percentages added  &#xD;&#xA;&#xD;&#xA;// --- Compute running average ---  &#xD;&#xA;if (WrinkledPercReportCount &gt; 0)&#xD;&#xA;    avgPercentageWrinkled = WrinkledPercReportSum / WrinkledPercReportCount;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---  &#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell59_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell59.Text = avgPercentageWrinkled.ToString(&quot;N2&quot;);&#xD;&#xA;          avgPercentageWrinkled = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell19_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---  &#xD;&#xA;decimal thinSpot = 0;&#xD;&#xA;decimal sampleQty = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---  &#xD;&#xA;if (GetCurrentColumnValue(&quot;ThinSpot&quot;) != null)&#xD;&#xA;    thinSpot = Convert.ToDecimal(GetCurrentColumnValue(&quot;ThinSpot&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SampleQty&quot;) != null)&#xD;&#xA;    sampleQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;SampleQty&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---  &#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (sampleQty &gt; 0)&#xD;&#xA;    percentage = (thinSpot * 100m) / sampleQty;&#xD;&#xA;&#xD;&#xA;// --- Add to report totals (for average) ---  &#xD;&#xA;decimal ThinSpotPercReportSum = 0;&#xD;&#xA;int ThinSpotPercReportCount = 0;&#xD;&#xA;ThinSpotPercReportSum += percentage;   // keep sum of percentages  &#xD;&#xA;ThinSpotPercReportCount++;             // count how many percentages added  &#xD;&#xA;&#xD;&#xA;// --- Compute running average ---  &#xD;&#xA;decimal avgPercentageThinSpot = 0;&#xD;&#xA;if (ThinSpotPercReportCount &gt; 0)&#xD;&#xA;    avgPercentageThinSpot = ThinSpotPercReportSum / ThinSpotPercReportCount;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---  &#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell61_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    xrTableCell61.Text = avgPercentageThinSpot.ToString(&quot;N2&quot;);&#xD;&#xA;    avgPercentageThinSpot = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell21_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal slabSides = 0;&#xD;&#xA;decimal bodyCheck = 0;&#xD;&#xA;decimal wrinkled = 0;&#xD;&#xA;decimal thinSpot = 0;&#xD;&#xA;decimal sampleQty = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SlabSides&quot;) != null)&#xD;&#xA;    slabSides = Convert.ToDecimal(GetCurrentColumnValue(&quot;SlabSides&quot;));&#xD;&#