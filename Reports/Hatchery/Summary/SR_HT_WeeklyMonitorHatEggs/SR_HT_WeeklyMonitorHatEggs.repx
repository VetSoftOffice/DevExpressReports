inedPercReportSum / StainedPercReportCount;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell43_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    xrTableCell43.Text = avgPercentageStained.ToString(&quot;0&quot;);&#xD;&#xA;    avgPercentageStained = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void tdDebit_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;// --- Declare values --- &#xD;&#xA;decimal adheringShaving = 0;&#xD;&#xA;decimal sampleQty = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;AdheringShaving&quot;) != null)&#xD;&#xA;    adheringShaving = Convert.ToDecimal(GetCurrentColumnValue(&quot;AdheringShaving&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SampleQty&quot;) != null)&#xD;&#xA;    sampleQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;SampleQty&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (sampleQty &gt; 0)&#xD;&#xA;    percentage = (adheringShaving * 100m) / sampleQty;&#xD;&#xA;&#xD;&#xA;// --- Add to report totals (for average) ---&#xD;&#xA;decimal AdheringShavingPercReportSum  = 0;&#xD;&#xA;int AdheringShavingPercReportCount = 0;&#xD;&#xA;AdheringShavingPercReportSum += percentage;   // keep sum of percentages&#xD;&#xA;AdheringShavingPercReportCount++;             // count how many percentages added&#xD;&#xA;&#xD;&#xA;// --- Compute running average ---&#xD;&#xA;if (AdheringShavingPercReportCount &gt; 0)&#xD;&#xA;    avgPercentageAdheringShaving = AdheringShavingPercReportSum / AdheringShavingPercReportCount;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToStri