  <CalculatedFields>
    <Item1 Ref="25" Name="TotalCostPerc_CF" DisplayName="TotalCostPerc_CF" Expression="(ToDecimal([TotalCost]) / ToDecimal(Sum([TotalCost])))*ToDecimal(100)&#xA;" DataMember="SR_FM_Stocktaking" />
    <Item2 Ref="26" Name="Per_Chick_CF" Expression="Iif([FemaleChicks]!=0,[TotalCost]/[FemaleChicks] ,[FemaleChicks] )" DataMember="SR_FM_Stocktaking" />
    <Item3 Ref="27" Name="PerHH_CF" DisplayName="PerHH_CF" Expression="Iif([FemalePOL]!=0,[TotalCost]/[FemalePOL] ,[FemalePOL] )&#xA;" DataMember="SR_FM_Stocktaking" />
    <Item4 Ref="28" Name="PerHE_CF" Expression="Iif([HatchingEggs]!=0,[TotalCost]/[HatchingEggs] ,[HatchingEggs] )&#xA;&#xA;" DataMember="SR_FM_Stocktaking" />
    <Item5 Ref="29" Name="DiffQtyq" Expression="IsNull([ActualQty], 0) - IsNull([SentOrClacQty], 0)" DataMember="SR_FM_Stocktaking" />
    <Item6 Ref="30" Name="DiffPriceq" Expression="Iif([CalcPriceUnit] &gt; 0, IsNull([AdjustedPriceUnit], 0) - IsNull([CalcPriceUnit], 0), 0)" DataMember="SR_FM_Stocktaking" />
    <Item7 Ref="31" Name="ActEggRecHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.ActRecEggs] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item8 Ref="32" Name="RejEggHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.RejEggs] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item9 Ref="33" Name="EstHatEggs" Expression="[ActEggRecHHCum] - [RejEggHHCum]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item10 Ref="34" Name="ActEggSetHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.ActSetEggCum] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item11 Ref="35" Name="EstHatEggsBefore21days" Expression="[SR_HT_WeeklyHHFlockSum.ActRecEggsBefore21days] - [SR_HT_WeeklyHHFlockSum.RejEggsBefore21days]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item12 Ref="36" Name="ActHatch_Per_Cum" Expression="Iif([SR_HT_WeeklyHHFlockSum.SettedEggs] &lt;&gt; 0, &#xD;&#xA;    ([SR_HT_WeeklyHHFlockSum.ActChicks] + [SR_HT_WeeklyHHFlockSum.CullsChicks] + [SR_HT_WeeklyHHFlockSum.DeadChicks]) &#xD;&#xA;    / [SR_HT_WeeklyHHFlockSum.SettedEggs] * 100, &#xD;&#xA;    0)&#xD;&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item13 Ref="37" Name="EstChiks" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &gt; 0, &#xA;    ([EstHatEggsBefore21days] * [ActHatch_Per_Cum] / 100) / [SR_HT_WeeklyHHFlockSum.POL], &#xA;    0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item14 Ref="38" Name="ActChicksHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, &#xD;&#xA;    ([SR_HT_WeeklyHHFlockSum.ActChicks] + [SR_HT_WeeklyHHFlockSum.CullsChicks] + [SR_HT_WeeklyHHFlockSum.DeadChicks]) &#xD;&#xA;    / [SR_HT_WeeklyHHFlockSum.POL], &#xD;&#xA;    0)&#xD;&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item15 Ref="39" Name="Diviation" Expression="[ActHatch_Per_Cum] - [SR_HT_WeeklyHHFlockSum.StdHatchCum]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item16 Ref="40" Name="TotalHatchedEggs" Expression="[ChicksSettedEggs]" DataMember="SR_HT_Production" />
    <Item17 Ref="41" Name="HatchPer" Expression="Iif([TotalHatchedEggs] &lt;&gt; 0, [SR_HT_Production.Chicks] * 100 / [TotalHatchedEggs], 0)&#xA;" DataMember="SR_HT_Production" />
    <Item18 Ref="42" Name="HOFPer" Expression="Iif([SR_HT_Production.FertPer] &lt;&gt; 0, [HatchPer] * 100.0 / [SR_HT_Production.FertPer], 0)&#xA;" DataMember="SR_HT_Production" />
    <Item19 Ref="43" Name="HatchPerc" Expression="Iif([SR_HT_Hatch.SettedEggs] &lt;&gt; 0, [SR_HT_Hatch.SellableChicks] * 100 / [SR_HT_Hatch.SettedEggs], 0)&#xA;" DataMember="SR_HT_Hatch" />
    <Item20 Ref="44" Name="HOFPerc" Expression="Iif([SR_HT_Hatch.FertPer] &lt;&gt; 0, [HatchPer] * 100.0 / [SR_HT_Hatch.FertPer], 0)&#xA;" DataMember="SR_HT_Hatch" />
    <Item21 Ref="45" Name="TotalHatchPerc" Expression="Iif(Sum([SR_HT_Hatch.SettedEggs]) &lt;&gt; 0, Sum([SR_HT_Hatch.SellableChicks]) * 100 / Sum([SR_HT_Hatch.SettedEggs]), 0)&#xA;" DataMember="SR_HT_Hatch" />
    <Item22 Ref="46" Name="FertileEggs_CF" Expression="[SR_HT_Hatch.FertPer] * [SR_HT_Hatch.SettedEggs] / 100&#xA;&#xA;" DataMember="SR_HT_Hatch" />
    <Item23 Ref="47" Name="FertPerc" Expression="Iif(Sum([SR_HT_Hatch.SettedEggs]) &lt;&gt; 0, Sum([FertileEggs]) * 100 / Sum([SR_HT_Hatch.SettedEggs]), 0)&#xA;" DataMember="SR_HT_Hatch" />
    <Item24 Ref="48" Name="TotalHOFPerc" Expression="Iif([FertPerc] &lt;&gt; 0, [TotalHatchPerc] * 100 / [FertPerc], 0)&#xA;" DataMember="SR_HT_Hatch" />
    <Item25 Ref="49" Name="Stained_Per" Expression="Iif([SR_HT_WeeklyMonitorHatEggs.SampleQty] &gt; 0, [SR_HT_WeeklyMonitorHatEggs.Stained] / [SR_HT_WeeklyMonitorHatEggs.SampleQty] * 100, 0)&#xA;" DataMember="SR_HT_WeeklyMonitorHatEggs" />
    <Item26 Ref="50" Name="sheving_Per" Expression="Iif([SR_HT_WeeklyMonitorHatEggs.SampleQty] &gt; 0, [SR_HT_WeeklyMonitorHatEggs.AdheringShaving] / [SR_HT_WeeklyMonitorHatEggs.SampleQty] * 100, 0)&#xA;" DataMember="SR_HT_WeeklyMonitorHatEggs" />
    <Item27 Ref="51" Name="Dirty_Per" Expression="Iif([SR_HT_WeeklyMonitorHatEggs.SampleQty] &gt; 0, [SR_HT_WeeklyMonitorHatEggs.DirtyEgg] / [SR_HT_WeeklyMonitorHatEggs.SampleQty] * 100, 0)&#xA;" DataMember="SR_HT_WeeklyMonitorHatEggs" />
    <Item28 Ref="52" Name="TotalDirty" Expression="[SR_HT_WeeklyMonitorHatEggs.Stained] + [SR_HT_WeeklyMonitorHatEggs.AdheringShaving] + [SR_HT_WeeklyMonitorHatEggs.DirtyEgg]&#xA;" DataMember="SR_HT_WeeklyMonitorHatEggs" />
    <Item29 Ref="53" Name="TDirtyper" Expression="Iif([SR_HT_WeeklyMonitorHatEggs.SampleQty] &gt; 0, [TotalDirty] / [SR_HT_WeeklyMonitorHatEggs.SampleQty] * 100, 0)&#xA;" DataMember="SR_HT_WeeklyMonitorHatEggs" />
    <Item30 Ref="54" Name="slapper" Expression="Iif([SR_HT_WeeklyMonitorHatEggs.SampleQty] &gt; 0, [SR_HT_WeeklyMonitorHatEggs.SlabSides] / [SR_HT_WeeklyMonitorHatEggs.SampleQty] * 100, 0)&#xA;" DataMember="SR_HT_WeeklyMonitorHatEggs" />
    <Item31 Ref="55" Name="body_Per" Expression="Iif([SR_HT_WeeklyMonitorHatEggs.SampleQty] &gt; 0, [SR_HT_WeeklyMonitorHatEggs.BodyCheck] / [SR_HT_WeeklyMonitorHatEggs.SampleQty] * 100, 0)&#xA;" DataMember="SR_HT_WeeklyMonitorHatEggs" />
    <Item32 Ref="56" Name="wrinked_Per" Expression="Iif([SR_HT_WeeklyMonitorHatEggs.SampleQty] &gt; 0, [SR_HT_WeeklyMonitorHatEggs.Wrinkled] / [SR_HT_WeeklyMonitorHatEggs.SampleQty] * 100, 0)&#xA;" DataMember="SR_HT_WeeklyMonitorHatEggs" />
    <Item33 Ref="57" Name="thin_Per" Expression="Iif([SR_HT_WeeklyMonitorHatEggs.SampleQty] &gt; 0, [SR_HT_WeeklyMonitorHatEggs.ThinSpot] / [SR_HT_WeeklyMonitorHatEggs.SampleQty] * 100, 0)&#xA;" DataMember="SR_HT_WeeklyMonitorHatEggs" />
    <Item34 Ref="58" Name="calculatedField2" DataMember="SR_HT_WeeklyMonitorHatEggs" />
    <Item35 Ref="59" Name="TotalRejEggs" Expression="[SR_HT_WeeklyMonitorHatEggs.SlabSides] + [SR_HT_WeeklyMonitorHatEggs.BodyCheck] + [SR_HT_WeeklyMonitorHatEggs.Wrinkled] + [SR_HT_WeeklyMonitorHatEggs.ThinSpot]&#xA;" DataMember="SR_HT_WeeklyMonitorHatEggs" />
    <Item36 Ref="60" Name="TotalRej_Per" Expression="Iif([SR_HT_WeeklyMonitorHatEggs.SampleQty] &gt; 0, [TotalRejEggs] / [SR_HT_WeeklyMonitorHatEggs.SampleQty] * 100, 0)&#xA;" DataMember="SR_HT_WeeklyMonitorHatEggs" />
    <Item37 Ref="61" Name="Updown_Per" Expression="Iif([SR_HT_WeeklyMonitorHatEggs.SampleQty] &gt; 0, [SR_HT_WeeklyMonitorHatEggs.UpsideDown] / [SR_HT_WeeklyMonitorHatEggs.SampleQty] * 100, 0)&#xA;" DataMember="SR_HT_WeeklyMonitorHatEggs" />
  </CalculatedFields>
