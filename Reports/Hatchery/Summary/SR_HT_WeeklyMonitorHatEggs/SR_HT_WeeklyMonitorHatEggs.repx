ntArgs e) {&#xD;&#xA;     xrTableCell47.Text = avgPercentageDirtyEgg.ToString(&quot;0&quot;);&#xD;&#xA;     avgPercentageDirtyEgg = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void tdCredit_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       // --- Declare values ---&#xD;&#xA;decimal stained = 0;&#xD;&#xA;decimal adheringShaving = 0;&#xD;&#xA;decimal dirtyEgg = 0;&#xD;&#xA;decimal sampleQty = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Stained&quot;) != null)&#xD;&#xA;    stained = Convert.ToDecimal(GetCurrentColumnValue(&quot;Stained&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;AdheringShaving&quot;) != null)&#xD;&#xA;    adheringShaving = Convert.ToDecimal(GetCurrentColumnValue(&quot;AdheringShaving&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DirtyEgg&quot;) != null)&#xD;&#xA;    dirtyEgg = Convert.ToDecimal(GetCurrentColumnValue(&quot;DirtyEgg&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SampleQty&quot;) != null)&#xD;&#xA;    sampleQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;SampleQty&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (sampleQty &gt; 0)&#xD;&#xA;    percentage = ((stained + adheringShaving + dirtyEgg) * 100m) / sampleQty;&#xD;&#xA;&#xD;&#xA;// --- Add to report totals (for average) ---&#xD;&#xA;decimal TotalSpecialEggsPercSum  = 0;&#xD;&#xA;int TotalSpecialEggsPercCount = 0;&#xD;&#xA;TotalSpecialEggsPercSum += percentage;   // sum of combined percentages&#xD;&#xA;TotalSpecialEggsPercCount++;             // count of rows&#xD;&#xA;&#xD;&#xA;// --- Compute running average ---&#xD;&#xA;if (TotalSpecialEggsPercCount &gt; 0)&#xD;&#xA;    avgPercentageTotalDirty = TotalSpecialEggsPercSum / TotalSpecialEggsPercCount;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToStr