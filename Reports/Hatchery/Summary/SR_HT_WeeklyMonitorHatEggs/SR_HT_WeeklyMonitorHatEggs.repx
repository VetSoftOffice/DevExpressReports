dheringShaving&quot;) != null)&#xD;&#xA;    adheringShaving = Convert.ToDecimal(GetCurrentColumnValue(&quot;AdheringShaving&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DirtyEgg&quot;) != null)&#xD;&#xA;    dirtyEgg = Convert.ToDecimal(GetCurrentColumnValue(&quot;DirtyEgg&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SampleQty&quot;) != null)&#xD;&#xA;    sampleQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;SampleQty&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;decimal totalSpecialRow = stained + adheringShaving + dirtyEgg;&#xD;&#xA;if (sampleQty &gt; 0)&#xD;&#xA;    percentage = ((stained + adheringShaving + dirtyEgg) * 100m) / sampleQty;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;// --- Weighted totals ---&#xD;&#xA;TotalSpecialEggs += totalSpecialRow;&#xD;&#xA;TotalSpecialEggsSampleQty += sampleQty;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell49_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Weighted Special Eggs % ---&#xD;&#xA;if (TotalSpecialEggsSampleQty &gt; 0)&#xD;&#xA;    PercentageSpecialEggs = (TotalSpecialEggs / TotalSpecialEggsSampleQty) * 100m;&#xD;&#xA;&#xD;&#xA;// --- Simple average of row percentages ---&#xD;&#xA;if (countRows &gt; 0)&#xD;&#xA;    avgPercentageSpecialEggs = PercentageSpecialEggs / countRows;&#xD;&#xA;    &#xD;&#xA;xrTableCell49.Text = avgPercentageTotalDirty.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell15_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---  &#xD;&#xA;decimal slabSides = 0;&#xD;&#xA;decimal sampleQty = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---  &#xD;&#xA;if (GetCurrentColumnValue(&quot;SlabSides&quot;) != null)&#xD;&#xA;    sla