0;&#xD;&#xA;decimal TotalStainedReport = 0;&#xD;&#xA;decimal TotalSampleQty = 0 ;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;double sample = Convert.ToDouble(GetCurrentColumnValue(&quot;SampleQty&quot;));&#xD;&#xA;double stained = Convert.ToDouble(GetCurrentColumnValue(&quot;Stained&quot;));&#xD;&#xA;&#xD;&#xA;if (sample &gt; 0)&#xD;&#xA;{&#xD;&#xA;    countRows++;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void tdCostCenter_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;  // --- Declare values ---&#xD;&#xA;decimal stained = 0;&#xD;&#xA;decimal sampleQty = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Stained&quot;) != null)&#xD;&#xA;    stained = Convert.ToDecimal(GetCurrentColumnValue(&quot;Stained&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SampleQty&quot;) != null)&#xD;&#xA;    sampleQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;SampleQty&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (sampleQty &gt; 0)&#xD;&#xA;    percentage = (stained * 100m) / sampleQty;&#xD;&#xA;&#xD;&#xA;// --- Add to report totals (for average) ---&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;TotalStainedReport += stained ;&#xD;&#xA;TotalSampleQty += sampleQty ;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell43_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Compute running average ---&#xD;&#xA;if (TotalSampleQty &gt; 0){&#xD;&#xA;    PercentageStained =( TotalStainedReport / TotalSampleQty) * 100m ;&#xD;&#xA;}&#xD;&#xA;if (countRows &gt; 0){&#xD;&#xA;    avgPercentageStained =( PercentageStained / countRows )  ;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;    x