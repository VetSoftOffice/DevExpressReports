eclare values ---  &#xD;&#xA;decimal dirtyEgg = 0;&#xD;&#xA;decimal sampleQty = 0;&#xD;&#xA;decimal DirtyEggPercReportCount = 0;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;DirtyEgg&quot;) != null)&#xD;&#xA;    dirtyEgg = Convert.ToDecimal(GetCurrentColumnValue(&quot;DirtyEgg&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SampleQty&quot;) != null)&#xD;&#xA;    sampleQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;SampleQty&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (sampleQty &gt; 0)&#xD;&#xA;    percentage = (dirtyEgg * 100m) / sampleQty;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;// --- Accumulate for weighted percentage ---&#xD;&#xA;TotalDirtyEgg += dirtyEgg;&#xD;&#xA;TotalDirtySampleQty += sampleQty;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell47_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Weighted percentage ---&#xD;&#xA;if (TotalDirtySampleQty &gt; 0)&#xD;&#xA;    PercentageDirtyEgg = (TotalDirtyEgg / TotalDirtySampleQty) * 100m;&#xD;&#xA;&#xD;&#xA;// --- Simple average ---&#xD;&#xA;if (countRows &gt; 0)&#xD;&#xA;    avgPercentageDirtyEgg = (PercentageDirtyEgg / countRows);&#xD;&#xA;    &#xD;&#xA; xrTableCell47.Text = avgPercentageDirtyEgg.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void tdCredit_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       // --- Declare values ---&#xD;&#xA;decimal stained = 0;&#xD;&#xA;decimal adheringShaving = 0;&#xD;&#xA;decimal dirtyEgg = 0;&#xD;&#xA;decimal sampleQty = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Stained&quot;) != null)&#xD;&#xA;    stained = Convert.ToDecimal(GetCurrentColumnValue(&q