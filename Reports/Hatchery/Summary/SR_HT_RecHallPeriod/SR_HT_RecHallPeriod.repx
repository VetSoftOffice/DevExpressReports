xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell62_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       xrTableCell62.Text = TotalDoubleYolkEggsReport.ToString(&quot;0&quot;);&#xD;&#xA;       TotalDoubleYolkEggsReport= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell51_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       // --- Declare values ---  &#xD;&#xA;decimal otherEggs = 0;&#xD;&#xA;decimal recEggs = 0;&#xD;&#xA;decimal totalPerc = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;OtherEggs&quot;) != null)&#xD;&#xA;    otherEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;OtherEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecEggs&quot;) != null)&#xD;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- IIf logic: OtherEggs % of RecEggs ---&#xD;&#xA;if (recEggs != 0)&#xD;&#xA;    totalPerc = (otherEggs * 100.0m / recEggs);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = string.Format(&quot;{0:N0}\n{1:N2}&quot;, otherEggs , totalPerc);&#xD;&#xA;// --- Add to group totals ---&#xD;&#xA;TotalRecEggs += recEggs ;&#xD;&#xA;TotalOtherEggs += otherEggs ;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell63_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    if(TotalRecEggs  != 0){&#xD;&#xA;        TotalOtherEggsReport = (TotalOtherEggs  * 100m) / TotalRecEggs ;&#xD;&#xA;        &#xD;&#xA;        }&#xD;&#xA;    xrTableCell63.Text = TotalOtherEggsReport.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell73_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;          // --- Declare values ---&#xD;&#xA