alPerc;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = string.Format(&quot;{0:N0}\n{1:N2}&quot;, destroyedEggs , totalPerc);&#xD;&#xA;// --- Add to group totals ---&#xD;&#xA;TotalReport += total;&#xD;&#xA;TotalPercReport += totalPerc;&#xD;&#xA;TotalDestroyedEggsReport = TotalReport + TotalPercReport;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell23_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell23.Text = TotalDestroyedEggsReport.ToString(&quot;0&quot;);&#xD;&#xA;      TotalDestroyedEggsReport= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell49_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       // --- Declare values --- &#xD;&#xA;decimal crackedEggs = 0;&#xD;&#xA;decimal recEggs = 0;&#xD;&#xA;decimal total = 0;&#xD;&#xA;decimal totalPerc = 0;&#xD;&#xA;decimal totalCrackedEggs = 0;&#xD;&#xA;decimal TotalReport  = 0;&#xD;&#xA;decimal TotalPercReport  = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CrackedEggs&quot;) != null)&#xD;&#xA;    crackedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;CrackedEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecEggs&quot;) != null)&#xD;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Base total (CrackedEggs) ---&#xD;&#xA;total = crackedEggs;&#xD;&#xA;&#xD;&#xA;// --- IIf logic: CrackedEggs % of RecEggs ---&#xD;&#xA;if (recEggs != 0)&#xD;&#xA;    totalPerc = (crackedEggs * 100.0m / recEggs);&#xD;&#xA;&#xD;&#xA;// --- Final sum ---&#xD;&#xA;totalCrackedEggs = total + totalPerc;&#xD;&#xA;&#xD;&#xA;;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = string.Format(&quot;{0:N0}\n{1:N2}&quot;, crackedEggs , totalPerc);&