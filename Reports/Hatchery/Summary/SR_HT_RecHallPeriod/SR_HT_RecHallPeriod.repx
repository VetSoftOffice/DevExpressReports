Eggs = total + totalPerc;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = string.Format(&quot;{0:N0}\n{1:N2}&quot;, destroyedEggs , totalPerc);&#xD;&#xA;// --- Add to group totals ---&#xD;&#xA;TotalReport += total;&#xD;&#xA;TotalPercReport += totalPerc;&#xD;&#xA;TotalDestroyedEggsReport = TotalReport + TotalPercReport;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell23_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell23.Text = TotalDestroyedEggsReport.ToString(&quot;0&quot;);&#xD;&#xA;      TotalDestroyedEggsReport= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell49_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       // --- Declare values --- &#xD;&#xA;decimal crackedEggs = 0;&#xD;&#xA;decimal recEggs = 0;&#xD;&#xA;decimal total = 0;&#xD;&#xA;decimal totalPerc = 0;&#xD;&#xA;decimal totalCrackedEggs = 0;&#xD;&#xA;decimal TotalReport  = 0;&#xD;&#xA;decimal TotalPercReport  = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CrackedEggs&quot;) != null)&#xD;&#xA;    crackedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;CrackedEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecEggs&quot;) != null)&#xD;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Base total (CrackedEggs) ---&#xD;&#xA;total = crackedEggs;&#xD;&#xA;&#xD;&#xA;// --- IIf logic: CrackedEggs % of RecEggs ---&#xD;&#xA;if (recEggs != 0)&#xD;&#xA;    totalPerc = (crackedEggs * 100.0m / recEggs);&#xD;&#xA;&#xD;&#xA;// --- Final sum ---&#xD;&#xA;totalCrackedEggs = total + totalPerc;&#xD;&#xA;&#xD;&#xA;;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = string.Format(&quot;{0:N0}\n{1:N2}&quot;, crackedEggs , totalPerc);&#xD;&#xA;// --- Add to group totals ---&#xD;&#xA;TotalReport += total;&#xD;&#xA;TotalPercReport += totalPerc;&#xD;&#xA;TotalCrackedEggsReport = TotalReport + TotalPercReport;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell61_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell61.Text = TotalCrackedEggsReport.ToString(&quot;0&quot;);&#xD;&#xA;       TotalCrackedEggsReport= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell50_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // --- Declare values ---  &#xD;&#xA;decimal doubleYolkEggs = 0;&#xD;&#xA;decimal recEggs = 0;&#xD;&#xA;decimal total = 0;&#xD;&#xA;decimal totalPerc = 0;&#xD;&#xA;decimal totalDoubleYolkEggs = 0;&#xD;&#xA;decimal TotalReport  = 0;&#xD;&#xA;decimal TotalPercReport  = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;DoubleYolkEggs&quot;) != null)&#xD;&#xA;    doubleYolkEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DoubleYolkEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecEggs&quot;) != null)&#xD;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Base total (DoubleYolkEggs) ---&#xD;&#xA;total = doubleYolkEggs;&#xD;&#xA;&#xD;&#xA;// --- IIf logic: DoubleYolkEggs % of RecEggs ---&#xD;&#xA;if (recEggs != 0)&#xD;&#xA;    totalPerc = (doubleYolkEggs * 100.0m / recEggs);&#xD;&#xA;&#xD;&#xA;// --- Final sum ---&#xD;&#xA;totalDoubleYolkEggs = total + totalPerc;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = string.Format(&quot;{0:N0}\n{1:N2}&quot;, doubleYolkEggs , totalPerc);&#xD;&#xA;// --- Add to group totals ---&#xD;&#xA;TotalReport += total;&#xD;&#xA;TotalPercReport += totalPerc;&#xD;&#xA;TotalDoubleYolkEggsReport = TotalReport + TotalPercReport;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell62_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       xrTableCell62.Text = TotalDoubleYolkEggsReport.ToString(&quot;0&quot;);&#xD;&#xA;       TotalDoubleYolkEggsReport= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell51_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       // --- Declare values ---  &#xD;&#xA;decimal otherEggs = 0;&#xD;&#xA;decimal recEggs = 0;&#xD;&#xA;decimal totalPerc = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;OtherEggs&quot;) != null)&#xD;&#xA;    otherEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;OtherEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecEggs&quot;) != null)&#xD;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- IIf logic: OtherEggs % of RecEggs ---&#xD;&#xA;if (recEggs != 0)&#xD;&#xA;    totalPerc = (otherEggs * 100.0m / recEggs);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = string.Format(&quot;{0:N0}\n{1:N2}&quot;, otherEggs , totalPerc);&#xD;&#xA;// --- Add to group totals ---&#xD;&#xA;TotalRecEggs += recEggs ;&#xD;&#xA;TotalOtherEggs += otherEggs ;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell63_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    if(TotalRecEggs  != 0){&#xD;&#xA;        TotalOtherEggsReport = (TotalOtherEggs  * 100m) / TotalRecEggs ;&#xD;&#xA;        &#xD;&#xA;        }&#xD;&#xA;    xrTableCell63.Text = TotalOtherEggsReport.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell73_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;          // --- Declare values ---&#xD;&#xA;decimal deformityEggs = 0;&#xD;&#xA;decimal recEggs = 0;&#xD;&#xA;decimal total = 0;&#xD;&#xA;decimal totalPerc = 0;&#xD;&#xA;decimal totalDeformityEggs = 0;&#xD;&#xA;decimal TotalReport  = 0;&#xD;&#xA;decimal TotalPercReport  = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;DeformityEggs&quot;) != null)&#xD;&#xA;    deformityEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeformityEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecEggs&quot;) != null)&#xD;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Base total (DeformityEggs) ---&#xD;&#xA;total = deformityEggs;&#xD;&#xA;&#xD;&#xA;// --- IIf logic: DeformityEggs % of RecEggs ---&#xD;&#xA;if (recEggs != 0)&#xD;&#xA;    totalPerc = (deformityEggs * 100.0m / recEggs);&#xD;&#xA;&#xD;&#xA;// --- Final sum ---&#xD;&#xA;totalDeformityEggs = total + totalPerc;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = totalPerc.ToString(&quot;N2&quot;); // no decimals&#xD;&#xA;&#xD;&#xA;// --- Add to group totals ---&#xD;&#xA;TotalReport += total;&#xD;&#xA;TotalPercReport += totalPerc;&#xD;&#xA;TotalDeformityEggsReport = TotalReport + TotalPercReport;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell40_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        decimal brokenEggs = 0;&#xD;&#xA;decimal recEggs = 0;&#xD;&#xA;decimal total = 0;&#xD;&#xA;decimal totalPerc = 0;&#xD;&#xA;decimal totalBrokenEggs = 0;&#xD;&#xA;decimal TotalReport  = 0;&#xD;&#xA;decimal TotalPercReport  = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;BrokenEggs&quot;) != null)&#xD;&#xA;    brokenEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;BrokenEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecEggs&quot;) != null)&#xD;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Base total (BrokenEggs) ---&#xD;&#xA;total = brokenEggs;&#xD;&#xA;&#xD;&#xA;// --- IIf logic: BrokenEggs % of RecEggs ---&#xD;&#xA;if (recEggs != 0)&#xD;&#xA;    totalPerc = (brokenEggs * 100.0m / recEggs);&#xD;&#xA;&#xD;&#xA;// --- Final sum ---&#xD;&#xA;totalBrokenEggs = total + totalPerc;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = string.Format(&quot;{0:N0}\n{1:N2}&quot;, brokenEggs, totalPerc);&#xD;&#xA;// --- Add to group totals ---&#xD;&#xA;TotalReport += total;&#xD;&#xA;TotalPercReport += totalPerc;&#xD;&#xA;TotalBrokenEggsReport = TotalReport + TotalPercReport;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell88_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;          xrTableCell88.Text = TotalPercGroup.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;    &#xD;&#xA;private void xrTableCell90_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      if(TotalRecEggsHatchGroup != 0){&#xD;&#xA;        TotalhatchingEggsGroupPerc = (TotalhatchingEggsGroup  * 100m) / TotalRecEggsHatchGroup ;&#xD;&#xA;                }&#xD;&#xA;      xrTableCell90.Text = TotalhatchingEggsGroupPerc.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void GroupHeader1_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    Total = 0;&#xD;&#xA;    TotalhatchingEggsGroup   = 0;&#xD;&#xA;    TotalRecEggsHatchGroup = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell33_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;            // --- Declare values ---&#xD;&#xA;decimal deformityEggs = 0;&#xD;&#xA;decimal recEggs = 0;&#xD;&#xA;decimal total = 0;&#xD;&#xA;decim