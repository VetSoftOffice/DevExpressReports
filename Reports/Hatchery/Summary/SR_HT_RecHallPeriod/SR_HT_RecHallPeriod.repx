ackedEggs&quot;) != null)&#xD;&#xA;    minorCrackedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;MinorCrackedEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;MajorCrackedEggs&quot;) != null)&#xD;&#xA;    majorCrackedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;MajorCrackedEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;ThinShellEggs&quot;) != null)&#xD;&#xA;    thinShellEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;ThinShellEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;OtherEggs&quot;) != null)&#xD;&#xA;    otherEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;OtherEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;WholeEggs&quot;) != null)&#xD;&#xA;    wholeEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;WholeEggs&quot;));&#xD;&#xA;    &#xD;&#xA;if (GetCurrentColumnValue(&quot;RecEggs&quot;) != null)&#xD;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;BrokenEggs&quot;) != null)&#xD;&#xA;    brokenEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;BrokenEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SmallEggs&quot;) != null)&#xD;&#xA;    smallEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SmallEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;OverWeightEggs&quot;) != null)&#xD;&#xA;    overWeightEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;OverWeightEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DirtyEggs&quot;) != null)&#xD;&#xA;    dirtyEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DirtyEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DeformityEggs&quot;) != null)&#xD;&#xA;    deformityEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeformityEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CrackedEggs&quot;) != null)&#xD;&#xA;    crackedEggs = Convert.ToDecimal(GetCurrentColum