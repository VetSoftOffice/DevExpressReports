D;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Base total (BrokenEggs) ---&#xD;&#xA;total = brokenEggs;&#xD;&#xA;&#xD;&#xA;// --- IIf logic: BrokenEggs % of RecEggs ---&#xD;&#xA;if (recEggs != 0)&#xD;&#xA;    totalPerc = (brokenEggs * 100.0m / recEggs);&#xD;&#xA;&#xD;&#xA;// --- Final sum ---&#xD;&#xA;totalBrokenEggs = total + totalPerc;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = string.Format(&quot;{0:N0}\n{1:N2}&quot;, brokenEggs, totalPerc);&#xD;&#xA;// --- Add to group totals ---&#xD;&#xA;TotalReport += total;&#xD;&#xA;TotalPercReport += totalPerc;&#xD;&#xA;TotalBrokenEggsReport = TotalReport + TotalPercReport;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell88_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;          xrTableCell88.Text = TotalPercGroup.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;    &#xD;&#xA;private void xrTableCell90_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      if(TotalRecEggsHatchGroup != 0){&#xD;&#xA;        TotalhatchingEggsGroupPerc = (TotalhatchingEggsGroup  * 100m) / TotalRecEggsHatchGroup ;&#xD;&#xA;                }&#xD;&#xA;      xrTableCell90.Text = TotalhatchingEggsGroupPerc.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;" PageWidth="1169" PageHeight="1654" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="24.2" DataMember="SR_HT_RecHall" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
