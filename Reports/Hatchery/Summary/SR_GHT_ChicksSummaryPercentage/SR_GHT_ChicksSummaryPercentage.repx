<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_GHT_ChicksSummaryPercentage" ScriptsSource="decimal groupSumChicks = 0;&#xD;&#xA;decimal groupSumCullsDead = 0;&#xD;&#xA;decimal groupSumOfCullsDead = 0;&#xD;&#xA;decimal groupSumOfTotalLoss = 0;&#xD;&#xA;decimal groupSumOftotalCullsDead = 0;&#xD;&#xA;decimal groupresultOfTotal = 0;&#xD;&#xA;decimal groupresultOfTotalLoss = 0;&#xD;&#xA;decimal groupSettedEggs = 0;&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;decimal percentageBroiler = 0;&#xD;&#xA;decimal percentageDestroyed = 0;&#xD;&#xA;decimal percentageUnHatEggs = 0;&#xD;&#xA;decimal percentageTotalLoss = 0;&#xD;&#xA;decimal percentageTotal = 0;&#xD;&#xA;decimal fChicksGroup  = 0;&#xD;&#xA;decimal mChicksGroup  = 0;&#xD;&#xA;decimal FChicksGroupBreeder = 0;&#xD;&#xA;decimal MChicksGroupBreeder = 0;&#xD;&#xA;decimal TotalChicksGroupBreeder = 0;&#xD;&#xA;decimal percentageBreeder =0;&#xD;&#xA;private void xrTableCell30_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    decimal fChicks = 0;&#xD;&#xA;    decimal mChicks = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FChicks&quot;) != null &amp;&amp; !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;FChicks&quot;).ToString()))&#xD;&#xA;        fChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;FChicks&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;MChicks&quot;) != null &amp;&amp; !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;MChicks&quot;).ToString()))&#xD;&#xA;        mChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;MChicks&quot;));&#xD;&#xA;&#xD;&#xA;    decimal result = fChicks + mChicks;&#xD;&#xA;&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;); &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    decimal fChicks = 0, mChicks = 0, settedEggs = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FChicks&quot;) != null &amp;&amp; !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;FChicks&quot;).ToString()))&#xD;&#xA;        fChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;FChicks&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;MChicks&quot;) != null &amp;&amp; !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;MChicks&quot;).ToString()))&#xD;&#xA;        mChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;MChicks&quot;));&#xD;&#xA;&#xD;&#xA;    fChicksGroup += fChicks ;&#xD;&#xA;    mChicksGroup += mChicks ;&#xD;&#xA;    groupSumChicks = (fChicksGroup + mChicksGroup);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp; !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;        settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    groupSettedEggs += settedEggs;&#xD;&#xA;&#xD;&#xA;    if (groupSettedEggs != 0)&#xD;&#xA;        percentage = (groupSumChicks * 100m) / groupSettedEggs;&#xD;&#xA;        &#xD;&#xA;    // new logic for Qty Perc of Breeder&#xD;&#xA;    &#xD;&#xA;    decimal FChiks = 0;&#xD;&#xA;    decimal MChiks = 0;&#xD;&#xA;    decimal SettedEggsBreeder  = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FChicks&quot;) != null)&#xD;&#xA;        FChiks = Convert.ToDecimal(GetCurrentColumnValue(&quot;FChicks&quot;));&#xD;&#xA;        &#xD;&#xA;    if (GetCurrentColumnValue(&quot;MChicks&quot;) != null)&#xD;&#xA;        MChiks = Convert.ToDecimal(GetCurrentColumnValue(&quot;MChicks&quot;));&#xD;&#xA;    &#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        SettedEggsBreeder = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;        &#xD;&#xA;    FChicksGroupBreeder += FChiks ;&#xD;&#xA;    MChicksGroupBreeder += MChiks ;&#xD;&#xA;    TotalChicksGroupBreeder = FChicksGroupBreeder  + MChicksGroupBreeder ;&#xD;&#xA;    if (TotalChicksGroupBreeder != 0)&#xD;&#xA;        percentageBreeder = (TotalChicksGroupBreeder * 100m) / SettedEggsBreeder ;&#xD;&#xA;&#xD;&#xA;    decimal DestroyedEggs = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;DestroyedEggs&quot;) != null &amp;&amp; !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;DestroyedEggs&quot;).ToString()))&#xD;&#xA;        DestroyedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DestroyedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    if (groupSettedEggs != 0)&#xD;&#xA;        percentageDestroyed = (DestroyedEggs * 100m) / groupSettedEggs;&#xD;&#xA;&#xD;&#xA;    decimal UnHatEggs = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;UnHatEggs&quot;) != null &amp;&amp; !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;UnHatEggs&quot;).ToString()))&#xD;&#xA;        UnHatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;UnHatEggs&quot;));&#xD;&#xA;&#xD;&#xA;    if (groupSettedEggs != 0)&#xD;&#xA;        percentageUnHatEggs = (UnHatEggs * 100m) / groupSettedEggs;&#xD;&#xA;&#xD;&#xA;    decimal fCulls = 0, mCulls = 0, fDead = 0, mDead = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FCulls&quot;) != null)&#xD;&#xA;        fCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;FCulls&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;MCulls&quot;) != null)&#xD;&#xA;        mCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;MCulls&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FDead&quot;) != null)&#xD;&#xA;        fDead = Convert.ToDecimal(GetCurrentColumnValue(&quot;FDead&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;MDead&quot;) != null)&#xD;&#xA;        mDead = Convert.ToDecimal(GetCurrentColumnValue(&quot;MDead&quot;));&#xD;&#xA;&#xD;&#xA;    groupSumCullsDead += (fCulls + mCulls + fDead + mDead);&#xD;&#xA;&#xD;&#xA;    decimal Culls = 0, Dead = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;        Culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Dead&quot;) != null)&#xD;&#xA;        Dead = Convert.ToDecimal(GetCurrentColumnValue(&quot;Dead&quot;));&#xD;&#xA;&#xD;&#xA;    groupSumOfCullsDead += (Culls + Dead);&#xD;&#xA;&#xD;&#xA;    groupSumOftotalCullsDead = groupSumCullsDead + groupSumOfCullsDead;&#xD;&#xA;&#xD;&#xA;    groupSumOfTotalLoss += (UnHatEggs + DestroyedEggs);&#xD;&#xA;&#xD;&#xA;    groupresultOfTotalLoss = groupSumOftotalCullsDead + groupSumOfTotalLoss;&#xD;&#xA;&#xD;&#xA;    if (groupSettedEggs != 0)&#xD;&#xA;        percentageTotalLoss = (groupresultOfTotalLoss * 100m) / groupSettedEggs;&#xD;&#xA;&#xD;&#xA;    decimal ChicksVal = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Chicks&quot;) != null)&#xD;&#xA;        ChicksVal = Convert.ToDecimal(GetCurrentColumnValue(&quot;Chicks&quot;));&#xD;&#xA;&#xD;&#xA;    groupresultOfTotal = ChicksVal + groupSumOfTotalLoss + groupSumCullsDead + groupSumChicks;&#xD;&#xA;&#xD;&#xA;    if (groupSettedEggs != 0)&#xD;&#xA;        percentageTotal = (groupresultOfTotal * 100m) / groupSettedEggs;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell55_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = groupSumChicks.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell56_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = percentageBreeder.ToString(&quot;0.00&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell58_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = percentageBroiler.ToString(&quot;0.00&quot;);&#xD;&#xA;    percentageBroiler = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell59_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = percentageDestroyed.ToString(&quot;0.00&quot;);&#xD;&#xA;    percentageDestroyed = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell61_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = percentageUnHatEggs.ToString(&quot;0.00&quot;);&#xD;&#xA;    percentageUnHatEggs = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell63_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = groupSumCullsDead.ToString(&quot;0&quot;);&#xD;&#xA;    groupSumCullsDead = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell64_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = groupSumOfCullsDead.ToString(&quot;0&quot;);&#xD;&#xA;    groupSumOfCullsDead = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell65_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = groupresultOfTotalLoss.ToString(&quot;0&quot;);&#xD;&#xA;    groupresultOfTotalLoss = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell66_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = percentageTotalLoss.ToString(&quot;0.00&quot;);&#xD;&#xA;    percentageTotalLoss = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell67_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = groupresultOfTotal.ToString(&quot;0&quot;);&#xD;&#xA;    groupresultOfTotal = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell68_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = percentageTotal.ToString(&quot;0.00&quot;);&#xD;&#xA;    percentageTotal = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell31_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal fChicks = 0;&#xD;&#xA;    decimal mChicks = 0;&#xD;&#xA;    decimal SettedEggs = 0;&#xD;&#xA;    decimal result = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FChicks&quot;) != null &amp;&amp; !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;FChicks&quot;).ToString()))&#xD;&#xA;        fChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;FChicks&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;MChicks&quot;) != null &amp;&amp; !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;MChicks&quot;).ToString()))&#xD;&#xA;        mChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;MChicks&quot;));&#xD;&#xA;        &#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        SettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;    &#xD;&#xA;    if (SettedEggs != 0)&#xD;&#xA;    result = ((fChicks  + mChicks) *100)/ SettedEggs ;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;); &#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;" PageWidth="1169" PageHeight="1654" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="24.2" DataMember="SR_GHT_ChicksSummary" DataSource="#Ref-0" TextAlignment=