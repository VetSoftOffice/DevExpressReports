 &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;MChicks&quot;).ToString()))&#xD;&#xA;    mChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;MChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Total ---&#xD;&#xA;decimal total =&#xD;&#xA;    chicks + destroyedEggs + unHatEggs +&#xD;&#xA;    fCulls + mCulls + fDead + mDead +&#xD;&#xA;    culls + dead + fChicks + mChicks;&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;if (settedEggs != 0)&#xD;&#xA;    result = (total * 100m) / settedEggs;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell62_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      if (groupSettedEggs != 0)&#xD;&#xA;        percentageUnHatEggs = (GroupUnHatEggs * 100m) / groupSettedEggs;&#xD;&#xA;        &#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = percentageUnHatEggs.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;" PageWidth="1169" PageHeight="1654" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="24.2" DataMember="SR_GHT_ChicksSummary" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
