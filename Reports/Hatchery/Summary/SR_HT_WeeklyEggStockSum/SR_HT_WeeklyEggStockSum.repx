<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_WeeklyEggStockSum" ScriptsSource="decimal rejOtherReport  =0;&#xD;&#xA;decimal stRejOtherReport  = 0;&#xD;&#xA;decimal TotalRejOtherReport =0;&#xD;&#xA;decimal rejOther  = 0;&#xD;&#xA;decimal stRejOther  = 0;&#xD;&#xA;decimal rejCracks = 0;&#xD;&#xA;decimal stRejCrack = 0;&#xD;&#xA;decimal TotalRejCracksReport = 0;&#xD;&#xA;decimal rejCracksReport  = 0;&#xD;&#xA;decimal stRejCrackReport = 0;&#xD;&#xA;decimal rejBroken = 0;&#xD;&#xA;decimal stRejBroken = 0;&#xD;&#xA;decimal TotalRejBrokenReport = 0;&#xD;&#xA;decimal rejBrokenReport  = 0;&#xD;&#xA;decimal stRejBrokenReport  = 0;&#xD;&#xA;decimal rejWhole = 0;&#xD;&#xA;decimal stRejWhole  = 0;&#xD;&#xA;decimal rejWholeReport  =0;&#xD;&#xA;decimal stRejWholeReport  = 0;&#xD;&#xA;decimal TotalRejWholeReport = 0;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    //RejOther Logic&#xD;&#xA;    // --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;RejOther&quot;) != null)&#xD;&#xA;    rejOther = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejOther&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;St_RejOther&quot;) != null)&#xD;&#xA;    stRejOther = Convert.ToDecimal(GetCurrentColumnValue(&quot;St_RejOther&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation: Sum of both fields ---&#xD;&#xA;rejOtherReport += rejOther ;&#xD;&#xA;stRejOtherReport += stRejOther ;&#xD;&#xA;&#xD;&#xA;//Rej Crack Logic&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;RejCracks&quot;) != null)&#xD;&#xA;    rejCracks = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejCracks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;St_RejCrack&quot;) != null)&#xD;&#xA;    stRejCrack = Convert.ToDecimal(GetCurrentColumnValue(&quot;St_RejCrack&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation: Sum of both fields ---&#xD;&#xA;rejCracksReport += rejCracks ;&#xD;&#xA;stRejCrackReport += stRejCrack ;&#xD;&#xA;&#xD;&#xA;//Logic for RejBroken Logic&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;RejBroken&quot;) != null)&#xD;&#xA;    rejBroken = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejBroken&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;St_RejBroken&quot;) != null)&#xD;&#xA;    stRejBroken = Convert.ToDecimal(GetCurrentColumnValue(&quot;St_RejBroken&quot;));&#xD;&#xA;&#xD;&#xA;rejBrokenReport += rejBroken ;&#xD;&#xA;stRejBrokenReport += stRejBroken ;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;//RejWhole Logic&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;RejWhole&quot;) != null)&#xD;&#xA;    rejWhole = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejWhole&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;St_RejWhole&quot;) != null)&#xD;&#xA;    stRejWhole = Convert.ToDecimal(GetCurrentColumnValue(&quot;St_RejWhole&quot;));&#xD;&#xA;rejWholeReport += rejWhole;&#xD;&#xA;stRejWholeReport += stRejWhole;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell61_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;&#xD;&#xA;// --- Add to report totals (for overall sum if needed) ---&#xD;&#xA;TotalRejBrokenReport = rejBrokenReport  + stRejBrokenReport ;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = TotalRejBrokenReport.ToString(&quot;N0&quot;); // no decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell60_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;&#xD;&#xA;// --- Add to report totals (for overall sum if needed) ---&#xD;&#xA;TotalRejWholeReport = rejWholeReport  + stRejWholeReport ;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = TotalRejWholeReport.ToString(&quot;N0&quot;); // no decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell63_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;&#xD;&#xA;// --- Add to report totals (for overall sum if needed) ---&#xD;&#xA;TotalRejCracksReport = rejCracksReport   + stRejCrackReport  ;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = TotalRejCracksReport.ToString(&quot;N0&quot;); // no decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void tdDebit_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Get the current cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// --- Read value safely ---&#xD;&#xA;decimal openStockReceivingHall = 0;&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;OpenStockReceivingHall&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;OpenStockReceivingHall&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    openStockReceivingHall = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenStockReceivingHall&quot;));&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    openStockReceivingHall = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Assign the value to the cell ---&#xD;&#xA;cell.Text = openStockReceivingHall.ToString(&quot;N2&quot;); // Format with 2 decimal places&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell62_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;&#xD;&#xA;// --- Add to report totals (for overall sum if needed) ---&#xD;&#xA;TotalRejOtherReport = rejOtherReport + stRejOtherReport ;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = TotalRejOtherReport.ToString(&quot;N0&quot;); // no decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;" PageWidth="1169" PageHeight="1654" Version="24.2" DataMember="SR_HT_WeeklyEggStockSum" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
