  <CalculatedFields>
    <Item1 Ref="33" Name="TotalCostPerc_CF" DisplayName="TotalCostPerc_CF" Expression="(ToDecimal([TotalCost]) / ToDecimal(Sum([TotalCost])))*ToDecimal(100)&#xA;" DataMember="SR_FM_Stocktaking" />
    <Item2 Ref="34" Name="Per_Chick_CF" Expression="Iif([FemaleChicks]!=0,[TotalCost]/[FemaleChicks] ,[FemaleChicks] )" DataMember="SR_FM_Stocktaking" />
    <Item3 Ref="35" Name="PerHH_CF" DisplayName="PerHH_CF" Expression="Iif([FemalePOL]!=0,[TotalCost]/[FemalePOL] ,[FemalePOL] )&#xA;" DataMember="SR_FM_Stocktaking" />
    <Item4 Ref="36" Name="PerHE_CF" Expression="Iif([HatchingEggs]!=0,[TotalCost]/[HatchingEggs] ,[HatchingEggs] )&#xA;&#xA;" DataMember="SR_FM_Stocktaking" />
    <Item5 Ref="37" Name="DiffQtyq" Expression="IsNull([ActualQty], 0) - IsNull([SentOrClacQty], 0)" DataMember="SR_FM_Stocktaking" />
    <Item6 Ref="38" Name="DiffPriceq" Expression="Iif([CalcPriceUnit] &gt; 0, IsNull([AdjustedPriceUnit], 0) - IsNull([CalcPriceUnit], 0), 0)" DataMember="SR_FM_Stocktaking" />
    <Item7 Ref="39" Name="ActEggRecHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.ActRecEggs] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item8 Ref="40" Name="RejEggHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.RejEggs] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item9 Ref="41" Name="EstHatEggs" Expression="[ActEggRecHHCum] - [RejEggHHCum]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item10 Ref="42" Name="ActEggSetHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.ActSetEggCum] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item11 Ref="43" Name="EstHatEggsBefore21days" Expression="[SR_HT_WeeklyHHFlockSum.ActRecEggsBefore21days] - [SR_HT_WeeklyHHFlockSum.RejEggsBefore21days]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item12 Ref="44" Name="ActHatch_Per_Cum" Expression="Iif([SR_HT_WeeklyHHFlockSum.SettedEggs] &lt;&gt; 0, &#xD;&#xA;    ([SR_HT_WeeklyHHFlockSum.ActChicks] + [SR_HT_WeeklyHHFlockSum.CullsChicks] + [SR_HT_WeeklyHHFlockSum.DeadChicks]) &#xD;&#xA;    / [SR_HT_WeeklyHHFlockSum.SettedEggs] * 100, &#xD;&#xA;    0)&#xD;&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item13 Ref="45" Name="EstChiks" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &gt; 0, &#xA;    ([EstHatEggsBefore21days] * [ActHatch_Per_Cum] / 100) / [SR_HT_WeeklyHHFlockSum.POL], &#xA;    0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item14 Ref="46" Name="ActChicksHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, &#xD;&#xA;    ([SR_HT_WeeklyHHFlockSum.ActChicks] + [SR_HT_WeeklyHHFlockSum.CullsChicks] + [SR_HT_WeeklyHHFlockSum.DeadChicks]) &#xD;&#xA;    / [SR_HT_WeeklyHHFlockSum.POL], &#xD;&#xA;    0)&#xD;&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item15 Ref="47" Name="Diviation" Expression="[ActHatch_Per_Cum] - [SR_HT_WeeklyHHFlockSum.StdHatchCum]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item16 Ref="48" Name="TotalHatchedEggs" Expression="[ChicksSettedEggs]" DataMember="SR_HT_Production" />
    <Item17 Ref="49" Name="HatchPer" Expression="Iif([TotalHatchedEggs] &lt;&gt; 0, [SR_HT_Production.Chicks] * 100 / [TotalHatchedEggs], 0)&#xA;" DataMember="SR_HT_Production" />
    <Item18 Ref="50" Name="HOFPer" Expression="Iif([SR_HT_Production.FertPer] &lt;&gt; 0, [HatchPer] * 100.0 / [SR_HT_Production.FertPer], 0)&#xA;" DataMember="SR_HT_Production" />
    <Item19 Ref="51" Name="Day" Expression="Iif(GetDayOfWeek([SR_HT_ExpectedHatch.ExitDate]) &lt;&gt; 0,&#xD;&#xA;    Iif(GetDayOfWeek([SR_HT_ExpectedHatch.ExitDate]) = 1, 'Monday',&#xD;&#xA;    Iif(GetDayOfWeek([SR_HT_ExpectedHatch.ExitDate]) = 2, 'Tuesday',&#xD;&#xA;    Iif(GetDayOfWeek([SR_HT_ExpectedHatch.ExitDate]) = 3, 'Wednesday',&#xD;&#xA;    Iif(GetDayOfWeek([SR_HT_ExpectedHatch.ExitDate]) = 4, 'Thursday',&#xD;&#xA;    Iif(GetDayOfWeek([SR_HT_ExpectedHatch.ExitDate]) = 5, 'Friday',&#xD;&#xA;    Iif(GetDayOfWeek([SR_HT_ExpectedHatch.ExitDate]) = 6, 'Saturday', 'Sunday')))))),&#xD;&#xA;    ''&#xD;&#xA;)&#xD;&#xA;&#xD;&#xA;" DataMember="SR_HT_ExpectedHatch" />
    <Item20 Ref="52" Name="QtySold" Expression="[SR_HT_BroilerChicks.Broiler] + [SR_HT_BroilerChicks.Female] + [SR_HT_BroilerChicks.Male]&#xA;" DataMember="SR_HT_BroilerChicks" />
    <Item21 Ref="53" Name="TotalStock" Expression="Iif(IsNull([OpenStockReceivingHall]), 0, [OpenStockReceivingHall]) +&#xD;&#xA;Iif(IsNull([FarmIntake]), 0, [FarmIntake]) +&#xD;&#xA;Iif(IsNull([HatcheryIntake]), 0, [HatcheryIntake]) -&#xD;&#xA;Iif(IsNull([RejCracks]), 0, [RejCracks]) -&#xD;&#xA;Iif(IsNull([RejWhole]), 0, [RejWhole]) -&#xD;&#xA;Iif(IsNull([RejBroken]), 0, [RejBroken]) -&#xD;&#xA;Iif(IsNull([RejOther]), 0, [RejOther]) -&#xD;&#xA;Iif(IsNull([SellToLogistic]), 0, [SellToLogistic]) -&#xD;&#xA;Iif(IsNull([SellOfHatEggs]), 0, [SellOfHatEggs]) -&#xD;&#xA;Iif(IsNull([SendToCollage]), 0, [SendToCollage]) -&#xD;&#xA;Iif(IsNull([TransToHatchery]), 0, [TransToHatchery]) -&#xD;&#xA;Iif(IsNull([SettedEggs]), 0, [SettedEggs]) -&#xD;&#xA;Iif(IsNull([St_RejCrack]), 0, [St_RejCrack]) -&#xD;&#xA;Iif(IsNull([St_RejWhole]), 0, [St_RejWhole]) -&#xD;&#xA;Iif(IsNull([St_RejBroken]), 0, [St_RejBroken]) -&#xD;&#xA;Iif(IsNull([St_RejOther]), 0, [St_RejOther]) -&#xD;&#xA;Iif(IsNull([EggsToOffal]), 0, [EggsToOffal])&#xD;&#xA;" DataMember="SR_HT_WeeklyEggStockSum" />
    <Item22 Ref="54" Name="RejCrack" Expression="Sum([RejCracks]) + Sum([St_RejCrack])&#xA;" DataMember="SR_HT_WeeklyEggStockSum" />
    <Item23 Ref="55" Name="RejBroken_CF" Expression="Sum([RejBroken]) + Sum([St_RejBroken])&#xA;" DataMember="SR_HT_WeeklyEggStockSum" />
    <Item24 Ref="56" Name="RejOther_CF" Expression="Sum([RejOther]) + Sum([St_RejOther])&#xA;" DataMember="SR_HT_WeeklyEggStockSum" />
    <Item25 Ref="57" Name="RejWhole_CF" Expression="Sum([RejWhole]) + Sum([St_RejWhole])&#xA;" DataMember="SR_HT_WeeklyEggStockSum" />
  </CalculatedFields>
