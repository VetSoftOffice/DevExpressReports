TotalPercentageSellableChicks.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell49_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // --- Declare values ---&#xD;&#xA;decimal fertileEggs = 0;&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;&#xD;&#xA;// --- Accumulators for totals ---&#xD;&#xA;decimal totalReportFertileEggs = 0;&#xD;&#xA;decimal totalReportSettedEggs = 0;&#xD;&#xA;&#xD;&#xA;// --- FertileEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;FertileEggs&quot;) != null)&#xD;&#xA;    fertileEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;FertileEggs&quot;));&#xD;&#xA;    totalReportFertileEggs += fertileEggs;&#xD;&#xA;&#xD;&#xA;// --- SettedEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;    totalReportSettedEggs += settedEggs;&#xD;&#xA;&#xD;&#xA;// --- Total percentage ---&#xD;&#xA;if (totalReportSettedEggs != 0)&#xD;&#xA;    TotalPercentageFertileEggs = (totalReportFertileEggs * 100m) / totalReportSettedEggs;&#xD;&#xA;&#xD;&#xA;// --- Assign row % to the cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = TotalPercentageFertileEggs.ToString(&quot;0.00&quot;);  // Row level %&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // --- Declare values ---&#xD;&#xA;decimal hatchPer = 0;&#xD;&#xA;decimal fertPer = 0;&#xD;&#xA;&#xD;&#xA;// --- Accumulators for totals ---&#xD;&#xA;decimal totalReportHatchPer = 0;&#xD;&#xA;decimal totalReportFertPer = 0;&#xD;&#xA;&#xD;&#xA;// --- HatchPer ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;HatchPer&quot;) != null)&#xD;&#xA;    hatchPer = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchPer&quot;));&#xD;&#xA;    totalReportHatchPer += hatchPer;&#xD;&#xA;&#xD;&#xA;// --- FertPer ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;FertPer&quot;) != null)&#xD;&#xA;    fertPer = Convert.ToDecimal(GetCurrentColumnValue(&quot;FertPer&quot;));&#xD;&#xA;    totalReportFertPer += fertPer;&#xD;&#xA;&#xD;&#xA;// --- Equation (row level %) ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (fertPer != 0)&#xD;&#xA;    percentage = (hatchPer * 100m) / fertPer;&#xD;&#xA;&#xD;&#xA;// --- Total percentage ---&#xD;&#xA;if (totalReportFertPer != 0)&#xD;&#xA;    TotalPercentageHatchPer = (totalReportHatchPer * 100m) / totalReportFertPer;&#xD;&#xA;&#xD;&#xA;// --- Assign row % to the cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.00&quot;);  // Row level %&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell51_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell51.Text = TotalPercentageSellableChicks.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void tdCredit_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    object handledEggsValue = GetCurrentColumnValue(&quot;HandledEggs&quot;);&#xD;&#xA;    &#xD;&#xA;    if (handledEggsValue == null || handledEggsValue == DBNull.Value || string.IsNullOrEmpty(handledEggsValue.ToString()))&#xD;&#xA;    {&#xD;&#xA;        // Set to 0 if null, DBNull, or empty&#xD;&#xA;        tdCredit.Text = &quot;0&quot;;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        // Use the actual value&#xD;&#xA;        tdCredit.Text = handledEggsValue.ToString();&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidth="1654" PageHeight="1169" Version="24.2" DataMember="SR_HT_Hatch" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
