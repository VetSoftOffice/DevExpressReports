    <Item28 Ref="48" Name="DYE" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.DoubleYolkEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item29 Ref="49" Name="OtherEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.OtherEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item30 Ref="50" Name="TotalUnHatch" Expression="[SR_HT_RecHall.SoftShellEggs] + [SR_HT_RecHall.MinorCrackedEggs] + [SR_HT_RecHall.MajorCrackedEggs] + [SR_HT_RecHall.ThinShellEggs] + [SR_HT_RecHall.OtherEggs] + [SR_HT_RecHall.WholeEggs] + &#xA;[SR_HT_RecHall.BrokenEggs] + [SR_HT_RecHall.SmallEggs] + [SR_HT_RecHall.OverWeightEggs] + [SR_HT_RecHall.DirtyEggs] + [SR_HT_RecHall.DeformityEggs] + [SR_HT_RecHall.CrackedEggs] + &#xA;[SR_HT_RecHall.DoubleYolkEggs] + [SR_HT_RecHall.DestroyedEggs]&#xA;" DataMember="SR_HT_RecHall" />
