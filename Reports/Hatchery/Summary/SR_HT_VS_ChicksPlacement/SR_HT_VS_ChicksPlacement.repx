    <Item22 Ref="42" Name="OverWeightEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.OverWeightEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
    <Item23 Ref="43" Name="DirtyEggs_CF" Expression="Iif([SR_HT_RecHall.RecEggs] != 0, [SR_HT_RecHall.DirtyEggs] * 100 / [SR_HT_RecHall.RecEggs], 0)&#xA;" DataMember="SR_HT_RecHall" />
