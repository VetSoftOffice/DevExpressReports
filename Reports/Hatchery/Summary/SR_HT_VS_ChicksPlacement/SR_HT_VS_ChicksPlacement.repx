    <Item16 Ref="36" Name="Avg_Wt_PP" Expression="Iif([Birds_PT] &gt; 0, &#xA;    [TotalWt_PT] / [Birds_PT], &#xA;    Null)&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
    <Item17 Ref="37" Name="Avg_Wt_SL" Expression="Iif([Birds_SL] &gt; 0, &#xA;    [TotalWt_SL] / [Birds_SL], &#xA;    Null)&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
