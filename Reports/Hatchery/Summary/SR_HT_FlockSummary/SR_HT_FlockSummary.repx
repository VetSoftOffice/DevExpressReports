    <Item29 Ref="33" Visible="false" Name="ModuleType" />
  </Parameters>
  <CalculatedFields>
    <Item1 Ref="34" Name="TotalCostPerc_CF" DisplayName="TotalCostPerc_CF" Expression="(ToDecimal([TotalCost]) / ToDecimal(Sum([TotalCost])))*ToDecimal(100)&#xA;" DataMember="SR_FM_Stocktaking" />
    <Item2 Ref="35" Name="Per_Chick_CF" Expression="Iif([FemaleChicks]!=0,[TotalCost]/[FemaleChicks] ,[FemaleChicks] )" DataMember="SR_FM_Stocktaking" />
    <Item3 Ref="36" Name="PerHH_CF" DisplayName="PerHH_CF" Expression="Iif([FemalePOL]!=0,[TotalCost]/[FemalePOL] ,[FemalePOL] )&#xA;" DataMember="SR_FM_Stocktaking" />
    <Item4 Ref="37" Name="PerHE_CF" Expression="Iif([HatchingEggs]!=0,[TotalCost]/[HatchingEggs] ,[HatchingEggs] )&#xA;&#xA;" DataMember="SR_FM_Stocktaking" />
    <Item5 Ref="38" Name="DiffQtyq" Expression="IsNull([ActualQty], 0) - IsNull([SentOrClacQty], 0)" DataMember="SR_FM_Stocktaking" />
    <Item6 Ref="39" Name="DiffPriceq" Expression="Iif([CalcPriceUnit] &gt; 0, IsNull([AdjustedPriceUnit], 0) - IsNull([CalcPriceUnit], 0), 0)" DataMember="SR_FM_Stocktaking" />
    <Item7 Ref="40" Name="ActEggRecHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.ActRecEggs] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item8 Ref="41" Name="RejEggHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.RejEggs] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item9 Ref="42" Name="EstHatEggs" Expression="[ActEggRecHHCum] - [RejEggHHCum]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item10 Ref="43" Name="ActEggSetHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.ActSetEggCum] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item11 Ref="44" Name="EstHatEggsBefore21days" Expression="[SR_HT_WeeklyHHFlockSum.ActRecEggsBefore21days] - [SR_HT_WeeklyHHFlockSum.RejEggsBefore21days]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item12 Ref="45" Name="ActHatch_Per_Cum" Expression="Iif([SR_HT_WeeklyHHFlockSum.SettedEggs] &lt;&gt; 0, &#xD;&#xA;    ([SR_HT_WeeklyHHFlockSum.ActChicks] + [SR_HT_WeeklyHHFlockSum.CullsChicks] + [SR_HT_WeeklyHHFlockSum.DeadChicks]) &#xD;&#xA;    / [SR_HT_WeeklyHHFlockSum.SettedEggs] * 100, &#xD;&#xA;    0)&#xD;&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item13 Ref="46" Name="EstChiks" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &gt; 0, &#xA;    ([EstHatEggsBefore21days] * [ActHatch_Per_Cum] / 100) / [SR_HT_WeeklyHHFlockSum.POL], &#xA;    0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item14 Ref="47" Name="ActChicksHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, &#xD;&#xA;    ([SR_HT_WeeklyHHFlockSum.ActChicks] + [SR_HT_WeeklyHHFlockSum.CullsChicks] + [SR_HT_WeeklyHHFlockSum.DeadChicks]) &#xD;&#xA;    / [SR_HT_WeeklyHHFlockSum.POL], &#xD;&#xA;    0)&#xD;&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item15 Ref="48" Name="Diviation" Expression="[ActHatch_Per_Cum] - [SR_HT_WeeklyHHFlockSum.StdHatchCum]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item16 Ref="49" Name="TotalHatchedEggs" Expression="[ChicksSettedEggs]" DataMember="SR_HT_Production" />
    <Item17 Ref="50" Name="HatchPer" Expression="Iif([TotalHatchedEggs] &lt;&gt; 0, [SR_HT_Production.Chicks] * 100 / [TotalHatchedEggs], 0)&#xA;" DataMember="SR_HT_Production" />
    <Item18 Ref="51" Name="HOFPer" Expression="Iif([SR_HT_Production.FertPer] &lt;&gt; 0, [HatchPer] * 100.0 / [SR_HT_Production.FertPer], 0)&#xA;" DataMember="SR_HT_Production" />
    <Item19 Ref="52" Name="HatchPerc" Expression="Iif([SR_HT_Hatch.SettedEggs] &lt;&gt; 0, [SR_HT_Hatch.SellableChicks] * 100 / [SR_HT_Hatch.SettedEggs], 0)&#xA;" DataMember="SR_HT_Hatch" />
    <Item20 Ref="53" Name="HOFPerc" Expression="Iif([SR_HT_Hatch.FertPer] &lt;&gt; 0, [HatchPer] * 100.0 / [SR_HT_Hatch.FertPer], 0)&#xA;" DataMember="SR_HT_Hatch" />
    <Item21 Ref="54" Name="TotalHatchPerc" Expression="Iif(Sum([SR_HT_Hatch.SettedEggs]) &lt;&gt; 0, Sum([SR_HT_Hatch.SellableChicks]) * 100 / Sum([SR_HT_Hatch.SettedEggs]), 0)&#xA;" DataMember="SR_HT_Hatch" />
    <Item22 Ref="55" Name="FertileEggs_CF" Expression="[SR_HT_Hatch.FertPer] * [SR_HT_Hatch.SettedEggs] / 100&#xA;&#xA;" DataMember="SR_HT_Hatch" />
    <Item23 Ref="56" Name="FertPerc" Expression="Iif(Sum([SR_HT_Hatch.SettedEggs]) &lt;&gt; 0, Sum([FertileEggs]) * 100 / Sum([SR_HT_Hatch.SettedEggs]), 0)&#xA;" DataMember="SR_HT_Hatch" />
    <Item24 Ref="57" Name="TotalHOFPerc" Expression="Iif([FertPerc] &lt;&gt; 0, [TotalHatchPerc] * 100 / [FertPerc], 0)&#xA;" DataMember="SR_HT_Hatch" />
    <Item25 Ref="58" Name="HatchPercentage" Expression="Iif([SR_HT_FlockSummary.EggsSetted] &gt; 0, [SR_HT_FlockSummary.SelChicks] * 100 / [SR_HT_FlockSummary.EggsSetted], 0)&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item26 Ref="59" Name="RejChicks" Expression="Iif(IsNullOrEmpty([Culls]), 0,[Culls] ) + Iif(IsNullOrEmpty([DeadChicks]), 0,[DeadChicks] )" DataMember="SR_HT_FlockSummary" />
    <Item27 Ref="60" Name="RejPerc" Expression="Iif([SR_HT_FlockSummary.EggsSetted] &gt; 0, [RejectChicks] * 100 / [SR_HT_FlockSummary.EggsSetted], 0)&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item28 Ref="61" Name="TotalChicks" Expression="ISNULL([SelChicks], 0) + ISNULL([Culls], 0) + ISNULL([DeadChicks], 0)&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item29 Ref="62" Name="TotalChicksPerc" Expression="Iif([SR_HT_FlockSummary.EggsSetted] &gt; 0, [TotalChicks] * 100 / [SR_HT_FlockSummary.EggsSetted], 0)&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item30 Ref="63" Name="TotalHatchPercentage" Expression="Iif([SR_HT_FlockSummary.EggsSetted] &gt; 0, [TotalChicks] * 100 / [SR_HT_FlockSummary.EggsSetted], 0)&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item31 Ref="64" Name="Deviation" Expression="[TotalHatchPrec] - [SR_HT_FlockSummary.StadHatchability]&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item32 Ref="65" Name="CumHatch" Expression="Iif(&#xD;&#xA;    [SR_HT_FlockSummary.CumSettingEggs] &gt; 0,&#xD;&#xA;    ([SR_HT_FlockSummary.CumDeadChicks] + [SR_HT_FlockSummary.CumCulls] + [SR_HT_FlockSummary.CumBroiler]) * 100 / [SR_HT_FlockSummary.CumSettingEggs],&#xD;&#xA;    0&#xD;&#xA;)&#xD;&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item33 Ref="66" Name="DevCum" Expression="[CumHatch] - [SR_HT_FlockSummary.StadCumHatchability]&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item34 Ref="67" Name="CumHatchAGrade" Expression="Iif(&#xA;    [SR_HT_FlockSummary.CumSettingEggs] &gt; 0,&#xA;    [SR_HT_FlockSummary.CumBroiler] * 100 / [SR_HT_FlockSummary.CumSettingEggs],&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item35 Ref="68" Name="DevCumAGrade" Expression="[CumHatchAGrade] - [SR_HT_FlockSummary.StadCumHatchabilityAGrade]&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item36 Ref="69" Name="EggsSetted_Sum" Expression="Sum([SR_HT_FlockSummary.EggsSetted])&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item37 Ref="70" Name="GT_HatchPer" Expression="Iif(&#xA;    [EggsSetted_Sum] &gt; 0,&#xA;    Sum([SR_HT_FlockSummary.SelChicks]) * 100 / [EggsSetted_Sum],&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item38 Ref="71" Name="GT_RejectPer" Expression="Iif(&#xA;    [EggsSetted_Sum] &gt; 0,&#xA;    Sum([RejectChicks]) * 100 / [EggsSetted_Sum],&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item39 Ref="72" Name="GT_TotalChicksPer" Expression="Iif(&#xA;    [SettedEggs_Sum] &gt; 0,&#xA;    Sum([TotalChicks]) * 100 / [SettedEggs_Sum],&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item40 Ref="73" Name="BrdStdAsNumber" Expression="[SR_HT_FlockSummary.StadHatchability] * [SR_HT_FlockSummary.EggsSetted] / 100&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item41 Ref="74" Name="GT_BrdStdAsNumber" Expression="Iif(&#xA;    [EggsSetted_Sum] &gt; 0,&#xA;    Sum([BrdStdAsNumber]) * 100 / Sum([SR_HT_FlockSummary.EggsSetted]),&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item42 Ref="75" Name="Hat_Deviation" Expression="Round([GT_TotalChicksPer], 2) - Round([GT_BrdStdAsNumber], 2)&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item43 Ref="76" Name="_CumSettingEggs" Expression="Sum([SR_HT_FlockSummary.CumSettingEggs])&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item44 Ref="77" Name="GT_CumHatch" Expression="Iif(&#xA;    [_CumSettingEggs] &gt; 0,&#xA;    (Sum([SR_HT_FlockSummary.CumDeadChicks]) + Sum([SR_HT_FlockSummary.CumCulls]) + Sum([SR_HT_FlockSummary.CumBroiler])) &#xA;    / [CumSettingEggs] * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item45 Ref="78" Name="GT_BrdStdAsNumberCum" Expression="Iif(&#xA;    [_CumSettingEggs] &gt; 0,&#xA;    Sum([BrdStdAsNumber_Cum]) * 100 / [cumSetted_SUM],&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item46 Ref="79" Name="GT_DevCum" Expression="Round([GT_CumHatch], 2) - Round([GT_BrdStdAsNumberCum], 2)&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item47 Ref="80" Name="GT_CumHatchAGrade" Expression="Iif(&#xA;    [_CumSettingEggs] &gt; 0,&#xA;    Sum([SR_HT_FlockSummary.CumBroiler]) / [_CumSettingEggs] * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item48 Ref="81" Name="BrdStdAsNumber_CumAGrade" Expression="[SR_HT_FlockSummary.StadCumHatchabilityAGrade] * [SR_HT_FlockSummary.CumSettingEggs] / 100&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item49 Ref="82" Name="GT_BrdStdAsNumberCumAGrade" Expression="Iif(&#xA;    [_CumSettingEggs] &gt; 0,&#xA;    Sum([@BrdStdAsNumber_CumAGrade]) * 100 / [cumSetted_SUM],&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_FlockSummary" />
    <Item50 Ref="83" Name="GT_DevCumAGrade" Expression="Round([@GT_CumHatchAGrade], 2) - Round([@GT_BrdStdAsNumberCumAGrade], 2)&#xA;" DataMember="SR_HT_FlockSummary" />
  </CalculatedFields>
