<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_FlockSummary" ScriptsSource="decimal rejectChicksSum = 0;&#xD;&#xA;decimal selChicksSum  = 0;&#xD;&#xA;decimal eggsSettedSum  = 0 ;&#xD;&#xA;decimal totalCumChicksPercentReport = 0;&#xD;&#xA;decimal totalCumChicksMinusHatchabilityReport = 0;&#xD;&#xA;decimal totalChicksSum  =0;&#xD;&#xA;decimal totalCumBroilerPercentReport  = 0;&#xD;&#xA;decimal totalCumBroilerMinusHatchabilityAGradeReport  = 0;&#xD;&#xA;decimal TotalCullsReport = 0;&#xD;&#xA;decimal TotalDeadChicksReport  = 0;&#xD;&#xA;decimal RejEggsSum = 0;&#xD;&#xA;decimal eggsSettedSumStdbrds = 0;&#xD;&#xA;decimal brdStdAsNumberTotal = 0;&#xD;&#xA;decimal BrdSTDTotal  =0;&#xD;&#xA;decimal totalHatchPrec = 0;&#xD;&#xA;decimal stadHatchabilityDev = 0;&#xD;&#xA;decimal brdStdAsNumberTotalDev = 0;&#xD;&#xA;decimal gtTotalChicksPer = 0;&#xD;&#xA;decimal gtBrdStdAsNumberPercent = 0;&#xD;&#xA;decimal TotalHatch  = 0;&#xD;&#xA;decimal cumSettingEggsTotal = 0;&#xD;&#xA;decimal cumDeadChicksTotal = 0;&#xD;&#xA;decimal cumCullsTotal = 0;&#xD;&#xA;decimal cumBroilerTotal = 0;&#xD;&#xA;decimal cumSettedSumSTDBrd  = 0;&#xD;&#xA;decimal brdStdAsNumberCumTotalSTDBrd  = 0;&#xD;&#xA;decimal ResultSTDBrd = 0;&#xD;&#xA;decimal eggsSettedSumStdbrdsCum = 0;&#xD;&#xA;decimal brdStdAsNumberTotalCum  = 0;&#xD;&#xA;decimal totalChicksSumCum  = 0;&#xD;&#xA;decimal TotalHatchCum = 0;&#xD;&#xA;decimal BrdSTDTotalCum = 0;&#xD;&#xA;decimal cumSettingEggsReport = 0;&#xD;&#xA;decimal cumBroilerReport = 0;&#xD;&#xA;decimal brdStdAsNumberCumTotalSTDBrdGrade  = 0;&#xD;&#xA;decimal ResultSTDBrdGrade  = 0;&#xD;&#xA;decimal AGradebrdStdAsNumberTotalCum   = 0;&#xD;&#xA;decimal totalChicksSumCumAGrade  = 0;&#xD;&#xA;decimal TotalHatchCumGrade   = 0;&#xD;&#xA;decimal BrdSTDTotalCumAGrade  = 0;&#xD;&#xA;void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       //-- new logic for BrdStd Percentage using total EggsSetted&#xD;&#xA;// --- Get Values ---&#xD;&#xA;decimal eggsSettedSTD = GetCurrentColumnValue(&quot;EggsSetted&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;EggsSetted&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;&#xD;&#xA;decimal stadHatchability = GetCurrentColumnValue(&quot;StadHatchability&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;StadHatchability&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;&#xD;&#xA;// --- Calculate @BrdStdAsNumber ---&#xD;&#xA;eggsSettedSumStdbrds += eggsSettedSTD ;&#xD;&#xA;brdStdAsNumberTotal += (stadHatchability * eggsSettedSTD / 100);&#xD;&#xA;&#xD;&#xA;//new logic for Dev &#xD;&#xA;   // --- Calculate @TotalChicks ---&#xD;&#xA;decimal selChicks = GetCurrentColumnValue(&quot;SelChicks&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;&#xD;&#xA;decimal culls = GetCurrentColumnValue(&quot;Culls&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;&#xD;&#xA;decimal deadChicks = GetCurrentColumnValue(&quot;DeadChicks&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;&#xD;&#xA;decimal totalChicks = selChicks + culls + deadChicks;&#xD;&#xA;&#xD;&#xA;// --- Calculate @TotalHatchPrec ---&#xD;&#xA;decimal eggsSettedDev = GetCurrentColumnValue(&quot;EggsSetted&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;EggsSetted&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;&#xD;&#xA;if (eggsSettedDev &gt; 0)&#xD;&#xA;{&#xD;&#xA;    totalHatchPrec = (totalChicks / eggsSettedDev ) * 100;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Get StadHatchability ---&#xD;&#xA;stadHatchabilityDev = GetCurrentColumnValue(&quot;StadHatchability&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;StadHatchability&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;&#xD;&#xA;//Logic To get Dev for all records &#xD;&#xA;    // --- Cumulative variables (declare at class level) ---&#xD;&#xA;decimal eggsSettedSumDev = 0;&#xD;&#xA;decimal totalChicksSumDev = 0;&#xD;&#xA;&#xD;&#xA;// --- In your script ---&#xD;&#xA;// --- Get current row values ---&#xD;&#xA;decimal eggsSettedHatDev = GetCurrentColumnValue(&quot;EggsSetted&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;EggsSetted&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;&#xD;&#xA;decimal selChicksDev = GetCurrentColumnValue(&quot;SelChicks&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;&#xD;&#xA;decimal cullsDev = GetCurrentColumnValue(&quot;Culls&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;&#xD;&#xA;decimal deadChicksDev = GetCurrentColumnValue(&quot;DeadChicks&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;&#xD;&#xA;decimal stadHatchabilityHatDev = GetCurrentColumnValue(&quot;StadHatchability&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;StadHatchability&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;&#xD;&#xA;// --- Calculate current row values ---&#xD;&#xA;decimal currentTotalChicks = selChicksDev + cullsDev + deadChicksDev ;&#xD;&#xA;decimal currentBrdStdAsNumber = stadHatchabilityHatDev * eggsSettedHatDev / 100;&#xD;&#xA;&#xD;&#xA;// --- Accumulate sums ---&#xD;&#xA;eggsSettedSumDev += eggsSettedHatDev ;&#xD;&#xA;totalChicksSumDev += currentTotalChicks;&#xD;&#xA;brdStdAsNumberTotalDev += currentBrdStdAsNumber;&#xD;&#xA;&#xD;&#xA;// --- Calculate @GT_TotalChicksPer ---&#xD;&#xA;// --- Calculate @GT_TotalChicksPer ---&#xD;&#xA;if (eggsSettedSumDev &gt; 0)&#xD;&#xA;{&#xD;&#xA;    gtTotalChicksPer = (totalChicksSumDev / eggsSettedSumDev) * 100;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Calculate @GT_BrdStdAsNumber as percentage ---&#xD;&#xA;if (eggsSettedSumDev &gt; 0)&#xD;&#xA;{&#xD;&#xA;    gtBrdStdAsNumberPercent = (brdStdAsNumberTotalDev / eggsSettedSumDev) * 100;&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Cum STDBrd Logic &#xD;&#xA;   // --- Declare cumulative variables at class level ---&#xD;&#xA;&#xD;&#xA;// --- In Before Print script ---&#xD;&#xA;// --- Get current row values ---&#xD;&#xA;decimal cumSettingEggsSTDbrd = GetCurrentColumnValue(&quot;CumSettingEggs&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;CumSettingEggs&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;&#xD;&#xA;decimal stadCumHatchabilitySTDbrd = GetCurrentColumnValue(&quot;StadCumHatchability&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;StadCumHatchability&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;    &#xD;&#xA;decimal stadCumHatchabilitySTDbrdGrade = GetCurrentColumnValue(&quot;StadCumHatchabilityAGrade&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;StadCumHatchabilityAGrade&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;&#xD;&#xA;// --- Calculate current row @BrdStdAsNumber_Cum ---&#xD;&#xA;// --- Calculate current row @BrdStdAsNumber_Cum ---&#xD;&#xA;&#xD;&#xA;// --- Accumulate sums ---&#xD;&#xA;cumSettedSumSTDBrd  += cumSettingEggsSTDbrd ;&#xD;&#xA;brdStdAsNumberCumTotalSTDBrd += (stadCumHatchabilitySTDbrd * cumSettingEggsSTDbrd / 100);&#xD;&#xA;brdStdAsNumberCumTotalSTDBrdGrade += (stadCumHatchabilitySTDbrdGrade * cumSettingEggsSTDbrd / 100);&#xD;&#xA;&#xD;&#xA;// --- Assign to Cell ---&#xD;&#xA;    if (cumSettedSumSTDBrd &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        ResultSTDBrd =  (brdStdAsNumberCumTotalSTDBrd * 100) / cumSettedSumSTDBrd;&#xD;&#xA;    }&#xD;&#xA;// Assign to another cell for Grade &#xD;&#xA;if (cumSettedSumSTDBrd &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        ResultSTDBrdGrade =  (brdStdAsNumberCumTotalSTDBrdGrade * 100) / cumSettedSumSTDBrd;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;//Logic for Cum Dev&#xD;&#xA;// --- Get Values ---&#xD;&#xA;decimal eggsSettedSTDCum = GetCurrentColumnValue(&quot;CumSettingEggs&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;CumSettingEggs&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;&#xD;&#xA;decimal stadHatchabilityCum = GetCurrentColumnValue(&quot;StadCumHatchability&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;StadCumHatchability&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;decimal AGradestadHatchabilityCum = GetCurrentColumnValue(&quot;StadCumHatchabilityAGrade&quot;) != null&#xD;&#xA;    ? Convert.ToDecimal(GetCurrentColumnValue(&quot;StadCumHatchabilityAGrade&quot;))&#xD;&#xA;    : 0;&#xD;&#xA;&#xD;&#xA;// --- Calculate @BrdStdAsNumber ---&#xD;&#xA;eggsSettedSumStdbrdsCum += eggsSettedSTDCum ;&#xD;&#xA;brdStdAsNumberTotalCum += (stadHatchabilityCum * eggsSettedSTDCum / 100);&#xD;&#xA;AGradebrdStdAsNumberTotalCum  += (AGradestadHatchabilityCum * eggsSettedSTDCum / 100);&#xD;&#xA;    // --- Get values from the current row ---&#xD;&#xA;    decimal eggsSettedCum = GetCurrentColumnValue(&quot;CumSettingEggs&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;CumSettingEggs&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    decimal BroilerChicksCum = GetCurrentColumnValue(&quot;CumBroiler&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;CumBroiler&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;        &#xD;&#xA;    decimal BroilerChicksCumAGrade = GetCurrentColumnValue(&quot;CumBroiler&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;CumBroiler&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;    decimal cullsCum = GetCurrentColumnValue(&quot;CumCulls&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;CumCulls&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    decimal deadChicksCum = GetCurrentColumnValue(&quot;CumDeadChicks&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;CumDeadChicks&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    // --- TotalChicks = BroilerChicks + Culls + DeadChicks ---&#xD;&#xA;    decimal totalChicksCum = BroilerChicksCum + cullsCum + deadChicksCum ;&#xD;&#xA;    totalChicksSumCum += totalChicksCum ;&#xD;&#xA;    decimal totalChicksCumAGrade = BroilerChicksCumAGrade  ;&#xD;&#xA;    totalChicksSumCumAGrade += totalChicksCumAGrade ;&#xD;&#xA;    // --- Calculate percentages ---&#xD;&#xA;    TotalHatchCum  = (eggsSettedSumStdbrdsCum &gt; 0)&#xD;&#xA;        ? (totalChicksSumCum * 100 / eggsSettedSumStdbrdsCum )&#xD;&#xA;        : 0;&#xD;&#xA;    // --- Calculate Result ---&#xD;&#xA;    if(eggsSettedSumStdbrdsCum &gt; 0){&#xD;&#xA;            &#xD;&#xA;              BrdSTDTotalCum =  (brdStdAsNumberTotalCum * 100 / eggsSettedSumStdbrdsCum);&#xD;&#xA;          &#xD;&#xA;      }&#xD;&#xA;&#xD;&#xA;   //Calculate Percetnages for Grade&#xD;&#xA;   TotalHatchCumGrade  = (eggsSettedSumStdbrdsCum &gt; 0)&#xD;&#xA;        ? (totalChicksSumCumAGrade * 100 / eggsSettedSumStdbrdsCum )&#xD;&#xA;        : 0;&#xD;&#xA;    // --- Calculate Result ---&#xD;&#xA;    if(eggsSettedSumStdbrdsCum &gt; 0){&#xD;&#xA;            &#xD;&#xA;              BrdSTDTotalCumAGrade =  (AGradebrdStdAsNumberTotalCum  * 100 / eggsSettedSumStdbrdsCum);&#xD;&#xA;          &#xD;&#xA;      }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell26_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     // --- Get Values ---&#xD;&#xA;    decimal eggsSetted = GetCurrentColumnValue(&quot;EggsSetted&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;EggsSetted&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;    decimal selChicks = GetCurrentColumnValue(&quot;SelChicks&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;    // --- Calculate Result ---&#xD;&#xA;    decimal result = (eggsSetted &gt; 0)&#xD;&#xA;        ? (selChicks * 100 / eggsSetted)&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    // --- Assign to Cell ---&#xD;&#xA;    ((XRTableCell)sender).Text = result.ToString(&quot;0.00&quot;);&#xD;&#xA;     eggsSettedSum += eggsSetted;&#xD;&#xA;     selChicksSum += selChicks ;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell53_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // --- Use global variables directly ---&#xD;&#xA;    decimal result = (eggsSettedSum &gt; 0)&#xD;&#xA;        ? (selChicksSum * 100 / eggsSettedSum)&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    // --- Assign to Cell ---&#xD;&#xA;    ((XRTableCell)sender).Text = result.ToString(&quot;0.00&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void tdCredit_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // --- Get values from the current row ---&#xD;&#xA;    decimal eggsSetted = GetCurrentColumnValue(&quot;EggsSetted&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;EggsSetted&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    decimal selChicks = GetCurrentColumnValue(&quot;SelChicks&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    decimal culls = GetCurrentColumnValue(&quot;Culls&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    decimal deadChicks = GetCurrentColumnValue(&quot;DeadChicks&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    // --- TotalChicks = SelChicks + Culls + DeadChicks ---&#xD;&#xA;    decimal totalChicks = selChicks + culls + deadChicks;&#xD;&#xA;    totalChicksSum += totalChicks ;&#xD;&#xA;    // --- Calculate percentage ---&#xD;&#xA;    decimal result = (eggsSetted &gt; 0)&#xD;&#xA;        ? (totalChicks * 100 / eggsSetted)&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    // --- Assign to cell ---&#xD;&#xA;   &#xD;&#xA;    ((XRTableCell)sender).Text = result.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell57_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Use global variables directly ---&#xD;&#xA;    TotalHatch  = (eggsSettedSum &gt; 0)&#xD;&#xA;        ? (totalChicksSum* 100 / eggsSettedSum)&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    // --- Assign to Cell ---&#xD;&#xA;    ((XRTableCell)sender).Text = TotalHatch.ToString(&quot;0.00&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell58_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    &#xD;&#xA;// --- Calculate Result ---&#xD;&#xA;if(eggsSettedSumStdbrds &gt; 0){&#xD;&#xA;        &#xD;&#xA;          BrdSTDTotal =  (brdStdAsNumberTotal * 100 / eggsSettedSumStdbrds );&#xD;&#xA;          &#xD;&#xA;                          }&#xD;&#xA;&#xD;&#xA;((XRTableCell)sender).Text = BrdSTDTotal.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell17_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    //-- new logic for Cum Chicks Percentage ((CumDeadChicks + CumCulls + CumBroiler) * 100 / CumSettingEggs)&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal cumSettingEggs = 0;&#xD;&#xA;decimal cumDeadChicks = 0;&#xD;&#xA;decimal cumCulls = 0;&#xD;&#xA;decimal cumBroiler = 0;&#xD;&#xA;decimal cumChicksPercent = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CumSettingEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CumSettingEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    cumSettingEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumSettingEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CumDeadChicks&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CumDeadChicks&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    cumDeadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumDeadChicks&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CumCulls&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CumCulls&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    cumCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumCulls&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CumBroiler&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CumBroiler&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    cumBroiler = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumBroiler&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif(CumSettingEggs &gt; 0, (CumDeadChicks + CumCulls + CumBroiler) * 100 / CumSettingEggs, 0)) ---&#xD;&#xA;if (cumSettingEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    cumChicksPercent = (cumDeadChicks + cumCulls + cumBroiler) * 100 / cumSettingEggs;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cumChicksPercent = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = cumChicksPercent.ToString(&quot;N2&quot;);&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;cumSettingEggsTotal += cumSettingEggs ;&#xD;&#xA;cumDeadChicksTotal += cumDeadChicks ;&#xD;&#xA;cumCullsTotal  += cumCulls ;&#xD;&#xA;cumBroilerTotal  += cumBroiler ;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell41_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     if(cumSettingEggsTotal  &gt; 0) {&#xD;&#xA;             decimal totalChicks = cumDeadChicksTotal + cumCullsTotal + cumBroilerTotal;&#xD;&#xA;             totalCumChicksPercentReport = (totalChicks / cumSettingEggsTotal) * 100;&#xD;&#xA;         }&#xD;&#xA;     xrTableCell41.Text = totalCumChicksPercentReport.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell28_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    //-- new logic for Cum Chicks Percentage minus StadCumHatchability&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal cumSettingEggs = 0;&#xD;&#xA;decimal cumDeadChicks = 0;&#xD;&#xA;decimal cumCulls = 0;&#xD;&#xA;decimal cumBroiler = 0;&#xD;&#xA;decimal stadCumHatchability = 0;&#xD;&#xA;decimal resultValue = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CumSettingEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CumSettingEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    cumSettingEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumSettingEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CumDeadChicks&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CumDeadChicks&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    cumDeadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumDeadChicks&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CumCulls&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CumCulls&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    cumCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumCulls&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CumBroiler&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CumBroiler&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    cumBroiler = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumBroiler&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;StadCumHatchability&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;StadCumHatchability&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    stadCumHatchability = Convert.ToDecimal(GetCurrentColumnValue(&quot;StadCumHatchability&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Calculate (CumDeadChicks + CumCulls + CumBroiler) * 100 / CumSettingEggs ---&#xD;&#xA;decimal cumChicksPercent = 0;&#xD;&#xA;if (cumSettingEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    cumChicksPercent = (cumDeadChicks + cumCulls + cumBroiler) * 100 / cumSettingEggs;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Final result: subtract StadCumHatchability ---&#xD;&#xA;resultValue = cumChicksPercent - stadCumHatchability;&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;totalCumChicksMinusHatchabilityReport += resultValue;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = resultValue.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell20_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    //-- new logic for Cum Broiler Percentage (CumBroiler * 100 / CumSettingEggs)&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal cumSettingEggs = 0;&#xD;&#xA;decimal cumBroiler = 0;&#xD;&#xA;decimal cumBroilerPercent = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CumSettingEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CumSettingEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    cumSettingEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumSettingEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CumBroiler&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CumBroiler&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    cumBroiler = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumBroiler&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif(CumSettingEggs &gt; 0, CumBroiler * 100 / CumSettingEggs, 0)) ---&#xD;&#xA;if (cumSettingEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    cumBroilerPercent = cumBroiler * 100 / cumSettingEggs;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cumBroilerPercent = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = cumBroilerPercent.ToString(&quot;N2&quot;);&#xD;&#xA;cumSettingEggsReport += cumSettingEggs ;&#xD;&#xA;cumBroilerReport += cumBroiler ;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    //-- new logic for Cum Broiler Percentage minus StadCumHatchabilityAGrade&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal cumSettingEggs = 0;&#xD;&#xA;decimal cumBroiler = 0;&#xD;&#xA;decimal stadCumHatchabilityAGrade = 0;&#xD;&#xA;decimal resultValue = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CumSettingEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CumSettingEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    cumSettingEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumSettingEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CumBroiler&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CumBroiler&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    cumBroiler = Convert.ToDecimal(GetCurrentColumnValue(&quot;CumBroiler&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;StadCumHatchabilityAGrade&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;StadCumHatchabilityAGrade&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    stadCumHatchabilityAGrade = Convert.ToDecimal(GetCurrentColumnValue(&quot;StadCumHatchabilityAGrade&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as (Iif(CumSettingEggs &gt; 0, CumBroiler / CumSettingEggs * 100, 0)) - StadCumHatchabilityAGrade) ---&#xD;&#xA;decimal cumBroilerPercent = 0;&#xD;&#xA;&#xD;&#xA;if (cumSettingEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    cumBroilerPercent = (cumBroiler / cumSettingEggs) * 100;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;resultValue = cumBroilerPercent - stadCumHatchabilityAGrade;&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;totalCumBroilerMinusHatchabilityAGradeReport += resultValue;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = resultValue.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell6_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     decimal eggsSetted;&#xD;&#xA;    decimal culls;&#xD;&#xA;    decimal deadChicks;&#xD;&#xA;    decimal rejectChicks = 0;&#xD;&#xA;    decimal result = 0;&#xD;&#xA;    &#xD;&#xA;    // Assignments&#xD;&#xA;    eggsSetted = GetCurrentColumnValue(&quot;EggsSetted&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;EggsSetted&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;    &#xD;&#xA;    culls = GetCurrentColumnValue(&quot;Culls&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;    &#xD;&#xA;    deadChicks = GetCurrentColumnValue(&quot;DeadChicks&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;    &#xD;&#xA;    // --- Calculate percentage ---&#xD;&#xA;    rejectChicks = culls + deadChicks;&#xD;&#xA;    &#xD;&#xA;    if (eggsSetted &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        result = (rejectChicks * 100m) / eggsSetted;&#xD;&#xA;    }&#xD;&#xA;         // --- Assign to cell ---&#xD;&#xA;    ((XRTableCell)sender).Text = result.ToString(&quot;0.00&quot;);&#xD;&#xA;    RejEggsSum += eggsSetted ;&#xD;&#xA;    TotalCullsReport += culls ;&#xD;&#xA;    TotalDeadChicksReport += deadChicks ;&#xD;&#xA;    rejectChicksSum = TotalCullsReport  + TotalDeadChicksReport ;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell55_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     // --- Use global variables directly ---&#xD;&#xA;    decimal result = 0 ;&#xD;&#xA;     if(RejEggsSum &gt; 0){&#xD;&#xA;         &#xD;&#xA;           result = (rejectChicksSum  * 100m) / RejEggsSum ;&#xD;&#xA;         }&#xD;&#xA;        &#xD;&#xA;    // --- Assign to Cell ---&#xD;&#xA;    ((XRTableCell)sender).Text = result.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell15_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA; &#xD;&#xA;// --- Calculate Final Result: {@TotalHatchPrec} - {SR_HT_FlockSummary.StadHatchability} ---&#xD;&#xA;    decimal finalResult = totalHatchPrec - stadHatchabilityDev;&#xD;&#xA;    ((XRTableCell)sender).Text = finalResult.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell59_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;decimal DevTotal =  Math.Round(TotalHatch  , 2)  -  Math.Round(BrdSTDTotal , 2);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign to cell ---&#xD;&#xA;((XRTableCell)sender).Text = DevTotal.ToString(&quot;0.00&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell42_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;&#xD;&#xA;    // --- Assign to cell in Report Footer ---&#xD;&#xA;    xrTableCell42.Text = ResultSTDBrd.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell43_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;  &#xD;&#xA;    decimal DevTotalCum =  Math.Round(TotalHatchCum  , 2)  -  Math.Round(BrdSTDTotalCum , 2);&#xD;&#xA;        xrTableCell43.Text = DevTotalCum.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell47_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    if(cumSettingEggsReport &gt; 0){&#xD;&#xA;             totalCumBroilerPercentReport = (cumBroilerReport * 100m) / cumSettingEggsReport ;&#xD;&#xA;        }&#xD;&#xA;      xrTableCell47.Text = totalCumBroilerPercentReport.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell49_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        xrTableCell49.Text = ResultSTDBrdGrade.ToString(&quot;0.00&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell52_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal DevTotalCumAGrade =  Math.Round(TotalHatchCumGrade, 2)  -  Math.Round(BrdSTDTotalCumAGrade, 2);&#xD;&#xA;        xrTableCell52.Text = DevTotalCumAGrade.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidth="1654" PageHeight="1169" Version="24.2" DataMember="SR_HT_FlockSummary" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
  <Parameters>
    <Item1 Ref="3" Visible="false" ValueInfo="False" Name="IsRTL" Type="#Ref-2" />
    <Item2 Ref="4" Visible="false" ValueInfo="False" Name="IsCustomReportHeader" Type="#Ref-2" />
    <Item3 Ref="5" Visible="false" ValueInfo="False" Name="IsCustomReportFooter" Type="#Ref-2" />
    <Item4 Ref="6" ValueInfo="False" Name="ShowSignature" Type="#Ref-2" />
    <Item5 Ref="7" ValueInfo="False" Name="ShowSignatureAllPages" Type="#Ref-2" />
    <Item6 Ref="8" ValueInfo="False" Name="HideReportHeader" Type="#Ref-2" />
    <Item7 Ref="9" ValueInfo="False" Name="HideReportFooter" Type="#Ref-2" />
    <Item8 Ref="11" Name="NoOfGroupsPerPage" />
    <Item9 Ref="12" Visible="false" Name="FontSize" />
    <Item10 Ref="13" Visible="false" Name="DateFrom" />
    <Item11 Ref="14" Visible="false" Name="DateTo" />
    <Item12 Ref="16" Visible="false" ValueInfo="0" AllowNull="true" Name="ReportType" Type="#Ref-15" />
    <Item13 Ref="17" Visible="false" AllowNull="true" Name="Price" />
    <Item14 Ref="18" Visible="false" AllowNull="true" Name="AdjustedPrice" />
    <Item15 Ref="19" Visible="false" AllowNull="true" Name="DiffPrice" />
    <Item16 Ref="20" Visible="false" AllowNull="true" Name="Available" />
    <Item17 Ref="21" Visible="false" AllowNull="true" Name="ActualQty" />
    <Item18 Ref="22" Visible="false" AllowNull="true" Name="DiffQty" />
    <Item19 Ref="23" Visible="false" AllowNull="true" Name="FarmNo" />
    <Item20 Ref="24" Visible="false" Name="BookPerf" />
    <Item21 Ref="25" Visible="false" Name="Hatchery" />
    <Item22 Ref="26" Visible="false" Name="BreederFarm" />
    <Item23 Ref="27" Visible="false" Name="GroupBreed" />
    <Item24 Ref="28" Visible="false" Name="AgeFrom" />
    <Item25 Ref="29" Visible="false" Name="AgeTo" />
    <Item26 Ref="30" Visible="false" Name="BreederCrop" />
    <Item27 Ref="31" Visible="false" Name="BreederFlock" />
