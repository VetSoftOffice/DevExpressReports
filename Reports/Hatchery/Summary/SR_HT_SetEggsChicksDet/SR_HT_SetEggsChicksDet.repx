    <Item11 Ref="36" Name="TotalSaleableChicksPerc" Expression="Iif(Sum([SettedEggs]) &lt;&gt; 0, &#xA;    (Sum([SaleableChicks]) * 100) / Sum([SettedEggs]), &#xA;    0)&#xA;" DataMember="SR_HT_SetEggsChicksDet" />
    <Item12 Ref="37" Name="TotalRejectPerc" Expression="Iif(Sum([SettedEggs]) &lt;&gt; 0, &#xA;    (Sum([RejectChicks]) * 100) / Sum([SettedEggs]), &#xA;    0)&#xA;" DataMember="SR_HT_SetEggsChicksDet" />
    <Item13 Ref="38" Name="TotalPercTotal" Expression="Iif(Sum([SettedEggs]) &lt;&gt; 0, &#xA;    ((Sum([SaleableChicks]) + Sum([RejectChicks])) * 100) / Sum([SettedEggs]), &#xA;    0)&#xA;" DataMember="SR_HT_SetEggsChicksDet" />
