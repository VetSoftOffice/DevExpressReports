erc += saleableChicks;&#xD;&#xA;    SettedEggssSaleableChicksReport += settedEggs;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    decimal saleableChicks = 0;&#xD;&#xA;    decimal settedEggs = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SaleableChicks&quot;) != null)&#xD;&#xA;        saleableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SaleableChicks&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    decimal percentage = 0;&#xD;&#xA;    if (settedEggs != 0)&#xD;&#xA;        percentage = (saleableChicks * 100m) / settedEggs;&#xD;&#xA;        &#xD;&#xA;    saleableChicksGroup += saleableChicks;&#xD;&#xA;    settedEggsGroup += settedEggs;&#xD;&#xA;    if (settedEggsGroup != 0)&#xD;&#xA;         SaleableChicksPercGroup = (saleableChicksGroup * 100) / settedEggsGroup;&#xD;&#xA;&#xD;&#xA;    //&#xD;&#xA;    decimal rejectChicks = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;RejectChicks&quot;) != null)&#xD;&#xA;        rejectChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejectChicks&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    if (settedEggs != 0)&#xD;&#xA;        percentage = (rejectChicks * 100m) / settedEggs;&#xD;&#xA;        &#xD;&#xA;    rejectChicksGroup += rejectChicks;&#xD;&#xA;    settedEggsRejGroup += settedEggs;&#xD;&#xA;    &#xD;&#xA;    if (settedEggsRejGroup != 0)&#xD;&#xA;         RejectChicksPercGroup = (rejectChicksGroup * 100) / settedEggsRejGroup;&#xD;&#xA;&#xD;&#xA;    //&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SaleableChicks&quot;) != null)&#xD;&#xA;        saleableChicks = Convert.ToDecimal