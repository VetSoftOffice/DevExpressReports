<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_MachineEfficiency" ScriptsSource="decimal SettedEggsHatchTotal =0;&#xD;&#xA;decimal GradeAChicksHatchTotal  = 0;&#xD;&#xA;decimal SettedEggsFertilityTotal =0;&#xD;&#xA;decimal FertilityWeightedSum = 0;&#xD;&#xA;decimal weightedAverageHatch = 0;&#xD;&#xA;decimal FertilityTotal  = 0;&#xD;&#xA;decimal weightedAverageFertility = 0;&#xD;&#xA;decimal SettedEggsTotalHOF = 0;&#xD;&#xA;decimal FertilityWeightedSumHOF = 0;&#xD;&#xA;decimal HatchPercWeightedSumHOF = 0;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;decimal SettedEggsHatch = 0;&#xD;&#xA;decimal GradeAChicksHatch = 0;&#xD;&#xA;&#xD;&#xA;// --- Deads ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    SettedEggsHatch = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Culls ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;GradeAChicks&quot;) != null)&#xD;&#xA;    GradeAChicksHatch = Convert.ToDecimal(GetCurrentColumnValue(&quot;GradeAChicks&quot;));&#xD;&#xA;    &#xD;&#xA;    SettedEggsHatchTotal += SettedEggsHatch ;&#xD;&#xA;    GradeAChicksHatchTotal += GradeAChicksHatch;&#xD;&#xA;&#xD;&#xA;//new logic for Fertiality&#xD;&#xA;decimal SettedEggsFertility = 0;&#xD;&#xA;decimal Fertility = 0;&#xD;&#xA;&#xD;&#xA;// --- Deads ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    SettedEggsFertility = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Culls ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Fertility&quot;) != null)&#xD;&#xA;    Fertility = Convert.ToDecimal(GetCurrentColumnValue(&quot;Fertility&quot;));&#xD;&#xA;    &#xD;&#xA;    SettedEggsFertilityTotal += SettedEggsFertility ;&#xD;&#xA;    FertilityTotal += Fertility;&#xD;&#xA;    FertilityWeightedSum += (Fertility * SettedEggsFertility );&#xD;&#xA;&#xD;&#xA;//new logic for HOF&#xD;&#xA;    decimal HatchPerc = 0;&#xD;&#xA;    if (SettedEggsHatch != 0)&#xD;&#xA;    {&#xD;&#xA;        HatchPerc = (GradeAChicksHatch * 100m) / SettedEggsHatch ;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // Accumulate for weighted averages&#xD;&#xA;    SettedEggsTotalHOF += SettedEggsHatch ;&#xD;&#xA;    FertilityWeightedSumHOF += (Fertility * SettedEggsHatch );&#xD;&#xA;    HatchPercWeightedSumHOF += (HatchPerc * SettedEggsFertility );&#xD;&#xA;    &#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell15_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Get the current cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// --- Read value safely ---&#xD;&#xA;decimal gradeAChicks = 0;&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;GradeAChicks&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;GradeAChicks&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    gradeAChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;GradeAChicks&quot;));&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    gradeAChicks = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Assign the value to the cell ---&#xD;&#xA;cell.Text = gradeAChicks.ToString(&quot;N0&quot;); // Format with 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell17_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Get the current cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// --- Read value safely ---&#xD;&#xA;decimal culls = 0;&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;Culls&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    culls = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Assign the value to the cell ---&#xD;&#xA;cell.Text = culls.ToString(&quot;N0&quot;); // Format with 2 decimal places&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell28_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;decimal SettedEggs= 0;&#xD;&#xA;decimal GradeAChicks = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;// --- Deads ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    SettedEggs= Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Culls ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;GradeAChicks&quot;) != null)&#xD;&#xA;    GradeAChicks= Convert.ToDecimal(GetCurrentColumnValue(&quot;GradeAChicks&quot;));&#xD;&#xA;   &#xD;&#xA;   if(SettedEggs != 0){&#xD;&#xA;        result  = (GradeAChicks * 100m) / SettedEggs;&#xD;&#xA;       }&#xD;&#xA;  &#xD;&#xA;   XRTableCell cell = sender as XRTableCell;&#xD;&#xA;   cell.Text = result.ToString(&quot;N2&quot;); // no decimals, adjust format if needed&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell46_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    &#xD;&#xA;    if (SettedEggsHatchTotal &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        weightedAverageHatch = (GradeAChicksHatchTotal * 100m) / SettedEggsHatchTotal ;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = weightedAverageHatch.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell48_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    &#xD;&#xA;    if (SettedEggsFertilityTotal &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        weightedAverageFertility = FertilityWeightedSum  / SettedEggsFertilityTotal  ;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = weightedAverageFertility.ToString(&quot;N2&quot;);&#xD;&#xA; &#xD;&#xA; &#xD;&#xA; }&#xD;&#xA;&#xD;&#xA;private void xrTableCell14_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal HatchPerc = 0;&#xD;&#xA;    decimal result = 0;&#xD;&#xA;    decimal SettedEggs_HOF  = 0;&#xD;&#xA;    decimal GradeAChicksHatch_HOF = 0;&#xD;&#xA;    decimal Fertility_HOF = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        SettedEggs_HOF= Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;GradeAChicks&quot;) != null)&#xD;&#xA;        GradeAChicksHatch_HOF = Convert.ToDecimal(GetCurrentColumnValue(&quot;GradeAChicks&quot;));&#xD;&#xA;        &#xD;&#xA;    if (GetCurrentColumnValue(&quot;Fertility&quot;) != null)&#xD;&#xA;        Fertility_HOF = Convert.ToDecimal(GetCurrentColumnValue(&quot;Fertility&quot;));&#xD;&#xA;        &#xD;&#xA;     if(SettedEggs_HOF!= 0){&#xD;&#xA;           HatchPerc = (GradeAChicksHatch_HOF* 100m) / SettedEggs_HOF;&#xD;&#xA;         }&#xD;&#xA;&#xD;&#xA;      if(Fertility_HOF!= 0){&#xD;&#xA;           result = (HatchPerc * 100m) / Fertility_HOF;&#xD;&#xA;         }&#xD;&#xA;  &#xD;&#xA;   XRTableCell cell = sender as XRTableCell;&#xD;&#xA;   cell.Text = result.ToString(&quot;N2&quot;); // no decimals, adjust format if needed&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell21_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal result = 0;&#xD;&#xA;    &#xD;&#xA;    // Calculate weighted averages&#xD;&#xA;    decimal weightedAvgFertility = (SettedEggsTotalHOF &gt; 0) ? FertilityWeightedSumHOF / SettedEggsTotalHOF : 0;&#xD;&#xA;    decimal weightedAvgHatchPerc = (SettedEggsTotalHOF &gt; 0) ? HatchPercWeightedSumHOF / SettedEggsTotalHOF : 0;&#xD;&#xA;    &#xD;&#xA;    // Apply the equation: (WeightedAvgHatchPerc * 100) / WeightedAvgFertility&#xD;&#xA;    if (weightedAvgFertility != 0)&#xD;&#xA;    {&#xD;&#xA;        result = (weightedAvgHatchPerc * 100m) / weightedAvgFertility;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;);    &#xD;&#xA;    &#xD;&#xA;   }&#xD;&#xA;&#xD;&#xA;private void xrLabel2_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;              XRLabel label = sender as XRLabel;&#xD;&#xA;&#xD;&#xA;if (Parameters[&quot;DateFrom&quot;].Value == null)&#xD;&#xA;{&#xD;&#xA;    label.Text = &quot;&quot;;&#xD;&#xA;    return;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;DateTime dt = Convert.ToDateTime(Parameters[&quot;DateFrom&quot;].Value);&#xD;&#xA;&#xD;&#xA;// Convert IsRTL safely&#xD;&#xA;int isRtl = Convert.ToInt32(Parameters[&quot;IsRTL&quot;].Value);&#xD;&#xA;&#xD;&#xA;if (isRtl == 1) // Arabic&#xD;&#xA;{&#xD;&#xA;    label.Text = $&quot;من: {dt:dd/MM/yyyy}&quot;;&#xD;&#xA;}&#xD;&#xA;else // English&#xD;&#xA;{&#xD;&#xA;    label.Text = $&quot;From: {dt:dd/MM/yyyy}&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrLabel1_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;           XRLabel label = sender as XRLabel;&#xD;&#xA;&#xD;&#xA;if (Parameters[&quot;DateTo&quot;].Value == null)&#xD;&#xA;{&#xD;&#xA;    label.Text = &quot;&quot;;&#xD;&#xA;    return;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;DateTime dt = Convert.ToDateTime(Parameters[&quot;DateTo&quot;].Value);&#xD;&#xA;&#xD;&#xA;// Convert IsRTL safely&#xD;&#xA;int isRtl = Convert.ToInt32(Parameters[&quot;IsRTL&quot;].Value);&#xD;&#xA;&#xD;&#xA;if (isRtl == 1) // Arabic&#xD;&#xA;{&#xD;&#xA;    label.Text = $&quot;الي: {dt:dd/MM/yyyy}&quot;;&#xD;&#xA;}&#xD;&#xA;else // English&#xD;&#xA;{&#xD;&#xA;    label.Text = $&quot;To: {dt:dd/MM/yyyy}&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" Version="25.2" DataMember="SR_HT_MachineEfficiency" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
