      <Controls>
        <Item1 Ref="206" ControlType="XRTable" Name="xrTable1" Padding="2,2,0,0,96" BorderWidth="1.4">
          <Rows>
            <Item1 Ref="207" ControlType="XRTableRow" Name="xrTableRow1">
              <Cells>
                <Item1 Ref="208" ControlType="XRTableCell" Name="xrTableCell39" Multiline="true" />
                <Item2 Ref="209" ControlType="XRTableCell" Name="xrTableCell42" Multiline="true" TextAlignment="MiddleRight" Borders="All">
                  <Summary Ref="210" Running="Report" />
                  <ExpressionBindings>
                    <Item1 Ref="211" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([SettedEggs])" />
                    <Item2 Ref="212" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="213" UseFont="false" UseBorders="false" UseTextAlignment="false" />
                </Item2>
                <Item3 Ref="214" ControlType="XRTableCell" Name="xrTableCell43" Multiline="true" TextAlignment="MiddleRight" Borders="All">
                  <Summary Ref="215" Running="Report" />
                  <ExpressionBindings>
                    <Item1 Ref="216" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([GradeAChicks])" />
                    <Item2 Ref="217" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="218" UseFont="false" UseBorders="false" UseTextAlignment="false" />
                </Item3>
                <Item4 Ref="219" ControlType="XRTableCell" Name="xrTableCell44" Multiline="true" TextAlignment="BottomCenter" Borders="All">
                  <Summary Ref="220" Running="Report" />
                  <ExpressionBindings>
                    <Item1 Ref="221" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Culls])" />
                    <Item2 Ref="222" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="223" UseFont="false" UseBorders="false" UseTextAlignment="false" />
                </Item4>
                <Item5 Ref="224" ControlType="XRTableCell" Name="xrTableCell45" Multiline="true" TextAlignment="MiddleRight" Borders="All">
                  <Summary Ref="225" Running="Report" />
                  <ExpressionBindings>
                    <Item1 Ref="226" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                    <Item2 Ref="227" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([GradeAChicks] + [Culls])" />
                  </ExpressionBindings>
                  <StylePriority Ref="228" UseFont="false" UseBorders="false" UseTextAlignment="false" />
                </Item5>
                <Item6 Ref="229" ControlType="XRTableCell" Name="xrTableCell46" Multiline="true" TextAlignment="MiddleRight" Borders="All">
                  <Summary Ref="230" Running="Report" />
                  <ExpressionBindings>
                    <Item1 Ref="231" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                    <Item2 Ref="232" EventName="BeforePrint" PropertyName="Text" Expression="sumSum(Iif([SettedEggs] &gt; 0,[GradeAChicks] / [SettedEggs] * 100 , 0)&#xA;)" />
                  </ExpressionBindings>
                  <StylePriority Ref="233" UseFont="false" UseBorders="false" UseTextAlignment="false" />
                </Item6>
                <Item7 Ref="234" ControlType="XRTableCell" Name="xrTableCell47" Multiline="true" TextAlignment="BottomLeft" Borders="All">
                  <Summary Ref="235" Running="Report" />
                  <ExpressionBindings>
                    <Item1 Ref="236" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([HatchPer])" />
                    <Item2 Ref="237" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="238" UseFont="false" UseBorders="false" UseTextAlignment="false" />
                </Item7>
                <Item8 Ref="239" ControlType="XRTableCell" Name="xrTableCell48" Multiline="true" TextAlignment="MiddleRight" Borders="All">
                  <Summary Ref="240" Running="Report" />
                  <ExpressionBindings>
                    <Item1 Ref="241" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Fertility])" />
                    <Item2 Ref="242" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="243" UseFont="false" UseBorders="false" UseTextAlignment="false" />
                </Item8>
                <Item9 Ref="244" ControlType="XRTableCell" Name="xrTableCell49" Multiline="true" TextAlignment="BottomCenter" Borders="All">
                  <Summary Ref="245" Running="Report" />
                  <ExpressionBindings>
                    <Item1 Ref="246" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([FertPer])" />
                    <Item2 Ref="247" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="248" UseFont="false" UseBorders="false" UseTextAlignment="false" />
                </Item9>
                <Item10 Ref="249" ControlType="XRTableCell" Name="xrTableCell21" Multiline="true" TextAlignment="BottomLeft" Borders="All">
                  <Summary Ref="250" Running="Report" />
                  <ExpressionBindings>
                    <Item1 Ref="251" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([MachinesEfficiency])" />
                    <Item2 Ref="252" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="253" UseFont="false" UseBorders="false" UseTextAlignment="false" />
                </Item10>
                <Item11 Ref="254" ControlType="XRTableCell" Name="xrTableCell4" Multiline="true" TextAlignment="MiddleRight" Borders="All">
                  <Summary Ref="255" Running="Report" />
                  <ExpressionBindings>
                    <Item1 Ref="256" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([HatchOfFertPer])" />
                    <Item2 Ref="257" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="258" UseFont="false" UseBorders="false" UseTextAlignment="false" />
                </Item11>
              </Cells>
            </Item1>
          </Rows>
          <StylePriority Ref="259" UseBorderWidth="false" />
        </Item1>
