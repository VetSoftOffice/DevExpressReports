  </Parameters>
  <CalculatedFields>
    <Item1 Ref="24" Name="TotalCostPerc_CF" DisplayName="TotalCostPerc_CF" Expression="(ToDecimal([TotalCost]) / ToDecimal(Sum([TotalCost])))*ToDecimal(100)&#xA;" DataMember="SR_FM_Stocktaking" />
    <Item2 Ref="25" Name="Per_Chick_CF" Expression="Iif([FemaleChicks]!=0,[TotalCost]/[FemaleChicks] ,[FemaleChicks] )" DataMember="SR_FM_Stocktaking" />
    <Item3 Ref="26" Name="PerHH_CF" DisplayName="PerHH_CF" Expression="Iif([FemalePOL]!=0,[TotalCost]/[FemalePOL] ,[FemalePOL] )&#xA;" DataMember="SR_FM_Stocktaking" />
    <Item4 Ref="27" Name="PerHE_CF" Expression="Iif([HatchingEggs]!=0,[TotalCost]/[HatchingEggs] ,[HatchingEggs] )&#xA;&#xA;" DataMember="SR_FM_Stocktaking" />
    <Item5 Ref="28" Name="DiffQtyq" Expression="IsNull([ActualQty], 0) - IsNull([SentOrClacQty], 0)" DataMember="SR_FM_Stocktaking" />
    <Item6 Ref="29" Name="DiffPriceq" Expression="Iif([CalcPriceUnit] &gt; 0, IsNull([AdjustedPriceUnit], 0) - IsNull([CalcPriceUnit], 0), 0)" DataMember="SR_FM_Stocktaking" />
    <Item7 Ref="30" Name="TotalBalanceStart" Expression="Iif(IsNullOrEmpty([BeginOfYearSettedEggs]), 0,[BeginOfYearSettedEggs]) + Iif(IsNullOrEmpty([BeginOutSide]), 0,[BeginOutSide]) &#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item8 Ref="31" Name="TotalFarmIn_DataVar" Expression="Iif(IsNullOrEmpty([AddDataVar]),0 ,[AddDataVar] ) + Iif(IsNullOrEmpty([FarmIntake]),0 ,[FarmIntake] )" DataMember="SR_HT_YearlyProdReport" />
    <Item9 Ref="32" Name="InputTotal" Expression="[TotalBalanceStart] + [TotalFarmIn_DataVar]&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item10 Ref="33" Name="RejCrack_Per" Expression="Iif([TotalFarmIn_DataVar] &gt; 0, [SR_HT_YearlyProdReport.RejCracks] / [TotalFarmIn_DataVar] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item11 Ref="34" Name="RejWhole_Per" Expression="Iif([TotalFarmIn_DataVar] &gt; 0, [SR_HT_YearlyProdReport.RejWhole] / [TotalFarmIn_DataVar] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item12 Ref="35" Name="RejBroken_Per" Expression="Iif([TotalFarmIn_DataVar] &gt; 0, [SR_HT_YearlyProdReport.RejBroken] / [TotalFarmIn_DataVar] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item13 Ref="36" Name="OtherEggs_Per" Expression="Iif([TotalFarmIn_DataVar] &gt; 0, [SR_HT_YearlyProdReport.OtherEggs] / [TotalFarmIn_DataVar] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item14 Ref="37" Name="RejHat_Per" Expression="Iif([TotalFarmIn_DataVar] &gt; 0, [SR_HT_YearlyProdReport.HT_RejEggs] / [TotalFarmIn_DataVar] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item15 Ref="38" Name="RejHatBroken_Per" Expression="Iif([TotalFarmIn_DataVar] &gt; 0, [SR_HT_YearlyProdReport.HT_BrokenEggs] / [TotalFarmIn_DataVar] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item16 Ref="39" Name="sndCollages_Per" Expression="Iif([AvailableHatchEgg] != 0, [SR_HT_YearlyProdReport.EggsToCollage] / [AvailableHatchEgg] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item17 Ref="40" Name="TotalRej" Expression="[SR_HT_YearlyProdReport.RejCracks] + [SR_HT_YearlyProdReport.RejWhole] + [SR_HT_YearlyProdReport.RejBroken] + [SR_HT_YearlyProdReport.HT_RejEggs] + [SR_HT_YearlyProdReport.HT_BrokenEggs] + [SR_HT_YearlyProdReport.OtherEggs]&#xD;&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item18 Ref="41" Name="SoldEggs" Expression="Iif(IsNullOrEmpty([RH_SoldEggs]), 0, [RH_SoldEggs]) +&#xD;&#xA;Iif(IsNullOrEmpty([ES_SoldEggs]), 0, [ES_SoldEggs]) -&#xD;&#xA;Iif(IsNullOrEmpty([MOL]), 0, [MOL]) -&#xD;&#xA;Iif(IsNullOrEmpty([EggsToCollage]), 0, [EggsToCollage])&#xD;&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item19 Ref="42" Name="AvailableHatchEgg" Expression="Iif(IsNullOrEmpty([InputTotal]), 0, [InputTotal]) -&#xD;&#xA;Iif(IsNullOrEmpty([TotalRej]), 0, [TotalRej]) -&#xD;&#xA;Iif(IsNullOrEmpty([EggsToCollage]), 0, [EggsToCollage]) -&#xD;&#xA;Iif(IsNullOrEmpty([MOL]), 0, [MOL]) -&#xD;&#xA;Iif(IsNullOrEmpty([SoldEggs]), 0, [SoldEggs])&#xD;&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item20 Ref="43" Name="MOL_Per" Expression="IIf([AvailableHatchEgg] &lt;&gt; 0, [SR_HT_YearlyProdReport.MOL] / [AvailableHatchEgg] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item21 Ref="44" Name="SoldEggsToCust_Per" Expression="IIf([AvailableHatchEgg] &lt;&gt; 0, [SoldEggs] / [AvailableHatchEgg] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item22 Ref="45" Name="SoldEggsToStores_Per" Expression="IIf([AvailableHatchEgg] &lt;&gt; 0, [SR_HT_YearlyProdReport.SoldEggsToStore] / [AvailableHatchEgg] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item23 Ref="46" Name="CondEggs_Per" Expression="IIf([AvailableHatchEgg] &lt;&gt; 0, [SR_HT_YearlyProdReport.CondEggs] / [AvailableHatchEgg] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item24 Ref="47" Name="ChickVetLab_Per" Expression="IIf([TotalChickProd] &lt;&gt; 0, [SR_HT_YearlyProdReport.ChicksToVet] / [TotalChickProd] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item25 Ref="48" Name="ChiksRejHat" Expression="Iif(IsNullOrEmpty([CullsChicks]), 0, [CullsChicks]) +&#xA;Iif(IsNullOrEmpty([DeadChicks]), 0, [DeadChicks])&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item26 Ref="49" Name="TotalChiksTrans" Expression="Iif(IsNullOrEmpty([ChicksToVet]), 0, [ChicksToVet]) +&#xD;&#xA;Iif(IsNullOrEmpty([ChicksToBroiler]), 0, [ChicksToBroiler]) +&#xD;&#xA;Iif(IsNullOrEmpty([SoldChicksWithoutCollege]), 0, [SoldChicksWithoutCollege]) +&#xD;&#xA;Iif(IsNullOrEmpty([CondemnedChicks]), 0, [CondemnedChicks]) +&#xD;&#xA;Iif(IsNullOrEmpty([OtherSentChicks]), 0, [OtherSentChicks])&#xD;&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item27 Ref="50" Name="TotalChickProd" Expression="Iif(IsNullOrEmpty([TotalChiksTrans]), 0, [TotalChiksTrans]) +&#xA;Iif(IsNullOrEmpty([DOA]), 0, [DOA]) +&#xA;Iif(IsNullOrEmpty([ChiksRejHat]), 0, [ChiksRejHat])&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item28 Ref="51" Name="ChiksBrioler_Per" Expression="IIf([TotalChickProd] &lt;&gt; 0, [SR_HT_YearlyProdReport.ChicksToBroiler] / [TotalChickProd] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item29 Ref="52" Name="SoldChicks_Per" Expression="IIf([TotalChickProd] &lt;&gt; 0, [SR_HT_YearlyProdReport.SoldChicksWithoutCollege] / [TotalChickProd] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item30 Ref="53" Name="CondemnedChicks_Per" Expression="IIf([TotalChickProd] &lt;&gt; 0, [SR_HT_YearlyProdReport.CondemnedChicks] / [TotalChickProd] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item31 Ref="54" Name="TotalChikstrans_Per" Expression="IIf([TotalChickProd] &lt;&gt; 0, [TotalChiksTrans] / [TotalChickProd] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item32 Ref="55" Name="DOA_Per" Expression="IIf([TotalChickProd] &lt;&gt; 0, [SR_HT_YearlyProdReport.DOA] / [TotalChickProd] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item33 Ref="56" Name="ChiksRejHat_Per" Expression="IIf([TotalChickProd] &lt;&gt; 0, [ChiksRejHat] / [TotalChickProd] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item34 Ref="57" Name="TotalBalnce_End" Expression="Iif(IsNullOrEmpty([EndOfYearSettedEggs]), 0, [EndOfYearSettedEggs]) +&#xA;Iif(IsNullOrEmpty([EndOutSide]), 0, [EndOutSide])&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item35 Ref="58" Name="TotalHat_Per" Expression="Iif(&#xD;&#xA;    (Iif(IsNullOrEmpty([AvailableHatchEgg]), 0, [AvailableHatchEgg]) - &#xD;&#xA;     Iif(IsNullOrEmpty([TotalBalnce_End]), 0, [TotalBalnce_End])) &lt;&gt; 0,&#xD;&#xA;    Iif(IsNullOrEmpty([TotalChickProd]), 0, [TotalChickProd]) / &#xD;&#xA;    (Iif(IsNullOrEmpty([AvailableHatchEgg]), 0, [AvailableHatchEgg]) - &#xD;&#xA;     Iif(IsNullOrEmpty([TotalBalnce_End]), 0, [TotalBalnce_End])) * 100,&#xD;&#xA;    0&#xD;&#xA;)&#xD;&#xA;" DataMember="SR_HT_YearlyProdReport" />
    <Item36 Ref="59" Name="OtherChicks_Per_CF" Expression="IIf([TotalChickProd] &lt;&gt; 0, [SR_HT_YearlyProdReport.OtherSentChicks] / [TotalChickProd] * 100, 0)&#xA;" DataMember="SR_HT_YearlyProdReport" />
  </CalculatedFields>
