    <Item19 Ref="39" Name="G_Wt" Expression="[TotalWt_PT] + IsNull([TotalWt_SL],0)&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
    <Item20 Ref="40" Name="G_Avg_Wt" Expression="Iif([G_Birds] &gt; 0, [G_Wt] / [G_Birds], 0)&#xA;" DataMember="SR_BRO_SoldBirdsAndSlaughter" />
