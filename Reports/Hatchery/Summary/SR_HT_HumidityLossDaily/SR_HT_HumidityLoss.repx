<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_HumidityLoss" ScriptsSource="decimal avgChickWtRatioAvg = 0;&#xD;&#xA;&#xD;&#xA;private void xrTableCell20_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare variables ---&#xD;&#xA;decimal avgChickWt = 0;&#xD;&#xA;decimal avgOneSetEggWt = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;AvgChickWt&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;AvgChickWt&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    avgChickWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;AvgChickWt&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;AvgOneSetEggWt&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;AvgOneSetEggWt&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    avgOneSetEggWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;AvgOneSetEggWt&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation: [AvgChickWt] * 100 / [AvgOneSetEggWt] ---&#xD;&#xA;if (avgOneSetEggWt != 0)&#xD;&#xA;    result = (avgChickWt * 100) / avgOneSetEggWt;&#xD;&#xA;else&#xD;&#xA;    result = 0;&#xD;&#xA;// --- Accumulate total for average later ---&#xD;&#xA;decimal avgChickWtRatioSum = 0;&#xD;&#xA;int avgChickWtRatioCount = 0;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);  // format with 2 decimal places&#xD;&#xA;avgChickWtRatioSum += result;&#xD;&#xA;avgChickWtRatioCount++;&#xD;&#xA;if (avgChickWtRatioCount &gt; 0)&#xD;&#xA;    avgChickWtRatioAvg = avgChickWtRatioSum / avgChickWtRatioCount;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell48_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell48.Text = avgChickWtRatioAvg.ToString(&quot;0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;" PageWidth="1169" PageHeight="1654" Version="24.2" DataMember="SR_HT_HumidityLoss" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
