                  <Item61 Ref="510" Name="InfertilePerc_GT" Expression="Iif(Sum([SettedEggs]) &gt; 0, Sum([InfertileEggs] )/ Sum([SettedEggs])* 100,0 )&#xA;" DataMember="SR_HT_DailyHatchWise_SubReports" />
                  <Item62 Ref="511" Name="AllOverSettedPerc_SubGT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([TotalHatchChicks]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise_SubReports" />
