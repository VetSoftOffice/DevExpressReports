                  <Item65 Ref="514" Name="SettedAndRejEggs_SubReport" Expression="Iif(IsNullOrEmpty([SettedEggs]),0,[SettedEggs]) + Iif(IsNullOrEmpty([RejSellEggs]),0,[RejSellEggs]) + Iif(IsNullOrEmpty([RejUnSellEggs]),0,[RejUnSellEggs])&#xA;" DataMember="SR_HT_DailyHatchWise_SubReports" />
