    <Item6 Ref="412" ControlType="ReportFooterBand" Name="ReportFooter">
      <SubBands>
        <Item1 Ref="413" ControlType="SubBand" Name="SubBand7" PageBreak="AfterBand">
          <Controls>
            <Item1 Ref="414" ControlType="XRSubreport" Name="SR_HT_DailyHatchWise_SubReport">
              <ReportSource Ref="416" ControlType="DevExpressReports.Reports.Hatchery.Summary.SR_HT_DailyHatchWise_SubReport.SR_HT_DailyHatchWise_SubReport, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="using System.ComponentModel;&#xD;&#xA;using DevExpress.XtraReports.Parameters;&#xD;&#xA;&#xD;&#xA;int groupCounter = 1;&#xD;&#xA;&#xD;&#xA;private void GroupFooter1_BeforePrint(object sender, CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    GroupFooterBand groupFooter = (GroupFooterBand)sender;&#xD;&#xA;    XtraReport report = (XtraReport)groupFooter.Report;&#xD;&#xA;    &#xD;&#xA;    Parameter noOfGroupsPerPageParam = report.Parameters[&quot;NoOfGroupsPerPage&quot;];&#xD;&#xA;    if(noOfGroupsPerPageParam != null &amp;&amp; noOfGroupsPerPageParam.Value != &quot;&quot;)&#xD;&#xA;    {&#xD;&#xA;        int noOfGroupsPerPage = Convert.ToInt32(noOfGroupsPerPageParam.Value);&#xD;&#xA;        if (noOfGroupsPerPage &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            if (groupCounter == noOfGroupsPerPage)&#xD;&#xA;            {&#xD;&#xA;                groupFooter.PageBreak = PageBreak.AfterBand;&#xD;&#xA;                groupCounter = 1;&#xD;&#xA;            }&#xD;&#xA;            else&#xD;&#xA;            {&#xD;&#xA;                groupFooter.PageBreak = PageBreak.None;&#xD;&#xA;                groupCounter += 1;&#xD;&#xA;            }&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}" Landscape="true" PageWidth="1654" PageHeight="1169" Version="24.2" DataMember="SR_HT_DailyHatchWise_SubReports" DataSource="#Ref-415" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
                <Parameters>
                  <Item1 Ref="417" Visible="false" ValueInfo="False" Name="IsRTL" Type="#Ref-2" />
                  <Item2 Ref="418" Visible="false" ValueInfo="False" Name="IsCustomReportHeader" Type="#Ref-2" />
                  <Item3 Ref="419" Visible="false" ValueInfo="False" Name="IsCustomReportFooter" Type="#Ref-2" />
                  <Item4 Ref="420" ValueInfo="False" Name="ShowSignature" Type="#Ref-2" />
                  <Item5 Ref="421" ValueInfo="False" Name="ShowSignatureAllPages" Type="#Ref-2" />
                  <Item6 Ref="422" ValueInfo="False" Name="HideReportHeader" Type="#Ref-2" />
                  <Item7 Ref="423" ValueInfo="False" Name="HideReportFooter" Type="#Ref-2" />
                  <Item8 Ref="424" Name="NoOfGroupsPerPage" />
                  <Item9 Ref="425" Visible="false" Name="FontSize" />
                  <Item10 Ref="426" Visible="false" Name="DateFrom" />
                  <Item11 Ref="427" Visible="false" Name="DateTo" />
                  <Item12 Ref="428" Visible="false" ValueInfo="0" AllowNull="true" Name="ReportType" Type="#Ref-15" />
                  <Item13 Ref="429" Visible="false" AllowNull="true" Name="Price" />
                  <Item14 Ref="430" Visible="false" AllowNull="true" Name="AdjustedPrice" />
                  <Item15 Ref="431" Visible="false" AllowNull="true" Name="DiffPrice" />
                  <Item16 Ref="432" Visible="false" AllowNull="true" Name="Available" />
                  <Item17 Ref="433" Visible="false" AllowNull="true" Name="ActualQty" />
                  <Item18 Ref="434" Visible="false" AllowNull="true" Name="DiffQty" />
                  <Item19 Ref="435" Visible="false" AllowNull="true" Name="FarmNo" />
                  <Item20 Ref="436" Visible="false" Name="BookPerf" />
                </Parameters>
                <CalculatedFields>
                  <Item1 Ref="437" Name="TotalCostPerc_CF" DisplayName="TotalCostPerc_CF" Expression="(ToDecimal([TotalCost]) / ToDecimal(Sum([TotalCost])))*ToDecimal(100)&#xA;" DataMember="SR_FM_Stocktaking" />
                  <Item2 Ref="438" Name="Per_Chick_CF" Expression="Iif([FemaleChicks]!=0,[TotalCost]/[FemaleChicks] ,[FemaleChicks] )" DataMember="SR_FM_Stocktaking" />
                  <Item3 Ref="439" Name="PerHH_CF" DisplayName="PerHH_CF" Expression="Iif([FemalePOL]!=0,[TotalCost]/[FemalePOL] ,[FemalePOL] )&#xA;" DataMember="SR_FM_Stocktaking" />
                  <Item4 Ref="440" Name="PerHE_CF" Expression="Iif([HatchingEggs]!=0,[TotalCost]/[HatchingEggs] ,[HatchingEggs] )&#xA;&#xA;" DataMember="SR_FM_Stocktaking" />
                  <Item5 Ref="441" Name="DiffQtyq" Expression="IsNull([ActualQty], 0) - IsNull([SentOrClacQty], 0)" DataMember="SR_FM_Stocktaking" />
                  <Item6 Ref="442" Name="DiffPriceq" Expression="Iif([CalcPriceUnit] &gt; 0, IsNull([AdjustedPriceUnit], 0) - IsNull([CalcPriceUnit], 0), 0)" DataMember="SR_FM_Stocktaking" />
                  <Item7 Ref="443" Name="ActEggRecHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.ActRecEggs] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item8 Ref="444" Name="RejEggHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.RejEggs] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item9 Ref="445" Name="EstHatEggs" Expression="[ActEggRecHHCum] - [RejEggHHCum]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item10 Ref="446" Name="ActEggSetHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.ActSetEggCum] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item11 Ref="447" Name="EstHatEggsBefore21days" Expression="[SR_HT_WeeklyHHFlockSum.ActRecEggsBefore21days] - [SR_HT_WeeklyHHFlockSum.RejEggsBefore21days]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item12 Ref="448" Name="ActHatch_Per_Cum" Expression="Iif([SR_HT_WeeklyHHFlockSum.SettedEggs] &lt;&gt; 0, &#xA;    ([SR_HT_WeeklyHHFlockSum.ActChicks] + [SR_HT_WeeklyHHFlockSum.CullsChicks] + [SR_HT_WeeklyHHFlockSum.DeadChicks]) &#xA;    / [SR_HT_WeeklyHHFlockSum.SettedEggs] * 100, &#xA;    0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item13 Ref="449" Name="EstChiks" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &gt; 0, &#xA;    ([EstHatEggsBefore21days] * [ActHatch_Per_Cum] / 100) / [SR_HT_WeeklyHHFlockSum.POL], &#xA;    0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item14 Ref="450" Name="ActChicksHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, &#xA;    ([SR_HT_WeeklyHHFlockSum.ActChicks] + [SR_HT_WeeklyHHFlockSum.CullsChicks] + [SR_HT_WeeklyHHFlockSum.DeadChicks]) &#xA;    / [SR_HT_WeeklyHHFlockSum.POL], &#xA;    0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item15 Ref="451" Name="Diviation" Expression="[ActHatch_Per_Cum] - [SR_HT_WeeklyHHFlockSum.StdHatchCum]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item16 Ref="452" Name="TotalHatchedEggs" Expression="[ChicksSettedEggs]" DataMember="SR_HT_Production" />
                  <Item17 Ref="453" Name="HatchPer" Expression="Iif([TotalHatchedEggs] &lt;&gt; 0, [SR_HT_Production.Chicks] * 100 / [TotalHatchedEggs], 0)&#xA;" DataMember="SR_HT_Production" />
                  <Item18 Ref="454" Name="HOFPer" Expression="Iif([SR_HT_Production.FertPer] &lt;&gt; 0, [HatchPer] * 100.0 / [SR_HT_Production.FertPer], 0)&#xA;" DataMember="SR_HT_Production" />
                  <Item19 Ref="455" Name="HatchPerc" Expression="Iif([SR_HT_Hatch.SettedEggs] &lt;&gt; 0, [SR_HT_Hatch.SellableChicks] * 100 / [SR_HT_Hatch.SettedEggs], 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item20 Ref="456" Name="HOFPerc" Expression="Iif([SR_HT_Hatch.FertPer] &lt;&gt; 0, [HatchPer] * 100.0 / [SR_HT_Hatch.FertPer], 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item21 Ref="457" Name="TotalHatchPerc" Expression="Iif(Sum([SR_HT_Hatch.SettedEggs]) &lt;&gt; 0, Sum([SR_HT_Hatch.SellableChicks]) * 100 / Sum([SR_HT_Hatch.SettedEggs]), 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item22 Ref="458" Name="FertileEggs_CF" Expression="[SR_HT_Hatch.FertPer] * [SR_HT_Hatch.SettedEggs] / 100&#xA;&#xA;" DataMember="SR_HT_Hatch" />
                  <Item23 Ref="459" Name="FertPerc" Expression="Iif(Sum([SR_HT_Hatch.SettedEggs]) &lt;&gt; 0, Sum([FertileEggs]) * 100 / Sum([SR_HT_Hatch.SettedEggs]), 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item24 Ref="460" Name="TotalHOFPerc" Expression="Iif([FertPerc] &lt;&gt; 0, [TotalHatchPerc] * 100 / [FertPerc], 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item25 Ref="461" Name="SettedAndRejEggs" Expression="[SettedEggs] + [RejSellEggs] + [RejUnSellEggs]" DataMember="SR_HT_DailyHatchWise" />
                  <Item26 Ref="462" Name="RejSellEggsPerc" Expression="Iif([SettedAndRejEggs], [RejSellEggs] / [SettedAndRejEggs] * 100 , 0)" DataMember="SR_HT_DailyHatchWise" />
                  <Item27 Ref="463" Name="BrokenPerc" Expression="Iif([SettedAndRejEggs], [RejUnSellEggs] / [SettedAndRejEggs] * 100 , 0)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item28 Ref="464" Name="InfertilePerc" Expression="Iif([SettedEggs] &gt; 0, [InfertileEggs] / [SettedEggs] * 100,0 )" DataMember="SR_HT_DailyHatchWise" />
                  <Item29 Ref="465" Name="NonHatchEggPerc" Expression="Iif([SettedEggs]&gt; 0, [FertileEggs] / [SettedEggs], 0)" DataMember="SR_HT_DailyHatchWise" />
