    <Item6 Ref="421" ControlType="ReportFooterBand" Name="ReportFooter">
      <SubBands>
        <Item1 Ref="422" ControlType="SubBand" Name="SubBand7" PageBreak="AfterBand">
          <Controls>
            <Item1 Ref="423" ControlType="XRSubreport" Name="SR_HT_DailyHatchWise_SubReport">
              <ReportSource Ref="425" ControlType="DevExpressReports.Reports.Hatchery.Summary.SR_HT_DailyHatchWise_SubReport.SR_HT_DailyHatchWise_SubReport, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="decimal SettedAndRejEggsTotal  = 0;&#xD;&#xA;decimal SettedAndRejEggsTotalReport = 0;&#xD;&#xA;decimal infertileEggsTotalReport=0;&#xD;&#xA;decimal totalCullsAndSellableChicksReport  = 0;&#xD;&#xA;decimal totalCullsAndSellableChicks  = 0;&#xD;&#xA;decimal totalDeadRatioReport = 0;&#xD;&#xA;decimal totalDeadRatio = 0;&#xD;&#xA;decimal totalCullsRatioReport = 0;&#xD;&#xA;decimal totalCullsRatio  =0 ;&#xD;&#xA;decimal totalSellableRatioReport = 0;&#xD;&#xA;decimal totalSellableRatio  = 0;&#xD;&#xA;decimal totalChicksRatioReport = 0;&#xD;&#xA;decimal totalChicksRatio = 0;&#xD;&#xA;decimal SaleFertileReport  = 0;&#xD;&#xA;decimal SaleFertile  = 0;&#xD;&#xA;decimal TotalAllSettedEggs = 0;&#xD;&#xA;decimal TotalAllSettedEggsGroup = 0;&#xD;&#xA;// Group variables&#xD;&#xA;decimal settedEggsRejSelableGroup = 0;&#xD;&#xA;decimal rejSellEggsGroup = 0;&#xD;&#xA;decimal rejUnSellEggsGroup = 0;&#xD;&#xA;decimal SettedAndRejEggsTotalGroup = 0;&#xD;&#xA;decimal SettedAndRejUnSelableEggsTotal = 0;&#xD;&#xA;decimal settedEggsInfertileEggsGroup = 0;&#xD;&#xA;decimal InfertileEggsGroup = 0;&#xD;&#xA;decimal InfertileEggsTotal = 0;&#xD;&#xA;decimal NonHatEggsSettedEggsGroup = 0;&#xD;&#xA;decimal NonHatEggsRejSellEggsGroup = 0;&#xD;&#xA;decimal NonHatEggsRejUnSellEggsGroup = 0;&#xD;&#xA;decimal TotaalSettedRejEggsGroup = 0;&#xD;&#xA;decimal NonHatEggsGroup = 0;&#xD;&#xA;decimal NonHatEggsTotal = 0;&#xD;&#xA;decimal deadsSettedEggsGroup = 0;&#xD;&#xA;decimal deadsGroup = 0;&#xD;&#xA;decimal CullsSettedEggsGroup= 0;&#xD;&#xA;decimal cullsGroup= 0;&#xD;&#xA;decimal sellableChicksSettedEggsGroup  = 0;&#xD;&#xA;decimal sellableChicksGroup= 0;&#xD;&#xA;decimal TotalChicksRatioSettedEggsGroup= 0;&#xD;&#xA;decimal TotalChicksRatiocullsGroup= 0;&#xD;&#xA;decimal TotalChicksRatioSellableChicksGroup= 0; &#xD;&#xA;decimal SellablePercSettedEggsGroup= 0;&#xD;&#xA;decimal sellableChicksPercGroup= 0;&#xD;&#xA;decimal TotalChicksRatioFertileEggsGroup  = 0;&#xD;&#xA;decimal TotalSaleFertileGroup  = 0;&#xD;&#xA;decimal result4 = 0;&#xD;&#xA;// Report variables&#xD;&#xA;decimal infertileEggsReport = 0;&#xD;&#xA;decimal settedEggsInfertileReport = 0;&#xD;&#xA;decimal settedEggsRejSelableReport = 0;&#xD;&#xA;decimal rejSellEggsReport = 0;&#xD;&#xA;decimal rejUnSellEggsReportForSellableEggs  = 0;&#xD;&#xA;decimal rejUnSellEggsReportForUnSellableEggs = 0;&#xD;&#xA;decimal TotalRejSelable = 0;&#xD;&#xA;decimal settedEggsUnSellableRejSelableReport = 0;&#xD;&#xA;decimal rejUnSellableSellEggsReport = 0;&#xD;&#xA;decimal TotalRejUnSellableSelable = 0;&#xD;&#xA;decimal SettedAndUnSellableRejEggsTotalReport = 0;&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal SettedEggs = 0;&#xD;&#xA;decimal RejSellEggs = 0;&#xD;&#xA;decimal RejUnSellEggs = 0;&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    SettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RejSellEggs&quot;) != null)&#xD;&#xA;    RejSellEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejSellEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RejUnSellEggs&quot;) != null)&#xD;&#xA;    RejUnSellEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejUnSellEggs&quot;));&#xD;&#xA;&#xD;&#xA;settedEggsRejSelableGroup +=  SettedEggs ;&#xD;&#xA;rejSellEggsGroup += RejSellEggs ;&#xD;&#xA;rejUnSellEggsGroup += RejUnSellEggs ;&#xD;&#xA;SettedAndRejEggsTotalGroup = settedEggsRejSelableGroup + rejSellEggsGroup + rejUnSellEggsGroup ;&#xD;&#xA;if (SettedAndRejEggsTotalGroup &gt; 0)&#xD;&#xA;    SettedAndRejEggsTotal = (rejSellEggsGroup / SettedAndRejEggsTotalGroup ) * 100;&#xD;&#xA;   //-- new logic for unSellableEggs&#xD;&#xA;if (SettedAndRejEggsTotalGroup &gt; 0)&#xD;&#xA;    SettedAndRejUnSelableEggsTotal = SettedAndRejEggsTotalGroup ;&#xD;&#xA;&#xD;&#xA;   //-- new logic for Infertile Eggs&#xD;&#xA;    // --- Declare variables ---&#xD;&#xA;    decimal infertileEggs = 0;&#xD;&#xA;    decimal SettedEggsinfertileEggs   = 0;&#xD;&#xA;    // --- Read values safely ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    SettedEggsinfertileEggs  = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;    &#xD;&#xA;    if (GetCurrentColumnValue(&quot;InfertileEggs&quot;) != null &amp;&amp;&#xD;&#xA;        !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;InfertileEggs&quot;).ToString()))&#xD;&#xA;    {&#xD;&#xA;        infertileEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;InfertileEggs&quot;));&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    // --- Equation (same as Iif([SettedEggs] &gt; 0, [InfertileEggs] / [SettedEggs] * 100, 0)) ---&#xD;&#xA;    settedEggsInfertileEggsGroup +=  SettedEggsinfertileEggs  ;&#xD;&#xA;    InfertileEggsGroup += infertileEggs ;&#xD;&#xA;    if (settedEggsInfertileEggsGroup &gt; 0)&#xD;&#xA;        InfertileEggsTotal =  (InfertileEggsGroup  * 100m) / settedEggsInfertileEggsGroup ;&#xD;&#xA;&#xD;&#xA;        //-- new logic for NonHat Eggs&#xD;&#xA;    // --- Declare variables ---&#xD;&#xA;    decimal NonHatEggs = 0;&#xD;&#xA;    decimal NonHatEggsSettedEggs  = 0;&#xD;&#xA;    decimal NonHatEggsRejSellEggs  = 0;&#xD;&#xA;    decimal NonHatEggsRejUnSellEggs  = 0;&#xD;&#xA;    // --- Read values safely ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;        !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;    {&#xD;&#xA;        NonHatEggsSettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;    }&#xD;&#xA;    if (GetCurrentColumnValue(&quot;RejSellEggs&quot;) != null &amp;&amp;&#xD;&#xA;        !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;RejSellEggs&quot;).ToString()))&#xD;&#xA;    {&#xD;&#xA;        NonHatEggsRejSellEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejSellEggs&quot;));&#xD;&#xA;    }&#xD;&#xA;    if (GetCurrentColumnValue(&quot;RejUnSellEggs&quot;) != null &amp;&amp;&#xD;&#xA;        !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;RejUnSellEggs&quot;).ToString()))&#xD;&#xA;    {&#xD;&#xA;        NonHatEggsRejUnSellEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejUnSellEggs&quot;));&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;NonHatEggs&quot;) != null &amp;&amp;&#xD;&#xA;        !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;NonHatEggs&quot;).ToString()))&#xD;&#xA;    {&#xD;&#xA;        NonHatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;NonHatEggs&quot;));&#xD;&#xA;    }&#xD;&#xA;    NonHatEggsSettedEggsGroup += NonHatEggsSettedEggs ;&#xD;&#xA;    NonHatEggsRejSellEggsGroup += NonHatEggsRejSellEggs ;&#xD;&#xA;    NonHatEggsRejUnSellEggsGroup += NonHatEggsRejUnSellEggs ;&#xD;&#xA;    NonHatEggsGroup += NonHatEggs ;&#xD;&#xA;    TotaalSettedRejEggsGroup = NonHatEggsSettedEggsGroup  + NonHatEggsRejSellEggsGroup  + NonHatEggsRejUnSellEggsGroup ;&#xD;&#xA;    // --- Equation (same as Iif([SettedEggs] &gt; 0, [NonHatEggs] / [SettedEggs] * 100, 0)) ---&#xD;&#xA;    if (NonHatEggsSettedEggsGroup &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        NonHatEggsTotal =  (NonHatEggsGroup * 100m)/ TotaalSettedRejEggsGroup ;&#xD;&#xA;    &#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        NonHatEggsTotal = 0;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;       //-- new logic for Total Chicks (Culls + SellableChicks)&#xD;&#xA;        // --- Declare variables ---&#xD;&#xA;        decimal culls = 0;&#xD;&#xA;        decimal sellableChicks = 0;&#xD;&#xA;        &#xD;&#xA;        // --- Read values safely ---&#xD;&#xA;        if (GetCurrentColumnValue(&quot;Culls&quot;) != null &amp;&amp;&#xD;&#xA;            !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;Culls&quot;).ToString()))&#xD;&#xA;        {&#xD;&#xA;            culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null &amp;&amp;&#xD;&#xA;            !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SellableChicks&quot;).ToString()))&#xD;&#xA;        {&#xD;&#xA;            sellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // --- Equation (same as [Culls] + [SellableChicks]) ---&#xD;&#xA;        result4 = culls + sellableChicks;&#xD;&#xA;        &#xD;&#xA;        // --- Optional: accumulate total ---&#xD;&#xA;        totalCullsAndSellableChicks += result4;&#xD;&#xA;        //-- new logic for Deads Eggs&#xD;&#xA;        decimal deadsSettedEggs  = 0;&#xD;&#xA;        decimal deads = 0;&#xD;&#xA;        decimal deadRatio = 0;&#xD;&#xA;        &#xD;&#xA;        // --- Read values safely ---&#xD;&#xA;        if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;            !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;        {&#xD;&#xA;            deadsSettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        if (GetCurrentColumnValue(&quot;Deads&quot;) != null &amp;&amp;&#xD;&#xA;            !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;Deads&quot;).ToString()))&#xD;&#xA;        {&#xD;&#xA;            deads = Convert.ToDecimal(GetCurrentColumnValue(&quot;Deads&quot;));&#xD;&#xA;        }&#xD;&#xA;        deadsSettedEggsGroup += deadsSettedEggs ;&#xD;&#xA;        deadsGroup += deads  ;&#xD;&#xA;        // --- Equation (same as Iif([SettedEggs] &gt; 0, [Deads] / [SettedEggs], 0)) ---&#xD;&#xA;        if (deadsSettedEggsGroup &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            deadRatio = (deadsGroup * 100m)/ deadsSettedEggsGroup ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            deadRatio = 0;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // --- Optional: accumulate total ---&#xD;&#xA;        &#xD;&#xA;        totalDeadRatioReport = deadRatio;&#xD;&#xA;            //-- new logic for Culls Ratio (Culls / SettedEggs)&#xD;&#xA;        // --- Declare variables ---&#xD;&#xA;        decimal CullsSettedEggs  = 0;&#xD;&#xA;        // --- Read values safely ---&#xD;&#xA;        if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;            !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;        {&#xD;&#xA;            CullsSettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        if (GetCurrentColumnValue(&quot;Culls&quot;) != null &amp;&amp;&#xD;&#xA;            !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;Culls&quot;).ToString()))&#xD;&#xA;        {&#xD;&#xA;            culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // --- Equation (same as Iif([SettedEggs] &gt; 0, [Culls] / [SettedEggs], 0)) ---&#xD;&#xA;        CullsSettedEggsGroup += CullsSettedEggs ;&#xD;&#xA;        cullsGroup += culls ;&#xD;&#xA;        if (CullsSettedEggsGroup &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            totalCullsRatio =  (cullsGroup * 100m) / CullsSettedEggsGroup ;  &#xD;&#xA;                    }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            totalCullsRatio = 0;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // --- Optional: accumulate total ---&#xD;&#xA;        &#xD;&#xA;            //-- new logic for Sellable Chicks Ratio (SellableChicks / SettedEggs)&#xD;&#xA;        // --- Declare variables ---&#xD;&#xA;        decimal sellableChicksSettedEggs  = 0;&#xD;&#xA;        // --- Read values safely ---&#xD;&#xA;        if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;            !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;        {&#xD;&#xA;            sellableChicksSettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null &amp;&amp;&#xD;&#xA;            !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SellableChicks&quot;).ToString()))&#xD;&#xA;        {&#xD;&#xA;            sellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // --- Equation (same as Iif([SettedEggs] &gt; 0, [SellableChicks] / [SettedEggs], 0)) ---&#xD;&#xA;        sellableChicksSettedEggsGroup  += sellableChicksSettedEggs ;&#xD;&#xA;        sellableChicksGroup += sellableChicks ;&#xD;&#xA;        if (sellableChicksSettedEggsGroup  &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            totalSellableRatio = (sellableChicksGroup * 100m) / sellableChicksSettedEggsGroup  ;&#xD;&#xA;        }&#xD;&#xA;        else&#xD;&#xA;        {&#xD;&#xA;            totalSellableRatio = 0;&#xD;&#xA;        }&#xD;&#xA;    //-- new logic for Total Chicks Ratio ((Culls + SellableChicks) / SettedEggs)&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal totalRatio = 0;&#xD;&#xA;decimal TotalChicksRatioSettedEggs  = 0;&#xD;&#xA;decimal TotalChicksRatioCulls = 0;&#xD;&#xA;decimal TotalChicksRatioSellableChicks  = 0;&#xD;&#xA;decimal TotalChicksRatioFertileEggs  = 0;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    TotalChicksRatioSettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;Culls&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    TotalChicksRatioCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SellableChicks&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    TotalChicksRatioSellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;}&#xD;&#xA;if (GetCurrentColumnValue(&quot;FertileEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;FertileEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    TotalChicksRatioFertileEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;FertileEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif([SettedEggs] &gt; 0, ([Culls] + [SellableChicks]) / [SettedEggs], 0)) ---&#xD;&#xA;TotalChicksRatioSettedEggsGroup += TotalChicksRatioSettedEggs ;&#xD;&#xA;TotalChicksRatiocullsGroup +=  TotalChicksRatioCulls ;&#xD;&#xA;TotalChicksRatioSellableChicksGroup += TotalChicksRatioSellableChicks  ;&#xD;&#xA;TotalChicksRatioFertileEggsGroup += TotalChicksRatioFertileEggs ;&#xD;&#xA;&#xD;&#xA;if (TotalChicksRatioSettedEggsGroup &gt; 0)&#xD;&#xA;{&#xD;&#xA;    totalRatio = ((TotalChicksRatiocullsGroup + TotalChicksRatioSellableChicksGroup ) * 100m)/ TotalChicksRatioSettedEggsGroup ;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    totalRatio = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;totalChicksRatio = totalRatio;&#xD;&#xA;    // -- New Logic for Sellable Chicks Percentage --&#xD;&#xA;&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal SellablePercSettedEggs = 0 ;&#xD;&#xA;decimal sellableChicksPercSellableChicks = 0;&#xD;&#xA;decimal SellablePerc = 0 ;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    SellablePercSettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SellableChicks&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    sellableChicksPercSellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Perform calculation ---&#xD;&#xA;SellablePercSettedEggsGroup += SellablePercSettedEggs ;&#xD;&#xA;sellableChicksPercGroup += sellableChicksPercSellableChicks ;&#xD;&#xA;if (SellablePercSettedEggsGroup &gt; 0)&#xD;&#xA;{&#xD;&#xA;    SellablePerc = (sellableChicksPercGroup * 100m) / SellablePercSettedEggsGroup ;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    SellablePerc = 0;&#xD;&#xA;}&#xD;&#xA;SaleFertile  = SellablePerc ;&#xD;&#xA;&#xD;&#xA;//New Logic for AllSetted Hatchibilty&#xD;&#xA;TotalAllSettedEggs = TotalChicksRatiocullsGroup  + TotalChicksRatioSellableChicksGroup ;&#xD;&#xA;if(TotalChicksRatioSettedEggsGroup  &gt; 0){&#xD;&#xA;    &#xD;&#xA;    TotalAllSettedEggsGroup = (TotalAllSettedEggs * 100m) / TotalChicksRatioSettedEggsGroup  ;&#xD;&#xA; }&#xD;&#xA; &#xD;&#xA;&#xD;&#xA;//New Logic for Sale / Fertile Hatchibilty&#xD;&#xA;if(TotalChicksRatioFertileEggsGroup&gt; 0){&#xD;&#xA;    &#xD;&#xA;    TotalSaleFertileGroup = (TotalChicksRatioSellableChicksGroup * 100m) / TotalChicksRatioFertileEggsGroup;&#xD;&#xA; }&#xD;&#xA; &#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell47_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     if(TotalRejSelable  &gt; 0){&#xD;&#xA;           &#xD;&#xA;            SettedAndRejEggsTotalReport = (rejSellEggsReport * 100m) / TotalRejSelable  ;&#xD;&#xA;         }&#xD;&#xA;     xrTableCell47.Text = SettedAndRejEggsTotalReport.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell49_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;         if(TotalRejUnSellableSelable  &gt; 0){ &#xD;&#xA;                  SettedAndUnSellableRejEggsTotalReport = (rejUnSellEggsReportForUnSellableEggs * 100m) / TotalRejUnSellableSelable ;&#xD;&#xA;             }&#xD;&#xA;         xrTableCell49.Text = SettedAndUnSellableRejEggsTotalReport.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell52_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell52.Text = infertileEggsTotalReport.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell103_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell103.Text = totalDeadRatioReport.ToString(&quot;N2&quot;);&#xD;&#xA;      totalDeadRatioReport= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell67_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    //-- new logic for Sellable Chicks Ratio (SellableChicks / SettedEggs)&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal sellableChicks = 0;&#xD;&#xA;decimal sellableRatio = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SellableChicks&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    sellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif([SettedEggs] &gt; 0, [SellableChicks] / [SettedEggs], 0)) ---&#xD;&#xA;if (settedEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    sellableRatio = sellableChicks / settedEggs;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    sellableRatio = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;totalSellableRatioReport += sellableRatio;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = sellableRatio.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell94_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell94.Text = totalSellableRatio.ToString(&quot;N2&quot;);&#xD;&#xA;      totalSellableRatio= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell107_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell107.Text = totalSellableRatioReport.ToString(&quot;N2&quot;);&#xD;&#xA;      totalSellableRatioReport= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell108_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell108.Text = totalChicksRatioReport.ToString(&quot;N2&quot;);&#xD;&#xA;      totalChicksRatioReport= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell109_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell109.Text = SaleFertileReport.ToString(&quot;N2&quot;);&#xD;&#xA;     SaleFertileReport= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell28_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        decimal SettedEggs = 0;&#xD;&#xA;decimal RejSellEggs = 0;&#xD;&#xA;decimal RejUnSellEggs = 0;&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    SettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RejSellEggs&quot;) != null)&#xD;&#xA;    RejSellEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejSellEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RejUnSellEggs&quot;) != null)&#xD;&#xA;    RejUnSellEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejUnSellEggs&quot;));&#xD;&#xA;&#xD;&#xA;decimal SettedAndRejEggs = SettedEggs + RejSellEggs + RejUnSellEggs;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;if (SettedAndRejEggs &gt; 0){&#xD;&#xA;    result = (RejUnSellEggs / SettedAndRejEggs) * 100;&#xD;&#xA;  }&#xD;&#xA; XRTableCell cell = sender as XRTableCell;&#xD;&#xA; cell.Text = result.ToString(&quot;N2&quot;); // format with 2 decimals&#xD;&#xA; settedEggsUnSellableRejSelableReport +=  SettedEggs ;&#xD;&#xA; rejUnSellableSellEggsReport += RejSellEggs ;&#xD;&#xA; rejUnSellEggsReportForUnSellableEggs += RejUnSellEggs ;&#xD;&#xA; TotalRejUnSellableSelable = settedEggsUnSellableRejSelableReport + rejUnSellableSellEggsReport  + rejUnSellEggsReportForUnSellableEggs ;&#xD;&#xA;     &#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;    private void xrTableCell17_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    &#xD;&#xA;    // --- Get values from the current row ---&#xD;&#xA;    decimal settedEggs = GetCurrentColumnValue(&quot;SettedEggs&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    decimal rejSellEggs = GetCurrentColumnValue(&quot;RejSellEggs&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;RejSellEggs&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    decimal rejUnSellEggs = GetCurrentColumnValue(&quot;RejUnSellEggs&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;RejUnSellEggs&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    // --- SettedAndRejEggs = SettedEggs + RejSellEggs + RejUnSellEggs ---&#xD;&#xA;    decimal settedAndRejEggs = settedEggs + rejSellEggs + rejUnSellEggs;&#xD;&#xA;&#xD;&#xA;    // --- Calculate percentage ---&#xD;&#xA;    decimal result = (settedAndRejEggs &gt; 0)&#xD;&#xA;        ? (rejSellEggs / settedAndRejEggs) * 100&#xD;&#xA;        : 0;&#xD;&#xA;    // --- Assign to cell ---&#xD;&#xA;    ((XRTableCell)sender).Text = result.ToString(&quot;0.00&quot;);&#xD;&#xA;     settedEggsRejSelableReport +=  settedEggs ;&#xD;&#xA;     rejSellEggsReport += rejSellEggs ;&#xD;&#xA;     rejUnSellEggsReportForSellableEggs += rejUnSellEggs ;&#xD;&#xA;     TotalRejSelable = settedEggsRejSelableReport  + rejSellEggsReport  + rejUnSellEggsReportForSellableEggs ;&#xD;&#xA;     &#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell78_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;          xrTableCell78.Text = SettedAndRejEggsTotal.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell20_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      // --- Declare values ---&#xD;&#xA;    decimal settedEggs = 0;&#xD;&#xA;    decimal infertileEggs = 0;&#xD;&#xA;&#xD;&#xA;    // --- Read values safely ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;        !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;    {&#xD;&#xA;        settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;InfertileEggs&quot;) != null &amp;&amp;&#xD;&#xA;        !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;InfertileEggs&quot;).ToString()))&#xD;&#xA;    {&#xD;&#xA;        infertileEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;InfertileEggs&quot;));&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    // --- Equation ---&#xD;&#xA;    decimal result = 0;&#xD;&#xA;    if (settedEggs &gt; 0){&#xD;&#xA;         result = (infertileEggs / settedEggs) * 100;&#xD;&#xA;        }&#xD;&#xA;       &#xD;&#xA;    // --- Assign result to cell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // format with 2 decimals&#xD;&#xA;    infertileEggsReport +=  infertileEggs ;&#xD;&#xA;    settedEggsInfertileReport += settedEggs ;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell83_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    xrTableCell83.Text = InfertileEggsTotal.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell11_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // --- Declare variables ---&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal NonHatEggs = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;decimal RejSellEggsNonHat  =0;&#xD;&#xA;decimal RejUnSellEggsNonHat  = 0;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;}&#xD;&#xA;if (GetCurrentColumnValue(&quot;RejSellEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;RejSellEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    RejSellEggsNonHat = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejSellEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RejUnSellEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;RejUnSellEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    RejUnSellEggsNonHat = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejUnSellEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;NonHatEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;NonHatEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    NonHatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;NonHatEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif([SettedEggs] &gt; 0, [FertileEggs] / [SettedEggs], 0)) ---&#xD;&#xA;decimal SettedRejTotal = settedEggs  + RejSellEggsNonHat  + RejUnSellEggsNonHat ;&#xD;&#xA;if (SettedRejTotal &gt; 0){&#xD;&#xA;    &#xD;&#xA;        result = (NonHatEggs / SettedRejTotal ) * 100;   // multiply by 100 if you want percentage&#xD;&#xA;&#xD;&#xA;    }&#xD;&#xA;else{&#xD;&#xA;        result = 0;&#xD;&#xA;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);   // format with 2 decimal places&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell87_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;          xrTableCell87.Text = NonHatEggsTotal.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell35_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // --- Declare variables ---&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal deads = 0;&#xD;&#xA;decimal deadRatio = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Deads&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;Deads&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    deads = Convert.ToDecimal(GetCurrentColumnValue(&quot;Deads&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif([SettedEggs] &gt; 0, [Deads] / [SettedEggs], 0)) ---&#xD;&#xA;if (settedEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    deadRatio = deads / settedEggs;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    deadRatio = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;totalDeadRatioReport += deadRatio;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = deadRatio.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell90_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell90.Text = totalDeadRatio.ToString(&quot;N2&quot;);&#xD;&#xA;      totalDeadRatio= 0; // reset for next group&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell37_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        //-- new logic for Culls Ratio (Culls / SettedEggs)&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal culls = 0;&#xD;&#xA;decimal cullsRatio = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;Culls&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif([SettedEggs] &gt; 0, [Culls] / [SettedEggs], 0)) ---&#xD;&#xA;if (settedEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    cullsRatio = (culls * 100m)/ settedEggs;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cullsRatio = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;totalCullsRatioReport += cullsRatio;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = cullsRatio.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell92_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;              xrTableCell92.Text = totalCullsRatio.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell12_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        //-- new logic for Total Chicks (Culls + SellableChicks)&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal culls = 0;&#xD;&#xA;decimal sellableChicks = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;Culls&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SellableChicks&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    sellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as [Culls] + [SellableChicks]) ---&#xD;&#xA;result = culls + sellableChicks;&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;totalCullsAndSellableChicksReport += result;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell93_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       xrTableCell93.Text = totalCullsAndSellableChicks.ToString(&quot;N2&quot;);&#xD;&#xA;      totalCullsAndSellableChicks  = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell38_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       //-- new logic for Total Chicks Ratio ((Culls + SellableChicks) / SettedEggs)&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal culls = 0;&#xD;&#xA;decimal sellableChicks = 0;&#xD;&#xA;decimal totalRatio = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;Culls&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SellableChicks&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    sellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif([SettedEggs] &gt; 0, ([Culls] + [SellableChicks]) / [SettedEggs], 0)) ---&#xD;&#xA;if (settedEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    totalRatio = ((culls + sellableChicks) * 100m) / settedEggs;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    totalRatio = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;totalChicksRatioReport += totalRatio;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = totalRatio.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell94_BeforePrint_1(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell94.Text = totalChicksRatio.ToString(&quot;N2&quot;);&#xD;&#xA;      totalChicksRatio= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell67_BeforePrint_1(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // -- New Logic for Sellable Chicks Percentage --&#xD;&#xA;&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal fertileEggs = 0;&#xD;&#xA;decimal sellableChicks = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;FertileEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;FertileEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    fertileEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;FertileEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SellableChicks&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    sellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Perform calculation ---&#xD;&#xA;if (fertileEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    result = (sellableChicks / fertileEggs) * 100;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    result = 0;&#xD;&#xA;}&#xD;&#xA;SaleFertileReport += result ;&#xD;&#xA;&#xD;&#xA;// --- Assign result to table cell ---&#xD;&#xA;XRTableCell cell = (XRTableCell)sender;&#xD;&#xA;cell.Text = result.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell95_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;         xrTableCell95.Text = TotalSaleFertileGroup.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell26_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare variables ---&#xD;&#xA;decimal settedEggsPercentatgeOfSellable = 0;&#xD;&#xA;decimal sellableChicksPercentage = 0;&#xD;&#xA;decimal totalRatio = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    settedEggsPercentatgeOfSellable = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SellableChicks&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    sellableChicksPercentage = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif([SettedEggs] &gt; 0, ([Culls] + [SellableChicks]) / [SettedEggs], 0)) ---&#xD;&#xA;if (settedEggsPercentatgeOfSellable &gt; 0)&#xD;&#xA;{&#xD;&#xA;    totalRatio = (sellableChicksPercentage * 100m) / settedEggsPercentatgeOfSellable ;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    totalRatio = 0;&#xD;&#xA;}&#xD;&#xA;// --- Assign result to table cell ---&#xD;&#xA;XRTableCell cell = (XRTableCell)sender;&#xD;&#xA;cell.Text = totalRatio.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell31_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;             xrTableCell31.Text = totalSellableRatio.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell80_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      if(SettedAndRejEggsTotalGroup &gt; 0){ &#xD;&#xA;                  SettedAndRejUnSelableEggsTotal = (rejUnSellEggsGroup * 100m) / SettedAndRejEggsTotalGroup ;&#xD;&#xA;             }&#xD;&#xA;     xrTableCell80.Text = SettedAndRejUnSelableEggsTotal.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void GroupHeader1_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // ================= RESET NEW GROUP VARIABLES =================&#xD;&#xA;&#xD;&#xA;// Rejected &amp; sellable eggs&#xD;&#xA;settedEggsRejSelableGroup = 0;&#xD;&#xA;rejSellEggsGroup = 0;&#xD;&#xA;rejUnSellEggsGroup = 0;&#xD;&#xA;SettedAndRejEggsTotalGroup = 0;&#xD;&#xA;&#xD;&#xA;// Infertile eggs&#xD;&#xA;settedEggsInfertileEggsGroup = 0;&#xD;&#xA;InfertileEggsGroup = 0;&#xD;&#xA;&#xD;&#xA;// Non-hatch eggs&#xD;&#xA;NonHatEggsSettedEggsGroup = 0;&#xD;&#xA;NonHatEggsGroup = 0;&#xD;&#xA;&#xD;&#xA;// Results&#xD;&#xA;result4 = 0;&#xD;&#xA;&#xD;&#xA;// Deads&#xD;&#xA;deadsSettedEggsGroup = 0;&#xD;&#xA;deadsGroup = 0;&#xD;&#xA;&#xD;&#xA;// Culls&#xD;&#xA;CullsSettedEggsGroup = 0;&#xD;&#xA;cullsGroup = 0;&#xD;&#xA;&#xD;&#xA;// Sellable chicks&#xD;&#xA;sellableChicksSettedEggsGroup = 0;&#xD;&#xA;sellableChicksGroup = 0;&#xD;&#xA;&#xD;&#xA;// Total chicks ratios&#xD;&#xA;TotalChicksRatioSettedEggsGroup = 0;&#xD;&#xA;TotalChicksRatiocullsGroup = 0;&#xD;&#xA;TotalChicksRatioSellableChicksGroup = 0;&#xD;&#xA;TotalChicksRatioFertileEggsGroup = 0;&#xD;&#xA;&#xD;&#xA;// Sellable percentages&#xD;&#xA;SellablePercSettedEggsGroup = 0;&#xD;&#xA;sellableChicksPercGroup = 0;&#xD;&#xA;&#xD;&#xA;// Grand total&#xD;&#xA;TotalAllSettedEggs = 0;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" Version="25.2" DataMember="SR_HT_DailyHatchWise_SubReports" DataSource="#Ref-424" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
