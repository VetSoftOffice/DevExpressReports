                  <Item3 Ref="448" Name="PerHH_CF" DisplayName="PerHH_CF" Expression="Iif([FemalePOL]!=0,[TotalCost]/[FemalePOL] ,[FemalePOL] )&#xA;" DataMember="SR_FM_Stocktaking" />
                  <Item4 Ref="449" Name="PerHE_CF" Expression="Iif([HatchingEggs]!=0,[TotalCost]/[HatchingEggs] ,[HatchingEggs] )&#xA;&#xA;" DataMember="SR_FM_Stocktaking" />
                  <Item5 Ref="450" Name="DiffQtyq" Expression="IsNull([ActualQty], 0) - IsNull([SentOrClacQty], 0)" DataMember="SR_FM_Stocktaking" />
                  <Item6 Ref="451" Name="DiffPriceq" Expression="Iif([CalcPriceUnit] &gt; 0, IsNull([AdjustedPriceUnit], 0) - IsNull([CalcPriceUnit], 0), 0)" DataMember="SR_FM_Stocktaking" />
                  <Item7 Ref="452" Name="ActEggRecHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.ActRecEggs] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item8 Ref="453" Name="RejEggHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.RejEggs] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item9 Ref="454" Name="EstHatEggs" Expression="[ActEggRecHHCum] - [RejEggHHCum]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item10 Ref="455" Name="ActEggSetHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.ActSetEggCum] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item11 Ref="456" Name="EstHatEggsBefore21days" Expression="[SR_HT_WeeklyHHFlockSum.ActRecEggsBefore21days] - [SR_HT_WeeklyHHFlockSum.RejEggsBefore21days]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item12 Ref="457" Name="ActHatch_Per_Cum" Expression="Iif([SR_HT_WeeklyHHFlockSum.SettedEggs] &lt;&gt; 0, &#xD;&#xA;    ([SR_HT_WeeklyHHFlockSum.ActChicks] + [SR_HT_WeeklyHHFlockSum.CullsChicks] + [SR_HT_WeeklyHHFlockSum.DeadChicks]) &#xD;&#xA;    / [SR_HT_WeeklyHHFlockSum.SettedEggs] * 100, &#xD;&#xA;    0)&#xD;&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item13 Ref="458" Name="EstChiks" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &gt; 0, &#xA;    ([EstHatEggsBefore21days] * [ActHatch_Per_Cum] / 100) / [SR_HT_WeeklyHHFlockSum.POL], &#xA;    0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item14 Ref="459" Name="ActChicksHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, &#xD;&#xA;    ([SR_HT_WeeklyHHFlockSum.ActChicks] + [SR_HT_WeeklyHHFlockSum.CullsChicks] + [SR_HT_WeeklyHHFlockSum.DeadChicks]) &#xD;&#xA;    / [SR_HT_WeeklyHHFlockSum.POL], &#xD;&#xA;    0)&#xD;&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item15 Ref="460" Name="Diviation" Expression="[ActHatch_Per_Cum] - [SR_HT_WeeklyHHFlockSum.StdHatchCum]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item16 Ref="461" Name="TotalHatchedEggs" Expression="[ChicksSettedEggs]" DataMember="SR_HT_Production" />
                  <Item17 Ref="462" Name="HatchPer" Expression="Iif([TotalHatchedEggs] &lt;&gt; 0, [SR_HT_Production.Chicks] * 100 / [TotalHatchedEggs], 0)&#xA;" DataMember="SR_HT_Production" />
                  <Item18 Ref="463" Name="HOFPer" Expression="Iif([SR_HT_Production.FertPer] &lt;&gt; 0, [HatchPer] * 100.0 / [SR_HT_Production.FertPer], 0)&#xA;" DataMember="SR_HT_Production" />
                  <Item19 Ref="464" Name="HatchPerc" Expression="Iif([SR_HT_Hatch.SettedEggs] &lt;&gt; 0, [SR_HT_Hatch.SellableChicks] * 100 / [SR_HT_Hatch.SettedEggs], 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item20 Ref="465" Name="HOFPerc" Expression="Iif([SR_HT_Hatch.FertPer] &lt;&gt; 0, [HatchPer] * 100.0 / [SR_HT_Hatch.FertPer], 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item21 Ref="466" Name="TotalHatchPerc" Expression="Iif(Sum([SR_HT_Hatch.SettedEggs]) &lt;&gt; 0, Sum([SR_HT_Hatch.SellableChicks]) * 100 / Sum([SR_HT_Hatch.SettedEggs]), 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item22 Ref="467" Name="FertileEggs_CF" Expression="[SR_HT_Hatch.FertPer] * [SR_HT_Hatch.SettedEggs] / 100&#xA;&#xA;" DataMember="SR_HT_Hatch" />
                  <Item23 Ref="468" Name="FertPerc" Expression="Iif(Sum([SR_HT_Hatch.SettedEggs]) &lt;&gt; 0, Sum([FertileEggs]) * 100 / Sum([SR_HT_Hatch.SettedEggs]), 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item24 Ref="469" Name="TotalHOFPerc" Expression="Iif([FertPerc] &lt;&gt; 0, [TotalHatchPerc] * 100 / [FertPerc], 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item25 Ref="470" Name="SettedAndRejEggs" Expression="[SettedEggs] + [RejSellEggs] + [RejUnSellEggs]" DataMember="SR_HT_DailyHatchWise" />
                  <Item26 Ref="471" Name="RejSellEggsPerc" Expression="Iif([SettedAndRejEggs], [RejSellEggs] / [SettedAndRejEggs] * 100 , 0)" DataMember="SR_HT_DailyHatchWise" />
                  <Item27 Ref="472" Name="BrokenPerc" Expression="Iif([SettedAndRejEggs], [RejUnSellEggs] / [SettedAndRejEggs] * 100 , 0)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item28 Ref="473" Name="InfertilePerc" Expression="Iif([SettedEggs] &gt; 0, [InfertileEggs] / [SettedEggs] * 100,0 )" DataMember="SR_HT_DailyHatchWise" />
                  <Item29 Ref="474" Name="NonHatchEggPerc" Expression="Iif([SettedEggs]&gt; 0, [FertileEggs] / [SettedEggs], 0)" DataMember="SR_HT_DailyHatchWise" />
                  <Item30 Ref="475" Name="TotalHatchChicks" Expression="[Culls] + [SellableChicks]" DataMember="SR_HT_DailyHatchWise" />
                  <Item31 Ref="476" Name="DeadPerc" Expression="Iif([SettedEggs] &gt; 0, [Deads] / [SettedEggs],0 )" DataMember="SR_HT_DailyHatchWise" />
                  <Item32 Ref="477" Name="CullsPerc" Expression="Iif([SettedEggs] &gt; 0, [Culls] / [SettedEggs], 0)" DataMember="SR_HT_DailyHatchWise" />
                  <Item33 Ref="478" Name="ChicksPerc" Expression="Iif([SettedEggs] &gt; 0, [SellableChicks] / [SettedEggs], 0)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item34 Ref="479" Name="AllOverSettedPerc" Expression="Iif([SettedEggs] &gt; 0, [TotalHatchChicks] / [SettedEggs], 0)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item35 Ref="480" Name="SaleOverFertilePerc" Expression="Iif([FertileEggs] &gt; 0, [SellableChicks] / [FertileEggs] * 100, 0)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item36 Ref="481" Name="RejSellEggsPerc_Total" Expression="Iif(&#xA;    Sum([SettedAndRejEggs]) &gt; 0,&#xA;    Sum([RejSellEggs]) / Sum([SettedAndRejEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item37 Ref="482" Name="BrokenPerc_Total" Expression="Iif(&#xA;    Sum([SettedAndRejEggs]) &gt; 0,&#xA;    Sum([RejUnSellEggs]) / Sum([SettedAndRejEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item38 Ref="483" Name="InfertilePerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([InfertileEggs]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item39 Ref="484" Name="NonHatchEggsPerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([NonHatEggs]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item40 Ref="485" Name="DeadPerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([Deads]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item41 Ref="487" Name="CullsPerc_Totaal" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([Culls]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataSource="#Ref-486" DataMember="SR_HT_DailyHatchWise" />
                  <Item42 Ref="488" Name="CullsPerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([Culls]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item43 Ref="489" Name="ChicksPerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([SellableChicks]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item44 Ref="490" Name="AllOverSettedPerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([TotalHatchChicks]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item45 Ref="491" Name="SaleOverFertilePerc_Total" Expression="Iif(&#xA;    Sum([FertileEggs]) &gt; 0,&#xA;    Sum([SellableChicks]) / Sum([FertileEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item46 Ref="492" Name="RejSellEggsPerc_GT" Expression="Iif(&#xA;    Sum([SettedAndRejEggs]) &gt; 0,&#xA;    Sum([RejSellEggs]) / Sum([SettedAndRejEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item47 Ref="493" Name="BrokenPerc_GT" Expression="Iif(&#xA;    Sum([SettedAndRejEggs]) &gt; 0,&#xA;    Sum([RejUnSellEggs]) / Sum([SettedAndRejEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item48 Ref="494" Name="NonHatchEggsPerc_GT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([NonHatEggs]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item49 Ref="495" Name="DeadPerc_GT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([Deads]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item50 Ref="496" Name="CullsPerc_GT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([Culls]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item51 Ref="497" Name="ChicksPerc_GT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([SellableChicks]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item52 Ref="498" Name="AllOverSettedPerc_GT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([TotalHatchChicks]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item53 Ref="499" Name="SaleOverFertilePerc_GT" Expression="Iif(&#xA;    Sum([FertileEggs]) &gt; 0,&#xA;    Sum([SellableChicks]) / Sum([FertileEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item54 Ref="500" Name="TotalHatchChicks_Sub" Expression="[Culls] + [SellableChicks]" DataMember="SR_HT_DailyHatchWise_SubReports" />
                  <Item55 Ref="501" Name="AllOverSettedPerc_Sub" Expression="Iif([SettedEggs] &gt; 0, [TotalHatchChicks] / [SettedEggs], 0)&#xA;" DataMember="SR_HT_DailyHatchWise_SubReports" />
                  <Item56 Ref="502" Name="SaleOverFertilePerc_Sub" Expression="Iif([FertileEggs] &gt; 0, [SellableChicks] / [FertileEggs] * 100, 0)&#xA;" DataMember="SR_HT_DailyHatchWise_SubReports" />
                  <Item57 Ref="503" Name="ChicksPerc_Sub" Expression="Iif([SettedEggs] &gt; 0, [SellableChicks] / [SettedEggs], 0)&#xA;" DataMember="SR_HT_DailyHatchWise_SubReports" />
                  <Item58 Ref="504" Name="AllOverSettedPerc_SubTotal" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([TotalHatchChicks]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise_SubReports" />
                  <Item59 Ref="505" Name="SaleOverFertilePerc_SubTotal" Expression="Iif(&#xA;    Sum([FertileEggs]) &gt; 0,&#xA;    Sum([SellableChicks]) / Sum([FertileEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise_SubReports" />
                  <Item60 Ref="506" Name="ChicksPerc_SubTotal" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([SellableChicks]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise_SubReports" />
                  <Item61 Ref="507" Name="InfertilePerc_GT" Expression="Iif(Sum([SettedEggs]) &gt; 0, Sum([InfertileEggs] )/ Sum([SettedEggs])* 100,0 )&#xA;" DataMember="SR_HT_DailyHatchWise_SubReports" />
                  <Item62 Ref="508" Name="AllOverSettedPerc_SubGT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([TotalHatchChicks]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise_SubReports" />
                  <Item63 Ref="509" Name="SaleOverFertilePerc_SubGT" Expression="Iif(&#xA;    Sum([FertileEggs]) &gt; 0,&#xA;    Sum([SellableChicks]) / Sum([FertileEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise_SubReports" />
                  <Item64 Ref="510" Name="ChicksPerc_SubGT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([SellableChicks]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise_SubReports" />
                  <Item65 Ref="511" Name="SettedAndRejEggs_SubReport" Expression="Iif(IsNullOrEmpty([SettedEggs]),0,[SettedEggs]) + Iif(IsNullOrEmpty([RejSellEggs]),0,[RejSellEggs]) + Iif(IsNullOrEmpty([RejUnSellEggs]),0,[RejUnSellEggs])&#xA;" DataMember="SR_HT_DailyHatchWise_SubReports" />
