    <Item6 Ref="424" ControlType="ReportFooterBand" Name="ReportFooter">
      <SubBands>
        <Item1 Ref="425" ControlType="SubBand" Name="SubBand7" PageBreak="AfterBand">
          <Controls>
            <Item1 Ref="426" ControlType="XRSubreport" Name="SR_HT_DailyHatchWise_SubReport">
              <ReportSource Ref="428" ControlType="DevExpressReports.Reports.Hatchery.Summary.SR_HT_DailyHatchWise_SubReport.SR_HT_DailyHatchWise_SubReport, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="using System.ComponentModel;&#xD;&#xA;using DevExpress.XtraReports.Parameters;&#xD;&#xA;&#xD;&#xA;int groupCounter = 1;&#xD;&#xA;&#xD;&#xA;private void GroupFooter1_BeforePrint(object sender, CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    GroupFooterBand groupFooter = (GroupFooterBand)sender;&#xD;&#xA;    XtraReport report = (XtraReport)groupFooter.Report;&#xD;&#xA;    &#xD;&#xA;    Parameter noOfGroupsPerPageParam = report.Parameters[&quot;NoOfGroupsPerPage&quot;];&#xD;&#xA;    if(noOfGroupsPerPageParam != null &amp;&amp; noOfGroupsPerPageParam.Value != &quot;&quot;)&#xD;&#xA;    {&#xD;&#xA;        int noOfGroupsPerPage = Convert.ToInt32(noOfGroupsPerPageParam.Value);&#xD;&#xA;        if (noOfGroupsPerPage &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            if (groupCounter == noOfGroupsPerPage)&#xD;&#xA;            {&#xD;&#xA;                groupFooter.PageBreak = PageBreak.AfterBand;&#xD;&#xA;                groupCounter = 1;&#xD;&#xA;            }&#xD;&#xA;            else&#xD;&#xA;            {&#xD;&#xA;                groupFooter.PageBreak = PageBreak.None;&#xD;&#xA;                groupCounter += 1;&#xD;&#xA;            }&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}" Landscape="true" PageWidth="1654" PageHeight="1169" Version="24.2" DataMember="SR_HT_DailyHatchWise_SubReports" DataSource="#Ref-427" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
                <Parameters>
                  <Item1 Ref="429" Visible="false" ValueInfo="False" Name="IsRTL" Type="#Ref-2" />
                  <Item2 Ref="430" Visible="false" ValueInfo="False" Name="IsCustomReportHeader" Type="#Ref-2" />
                  <Item3 Ref="431" Visible="false" ValueInfo="False" Name="IsCustomReportFooter" Type="#Ref-2" />
                  <Item4 Ref="432" ValueInfo="False" Name="ShowSignature" Type="#Ref-2" />
                  <Item5 Ref="433" ValueInfo="False" Name="ShowSignatureAllPages" Type="#Ref-2" />
                  <Item6 Ref="434" ValueInfo="False" Name="HideReportHeader" Type="#Ref-2" />
                  <Item7 Ref="435" ValueInfo="False" Name="HideReportFooter" Type="#Ref-2" />
                  <Item8 Ref="436" Name="NoOfGroupsPerPage" />
                  <Item9 Ref="437" Visible="false" Name="FontSize" />
                  <Item10 Ref="438" Visible="false" Name="DateFrom" />
                  <Item11 Ref="439" Visible="false" Name="DateTo" />
                  <Item12 Ref="440" Visible="false" ValueInfo="0" AllowNull="true" Name="ReportType" Type="#Ref-15" />
                  <Item13 Ref="441" Visible="false" AllowNull="true" Name="Price" />
                  <Item14 Ref="442" Visible="false" AllowNull="true" Name="AdjustedPrice" />
                  <Item15 Ref="443" Visible="false" AllowNull="true" Name="DiffPrice" />
                  <Item16 Ref="444" Visible="false" AllowNull="true" Name="Available" />
                  <Item17 Ref="445" Visible="false" AllowNull="true" Name="ActualQty" />
                  <Item18 Ref="446" Visible="false" AllowNull="true" Name="DiffQty" />
                  <Item19 Ref="447" Visible="false" AllowNull="true" Name="FarmNo" />
                  <Item20 Ref="448" Visible="false" Name="BookPerf" />
                </Parameters>
                <CalculatedFields>
                  <Item1 Ref="449" Name="TotalCostPerc_CF" DisplayName="TotalCostPerc_CF" Expression="(ToDecimal([TotalCost]) / ToDecimal(Sum([TotalCost])))*ToDecimal(100)&#xA;" DataMember="SR_FM_Stocktaking" />
                  <Item2 Ref="450" Name="Per_Chick_CF" Expression="Iif([FemaleChicks]!=0,[TotalCost]/[FemaleChicks] ,[FemaleChicks] )" DataMember="SR_FM_Stocktaking" />
                  <Item3 Ref="451" Name="PerHH_CF" DisplayName="PerHH_CF" Expression="Iif([FemalePOL]!=0,[TotalCost]/[FemalePOL] ,[FemalePOL] )&#xA;" DataMember="SR_FM_Stocktaking" />
                  <Item4 Ref="452" Name="PerHE_CF" Expression="Iif([HatchingEggs]!=0,[TotalCost]/[HatchingEggs] ,[HatchingEggs] )&#xA;&#xA;" DataMember="SR_FM_Stocktaking" />
                  <Item5 Ref="453" Name="DiffQtyq" Expression="IsNull([ActualQty], 0) - IsNull([SentOrClacQty], 0)" DataMember="SR_FM_Stocktaking" />
                  <Item6 Ref="454" Name="DiffPriceq" Expression="Iif([CalcPriceUnit] &gt; 0, IsNull([AdjustedPriceUnit], 0) - IsNull([CalcPriceUnit], 0), 0)" DataMember="SR_FM_Stocktaking" />
                  <Item7 Ref="455" Name="ActEggRecHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.ActRecEggs] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item8 Ref="456" Name="RejEggHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.RejEggs] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item9 Ref="457" Name="EstHatEggs" Expression="[ActEggRecHHCum] - [RejEggHHCum]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item10 Ref="458" Name="ActEggSetHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.ActSetEggCum] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item11 Ref="459" Name="EstHatEggsBefore21days" Expression="[SR_HT_WeeklyHHFlockSum.ActRecEggsBefore21days] - [SR_HT_WeeklyHHFlockSum.RejEggsBefore21days]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item12 Ref="460" Name="ActHatch_Per_Cum" Expression="Iif([SR_HT_WeeklyHHFlockSum.SettedEggs] &lt;&gt; 0, &#xD;&#xA;    ([SR_HT_WeeklyHHFlockSum.ActChicks] + [SR_HT_WeeklyHHFlockSum.CullsChicks] + [SR_HT_WeeklyHHFlockSum.DeadChicks]) &#xD;&#xA;    / [SR_HT_WeeklyHHFlockSum.SettedEggs] * 100, &#xD;&#xA;    0)&#xD;&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item13 Ref="461" Name="EstChiks" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &gt; 0, &#xA;    ([EstHatEggsBefore21days] * [ActHatch_Per_Cum] / 100) / [SR_HT_WeeklyHHFlockSum.POL], &#xA;    0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item14 Ref="462" Name="ActChicksHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, &#xD;&#xA;    ([SR_HT_WeeklyHHFlockSum.ActChicks] + [SR_HT_WeeklyHHFlockSum.CullsChicks] + [SR_HT_WeeklyHHFlockSum.DeadChicks]) &#xD;&#xA;    / [SR_HT_WeeklyHHFlockSum.POL], &#xD;&#xA;    0)&#xD;&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item15 Ref="463" Name="Diviation" Expression="[ActHatch_Per_Cum] - [SR_HT_WeeklyHHFlockSum.StdHatchCum]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item16 Ref="464" Name="TotalHatchedEggs" Expression="[ChicksSettedEggs]" DataMember="SR_HT_Production" />
                  <Item17 Ref="465" Name="HatchPer" Expression="Iif([TotalHatchedEggs] &lt;&gt; 0, [SR_HT_Production.Chicks] * 100 / [TotalHatchedEggs], 0)&#xA;" DataMember="SR_HT_Production" />
                  <Item18 Ref="466" Name="HOFPer" Expression="Iif([SR_HT_Production.FertPer] &lt;&gt; 0, [HatchPer] * 100.0 / [SR_HT_Production.FertPer], 0)&#xA;" DataMember="SR_HT_Production" />
                  <Item19 Ref="467" Name="HatchPerc" Expression="Iif([SR_HT_Hatch.SettedEggs] &lt;&gt; 0, [SR_HT_Hatch.SellableChicks] * 100 / [SR_HT_Hatch.SettedEggs], 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item20 Ref="468" Name="HOFPerc" Expression="Iif([SR_HT_Hatch.FertPer] &lt;&gt; 0, [HatchPer] * 100.0 / [SR_HT_Hatch.FertPer], 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item21 Ref="469" Name="TotalHatchPerc" Expression="Iif(Sum([SR_HT_Hatch.SettedEggs]) &lt;&gt; 0, Sum([SR_HT_Hatch.SellableChicks]) * 100 / Sum([SR_HT_Hatch.SettedEggs]), 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item22 Ref="470" Name="FertileEggs_CF" Expression="[SR_HT_Hatch.FertPer] * [SR_HT_Hatch.SettedEggs] / 100&#xA;&#xA;" DataMember="SR_HT_Hatch" />
                  <Item23 Ref="471" Name="FertPerc" Expression="Iif(Sum([SR_HT_Hatch.SettedEggs]) &lt;&gt; 0, Sum([FertileEggs]) * 100 / Sum([SR_HT_Hatch.SettedEggs]), 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item24 Ref="472" Name="TotalHOFPerc" Expression="Iif([FertPerc] &lt;&gt; 0, [TotalHatchPerc] * 100 / [FertPerc], 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item25 Ref="473" Name="SettedAndRejEggs" Expression="[SettedEggs] + [RejSellEggs] + [RejUnSellEggs]" DataMember="SR_HT_DailyHatchWise" />
                  <Item26 Ref="474" Name="RejSellEggsPerc" Expression="Iif([SettedAndRejEggs], [RejSellEggs] / [SettedAndRejEggs] * 100 , 0)" DataMember="SR_HT_DailyHatchWise" />
                  <Item27 Ref="475" Name="BrokenPerc" Expression="Iif([SettedAndRejEggs], [RejUnSellEggs] / [SettedAndRejEggs] * 100 , 0)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item28 Ref="476" Name="InfertilePerc" Expression="Iif([SettedEggs] &gt; 0, [InfertileEggs] / [SettedEggs] * 100,0 )" DataMember="SR_HT_DailyHatchWise" />
                  <Item29 Ref="477" Name="NonHatchEggPerc" Expression="Iif([SettedEggs]&gt; 0, [FertileEggs] / [SettedEggs], 0)" DataMember="SR_HT_DailyHatchWise" />
                  <Item30 Ref="478" Name="TotalHatchChicks" Expression="[Culls] + [SellableChicks]" DataMember="SR_HT_DailyHatchWise" />
                  <Item31 Ref="479" Name="DeadPerc" Expression="Iif([SettedEggs] &gt; 0, [Deads] / [SettedEggs],0 )" DataMember="SR_HT_DailyHatchWise" />
                  <Item32 Ref="480" Name="CullsPerc" Expression="Iif([SettedEggs] &gt; 0, [Culls] / [SettedEggs], 0)" DataMember="SR_HT_DailyHatchWise" />
                  <Item33 Ref="481" Name="ChicksPerc" Expression="Iif([SettedEggs] &gt; 0, [SellableChicks] / [SettedEggs], 0)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item34 Ref="482" Name="AllOverSettedPerc" Expression="Iif([SettedEggs] &gt; 0, [TotalHatchChicks] / [SettedEggs], 0)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item35 Ref="483" Name="SaleOverFertilePerc" Expression="Iif([FertileEggs] &gt; 0, [SellableChicks] / [FertileEggs] * 100, 0)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item36 Ref="484" Name="RejSellEggsPerc_Total" Expression="Iif(&#xA;    Sum([SettedAndRejEggs]) &gt; 0,&#xA;    Sum([RejSellEggs]) / Sum([SettedAndRejEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item37 Ref="485" Name="BrokenPerc_Total" Expression="Iif(&#xA;    Sum([SettedAndRejEggs]) &gt; 0,&#xA;    Sum([RejUnSellEggs]) / Sum([SettedAndRejEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item38 Ref="486" Name="InfertilePerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([InfertileEggs]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item39 Ref="487" Name="NonHatchEggsPerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([NonHatEggs]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item40 Ref="488" Name="DeadPerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([Deads]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item41 Ref="490" Name="CullsPerc_Totaal" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([Culls]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataSource="#Ref-489" DataMember="SR_HT_DailyHatchWise" />
                  <Item42 Ref="491" Name="CullsPerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([Culls]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item43 Ref="492" Name="ChicksPerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([SellableChicks]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item44 Ref="493" Name="AllOverSettedPerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([TotalHatchChicks]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item45 Ref="494" Name="SaleOverFertilePerc_Total" Expression="Iif(&#xA;    Sum([FertileEggs]) &gt; 0,&#xA;    Sum([SellableChicks]) / Sum([FertileEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item46 Ref="495" Name="RejSellEggsPerc_GT" Expression="Iif(&#xA;    Sum([SettedAndRejEggs]) &gt; 0,&#xA;    Sum([RejSellEggs]) / Sum([SettedAndRejEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item47 Ref="496" Name="BrokenPerc_GT" Expression="Iif(&#xA;    Sum([SettedAndRejEggs]) &gt; 0,&#xA;    Sum([RejUnSellEggs]) / Sum([SettedAndRejEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item48 Ref="497" Name="NonHatchEggsPerc_GT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([NonHatEggs]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item49 Ref="498" Name="DeadPerc_GT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([Deads]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item50 Ref="499" Name="CullsPerc_GT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([Culls]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
                  <Item51 Ref="500" Name="ChicksPerc_GT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([SellableChicks]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
