    <Item2 Ref="27" Name="Per_Chick_CF" Expression="Iif([FemaleChicks]!=0,[TotalCost]/[FemaleChicks] ,[FemaleChicks] )" DataMember="SR_FM_Stocktaking" />
    <Item3 Ref="28" Name="PerHH_CF" DisplayName="PerHH_CF" Expression="Iif([FemalePOL]!=0,[TotalCost]/[FemalePOL] ,[FemalePOL] )&#xA;" DataMember="SR_FM_Stocktaking" />
    <Item4 Ref="29" Name="PerHE_CF" Expression="Iif([HatchingEggs]!=0,[TotalCost]/[HatchingEggs] ,[HatchingEggs] )&#xA;&#xA;" DataMember="SR_FM_Stocktaking" />
    <Item5 Ref="30" Name="DiffQtyq" Expression="IsNull([ActualQty], 0) - IsNull([SentOrClacQty], 0)" DataMember="SR_FM_Stocktaking" />
    <Item6 Ref="31" Name="DiffPriceq" Expression="Iif([CalcPriceUnit] &gt; 0, IsNull([AdjustedPriceUnit], 0) - IsNull([CalcPriceUnit], 0), 0)" DataMember="SR_FM_Stocktaking" />
    <Item7 Ref="32" Name="ActEggRecHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.ActRecEggs] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item8 Ref="33" Name="RejEggHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.RejEggs] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item9 Ref="34" Name="EstHatEggs" Expression="[ActEggRecHHCum] - [RejEggHHCum]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item10 Ref="35" Name="ActEggSetHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.ActSetEggCum] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item11 Ref="36" Name="EstHatEggsBefore21days" Expression="[SR_HT_WeeklyHHFlockSum.ActRecEggsBefore21days] - [SR_HT_WeeklyHHFlockSum.RejEggsBefore21days]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item12 Ref="37" Name="ActHatch_Per_Cum" Expression="Iif([SR_HT_WeeklyHHFlockSum.SettedEggs] &lt;&gt; 0, &#xD;&#xA;    ([SR_HT_WeeklyHHFlockSum.ActChicks] + [SR_HT_WeeklyHHFlockSum.CullsChicks] + [SR_HT_WeeklyHHFlockSum.DeadChicks]) &#xD;&#xA;    / [SR_HT_WeeklyHHFlockSum.SettedEggs] * 100, &#xD;&#xA;    0)&#xD;&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item13 Ref="38" Name="EstChiks" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &gt; 0, &#xA;    ([EstHatEggsBefore21days] * [ActHatch_Per_Cum] / 100) / [SR_HT_WeeklyHHFlockSum.POL], &#xA;    0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item14 Ref="39" Name="ActChicksHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, &#xD;&#xA;    ([SR_HT_WeeklyHHFlockSum.ActChicks] + [SR_HT_WeeklyHHFlockSum.CullsChicks] + [SR_HT_WeeklyHHFlockSum.DeadChicks]) &#xD;&#xA;    / [SR_HT_WeeklyHHFlockSum.POL], &#xD;&#xA;    0)&#xD;&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item15 Ref="40" Name="Diviation" Expression="[ActHatch_Per_Cum] - [SR_HT_WeeklyHHFlockSum.StdHatchCum]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
    <Item16 Ref="41" Name="TotalHatchedEggs" Expression="[ChicksSettedEggs]" DataMember="SR_HT_Production" />
    <Item17 Ref="42" Name="HatchPer" Expression="Iif([TotalHatchedEggs] &lt;&gt; 0, [SR_HT_Production.Chicks] * 100 / [TotalHatchedEggs], 0)&#xA;" DataMember="SR_HT_Production" />
    <Item18 Ref="43" Name="HOFPer" Expression="Iif([SR_HT_Production.FertPer] &lt;&gt; 0, [HatchPer] * 100.0 / [SR_HT_Production.FertPer], 0)&#xA;" DataMember="SR_HT_Production" />
    <Item19 Ref="44" Name="HatchPerc" Expression="Iif([SR_HT_Hatch.SettedEggs] &lt;&gt; 0, [SR_HT_Hatch.SellableChicks] * 100 / [SR_HT_Hatch.SettedEggs], 0)&#xA;" DataMember="SR_HT_Hatch" />
    <Item20 Ref="45" Name="HOFPerc" Expression="Iif([SR_HT_Hatch.FertPer] &lt;&gt; 0, [HatchPer] * 100.0 / [SR_HT_Hatch.FertPer], 0)&#xA;" DataMember="SR_HT_Hatch" />
    <Item21 Ref="46" Name="TotalHatchPerc" Expression="Iif(Sum([SR_HT_Hatch.SettedEggs]) &lt;&gt; 0, Sum([SR_HT_Hatch.SellableChicks]) * 100 / Sum([SR_HT_Hatch.SettedEggs]), 0)&#xA;" DataMember="SR_HT_Hatch" />
    <Item22 Ref="47" Name="FertileEggs_CF" Expression="[SR_HT_Hatch.FertPer] * [SR_HT_Hatch.SettedEggs] / 100&#xA;&#xA;" DataMember="SR_HT_Hatch" />
    <Item23 Ref="48" Name="FertPerc" Expression="Iif(Sum([SR_HT_Hatch.SettedEggs]) &lt;&gt; 0, Sum([FertileEggs]) * 100 / Sum([SR_HT_Hatch.SettedEggs]), 0)&#xA;" DataMember="SR_HT_Hatch" />
    <Item24 Ref="49" Name="TotalHOFPerc" Expression="Iif([FertPerc] &lt;&gt; 0, [TotalHatchPerc] * 100 / [FertPerc], 0)&#xA;" DataMember="SR_HT_Hatch" />
    <Item25 Ref="50" Name="SettedAndRejEggs" Expression="Iif(IsNullOrEmpty([SettedEggs]),0,[SettedEggs]) + Iif(IsNullOrEmpty([RejSellEggs]),0,[RejSellEggs]) + Iif(IsNullOrEmpty([RejUnSellEggs]),0,[RejUnSellEggs])" DataMember="SR_HT_DailyHatchWise" />
    <Item26 Ref="51" Name="RejSellEggsPerc" Expression="Iif([SettedAndRejEggs], [RejSellEggs] / [SettedAndRejEggs] * 100 , 0)" DataMember="SR_HT_DailyHatchWise" />
    <Item27 Ref="52" Name="BrokenPerc" Expression="Iif([SettedAndRejEggs], [RejUnSellEggs] / [SettedAndRejEggs] * 100 , 0)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item28 Ref="53" Name="InfertilePerc" Expression="Iif([SettedEggs] &gt; 0, [InfertileEggs] / [SettedEggs] * 100,0 )" DataMember="SR_HT_DailyHatchWise" />
    <Item29 Ref="54" Name="NonHatchEggPerc" Expression="Iif([SettedEggs]&gt; 0, [FertileEggs] / [SettedEggs], 0)" DataMember="SR_HT_DailyHatchWise" />
    <Item30 Ref="55" Name="TotalHatchChicks" Expression="[Culls] + [SellableChicks]" DataMember="SR_HT_DailyHatchWise" />
    <Item31 Ref="56" Name="DeadPerc" Expression="Iif([SettedEggs] &gt; 0, [Deads] / [SettedEggs],0 )" DataMember="SR_HT_DailyHatchWise" />
    <Item32 Ref="57" Name="CullsPerc" Expression="Iif([SettedEggs] &gt; 0, [Culls] / [SettedEggs], 0)" DataMember="SR_HT_DailyHatchWise" />
    <Item33 Ref="58" Name="ChicksPerc" Expression="Iif([SettedEggs] &gt; 0, [SellableChicks] / [SettedEggs], 0)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item34 Ref="59" Name="AllOverSettedPerc" Expression="Iif([SettedEggs] &gt; 0, [TotalHatchChicks] / [SettedEggs], 0)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item35 Ref="60" Name="SaleOverFertilePerc" Expression="Iif([FertileEggs] &gt; 0, [SellableChicks] / [FertileEggs] * 100, 0)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item36 Ref="61" Name="RejSellEggsPerc_Total" Expression="Iif(&#xA;    Sum([SettedAndRejEggs]) &gt; 0,&#xA;    Sum([RejSellEggs]) / Sum([SettedAndRejEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item37 Ref="62" Name="BrokenPerc_Total" Expression="Iif(&#xA;    Sum([SettedAndRejEggs]) &gt; 0,&#xA;    Sum([RejUnSellEggs]) / Sum([SettedAndRejEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item38 Ref="63" Name="InfertilePerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([InfertileEggs]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item39 Ref="64" Name="NonHatchEggsPerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([NonHatEggs]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item40 Ref="65" Name="DeadPerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([Deads]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item41 Ref="67" Name="CullsPerc_Totaal" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([Culls]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataSource="#Ref-66" DataMember="SR_HT_DailyHatchWise" />
    <Item42 Ref="68" Name="CullsPerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([Culls]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item43 Ref="69" Name="ChicksPerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([SellableChicks]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item44 Ref="70" Name="AllOverSettedPerc_Total" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([TotalHatchChicks]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item45 Ref="71" Name="SaleOverFertilePerc_Total" Expression="Iif(&#xA;    Sum([FertileEggs]) &gt; 0,&#xA;    Sum([SellableChicks]) / Sum([FertileEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item46 Ref="72" Name="RejSellEggsPerc_GT" Expression="Iif(&#xA;    Sum([SettedAndRejEggs]) &gt; 0,&#xA;    Sum([RejSellEggs]) / Sum([SettedAndRejEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item47 Ref="73" Name="BrokenPerc_GT" Expression="Iif(&#xA;    Sum([SettedAndRejEggs]) &gt; 0,&#xA;    Sum([RejUnSellEggs]) / Sum([SettedAndRejEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item48 Ref="74" Name="NonHatchEggsPerc_GT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([NonHatEggs]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item49 Ref="75" Name="DeadPerc_GT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([Deads]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item50 Ref="76" Name="CullsPerc_GT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([Culls]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item51 Ref="77" Name="ChicksPerc_GT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([SellableChicks]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item52 Ref="78" Name="AllOverSettedPerc_GT" Expression="Iif(&#xA;    Sum([SettedEggs]) &gt; 0,&#xA;    Sum([TotalHatchChicks]) / Sum([SettedEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
    <Item53 Ref="79" Name="SaleOverFertilePerc_GT" Expression="Iif(&#xA;    Sum([FertileEggs]) &gt; 0,&#xA;    Sum([SellableChicks]) / Sum([FertileEggs]) * 100,&#xA;    0&#xA;)&#xA;" DataMember="SR_HT_DailyHatchWise" />
