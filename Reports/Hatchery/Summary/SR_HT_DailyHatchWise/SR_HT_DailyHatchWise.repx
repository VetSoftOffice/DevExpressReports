;).ToString()))&#xD;&#xA;    {&#xD;&#xA;        infertileEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;InfertileEggs&quot;));&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    // --- Equation ---&#xD;&#xA;    decimal result = 0;&#xD;&#xA;    if (settedEggs &gt; 0){&#xD;&#xA;         result = (infertileEggs / settedEggs) * 100;&#xD;&#xA;        }&#xD;&#xA;       &#xD;&#xA;    // --- Assign result to cell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;); // format with 2 decimals&#xD;&#xA;    infertileEggsTotal_1+= infertileEggs ;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;        !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;    {&#xD;&#xA;        InfertileEggsSettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;        InfertileEggsSettedEggsReport += InfertileEggsSettedEggs;&#xD;&#xA;    }&#xD;&#xA;    if(InfertileEggsSettedEggsReport  !=0){&#xD;&#xA;           infertileEggsTotalReport = (infertileEggsTotal_1* 100m) / InfertileEggsSettedEggsReport; &#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell83_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;          xrTableCell83.Text = infertileEggsTotal.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell52_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell52.Text = infertileEggsTotalReport.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell11_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare variables ---&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal fertileEggs = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;FertileEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;FertileEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    fertileEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;FertileEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif([SettedEggs] &gt; 0, [FertileEggs] / [SettedEggs], 0)) ---&#xD;&#xA;if (settedEggs &gt; 0){&#xD;&#xA;    &#xD;&#xA;        result = (fertileEggs / settedEggs) * 100;   // multiply by 100 if you want percentage&#xD;&#xA;        fertileEggsTotalReport+= result;&#xD;&#xA;&#xD;&#xA;    }&#xD;&#xA;else{&#xD;&#xA;        result = 0;&#xD;&#xA;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);   // format with 2 decimal places&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell87_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell87.Text = fertileEggsTotalReport.ToString(&quot;N2&quot;);&#xD;&#xA;      fertileEggsTotalReport = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell100_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell100.Text = fertileEggsTotal.ToString(&quot;N2&quot;);&#xD;&#xA;      fertileEggsTotal  = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell12_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    //-- new logic for Total Chicks (Culls + SellableChicks)&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal culls = 0;&#xD;&#xA;decimal sellableChicks = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;Culls&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SellableChicks&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    sellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as [Culls] + [SellableChicks]) ---&#xD;&#xA;result = culls + sellableChicks;&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;totalCullsAndSellableChicksReport += result;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell88_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell88.Text = totalCullsAndSellableChicks.ToString(&quot;N2&quot;);&#xD;&#xA;      totalCullsAndSellableChicks  = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell101_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    xrTableCell101.Text = totalCullsAndSellableChicksReport.ToString(&quot;N2&quot;);&#xD;&#xA;      totalCullsAndSellableChicksReport= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell35_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare variables ---&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal deads = 0;&#xD;&#xA;decimal deadRatio = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Deads&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;Deads&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    deads = Convert.ToDecimal(GetCurrentColumnValue(&quot;Deads&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif([SettedEggs] &gt; 0, [Deads] / [SettedEggs], 0)) ---&#xD;&#xA;if (settedEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    deadRatio = deads / settedEggs;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    deadRatio = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;totalDeadRatioReport += deadRatio;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = deadRatio.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell90_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell90.Text = totalDeadRatio.ToString(&quot;N2&quot;);&#xD;&#xA;      totalDeadRatio= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell103_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell103.Text = totalDeadRatioReport.ToString(&quot;N2&quot;);&#xD;&#xA;      totalDeadRatioReport= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell37_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    //-- new logic for Culls Ratio (Culls / SettedEggs)&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal culls = 0;&#xD;&#xA;decimal cullsRatio = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;Culls&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif([SettedEggs] &gt; 0, [Culls] / [SettedEggs], 0)) ---&#xD;&#xA;if (settedEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    cullsRatio = culls / settedEggs;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cullsRatio = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;totalCullsRatioReport += cullsRatio;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = cullsRatio.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell92_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell92.Text = totalCullsRatioReport.ToString(&quot;N2&quot;);&#xD;&#xA;      totalCullsRatioReport= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell105_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell105.Text = totalCullsRatio.ToString(&quot;N2&quot;);&#xD;&#xA;      totalCullsRatio= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell67_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    //-- new logic for Sellable Chicks Ratio (SellableChicks / SettedEggs)&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal sellableChicks = 0;&#xD;&#xA;decimal sellableRatio = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SellableChicks&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    sellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif([SettedEggs] &gt; 0, [SellableChicks] / [SettedEggs], 0)) ---&#xD;&#xA;if (settedEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    sellableRatio = sellableChicks / settedEggs;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    sellableRatio = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;totalSellableRatioReport += sellableRatio;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = sellableRatio.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell94_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell94.Text = totalSellableRatio.ToString(&quot;N2&quot;);&#xD;&#xA;      totalSellableRatio= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell107_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell107.Text = totalSellableRatioReport.ToString(&quot;N2&quot;);&#xD;&#xA;      totalSellableRatioReport= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell68_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    //-- new logic for Total Chicks Ratio ((Culls + SellableChicks) / SettedEggs)&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal culls = 0;&#xD;&#xA;decimal sellableChicks = 0;&#xD;&#xA;decimal totalRatio = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SettedEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;Culls&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SellableChicks&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    sellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif([SettedEggs] &gt; 0, ([Culls] + [SellableChicks]) / [SettedEggs], 0)) ---&#xD;&#xA;if (settedEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    totalRatio = (culls + sellableChicks) / settedEggs;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    totalRatio = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;totalChicksRatioReport += totalRatio;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = totalRatio.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell95_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell95.Text = totalChicksRatio.ToString(&quot;N2&quot;);&#xD;&#xA;      totalChicksRatio= 0; // reset for next group&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell108_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell108.Text = totalChicksRatioReport.ToString(&quot;N2&quot;);&#xD;&#xA;      totalChicksRatioReport= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell69_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // -- New Logic for Sellable Chicks Percentage --&#xD;&#xA;&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal fertileEggs = 0;&#xD;&#xA;decimal sellableChicks = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;FertileEggs&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;FertileEggs&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    fertileEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;FertileEggs&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;SellableChicks&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    sellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Perform calculation ---&#xD;&#xA;if (fertileEggs &gt; 0)&#xD;&#xA;{&#xD;&#xA;    result = (sellableChicks / fertileEggs) * 100;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    result = 0;&#xD;&#xA;}&#xD;&#xA;SaleFertileReport += result ;&#xD;&#xA;&#xD;&#xA;// --- Assign result to table cell ---&#xD;&#xA;XRTableCell cell = (XRTableCell)sender;&#xD;&#xA;cell.Text = result.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell96_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell96.Text = SaleFertile.ToString(&quot;N2&quot;);&#xD;&#xA;     SaleFertile= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell109_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell109.Text = SaleFertileReport.ToString(&quot;N2&quot;);&#xD;&#xA;     SaleFertileReport= 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;" Landscape="true" PageWidth="1654" PageHeight="1169" Version="24.2" DataMember="SR_HT_DailyHatchWise" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
  <Parameters>
    <Item1 Ref="3" Visible="false" ValueInfo="False" Name="IsRTL" Type="#Ref-2" />
    <Item2 Ref="4" Visible="false" ValueInfo="False" Name="IsCustomReportHeader" Type="#Ref-2" />
