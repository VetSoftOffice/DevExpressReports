<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_Production" ScriptsSource="&#xD;&#xA;decimal TotalPercentageChicksSettedEggs  = 0;&#xD;&#xA;decimal TotalPercentageChicksVsFert  = 0;&#xD;&#xA;decimal TotalPercentageChicksSettedVsFert = 0;&#xD;&#xA;decimal totalReportChicks = 0;&#xD;&#xA;decimal totalReportChicksSettedEggs = 0;&#xD;&#xA;decimal totalReportChicksFertile = 0;&#xD;&#xA;decimal totalReportFertPer = 0;&#xD;&#xA;decimal totalReportFertileEggs = 0;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell18_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal chicks = 0;&#xD;&#xA;decimal chicksSettedEggs = 0;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Chicks ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Chicks&quot;) != null)&#xD;&#xA;    chicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;Chicks&quot;));&#xD;&#xA;&#xD;&#xA;// --- ChicksSettedEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;ChicksSettedEggs&quot;) != null)&#xD;&#xA;    chicksSettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChicksSettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation (row level %) ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (chicksSettedEggs != 0)&#xD;&#xA;    percentage = (chicks * 100m) / chicksSettedEggs;&#xD;&#xA;&#xD;&#xA;// --- Total percentage ---&#xD;&#xA;totalReportChicks += chicks;&#xD;&#xA;totalReportChicksSettedEggs += chicksSettedEggs;&#xD;&#xA;if (totalReportChicksSettedEggs != 0)&#xD;&#xA;    TotalPercentageChicksSettedEggs = (totalReportChicks * 100m) / totalReportChicksSettedEggs;&#xD;&#xA;&#xD;&#xA;// --- Assign row % to the cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.00&quot;);  // Row level %&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell37_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell37.Text = TotalPercentageChicksSettedEggs.ToString(&quot;0&quot;);&#xD;&#xA;      TotalPercentageChicksSettedEggs  = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell39_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell; &#xD;&#xA;     cell.Text = TotalPercentageChicksSettedEggs.ToString(&quot;0.00&quot;);&#xD;&#xA;}&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal chicks = 0;&#xD;&#xA;decimal chicksSettedEggs = 0;&#xD;&#xA;decimal fertPer = 0;&#xD;&#xA;&#xD;&#xA;// --- Accumulators for totals ---&#xD;&#xA;&#xD;&#xA;// --- Chicks ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Chicks&quot;) != null)&#xD;&#xA;    chicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;Chicks&quot;));&#xD;&#xA;&#xD;&#xA;// --- ChicksSettedEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;ChicksSettedEggs&quot;) != null)&#xD;&#xA;    chicksSettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChicksSettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- FertPer ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;FertPer&quot;) != null)&#xD;&#xA;    fertPer = Convert.ToDecimal(GetCurrentColumnValue(&quot;FertPer&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation (row level %) ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (fertPer != 0 &amp;&amp; chicksSettedEggs != 0)&#xD;&#xA;    percentage = ((chicks * 100m / chicksSettedEggs) / fertPer) * 100m;&#xD;&#xA;&#xD;&#xA;// --- Total percentage ---&#xD;&#xA;totalReportChicksFertile += chicks;&#xD;&#xA;totalReportChicksSettedEggs += chicksSettedEggs;&#xD;&#xA;totalReportFertPer += fertPer;&#xD;&#xA;if (totalReportFertPer != 0 &amp;&amp; totalReportChicksSettedEggs != 0)&#xD;&#xA;    TotalPercentageChicksVsFert = ((totalReportChicks * 100m / totalReportChicksSettedEggs) / totalReportFertPer) * 100m;&#xD;&#xA;&#xD;&#xA;// --- Assign row % to the cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.00&quot;);  // Row level %&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell41_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal chicksSettedEggs = 0;&#xD;&#xA;decimal fertileEggs = 0;&#xD;&#xA;decimal fertPer = 0;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- ChicksSettedEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;ChicksSettedEggs&quot;) != null)&#xD;&#xA;    chicksSettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChicksSettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- FertileEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;FertileEggs&quot;) != null)&#xD;&#xA;    fertileEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;FertileEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- FertPer ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;FertPer&quot;) != null)&#xD;&#xA;    fertPer = Convert.ToDecimal(GetCurrentColumnValue(&quot;FertPer&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation (row level %) ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (fertPer != 0)&#xD;&#xA;{&#xD;&#xA;    if (totalReportChicksSettedEggs != 0)&#xD;&#xA;        percentage = (chicksSettedEggs * 100m) / ((fertileEggs * 100m) / totalReportChicksSettedEggs);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Total percentage ---&#xD;&#xA;totalReportChicksSettedEggs += chicksSettedEggs;&#xD;&#xA;totalReportFertileEggs += fertileEggs;&#xD;&#xA;totalReportFertPer += fertPer;&#xD;&#xA;&#xD;&#xA;if (totalReportFertPer != 0 &amp;&amp; totalReportChicksSettedEggs != 0)&#xD;&#xA;    TotalPercentageChicksSettedVsFert = (totalReportChicksSettedEggs * 100m) /&#xD;&#xA;                                        ((totalReportFertileEggs * 100m) / totalReportChicksSettedEggs);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal Fertile = 0;&#xD;&#xA;    decimal chicksSettedEggs = 0;&#xD;&#xA;    &#xD;&#xA;    if (GetCurrentColumnValue(&quot;FertileEggs&quot;) != null)&#xD;&#xA;        Fertile = Convert.ToDecimal(GetCurrentColumnValue(&quot;FertileEggs&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;ChicksSettedEggs&quot;) != null)&#xD;&#xA;        chicksSettedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChicksSettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    decimal percentage = 0;&#xD;&#xA;    if (chicksSettedEggs != 0)&#xD;&#xA;        percentage = (Fertile * 100m) / chicksSettedEggs ;&#xD;&#xA;&#xD;&#xA;    TotalPercentageChicksSettedEggs += percentage;&#xD;&#xA;&#xD;&#xA;  }&#xD;&#xA;" PageWidth="1169" PageHeight="1654" Version="24.2" DataMember="SR_HT_Production" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
