<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_Production" ScriptsSource="decimal totalChicks = 0;&#xD;&#xA;decimal totalSettedEggs = 0;&#xD;&#xA;decimal totalChicksSettedEggs_Hatch = 0;&#xD;&#xA;decimal totalFertPer_Hatch = 0;&#xD;&#xA;decimal totalFertileEggs_Hatch = 0;&#xD;&#xA;decimal totalChicks_Hatch = 0;&#xD;&#xA;decimal totalFertileEggs_Fertile = 0;&#xD;&#xA;decimal totalChicksSettedEggs_Fertile = 0;&#xD;&#xA;private void xrTableCell18_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;   decimal chicks = 0;&#xD;&#xA;    decimal settedEggs = 0;&#xD;&#xA;    decimal hatchPercent = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Chicks&quot;) != null)&#xD;&#xA;        chicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;Chicks&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;ChicksSettedEggs&quot;) != null)&#xD;&#xA;        settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChicksSettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    if (settedEggs != 0)&#xD;&#xA;        hatchPercent = chicks * 100 / settedEggs;&#xD;&#xA;&#xD;&#xA;    ((XRTableCell)sender).Text = hatchPercent.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;    // accumulate total hatch percentage&#xD;&#xA;       // accumulate for overall total&#xD;&#xA;    totalChicks += chicks;&#xD;&#xA;    totalSettedEggs += settedEggs;&#xD;&#xA;    &#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;private void xrTableCell37_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     decimal totalHatchPercent = 0;&#xD;&#xA;&#xD;&#xA;    if (totalSettedEggs != 0)&#xD;&#xA;        totalHatchPercent = totalChicks * 100 / totalSettedEggs;&#xD;&#xA;&#xD;&#xA;    ((XRTableCell)sender).Text = totalHatchPercent.ToString(&quot;0.00&quot;);   &#xD;&#xA;   }&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal Chicks_HOF= 0;&#xD;&#xA;    decimal settedEggs_HOF= 0;&#xD;&#xA;    decimal fertPer = 0;&#xD;&#xA;    decimal hatchPer = 0;&#xD;&#xA;    decimal hatchOverFert = 0;&#xD;&#xA;    decimal fertileEggs_HOF = 0;&#xD;&#xA;    // Get values from current row&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Chicks&quot;) != null)&#xD;&#xA;        Chicks_HOF= Convert.ToDecimal(GetCurrentColumnValue(&quot;Chicks&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;ChicksSettedEggs&quot;) != null)&#xD;&#xA;        settedEggs_HOF = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChicksSettedEggs&quot;));&#xD;&#xA;        &#xD;&#xA;    if (GetCurrentColumnValue(&quot;FertileEggs&quot;) != null)&#xD;&#xA;        fertileEggs_HOF = Convert.ToDecimal(GetCurrentColumnValue(&quot;FertileEggs&quot;));&#xD;&#xA;        &#xD;&#xA;    if (GetCurrentColumnValue(&quot;FertPer&quot;) != null)&#xD;&#xA;        fertPer = Convert.ToDecimal(GetCurrentColumnValue(&quot;FertPer&quot;));&#xD;&#xA;&#xD;&#xA;    // Compute @HatchPer&#xD;&#xA;    if (settedEggs_HOF&gt; 0)&#xD;&#xA;        hatchPer = Chicks_HOF * 100 / settedEggs_HOF;&#xD;&#xA;&#xD;&#xA;    // Now apply main formula&#xD;&#xA;    if (fertPer != 0)&#xD;&#xA;        hatchOverFert = hatchPer * 100 / fertPer;&#xD;&#xA;&#xD;&#xA;    ((XRTableCell)sender).Text = hatchOverFert.ToString(&quot;0.00&quot;);&#xD;&#xA;&#xD;&#xA;    // accumulate totals for footer&#xD;&#xA;    totalChicks_Hatch += Chicks_HOF;&#xD;&#xA;    totalFertileEggs_Hatch += fertileEggs_HOF;&#xD;&#xA;    totalChicksSettedEggs_Hatch += settedEggs_HOF;&#xD;&#xA;    totalFertPer_Hatch += fertPer;&#xD;&#xA;   }&#xD;&#xA;&#xD;&#xA;private void xrTableCell41_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     decimal totalHatchPer = 0;&#xD;&#xA;     decimal totalFertilePer = 0;&#xD;&#xA;    decimal totalHatchOverFert = 0;&#xD;&#xA;&#xD;&#xA;    // compute @HatchPer from totals&#xD;&#xA;    if (totalChicksSettedEggs_Hatch &gt; 0)&#xD;&#xA;        totalHatchPer =  totalChicks_Hatch * 100 / totalChicksSettedEggs_Hatch;&#xD;&#xA;   &#xD;&#xA;   if (totalChicksSettedEggs_Hatch &gt; 0)&#xD;&#xA;        totalFertilePer =  totalFertileEggs_Hatch * 100 / totalChicksSettedEggs_Hatch;&#xD;&#xA;&#xD;&#xA;    // compute final value&#xD;&#xA;    if (totalFertilePer  != 0)&#xD;&#xA;        totalHatchOverFert = totalHatchPer * 100 / totalFertilePer ;&#xD;&#xA;&#xD;&#xA;    ((XRTableCell)sender).Text = totalHatchOverFert.ToString(&quot;0.00&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell39_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     decimal FertPer   = 0;&#xD;&#xA;    // Compute @HatchPer&#xD;&#xA;    if (totalChicksSettedEggs_Fertile&gt; 0)&#xD;&#xA;        FertPer = ( totalFertileEggs_Fertile * 100m) / totalChicksSettedEggs_Fertile;&#xD;&#xA;        &#xD;&#xA;      ((XRTableCell)sender).Text =  FertPer.ToString(&quot;0.00&quot;);&#xD;&#xA;      &#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal settedEggs_Fertile = 0;&#xD;&#xA;    decimal fertileEggs_Fertile = 0;&#xD;&#xA;    decimal FertPer  =0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;ChicksSettedEggs&quot;) != null)&#xD;&#xA;        settedEggs_Fertile = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChicksSettedEggs&quot;));&#xD;&#xA;        &#xD;&#xA;    if (GetCurrentColumnValue(&quot;FertileEggs&quot;) != null)&#xD;&#xA;        fertileEggs_Fertile = Convert.ToDecimal(GetCurrentColumnValue(&quot;FertileEggs&quot;));&#xD;&#xA;       &#xD;&#xA;    totalFertileEggs_Fertile += fertileEggs_Fertile;&#xD;&#xA;    totalChicksSettedEggs_Fertile += settedEggs_Fertile;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;" PageWidthF="1169.29138" PageHeightF="1653.54333" Version="25.2" DataMember="SR_HT_Production" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
