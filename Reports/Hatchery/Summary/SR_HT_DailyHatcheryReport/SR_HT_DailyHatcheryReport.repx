ecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation (row level %) ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (settedEggs != 0)&#xD;&#xA;    percentage = (nonHatEggs * 100m) / settedEggs;&#xD;&#xA;&#xD;&#xA;// --- Assign row % to the cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.00&quot;);  // Row level %&#xD;&#xA; if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null){&#xD;&#xA;            settedEggsNonHatchery = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;            settedEggsNonHatcheryReport += settedEggsNonHatchery;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;        }&#xD;&#xA;        totalReportNonHatEggs += nonHatEggs;&#xD;&#xA;  if (settedEggsNonHatcheryReport != 0)&#xD;&#xA;    TotalPercentageNonHatEggs = (totalReportNonHatEggs * 100m) / settedEggsNonHatcheryReport ;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell46_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // --- Declare values ---&#xD;&#xA;decimal deads = 0;&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Deads ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Deads&quot;) != null)&#xD;&#xA;    deads = Convert.ToDecimal(GetCurrentColumnValue(&quot;Deads&quot;));&#xD;&#xA;//--- SettedEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Equation (row level %) ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (settedEggs != 0)&#xD;&#xA;    percentage = (deads * 100m) / settedEggs;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign row % to the cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.00&quot;);  // Row level&#xD;&#xA;&#xD;&#xA;// --- SettedEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null){&#xD;&#xA;        settedEggsDeads = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;        totalsettedEggsDeadsReport += settedEggsDeads; &#xD;&#xA;&#xD;&#xA;    }&#xD;&#xA;    totalReportDeads += deads;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;if (totalsettedEggsDeadsReport != 0)&#xD;&#xA;    TotalPercentageDeads = (totalReportDeads * 100m) / totalsettedEggsDeadsReport ;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell87_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;             xrTableCell87.Text = TotalDeadEggsGroup.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell50_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // --- Declare values ---&#xD;&#xA;decimal culls = 0;&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Culls ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;&#xD;&#xA;// --- SettedEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation (row level %) ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (settedEggs != 0)&#xD;&#xA;    percentage = (culls * 100m) / settedEggs;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign row % to the cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.00&quot;);  // Row level %&#xD;&#xA;// --- SettedEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null){&#xD;&#xA;        settedEggsCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;        totalSettedEggsCullsReport+= settedEggsCulls ;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;    &#xD;&#xA;    }&#xD;&#xA;totalReportCulls += culls;&#xD;&#xA;&#xD;&#xA;if (totalSettedEggsCullsReport!= 0)&#xD;&#xA;    TotalPercentageCulls = (totalReportCulls * 100m) / totalSettedEggsCullsReport;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell89_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;              xrTableCell89.Text = TotalCullsEggsGroup.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell64_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // --- Declare values ---&#xD;&#xA;decimal culls = 0;&#xD;&#xA;decimal sellableChicks = 0;&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Culls ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;&#xD;&#xA;// --- SellableChicks ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null)&#xD;&#xA;    sellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;&#xD;&#xA;// --- SettedEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation (row level %) ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (settedEggs != 0)&#xD;&#xA;    percentage = ((culls + sellableChicks) * 100m) / settedEggs;&#xD;&#xA;&#xD;&#xA;// --- Total percentage ---&#xD;&#xA;if (totalReportSettedEggs != 0)&#xD;&#xA;    TotalPercentageCullsSellableChicks = (totalReportCullsSellable * 100m) / totalReportSettedEggs;&#xD;&#xA;&#xD;&#xA;// --- Assign row % to the cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.00&quot;);  // Row level %&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null){&#xD;&#xA;        CullsSelableSettedEggs_1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;        CullsSelableSettedEggsReport_1 += CullsSelableSettedEggs ;&#xD;&#xA;&#xD;&#xA;    &#xD;&#xA;    }&#xD;&#xA;    totalReportCullsSellable_1 += (culls + sellableChicks);&#xD;&#xA;   if(CullsSelableSettedEggsReport != 0)&#xD;&#xA;    TotalPercentageCullsSellable = (totalReportCullsSellable* 100m) / CullsSelableSettedEggsReport;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell66_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     decimal sellableChicks =0 ;&#xD;&#xA;    decimal settedEggs  = 0;&#xD;&#xA;&#xD;&#xA;     if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null)&#xD;&#xA;        sellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;&#xD;&#xA;     if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;        &#xD;&#xA;     // --- Equation (row level %) ---&#xD;&#xA;    decimal percentage = 0;&#xD;&#xA;    if (settedEggs != 0)&#xD;&#xA;        percentage = (sellableChicks * 100m) / settedEggs;&#xD;&#xA;&#xD;&#xA;    // --- Assign row % to the cell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = percentage.ToString(&quot;0.00&quot;);  // Row level %&#xD;&#xA;&#xD;&#xA;     TotalSellableChicks += SellableChicks;&#xD;&#xA;     TotalSettedEggs += settedEggs;&#xD;&#xA;     Total = (TotalSettedEggs * 100)  /  TotalSellableChicks ;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell7_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;             xrTableCell7.Text = TotalNonHatEggsGroup.ToString(&quot;N2&quot;); &#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell91_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;              TotalCullsSellableEggsGroup =  ((groupSellableChicks + groupCullsEggs ) * 100m)  /groupSettedEggs;&#xD;&#xA;              xrTableCell91.Text = TotalCullsSellableEggsGroup.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell93_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;                  xrTableCell93.Text = TotalSelChicksGroup.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;" PageWidth="1169" PageHeight="1654" Version="24.2" DataMember="SR_HT_DailyHatcheryReport" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
