<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_DailyHatcheryReport" ScriptsSource="decimal groupSellableChicks = 0;&#xD;&#xA;decimal groupSettedEggs  = 0;&#xD;&#xA;decimal TotalSelChicksGroup = 0;&#xD;&#xA;decimal TotalSellableChicks = 0;&#xD;&#xA;decimal TotalSettedEggs  = 0;&#xD;&#xA;decimal Total = 0;&#xD;&#xA;decimal TotalInfertileEggsGroup  = 0;&#xD;&#xA;decimal TotalInfertileEggs  =0 ;&#xD;&#xA;decimal TotalPercentageNonHatEggs  = 0;&#xD;&#xA;decimal TotalNonHatEggsGroup  = 0;&#xD;&#xA;decimal TotalPercentageDeads  =0 ;&#xD;&#xA;decimal TotalDeadEggsGroup  = 0 ;&#xD;&#xA;decimal TotalPercentageCulls  = 0;&#xD;&#xA;decimal TotalCullsEggsGroup  = 0;&#xD;&#xA;decimal TotalCullsSellableEggsGroup  = 0;&#xD;&#xA;decimal TotalPercentageCullsSellable  = 0;&#xD;&#xA;decimal TotalPercentageCullsSellableChicks = 0;&#xD;&#xA;decimal TotalCullsSellableEggsGroupChicks  = 0;&#xD;&#xA;decimal SellableChicks =0 ;&#xD;&#xA;decimal TotalInfertileSettedEggs = 0 ;&#xD;&#xA;decimal InfertileEggs  =0;&#xD;&#xA;decimal TotalgroupInfertileEggs  = 0;&#xD;&#xA;decimal TotalReportInfertileEggs  = 0;&#xD;&#xA;decimal totalReportSettedEggs  = 0;&#xD;&#xA;decimal totalReportNonHatEggs = 0;&#xD;&#xA;decimal totaltNonHatEggsGroup = 0;&#xD;&#xA;decimal totalNonHatSettedEggsGroup = 0;&#xD;&#xA;decimal groupDeadEggs = 0;  &#xD;&#xA;decimal groupCullsEggs = 0;    &#xD;&#xA;decimal totalReportDeads = 0;&#xD;&#xA;decimal totalReportCulls = 0;&#xD;&#xA;decimal settedEggsInfertile  = 0;&#xD;&#xA;decimal settedEggsInfertileReport  = 0;&#xD;&#xA;decimal settedEggsNonHatchery= 0;&#xD;&#xA;decimal settedEggsNonHatcheryReport = 0;&#xD;&#xA;decimal settedEggsDeads =0;&#xD;&#xA;decimal totalsettedEggsDeadsReport= 0;&#xD;&#xA;decimal settedEggsCulls= 0;&#xD;&#xA;decimal totalSettedEggsCullsReport= 0;&#xD;&#xA;decimal totalReportCullsSellable = 0;&#xD;&#xA;decimal CullsSelableSettedEggs = 0;&#xD;&#xA;decimal CullsSelableSettedEggsReport= 0;&#xD;&#xA;decimal CullsSelableSettedEggs_1= 0;&#xD;&#xA;decimal CullsSelableSettedEggsReport_1= 0;&#xD;&#xA;decimal totalReportCullsSellable_1= 0;&#xD;&#xA;decimal sellableChicksReport  = 0;&#xD;&#xA;decimal cullsReport  = 0;&#xD;&#xA;&#xD;&#xA;private void detailBand1_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      decimal settedEggs  = 0;&#xD;&#xA;       if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null)&#xD;&#xA;        SellableChicks= Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;&#xD;&#xA;     if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        settedEggs= Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;        &#xD;&#xA;     groupSellableChicks+= SellableChicks;&#xD;&#xA;     groupSettedEggs += settedEggs;&#xD;&#xA;     TotalSelChicksGroup = (groupSellableChicks* 100m) / groupSettedEggs ;&#xD;&#xA;    //---------- new logic for Infertile Eggs ------------------&#xD;&#xA;      if (GetCurrentColumnValue(&quot;InfertileEggs&quot;) != null){&#xD;&#xA;               InfertileEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;InfertileEggs&quot;));&#xD;&#xA;          }&#xD;&#xA;       &#xD;&#xA;    // --- SettedEggs ---&#xD;&#xA;    decimal settedEggs_Infertile = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null){&#xD;&#xA;             settedEggs_Infertile = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;        }&#xD;&#xA;            // ---TOTAL -----&#xD;&#xA;     TotalgroupInfertileEggs += InfertileEggs;&#xD;&#xA;     TotalInfertileSettedEggs +=  settedEggs_Infertile;&#xD;&#xA;    if (TotalInfertileSettedEggs != 0)&#xD;&#xA;         TotalInfertileEggsGroup = (TotalgroupInfertileEggs * 100)  /  TotalInfertileSettedEggs ;&#xD;&#xA;     //---------- new logic for NonHat Eggs ------------------&#xD;&#xA;             // --- Declare values ---&#xD;&#xA;    decimal nonHatEggs = 0;&#xD;&#xA;    decimal settedEggs_NonHat = 0;&#xD;&#xA;    &#xD;&#xA;    // --- NonHatEggs ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;NonHatEggs&quot;) != null)&#xD;&#xA;        nonHatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;NonHatEggs&quot;));&#xD;&#xA;    &#xD;&#xA;    // --- SettedEggs ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        settedEggs_NonHat= Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;    &#xD;&#xA;    // --- Total percentage ---&#xD;&#xA;    totaltNonHatEggsGroup += nonHatEggs;&#xD;&#xA;    totalNonHatSettedEggsGroup += settedEggs_NonHat;&#xD;&#xA;    if (totalNonHatSettedEggsGroup != 0)&#xD;&#xA;        TotalNonHatEggsGroup = (totaltNonHatEggsGroup * 100m) / totalNonHatSettedEggsGroup ;&#xD;&#xA;    //---------- new logic for Dead Eggs ------------------&#xD;&#xA;     decimal Dead = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Deads&quot;) != null)&#xD;&#xA;        Dead = Convert.ToDecimal(GetCurrentColumnValue(&quot;Deads&quot;));&#xD;&#xA;    groupDeadEggs += Dead;&#xD;&#xA;    if(groupSettedEggs != 0){&#xD;&#xA;               TotalDeadEggsGroup = (groupDeadEggs * 100m) / groupSettedEggs;&#xD;&#xA;        }&#xD;&#xA;    //---------- new logic for Culls Eggs ------------------&#xD;&#xA;    decimal Culls = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;         Culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;    groupCullsEggs += Culls;&#xD;&#xA;    if(groupSettedEggs != 0){&#xD;&#xA;            TotalCullsEggsGroup = (groupCullsEggs * 100m) / groupSettedEggs;&#xD;&#xA;        }&#xD;&#xA;    //---------- new logic for Culls + SellableChicks ------------------&#xD;&#xA;    decimal groupCullsSellableEggs  = 0;&#xD;&#xA;    decimal CullsGroup  = 0;&#xD;&#xA;    decimal SellableChicksGroup  = 0;&#xD;&#xA;    decimal CullsTotalHatch = 0;&#xD;&#xA;    decimal SellableChicksHatch = 0; &#xD;&#xA;    decimal settedEggs_TotalHatch = 0;&#xD;&#xA;    decimal totalHatchChiksSettedEggsGroup  = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        settedEggs_TotalHatch= Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;    // --- Culls ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;        CullsTotalHatch= Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;    &#xD;&#xA;    // --- SellableChicks ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null)&#xD;&#xA;        SellableChicksHatch = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;        &#xD;&#xA;    totalHatchChiksSettedEggsGroup  += settedEggs_TotalHatch;   &#xD;&#xA;    CullsGroup += CullsTotalHatch;&#xD;&#xA;    SellableChicksGroup += SellableChicksHatch ;&#xD;&#xA;    groupCullsSellableEggs  = CullsGroup  + SellableChicksGroup  ;&#xD;&#xA;    // --- Percentage ---&#xD;&#xA;    TotalCullsSellableEggsGroup = ((groupSellableChicks +groupCullsEggs ) * 100m)  / groupSettedEggs;&#xD;&#xA;    //---------- new logic for Culls + SellableChicks ------------------&#xD;&#xA;    decimal groupCullsSellableEggsChicks  = 0;&#xD;&#xA;    // --- Culls ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;        Culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;    &#xD;&#xA;    // --- SellableChicks ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null)&#xD;&#xA;        SellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;        groupCullsSellableEggsChicks  += (Culls + SellableChicks );&#xD;&#xA;    &#xD;&#xA;    // --- Percentage ---&#xD;&#xA;    TotalCullsSellableEggsGroupChicks = (groupCullsSellableEggsChicks  * 100m) / groupSettedEggs;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell68_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell68.Text = Total.ToString(&quot;0&quot;);&#xD;&#xA;      Total = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell45_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      if (totalReportSettedEggs  != 0){&#xD;&#xA;              TotalInfertileEggs = (TotalReportInfertileEggs  * 100m) / settedEggsInfertileReport;&#xD;&#xA;         }&#xD;&#xA;     xrTableCell45.Text = TotalInfertileEggs.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell52_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;          xrTableCell52.Text = TotalPercentageDeads.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell36_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell36.Text = TotalPercentageCulls.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell2_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal culls = 0;&#xD;&#xA;decimal sellableChicks = 0;&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;&#xD;&#xA;// --- Accumulators for totals ---&#xD;&#xA;decimal totalReportCullsSellable = 0;&#xD;&#xA;decimal totalReportSettedEggs = 0;&#xD;&#xA;&#xD;&#xA;// --- Culls ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;&#xD;&#xA;// --- SellableChicks ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SellableChicks&quot;) != null)&#xD;&#xA;    sellableChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SellableChicks&quot;));&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- SettedEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Equation (row level %) ---&#xD;&#xA;decimal TotaChicksHatch = 0;&#xD;&#xA;TotaChicksHatch = culls + sellableChicks ;&#xD;&#xA;&#xD;&#xA;// --- Total percentage ---&#xD;&#xA;// --- Assign row % to the cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = TotaChicksHatch.ToString(&quot;N0&quot;);  // Row level %&#xD;&#xA;totalReportSettedEggs += settedEggs;&#xD;&#xA;sellableChicksReport += sellableChicks ;&#xD;&#xA;cullsReport += culls ;&#xD;&#xA;totalReportCullsSellable = (sellableChicksReport + cullsReport );&#xD;&#xA;if(totalReportSettedEggs != 0)&#xD;&#xA;    TotalPercentageCullsSellable = (totalReportCullsSellable * 100m) / totalReportSettedEggs ;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell90_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell90.Text = TotalCullsSellableEggsGroup.ToString(&quot;0&quot;);&#xD;&#xA;      TotalCullsSellableEggsGroup = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell37_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell37.Text = TotalPercentageCullsSellable.ToString(&quot;0&quot;);&#xD;&#xA;      TotalPercentageCullsSellable  = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell38_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell38.Text = TotalPercentageCullsSellableChicks.ToString(&quot;0&quot;);&#xD;&#xA;      TotalPercentageCullsSellableChicks = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xr