    <Item21 Ref="43" Name="Age_CF" Expression="ToStr([Age]) + '/' + [FarmCode] + '/' + ToStr([CropNo]) + '/' + [Breed]" DataMember="SR_HT_WeeklyHatPerf" />
    <Item22 Ref="44" Name="ChicksPercent" Expression="Iif([SettedEggs] &lt;&gt; 0, ([Chicks] / [SettedEggs])* 100, 0)" DataMember="SR_HT_WeeklyHatPerf" />
    <Item23 Ref="45" Name="Total_TotalEggs" Expression="Sum([SettedEggs])" DataMember="SR_HT_WeeklyHatPerf" />
    <Item24 Ref="46" Name="HatPerf" Expression="Iif([AverageOfSetEgg_GT] &lt;&gt; 0, &#xA;    ([ChicksPercent] / Max([AverageOfSetEgg_GT])) * [SettedEggsPercent], &#xA;    0&#xA;)&#xA;" DataMember="SR_HT_WeeklyHatPerf" />
