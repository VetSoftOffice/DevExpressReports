<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_WeeklyHatPerf" ScriptsSource="&#xD;&#xA;private void crossTabDataCell2_BeforePrint(object sender, DevExpress.XtraReports.UI.CrossTab.CrossTabCellPrintEventArgs e) {&#xD;&#xA;       // Get full current row as a data record&#xD;&#xA;    var row = this.GetCurrentRow() as XRDataRecord;&#xD;&#xA;    if (row == null)&#xD;&#xA;    {&#xD;&#xA;        ((XRCrossTabCell)sender).Text = &quot;&quot;;&#xD;&#xA;        return;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    decimal chicks = 0;&#xD;&#xA;    decimal settedEggs = 0;&#xD;&#xA;&#xD;&#xA;    // Read fields directly from the data row&#xD;&#xA;    if (row[&quot;Chicks&quot;] != null)&#xD;&#xA;        chicks = Convert.ToDecimal(row[&quot;Chicks&quot;]);&#xD;&#xA;&#xD;&#xA;    if (row[&quot;SettedEggs&quot;] != null)&#xD;&#xA;        settedEggs = Convert.ToDecimal(row[&quot;SettedEggs&quot;]);&#xD;&#xA;&#xD;&#xA;    // Calculate %&#xD;&#xA;    if (settedEggs &gt; 0)&#xD;&#xA;        ((XRCrossTabCell)sender).Text = ((chicks * 100m) / settedEggs).ToString(&quot;N2&quot;);&#xD;&#xA;    else&#xD;&#xA;        ((XRCrossTabCell)sender).Text = &quot;&quot;;&#xD;&#xA;}&#xD;&#xA;" Landscape="true" PageWidth="1654" PageHeight="1169" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="24.2" DataMember="SR_HT_WeeklyHatPerf" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
