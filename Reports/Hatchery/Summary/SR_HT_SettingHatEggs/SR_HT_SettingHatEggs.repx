    <Item35 Ref="55" Name="TotalCulls" Expression="[rf_HatsCulls] + [rf_InjCulls] + [InjCulls] + [Culls] + [ExitCullsChicks]&#xA;" DataMember="SR_HT_SettingHatEggs" />
    <Item36 Ref="56" Name="TotalDeads" Expression="[ExitDeadChicks]" DataMember="SR_HT_SettingHatEggs" />
