#xD;&#xA;    exitCullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;ExitCullsChicks&quot;));&#xD;&#xA;&#xD;&#xA;// --- Sum them all ---&#xD;&#xA;decimal result = rfHatsCulls + rfInjCulls + injCulls + culls + exitCullsChicks;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N0&quot;); // no decimals, adjust format if needed&#xD;&#xA;rfHatsCullsReport += rfHatsCulls ;&#xD;&#xA;rfInjCullsReport  += rfInjCulls ;&#xD;&#xA;injCullsReport  += injCulls ;&#xD;&#xA;cullsReport += culls ;&#xD;&#xA;exitCullsChicksReport += exitCullsChicks ;&#xD;&#xA;TotalCullsReport = rfHatsCullsReport  + rfInjCullsReport   + injCullsReport   + cullsReport  + exitCullsChicksReport  ;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal rfHatsCulls = 0;&#xD;&#xA;decimal rfInjCulls = 0;&#xD;&#xA;decimal injCulls = 0;&#xD;&#xA;decimal culls = 0;&#xD;&#xA;decimal exitCullsChicks = 0;&#xD;&#xA;decimal exitDeadChicks = 0;&#xD;&#xA;&#xD;&#xA;// --- rf_HatsCulls ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;rf_HatsCulls&quot;) != null)&#xD;&#xA;    rfHatsCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_HatsCulls&quot;));&#xD;&#xA;&#xD;&#xA;// --- rf_InjCulls ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;rf_InjCulls&quot;) != null)&#xD;&#xA;    rfInjCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_InjCulls&quot;));&#xD;&#xA;&#xD;&#xA;// --- InjCulls ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;InjCulls&quot;) != null)&#xD;&#xA;    injCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;InjCulls&quot;));&#xD;&#xA;&#xD;&#xA;// --- Culls ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;&#xD;&#xA;// --- ExitCullsChicks ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;ExitCullsChicks&quot;) != null)&#xD;&#xA;    exitCullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;ExitCullsChicks&quot;));&#xD;&#xA;&#xD;&#xA;// --- Add to group sum ---&#xD;&#xA;rfHatsCullsGroup += rfHatsCulls ;&#xD;&#xA;rfInjCullsGroup  += rfInjCulls ;&#xD;&#xA;injCullsGroup  += injCulls ;&#xD;&#xA;cullsGroup += culls ;&#xD;&#xA;exitCullsChicksGroup += exitCullsChicks ;&#xD;&#xA;&#xD;&#xA;groupSumCulls = (rfHatsCullsGroup + rfInjCullsGroup  + injCullsGroup  + cullsGroup + exitCullsChicksGroup );&#xD;&#xA;&#xD;&#xA;   // --- New logic for total deads&#xD;&#xA;if (GetCurrentColumnValue(&quot;ExitDeadChicks&quot;) != null)&#xD;&#xA;    exitDeadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;ExitDeadChicks&quot;));&#xD;&#xA;&#xD;&#xA;// --- Add to group sum ---&#xD;&#xA;groupSumDeads += exitDeadChicks ;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell29_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell29.Text = groupSumCulls.ToString(&quot;N0&quot;);&#xD;&#xA;      groupSumCulls = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell63_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    xrTableCell63.Text = TotalCullsReport.ToString(&quot;N0&quot;);&#xD;&#xA;    TotalCullsReport = 0; // reset for next group&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell53_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare value ---&#xD;&#xA;decimal exitDeadChicks = 0;&#xD;&#xA;&#xD;&#xA;// --- ExitDeadChicks ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;ExitDeadChicks&quot;) != null)&#xD;&#xA;    exitDeadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;ExitDeadChicks&quot;));&#xD;&#xA;    &#xD;&#xA;TotalDeadsReport += exitDeadChicks ;&#xD;&#xA;&#xD;&#xA;// --- Assign value to the cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = exitDeadChicks.ToString(&quot;N0&quot;); // no decimals, adjust format if needed&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell34_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    xrTableCell34.Text = groupSumDeads.ToString(&quot;N0&quot;);&#xD;&#xA;    groupSumDeads  = 0; // reset for next LineType group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell64_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    xrTableCell64.Text = TotalDeadsReport.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void GroupHeader1_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    rfHatsCullsGroup = 0;&#xD;&#xA;rfInjCullsGroup = 0;&#xD;&#xA;injCullsGroup = 0;&#xD;&#xA;cullsGroup = 0;&#xD;&#xA;exitCullsChicksGroup = 0;&#xD;&#xA;groupSumCulls = 0;&#xD;&#xA;groupSumDeads = 0;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;" PageWidth="827" PageHeight="1169" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="24.2" DataMember="SR_HT_SettingHatEggs" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
