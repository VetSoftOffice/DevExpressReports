;&#xD;&#xA;    decimal fDead = 0;&#xD;&#xA;    decimal mDead = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FCulls&quot;) != null)&#xD;&#xA;        fCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;FCulls&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;MCulls&quot;) != null)&#xD;&#xA;        mCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;MCulls&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FDead&quot;) != null)&#xD;&#xA;        fDead = Convert.ToDecimal(GetCurrentColumnValue(&quot;FDead&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;MDead&quot;) != null)&#xD;&#xA;        mDead = Convert.ToDecimal(GetCurrentColumnValue(&quot;MDead&quot;));&#xD;&#xA;&#xD;&#xA;    groupSumCullsDead += (fCulls + mCulls + fDead + mDead);&#xD;&#xA;&#xD;&#xA;    // -- new logic for culls and dead without specifying the gender&#xD;&#xA;    decimal Culls = 0;&#xD;&#xA;    decimal Dead = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;        Culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Dead&quot;) != null)&#xD;&#xA;        Dead = Convert.ToDecimal(GetCurrentColumnValue(&quot;Dead&quot;));&#xD;&#xA;&#xD;&#xA;    groupSumOfCullsDead += (Culls + Dead);&#xD;&#xA;&#xD;&#xA;    // -- new logic for total Loss&#xD;&#xA;    decimal UnHatEggs = 0;&#xD;&#xA;    decimal DestroyedEggs = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;UnHatEggs&quot;) != null)&#xD;&#xA;        UnHatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;UnHatEggs&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;DestroyedEggs&quot;) != null)&#xD;&#xA;        DestroyedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DestroyedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    groupSumOfTotalCullsDead = groupSumCullsDead + groupSumOfCullsDead;&#xD;&#xA;    groupSumOfTotalLoss += (UnHatEggs + DestroyedEggs);&#xD;&#xA;    groupResultOfTotalLoss = groupSumOfTotalCullsDead + groupSumOfTotalLoss;&#xD;&#xA;&#xD;&#xA;    // --- New logic for total&#xD;&#xA;    decimal Chicks = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Chicks&quot;) != null)&#xD;&#xA;        Chicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;Chicks&quot;));&#xD;&#xA;&#xD;&#xA;    groupResultOfTotal = Chicks + groupSumOfTotalLoss + groupSumCullsDead + groupSumChicks;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell55_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    xrTableCell55.Text = groupSumChicks.ToString(&quot;N0&quot;);&#xD;&#xA;    groupSumChicks = 0; // reset for next LineType group&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell45_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal fCulls = 0;&#xD;&#xA;    decimal mCulls = 0;&#xD;&#xA;    decimal fDead = 0;&#xD;&#xA;    decimal mDead = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FCulls&quot;) != null)&#xD;&#xA;        fCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;FCulls&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;MCulls&quot;) != null)&#xD;&#xA;        mCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;MCulls&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FDead&quot;) != null)&#xD;&#xA;        fDead = Convert.ToDecimal(GetCurrentColumnValue(&quot;FDead&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;MDead&quot;) != null)&#xD;&#xA;        mDead = Convert.ToDecimal(GetCurrentColumnValue(&quot;MDead&quot;));&#xD;&#xA;&#xD;&#xA;    decimal result = fCulls + mCulls + fDead + mDead;&#xD;&#xA;&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell63_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    xrTableCell63.Text = groupSumCullsDead.ToString(&quot;0&qu