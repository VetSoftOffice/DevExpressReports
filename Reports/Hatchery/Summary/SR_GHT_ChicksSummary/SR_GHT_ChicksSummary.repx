l(GetCurrentColumnValue(&quot;MCulls&quot;));&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FDead&quot;) != null)&#xD;&#xA;        fDead = Convert.ToDecimal(GetCurrentColumnValue(&quot;FDead&quot;));&#xD;&#xA;    if (GetCurrentColumnValue(&quot;MDead&quot;) != null)&#xD;&#xA;        mDead = Convert.ToDecimal(GetCurrentColumnValue(&quot;MDead&quot;));&#xD;&#xA;&#xD;&#xA;    decimal broilerBreederMort = fCulls + mCulls + fDead + mDead;&#xD;&#xA;&#xD;&#xA;    // --- BroilerMort = Culls + Dead ---&#xD;&#xA;    decimal culls = 0, dead = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;        culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Dead&quot;) != null)&#xD;&#xA;        dead = Convert.ToDecimal(GetCurrentColumnValue(&quot;Dead&quot;));&#xD;&#xA;&#xD;&#xA;    decimal broilerMort = culls + dead;&#xD;&#xA;&#xD;&#xA;    // --- Final Result ---&#xD;&#xA;    decimal total = unHatEggs + destroyedEggs + broilerBreederMort + broilerMort;&#xD;&#xA;&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = total.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell66_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    xrTableCell66.Text = groupResultOfTotalLoss.ToString(&quot;N0&quot;);&#xD;&#xA;    groupResultOfTotalLoss = 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell52_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal chicks = 0, destroyedEggs = 0, unHatEggs = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Chicks&quot;) != null)&#xD;&#xA;        chicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;Chicks&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;DestroyedEggs&quot;) != null)&#xD;&#xA;        destroyedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DestroyedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;UnHatEggs&quot;) != null)&#xD;&#xA;        unHatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;UnHatEggs&quot;));&#xD;&#xA;&#xD;&#xA;    decimal fCulls = 0, mCulls = 0, fDead = 0, mDead = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FCulls&quot;) != null)&#xD;&#xA;        fCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;FCulls&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;MCulls&quot;) != null)&#xD;&#xA;        mCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;MCulls&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FDead&quot;) != null)&#xD;&#xA;        fDead = Convert.ToDecimal(GetCurrentColumnValue(&quot;FDead&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;MDead&quot;) != null)&#xD;&#xA;        mDead = Convert.ToDecimal(GetCurrentColumnValue(&quot;MDead&quot;));&#xD;&#xA;&#xD;&#xA;    decimal broilerBreederMort = fCulls + mCulls + fDead + mDead;&#xD;&#xA;&#xD;&#xA;    decimal fChicks = 0, mChicks = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FChicks&quot;) != null)&#xD;&#xA;        fChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;FChicks&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;MChicks&quot;) != null)&#xD;&#xA;        mChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;MChicks&quot;));&#xD;&#xA;&#xD;&#xA;    decimal boilerBreeder = fChicks + mChicks;&#xD;&#xA;&#xD;&#xA;    decimal total = chicks + broilerBreederMort + destroyedEggs + unHatEggs + boilerBreeder;&#xD;&#xA;&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = total.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell68_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    xrTableCell68.Text = groupResultOfTotal.ToString(&quot;N0&quot;);&#xD;&#xA;    groupResultOfTotal = 0;&#xD;&#xA;}&#xD;&#xA;" PageWidth="1169" PageHeight="1654" ScriptReferencesString="E:\VetSoft Projects .Net20