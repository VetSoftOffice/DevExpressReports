<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_GHT_ChicksSummary" ScriptsSource="decimal groupSumChicks = 0;&#xD;&#xA;decimal groupSumCullsDead = 0;&#xD;&#xA;decimal groupSumOfCullsDead = 0;&#xD;&#xA;decimal groupSumOfTotalLoss = 0;&#xD;&#xA;decimal groupSumOfTotalCullsDead = 0;&#xD;&#xA;decimal groupResultOfTotal = 0;&#xD;&#xA;decimal groupResultOfTotalLoss = 0;&#xD;&#xA;decimal fChicksGroup  = 0;&#xD;&#xA;decimal mChicksGroup  = 0;&#xD;&#xA;decimal fCullsGroup = 0 ;&#xD;&#xA;decimal mCullsGroup = 0;&#xD;&#xA;decimal fDeadGroup = 0;&#xD;&#xA;decimal mDeadGroup = 0;&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    &#xD;&#xA;    // --- New logic for culls + dead ---&#xD;&#xA;    decimal fCulls = 0;&#xD;&#xA;    decimal mCulls = 0;&#xD;&#xA;    decimal fDead = 0;&#xD;&#xA;    decimal mDead = 0;&#xD;&#xA;    decimal fCullsGroup = 0;&#xD;&#xA;    decimal mCullsGroup = 0;&#xD;&#xA;    decimal fDeadGroup = 0;&#xD;&#xA;    decimal mDeadGroup  = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FCulls&quot;) != null)&#xD;&#xA;        fCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;FCulls&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;MCulls&quot;) != null)&#xD;&#xA;        mCulls = Convert.ToDecimal(GetCurrentColumnValue(&quot;MCulls&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FDead&quot;) != null)&#xD;&#xA;        fDead = Convert.ToDecimal(GetCurrentColumnValue(&quot;FDead&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;MDead&quot;) != null)&#xD;&#xA;        mDead = Convert.ToDecimal(GetCurrentColumnValue(&quot;MDead&quot;));&#xD;&#xA;    fCullsGroup += fCulls;&#xD;&#xA;    mCullsGroup += mCulls;&#xD;&#xA;    fDeadGroup += fDead;&#xD;&#xA;    mDeadGroup += mDead;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;    groupSumCullsDead = (fCullsGroup + mCullsGroup + fDeadGroup + mDeadGroup );&#xD;&#xA;&#xD;&#xA;    // -- new logic for culls and dead without specifying the gender&#xD;&#xA;    decimal Culls = 0;&#xD;&#xA;    decimal Dead = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;        Culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Dead&quot;) != null)&#xD;&#xA;        Dead = Convert.ToDecimal(GetCurrentColumnValue(&quot;Dead&quot;));&#xD;&#xA;&#xD;&#xA;    groupSumOfCullsDead += (Culls + Dead);&#xD;&#xA;&#xD;&#xA;    // -- new logic for total Loss&#xD;&#xA;    decimal UnHatEggs = 0;&#xD;&#xA;    decimal DestroyedEggs = 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;UnHatEggs&quot;) != null)&#xD;&#xA;        UnHatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;UnHatEggs&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;DestroyedEggs&quot;) != null)&#xD;&#xA;        DestroyedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DestroyedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    groupSumOfTotalCullsDead = groupSumCullsDead + groupSumOfCullsDead;&#xD;&#xA;    groupSumOfTotalLoss += (UnHatEggs + DestroyedEggs);&#xD;&#xA;    groupResultOfTotalLoss = groupSumOfTotalCullsDead + groupSumOfTotalLoss;&#xD;&#xA;&#xD;&#xA;    // --- New logic for total&#xD;&#xA;    decimal Chicks = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Chicks&quot;) != null)&#xD;&#xA;        Chicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;Chicks&quot;));&#xD;&#xA;&#xD;&#xA;    groupResultOfTotal = Chicks + groupSumOfTotalLoss + groupSumCullsDead + groupSumChicks;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;" PageWidth="1169" PageHeight="1654" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="24.2" DataMember="SR_GHT_ChicksSummary" DataSource="