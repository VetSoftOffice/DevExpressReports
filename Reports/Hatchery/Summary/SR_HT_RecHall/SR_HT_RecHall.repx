<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_RecHall" ScriptsSource="decimal TotalhatchingEggsReportPerc  = 0 ;&#xD;&#xA;decimal TotalOverWeightEggsReport = 0;&#xD;&#xA;decimal TotalDirtyEggsReport = 0;&#xD;&#xA;decimal TotalDeformityEggsReport = 0;&#xD;&#xA;decimal TotalBrokenEggsReport = 0;&#xD;&#xA;decimal TotalDestroyedEggsReport = 0;&#xD;&#xA;decimal TotalCrackedEggsReport = 0;&#xD;&#xA;decimal TotalDoubleYolkEggsReport = 0;&#xD;&#xA;decimal TotalOtherEggsReport = 0;&#xD;&#xA;decimal TotalRecEggs = 0;&#xD;&#xA;decimal TotalOtherEggs = 0;&#xD;&#xA;decimal TotalPerc  = 0;&#xD;&#xA;decimal TotalSpecialEggsReport = 0;&#xD;&#xA;decimal TotalhatchingEggs   = 0;&#xD;&#xA;decimal TotalRecEggsHatch = 0;&#xD;&#xA;private void xrTableCell52_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       // --- Declare values ---&#xD;&#xA;decimal softShellEggs = 0;&#xD;&#xA;decimal minorCrackedEggs = 0;&#xD;&#xA;decimal majorCrackedEggs = 0;&#xD;&#xA;decimal thinShellEggs = 0;&#xD;&#xA;decimal otherEggs = 0;&#xD;&#xA;decimal wholeEggs = 0;&#xD;&#xA;decimal brokenEggs = 0;&#xD;&#xA;decimal smallEggs = 0;&#xD;&#xA;decimal overWeightEggs = 0;&#xD;&#xA;decimal dirtyEggs = 0;&#xD;&#xA;decimal deformityEggs = 0;&#xD;&#xA;decimal crackedEggs = 0;&#xD;&#xA;decimal doubleYolkEggs = 0;&#xD;&#xA;decimal recEggs = 0;&#xD;&#xA;decimal destroyedEggs = 0;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SoftShellEggs&quot;) != null)&#xD;&#xA;    softShellEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SoftShellEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;MinorCrackedEggs&quot;) != null)&#xD;&#xA;    minorCrackedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;MinorCrackedEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;MajorCrackedEggs&quot;) != null)&#xD;&#xA;    majorCrackedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;MajorCrackedEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;ThinShellEggs&quot;) != null)&#xD;&#xA;    thinShellEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;ThinShellEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;OtherEggs&quot;) != null)&#xD;&#xA;    otherEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;OtherEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;WholeEggs&quot;) != null)&#xD;&#xA;    wholeEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;WholeEggs&quot;));&#xD;&#xA;    &#xD;&#xA;if (GetCurrentColumnValue(&quot;RecEggs&quot;) != null)&#xD;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;BrokenEggs&quot;) != null)&#xD;&#xA;    brokenEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;BrokenEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SmallEggs&quot;) != null)&#xD;&#xA;    smallEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SmallEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;OverWeightEggs&quot;) != null)&#xD;&#xA;    overWeightEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;OverWeightEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DirtyEggs&quot;) != null)&#xD;&#xA;    dirtyEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DirtyEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DeformityEggs&quot;) != null)&#xD;&#xA;    deformityEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeformityEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CrackedEggs&quot;) != null)&#xD;&#xA;    crackedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;CrackedEggs&quot;));&#xD;&#xA;    &#xD;&#xA;if (GetCurrentColumnValue(&quot;DestroyedEggs&quot;) != null)&#xD;&#xA;    destroyedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DestroyedEggs&quot;));&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DoubleYolkEggs&quot;) != null)&#xD;&#xA;    doubleYolkEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DoubleYolkEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Sum them ---&#xD;&#xA;decimal result =  softShellEggs + minorCrackedEggs + majorCrackedEggs + thinShellEggs +&#xD;&#xA;                 otherEggs + wholeEggs + brokenEggs + smallEggs + overWeightEggs +&#xD;&#xA;                 dirtyEggs + deformityEggs + crackedEggs + doubleYolkEggs + destroyedEggs  ;&#xD;&#xA;&#xD;&#xA;// --- Add to group total ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (recEggs != 0)&#xD;&#xA;    percentage = (result * 100m) / recEggs;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = string.Format(&quot;{0:N0}\n{1:N2}&quot;, result , percentage);&#xD;&#xA;TotalPerc += result;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell64_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell64.Text = TotalPerc.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell54_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // --- Declare values ---&#xD;&#xA;decimal hatchingEggs = 0;&#xD;&#xA;decimal recEggs = 0;&#xD;&#xA;&#xD;&#xA;// --- HatchingEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;HatchingEggs&quot;) != null)&#xD;&#xA;    hatchingEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;HatchingEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- RecEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecEggs&quot;) != null)&#xD;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (recEggs != 0)&#xD;&#xA;    percentage = (hatchingEggs * 100m) / recEggs;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.00&quot;); // 2 decimals&#xD;&#xA;TotalhatchingEggs  += hatchingEggs ;&#xD;&#xA;TotalRecEggsHatch += recEggs ;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell66_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    if(TotalRecEggsHatch != 0){&#xD;&#xA;        TotalhatchingEggsReportPerc = (TotalhatchingEggs   * 100m) / TotalRecEggsHatch ;&#xD;&#xA;        }&#xD;&#xA;      xrTableCell66.Text = TotalhatchingEggsReportPerc.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell30_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       // --- Declare values ---&#xD;&#xA;decimal smallEggs = 0;&#xD;&#xA;decimal recEggs = 0;&#xD;&#xA;decimal total = 0;&#xD;&#xA;decimal totalPerc = 0;&#xD;&#xA;decimal totalSpecialEggs = 0;&#xD;&#xA;decimal TotalReport  = 0;&#xD;&#xA;decimal TotalPercReport  = 0;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SmallEggs&quot;) != null)&#xD;&#xA;    smallEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SmallEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecEggs&quot;) != null)&#xD;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Base total (SmallEggs) ---&#xD;&#xA;total = smallEggs;&#xD;&#xA;&#xD;&#xA;// --- IIf logic: SmallEggs % of RecEggs ---&#xD;&#xA;if (recEggs != 0)&#xD;&#xA;    totalPerc = (smallEggs * 100.0m / recEggs);&#xD;&#xA;&#xD;&#xA;// --- Final sum ---&#xD;&#xA;totalSpecialEggs = total + totalPerc ;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = string.Format(&quot;{0:N0}\n{1:N2}&quot;, smallEggs, totalPerc);&#xD;&#xA;// --- Add to group totals ---&#xD;&#xA;TotalReport += total;&#xD;&#xA;TotalPercRepor