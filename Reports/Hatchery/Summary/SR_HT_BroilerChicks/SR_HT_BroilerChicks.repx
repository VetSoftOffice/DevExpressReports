<XtraReportsLayoutSerializer SerializerVersion="26.1.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_BroilerChicks" ScriptsSource="decimal QtyReport = 0 ;&#xD;&#xA;decimal QtyGroup = 0 ;&#xD;&#xA;private void xrTableCell33_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal Broiler= 0;&#xD;&#xA;    decimal Female = 0;&#xD;&#xA;    decimal  Male= 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Broiler&quot;) != null)&#xD;&#xA;        Broiler= Convert.ToDecimal(GetCurrentColumnValue(&quot;Broiler&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Female&quot;) != null)&#xD;&#xA;        Female= Convert.ToDecimal(GetCurrentColumnValue(&quot;Female&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Male&quot;) != null)&#xD;&#xA;        Male= Convert.ToDecimal(GetCurrentColumnValue(&quot;Male&quot;));&#xD;&#xA;&#xD;&#xA;   &#xD;&#xA;    decimal Qty = Broiler + Female + Male;&#xD;&#xA;    QtyReport += Qty;&#xD;&#xA;     // Set value in cell&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = Qty.ToString(&quot;N0&quot;); // show as integer, adjust if needed&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void detailBand1_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal Broiler= 0;&#xD;&#xA;    decimal Female = 0;&#xD;&#xA;    decimal Male= 0;&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Broiler&quot;) != null)&#xD;&#xA;        Broiler= Convert.ToDecimal(GetCurrentColumnValue(&quot;Broiler&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Female&quot;) != null)&#xD;&#xA;        Female= Convert.ToDecimal(GetCurrentColumnValue(&quot;Female&quot;));&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;Male&quot;) != null)&#xD;&#xA;        Male= Convert.ToDecimal(GetCurrentColumnValue(&quot;Male&quot;));&#xD;&#xA;&#xD;&#xA;   &#xD;&#xA;    QtyGroup += Broiler + Female + Male;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell21_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell21.Text = QtyGroup.ToString(&quot;N0&quot;);&#xD;&#xA;      QtyGroup= 0; // reset for next LineType group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell10_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell10.Text = QtyReport.ToString(&quot;N0&quot;);&#xD;&#xA;      QtyReport= 0; // reset for next LineType group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;" PageWidthF="826.771667" PageHeightF="1169.29138" Version="26.1" DataMember="SR_HT_BroilerChicks" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
