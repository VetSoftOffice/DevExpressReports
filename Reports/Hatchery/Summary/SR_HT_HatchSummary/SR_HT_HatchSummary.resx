    <value>// Global variables (define ONCE at the top)
decimal settedEggs = 0;
decimal selChicks = 0;
decimal percentage = 0;


decimal deadChicks = 0;
decimal cullsChicks = 0;
decimal totalDeadAndCulls = 0;
decimal grandTotalDeadAndCulls = 0;

decimal rejChicks = 0;
decimal grandTotalRejSel = 0;

decimal grandTotalSettedEggs = 0;
decimal grandTotalRejectChicks = 0;   // renamed for clarity
decimal sumRowPercentages = 0m;
int rowCount = 0;
     // also declare at class level// ---------------- ROW LEVEL CALCULATIONS ----------------

private void xrTableCell28_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    XRTableCell cell = (XRTableCell)sender;

    settedEggs = Convert.ToDecimal(GetCurrentColumnValue("SettedEggs"));
    selChicks  = Convert.ToDecimal(GetCurrentColumnValue("SelChicks"));

    percentage = (settedEggs &gt; 0) ? (selChicks / settedEggs) * 100 : 0;

    cell.Text = percentage.ToString("0.##");
}

private void xrTableCell49_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    XRTableCell cell = sender as XRTableCell;

    deadChicks  = Convert.ToDecimal(GetCurrentColumnValue("DeadChicks"));
    cullsChicks = Convert.ToDecimal(GetCurrentColumnValue("CullsChicks"));

    totalDeadAndCulls = deadChicks + cullsChicks;
    cell.Text = totalDeadAndCulls.ToString("N2");

    grandTotalDeadAndCulls += totalDeadAndCulls;
}

private void xrTableCell50_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    XRTableCell cell = sender as XRTableCell;

    settedEggs  = Convert.ToDecimal(GetCurrentColumnValue("SettedEggs"));
    deadChicks  = Convert.ToDecimal(GetCurrentColumnValue("DeadChicks"));
    cullsChicks = Convert.ToDecimal(GetCurrentColumnValue("CullsChicks"));

    rejChicks = deadChicks + cullsChicks;
    decimal rejPercent = (settedEggs &gt; 0) ? (rejChicks / settedEggs) * 100 : 0;

    cell.Text = rejPercent.ToString("N2");

    // accumulate totals
    grandTotalSettedEggs += settedEggs;
    grandTotalRejectChicks += rejChicks;
}

private void xrTableCell52_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    XRTableCell cell = sender as XRTableCell;

    // Get the previously calculated RejChicks for this row
    decimal deadChicks  = Convert.ToDecimal(GetCurrentColumnValue("DeadChicks"));
    decimal cullsChicks = Convert.ToDecimal(GetCurrentColumnValue("CullsChicks"));
    decimal rejChicks   = deadChicks + cullsChicks;

    // Get SelChicks from dataset
    decimal selChicks = Convert.ToDecimal(GetCurrentColumnValue("SelChicks"));

    // Equation: RejChicks + SelChicks
    decimal totalRejSel = rejChicks + selChicks;

    // Set value in cell
    cell.Text = totalRejSel.ToString("N2");

    // Keep grand total for all rows
    grandTotalRejSel += totalRejSel;
}

private void xrTableCell53_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
  XRTableCell cell = (XRTableCell)sender;

    decimal rejChicks  = Convert.ToDecimal(GetCurrentColumnValue("DeadChicks"))
                       + Convert.ToDecimal(GetCurrentColumnValue("CullsChicks"));
    decimal selChicks  = Convert.ToDecimal(GetCurrentColumnValue("SelChicks"));
    decimal settedEggs = Convert.ToDecimal(GetCurrentColumnValue("SettedEggs"));

    decimal rowPercentage = (settedEggs &gt; 0) ? (rejChicks + selChicks) / settedEggs * 100m : 0m;

    cell.Text = rowPercentage.ToString("N2");

    // accumulate for the footer average
    sumRowPercentages += rowPercentage;
    rowCount++;
               }
 
// ---------------- FOOTER TOTAL CELLS ----------------

private void xrTableCell63_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    ((XRTableCell)sender).Text = grandTotalDeadAndCulls.ToString("N2");
}

private void xrTableCell65_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    XRTableCell cell = sender as XRTableCell;
    decimal totalRejectPercent = (grandTotalSettedEggs &gt; 0) 
        ? (grandTotalRejectChicks / grandTotalSettedEggs) * 100 
        : 0;
        
    cell.Text = totalRejectPercent.ToString("N2");
}

private void xrTableCell66_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    ((XRTableCell)sender).Text = grandTotalRejSel.ToString("N2");
}

private void xrTableCell67_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
        XRTableCell cell = (XRTableCell)sender;

    decimal avgPercentage = (rowCount &gt; 0) ? (sumRowPercentages / rowCount) : 0m;
    cell.Text = avgPercentage.ToString("N2");         
