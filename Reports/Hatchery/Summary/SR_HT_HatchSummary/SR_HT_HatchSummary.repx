<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_HatchSummary" ScriptsSource="// Global variables (define ONCE at the top)&#xD;&#xA;&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal deadChicks = 0;&#xD;&#xA;decimal cullsChicks = 0;&#xD;&#xA;decimal totalDeadAndCulls = 0;&#xD;&#xA;decimal grandTotalDeadAndCulls = 0;&#xD;&#xA;decimal deadChicksReport  = 0;&#xD;&#xA;decimal cullsChicksReport  = 0;&#xD;&#xA;decimal selChicksReport = 0;&#xD;&#xA;decimal settedEggsReport  = 0;&#xD;&#xA;decimal grandTotalSelChicks  = 0;&#xD;&#xA;decimal rejChicks = 0;&#xD;&#xA;decimal grandTotalRejSel = 0;&#xD;&#xA;&#xD;&#xA;decimal grandTotalSettedEggs = 0;&#xD;&#xA;decimal grandTotalRejectChicks = 0;   // renamed for clarity&#xD;&#xA;decimal sumRowPercentages = 0;&#xD;&#xA;int rowCount = 0;&#xD;&#xA;decimal grandTotalDeadChicks    = 0;&#xD;&#xA;decimal grandTotalCullsChicks = 0;&#xD;&#xA;decimal TotalChicksHatch = 0;&#xD;&#xA;     // also declare at class level// ---------------- ROW LEVEL CALCULATIONS ----------------&#xD;&#xA;&#xD;&#xA;private void xrTableCell28_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal settedEggs_Hatch = 0;&#xD;&#xA;    decimal selChicks = 0;&#xD;&#xA;    decimal percentage = 0;&#xD;&#xA;    &#xD;&#xA;&#xD;&#xA;    settedEggs_Hatch = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;    selChicks  = Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;));&#xD;&#xA;&#xD;&#xA;    percentage = (settedEggs_Hatch &gt; 0) ? (selChicks / settedEggs_Hatch ) * 100 : 0;&#xD;&#xA;    &#xD;&#xA;    XRTableCell cell = (XRTableCell)sender;&#xD;&#xA;    cell.Text = percentage.ToString(&quot;0.##&quot;);&#xD;&#xA;    selChicksReport +=  selChicks ;&#xD;&#xA;    settedEggsReport += settedEggs_Hatch ;&#xD;&#xA;    grandTotalSelChicks = selChicksReport + settedEggsReport ;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell49_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    deadChicks  = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;    cullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;&#xD;&#xA;    totalDeadAndCulls = deadChicks + cullsChicks;&#xD;&#xA;    cell.Text = totalDeadAndCulls.ToString(&quot;N0&quot;);&#xD;&#xA;    deadChicksReport +=  deadChicks  ;&#xD;&#xA;    cullsChicksReport += cullsChicks ;&#xD;&#xA;    grandTotalDeadAndCulls = deadChicksReport  + cullsChicksReport ;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell50_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    settedEggs  = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;    deadChicks  = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;    cullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;&#xD;&#xA;    rejChicks = deadChicks + cullsChicks;&#xD;&#xA;    decimal rejPercent = (settedEggs &gt; 0) ? (rejChicks / settedEggs) * 100 : 0;&#xD;&#xA;&#xD;&#xA;    cell.Text = rejPercent.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;    // accumulate totals&#xD;&#xA;    grandTotalSettedEggs += settedEggs;&#xD;&#xA;    grandTotalRejectChicks += rejChicks;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell52_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get the previously calculated RejChicks for this row&#xD;&#xA;    decimal deadChicks  = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;    decimal cullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;    decimal rejChicks   = deadChicks + cullsChicks;&#xD;&#xA;&#xD;&#xA;    // Get SelChicks from dataset&#xD;&#xA;    decimal selChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;));&#xD;&#xA;&#xD;&#xA;    // Equation: RejChicks + SelChicks&#xD;&#xA;    decimal totalRejSel = rejChicks + selChicks;&#xD;&#xA;&#xD;&#xA;    // Set value in cell&#xD;&#xA;    cell.Text = totalRejSel.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;    // Keep grand total for all rows&#xD;&#xA;        // accumulate totals&#xD;&#xA;    grandTotalDeadChicks   += deadChicks  ;&#xD;&#xA;    grandTotalCullsChicks += totalRejSel ;&#xD;&#xA;    grandTotalSelChicks += selChicks;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell53_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;  XRTableCell cell = (XRTableCell)sender;&#xD;&#xA;&#xD;&#xA;    decimal rejChicks  = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;))&#xD;&#xA;                       + Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;    decimal selChicks  = Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;));&#xD;&#xA;    decimal settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    decimal rowPercentage = (settedEggs &gt; 0) ? (rejChicks + selChicks) / settedEggs * 100m : 0m;&#xD;&#xA;&#xD;&#xA;    cell.Text = rowPercentage.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;    // accumulate for the footer average&#xD;&#xA;    sumRowPercentages += rowPercentage;&#xD;&#xA;    rowCount++;&#xD;&#xA;               }&#xD;&#xA; &#xD;&#xA;// ---------------- FOOTER TOTAL CELLS ----------------&#xD;&#xA;&#xD;&#xA;private void xrTableCell63_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    ((XRTableCell)sender).Text = grandTotalDeadAndCulls.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell65_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    decimal totalRejectPercent = (grandTotalSettedEggs &gt; 0) &#xD;&#xA;        ? (grandTotalRejectChicks / grandTotalSettedEggs) * 100 &#xD;&#xA;        : 0;&#xD;&#xA;        &#xD;&#xA;    cell.Text = totalRejectPercent.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell66_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    TotalChicksHatch = grandTotalCullsChicks  ;&#xD;&#xA;    ((XRTableCell)sender).Text = TotalChicksHatch.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell67_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    decimal totalHatchPer = (grandTotalSettedEggs &gt; 0) &#xD;&#xA;        ? (TotalChicksHatch/ grandTotalSettedEggs) * 100 &#xD;&#xA;        : 0;&#xD;&#xA;        &#xD;&#xA;    cell.Text = totalHatchPer.ToString(&quot;N2&quot;);        &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell62_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    decimal totalHatchPercent = (settedEggsReport &gt; 0) &#xD;&#xA;        ? (selChicksReport / settedEggsReport ) * 100 &#xD;&#xA;        : 0;&#xD;&#xA;        &#xD;&#xA;    cell.Text = totalHatchPercent.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;" PageWidthF="1169.29138" PageHeightF="1653.54333" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="25.2" DataMember="SR_HT_HatchSummary" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
