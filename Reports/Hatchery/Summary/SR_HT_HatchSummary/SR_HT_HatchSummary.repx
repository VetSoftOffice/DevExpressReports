<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_HatchSummary" ScriptsSource="// Global variables (define ONCE at the top)&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal selChicks = 0;&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;&#xD;&#xA;decimal settedEggs_Sum = 0;&#xD;&#xA;decimal selChicks_Sum = 0;&#xD;&#xA;decimal percentage2 = 0;&#xD;&#xA;&#xD;&#xA;decimal deadChicks = 0;&#xD;&#xA;decimal cullsChicks = 0;&#xD;&#xA;decimal totalDeadAndCulls = 0;&#xD;&#xA;decimal grandTotalDeadAndCulls = 0;&#xD;&#xA;&#xD;&#xA;decimal rejChicks = 0;&#xD;&#xA;decimal totalRejSel = 0;&#xD;&#xA;decimal grandTotalRejSel = 0;&#xD;&#xA;&#xD;&#xA;decimal grandTotalSettedEggs = 0;&#xD;&#xA;decimal grandTotalRejectChicks = 0;   // renamed for clarity&#xD;&#xA;decimal grandTotalChicksHatchery = 0;&#xD;&#xA;decimal grandTotalPercent = 0; // declare this at class level&#xD;&#xA;decimal rowPercent = 0;        // also declare at class level// ---------------- ROW LEVEL CALCULATIONS ----------------&#xD;&#xA;&#xD;&#xA;private void xrTableCell28_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = (XRTableCell)sender;&#xD;&#xA;&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;    selChicks  = Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;));&#xD;&#xA;&#xD;&#xA;    percentage = (settedEggs &gt; 0) ? (selChicks / settedEggs) * 100 : 0;&#xD;&#xA;&#xD;&#xA;    cell.Text = percentage.ToString(&quot;0.##&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell49_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    deadChicks  = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;    cullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;&#xD;&#xA;    totalDeadAndCulls = deadChicks + cullsChicks;&#xD;&#xA;    cell.Text = totalDeadAndCulls.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;    grandTotalDeadAndCulls += totalDeadAndCulls;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell50_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    settedEggs  = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;    deadChicks  = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;    cullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;&#xD;&#xA;    rejChicks = deadChicks + cullsChicks;&#xD;&#xA;    decimal rejPercent = (settedEggs &gt; 0) ? (rejChicks / settedEggs) * 100 : 0;&#xD;&#xA;&#xD;&#xA;    cell.Text = rejPercent.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;    // accumulate totals&#xD;&#xA;    grandTotalSettedEggs += settedEggs;&#xD;&#xA;    grandTotalRejectChicks += rejChicks;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell52_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    rejChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejChicks&quot;));&#xD;&#xA;    selChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;));&#xD;&#xA;&#xD;&#xA;    totalRejSel = rejChicks + selChicks;&#xD;&#xA;    cell.Text = totalRejSel.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;    grandTotalRejSel += totalRejSel;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell53_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;   XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    // Get current row values&#xD;&#xA;    decimal rejChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejChicks&quot;));&#xD;&#xA;    decimal selChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;));&#xD;&#xA;    decimal settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;    // ChickHatchery = RejChicks + SelChicks&#xD;&#xA;    decimal chickHatchery = rejChicks + selChicks;&#xD;&#xA;&#xD;&#xA;    // Calculate percentage&#xD;&#xA;    decimal percent = 0;&#xD;&#xA;    if (settedEggs &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        percent = (chickHatchery / settedEggs) * 100;&#xD;&#xA;    }&#xD;&#xA;     grandTotalPercent += percent ;&#xD;&#xA;    // Show with 2 decimal places&#xD;&#xA;    cell.Text = percent.ToString(&quot;N2&quot;);    &#xD;&#xA;     }&#xD;&#xA;&#xD;&#xA;// ---------------- FOOTER TOTAL CELLS ----------------&#xD;&#xA;&#xD;&#xA;private void xrTableCell63_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    ((XRTableCell)sender).Text = grandTotalDeadAndCulls.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell65_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    decimal totalRejectPercent = (grandTotalSettedEggs &gt; 0) &#xD;&#xA;        ? (grandTotalRejectChicks / grandTotalSettedEggs) * 100 &#xD;&#xA;        : 0;&#xD;&#xA;    cell.Text = totalRejectPercent.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell66_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    ((XRTableCell)sender).Text = grandTotalRejSel.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell67_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;    cell.Text = grandTotalPercent.ToString(&quot;N2&quot;); // show grand total percent&#xD;&#xA;    }&#xD;&#xA;" PageWidth="1169" PageHeight="1654" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="24.2" DataMember="SR_HT_HatchSummary" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
