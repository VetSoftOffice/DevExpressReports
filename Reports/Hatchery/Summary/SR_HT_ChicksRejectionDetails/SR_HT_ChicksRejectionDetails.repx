<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_ChicksRejectionDetails" ScriptsSource="decimal TotalPercentageSelChicks = 0;&#xD;&#xA;decimal TotalPercentageTotalCulls = 0 ;&#xD;&#xA;decimal totalSelChicks  = 0;&#xD;&#xA;decimal totalsettedEggs   = 0;&#xD;&#xA;decimal totalTotalCulls  = 0;&#xD;&#xA;decimal totalSettedEggsCulls = 0;&#xD;&#xA;private void xrTableCell1_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal SelChicks= 0;&#xD;&#xA;    decimal settedEggs  = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SelChicks&quot;) != null)&#xD;&#xA;        SelChicks= Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;));&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;     // --- Equation ---&#xD;&#xA;    decimal percentage = 0;&#xD;&#xA;    if (settedEggs != 0)&#xD;&#xA;        percentage = (SelChicks* 100m) / settedEggs;&#xD;&#xA;        // --- Assign result to cell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = percentage.ToString(&quot;0.##&quot;);   // 2 decimal places&#xD;&#xA;    totalSelChicks += SelChicks;&#xD;&#xA;    totalsettedEggs  += settedEggs ;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell45_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    if(totalsettedEggs   != 0)&#xD;&#xA;    {&#xD;&#xA;        &#xD;&#xA;        TotalPercentageSelChicks = (totalSelChicks  * 100m) / totalsettedEggs  ;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;     xrTableCell45.Text = TotalPercentageSelChicks.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell15_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     decimal TotalCulls= 0;&#xD;&#xA;     decimal settedEggs = 0;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;TotalCulls&quot;) != null)&#xD;&#xA;        TotalCulls= Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalCulls&quot;));&#xD;&#xA;    if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;        settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;     // --- Equation ---&#xD;&#xA;    decimal percentage = 0;&#xD;&#xA;    if (settedEggs != 0)&#xD;&#xA;        percentage = (TotalCulls* 100m) / settedEggs;&#xD;&#xA;    // --- Assign result to cell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = percentage.ToString(&quot;0.##&quot;);   // 2 decimal places&#xD;&#xA;    totalTotalCulls += TotalCulls;&#xD;&#xA;    totalSettedEggsCulls += settedEggs ;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell46_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    if(totalSettedEggsCulls != 0)&#xD;&#xA;    {&#xD;&#xA;        &#xD;&#xA;        TotalPercentageTotalCulls = (totalTotalCulls * 100m) / totalSettedEggsCulls ;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;      xrTableCell46.Text = TotalPercentageTotalCulls.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;" Landscape="true" PageWidth="1654" PageHeight="1169" Version="24.2" DataMember="SR_HT_ChicksRejDetails" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
  <Parameters>
