private void xrTableCell1_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    decimal SelChicks= 0;
    decimal settedEggs  = 0;
    if (GetCurrentColumnValue("SelChicks") != null)
        SelChicks= Convert.ToDecimal(GetCurrentColumnValue("SelChicks"));
    if (GetCurrentColumnValue("SettedEggs") != null)
        settedEggs = Convert.ToDecimal(GetCurrentColumnValue("SettedEggs"));

     // --- Equation ---
    decimal percentage = 0;
    if (settedEggs != 0)
        percentage = (SelChicks* 100m) / settedEggs;
        // --- Assign result to cell ---
    XRTableCell cell = sender as XRTableCell;
    cell.Text = percentage.ToString("0.##");   // 2 decimal places
    totalSelChicks += SelChicks;
    totalsettedEggs  += settedEggs ;
}


private void xrTableCell45_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
    if(totalsettedEggs   != 0)
    {
        
        TotalPercentageSelChicks = (totalSelChicks  * 100m) / totalsettedEggs  ;
    }
    
     xrTableCell45.Text = TotalPercentageSelChicks.ToString("N2");

}

private void xrTableCell15_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {
