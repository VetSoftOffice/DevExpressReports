<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_RecAndSettedEggs" ScriptsSource="decimal openSetterEggsReport  = 0;&#xD;&#xA;decimal openHatcherEggsReport  = 0;&#xD;&#xA;decimal OpenMachineReport  = 0;&#xD;&#xA;decimal groupSumOpenEggs  =0;&#xD;&#xA;decimal CloseMachineReport  = 0;&#xD;&#xA;decimal groupSumCloseEggs  = 0 ;&#xD;&#xA;decimal OpenEggsReport  = 0 ;&#xD;&#xA;decimal openEggStoreEggsReport  = 0;&#xD;&#xA;decimal recEggsReport  = 0;&#xD;&#xA;decimal groupSumOpenBalance = 0 ;&#xD;&#xA;decimal TotalEggsAndChicksReport  = 0 ;&#xD;&#xA;decimal groupSumEggsAndChicks  = 0 ;&#xD;&#xA;decimal openSetterEggsGroup  = 0;&#xD;&#xA;decimal openHatcherEggsGroup  = 0;&#xD;&#xA;decimal closeSetterEggsReport  = 0;&#xD;&#xA;decimal closeHatcherEggsReport = 0;&#xD;&#xA;decimal deadsGroup = 0;&#xD;&#xA;decimal cullsGroup = 0;&#xD;&#xA;decimal destroyedEggsGroup = 0;&#xD;&#xA;decimal unHatEggsGroup = 0;&#xD;&#xA;decimal chicksGroup = 0;&#xD;&#xA;private void xrTableCell31_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal openSetterEggs = 0;&#xD;&#xA;decimal openHatcherEggs = 0;&#xD;&#xA;&#xD;&#xA;// --- OpenSetterEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;OpenSetterEggs&quot;) != null)&#xD;&#xA;    openSetterEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenSetterEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- OpenHatcherEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;OpenHatcherEggs&quot;) != null)&#xD;&#xA;    openHatcherEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenHatcherEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Result (sum) ---&#xD;&#xA;decimal result = openSetterEggs + openHatcherEggs;&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N0&quot;); // no decimals, adjust format if needed&#xD;&#xA;openSetterEggsReport += openSetterEggs ;&#xD;&#xA;openHatcherEggsReport += openHatcherEggs ;&#xD;&#xA;OpenMachineReport = openSetterEggsReport + openHatcherEggsReport ;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal openSetterEggs = 0;&#xD;&#xA;decimal openHatcherEggs = 0;&#xD;&#xA;&#xD;&#xA;// --- OpenSetterEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;OpenSetterEggs&quot;) != null)&#xD;&#xA;    openSetterEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenSetterEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- OpenHatcherEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;OpenHatcherEggs&quot;) != null)&#xD;&#xA;    openHatcherEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenHatcherEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Add to group sum ---&#xD;&#xA;openSetterEggsGroup +=  openSetterEggs ;  &#xD;&#xA;openHatcherEggsGroup += openHatcherEggs ;&#xD;&#xA;groupSumOpenEggs = (openSetterEggsGroup + openHatcherEggsGroup );&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal closeSetterEggs = 0;&#xD;&#xA;decimal closeHatcherEggs = 0;&#xD;&#xA;&#xD;&#xA;// --- OpenSetterEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CloseSetterEggs&quot;) != null)&#xD;&#xA;    closeSetterEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;CloseSetterEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- OpenHatcherEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CloseHatcherEggs&quot;) != null)&#xD;&#xA;    closeHatcherEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;CloseHatcherEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Add to group sum ---&#xD;&#xA;closeSetterEggsReport += closeSetterEggs ;&#xD;&#xA;closeHatcherEggsReport += closeHatcherEggs;&#xD;&#xA;groupSumCloseEggs += (closeSetterEggs + closeHatcherEggs);&#xD;&#xA;// --- Declare values ---&#xD;&#xA;decimal openEggStoreEggs = 0;&#xD;&#xA;decimal recEggs = 0;&#xD;&#xA;&#xD;&#xA;// --- OpenEggStoreEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;OpenEggStoreEggs&quot;) != null)&#xD;&#xA;    openEggStoreEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenEggStoreEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- RecEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecEggs&quot;) != null)&#xD;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Add to group sum ---&#xD;&#xA;openEggStoreEggsReport += openEggStoreEggs ;&#xD;&#xA;recEggsReport += recEggs  ;&#xD;&#xA;groupSumOpenBalance = (openEggStoreEggsReport + recEggsReport );&#xD;&#xA;&#xD;&#xA;// --- Declare values ---&#xD;&#xA;decimal deads = 0;&#xD;&#xA;decimal culls = 0;&#xD;&#xA;decimal destroyedEggs = 0;&#xD;&#xA;decimal unHatEggs = 0;&#xD;&#xA;decimal chicks = 0;&#xD;&#xA;&#xD;&#xA;// --- Deads ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Deads&quot;) != null)&#xD;&#xA;    deads = Convert.ToDecimal(GetCurrentColumnValue(&quot;Deads&quot;));&#xD;&#xA;&#xD;&#xA;// --- Culls ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;&#xD;&#xA;// --- DestroyedEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;DestroyedEggs&quot;) != null)&#xD;&#xA;    destroyedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DestroyedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- UnHatEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;UnHatEggs&quot;) != null)&#xD;&#xA;    unHatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;UnHatEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Chicks ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Chicks&quot;) != null)&#xD;&#xA;    chicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;Chicks&quot;));&#xD;&#xA;&#xD;&#xA;// --- Add to group sum ---&#xD;&#xA;deadsGroup += deads;&#xD;&#xA;cullsGroup += culls;&#xD;&#xA;destroyedEggsGroup += destroyedEggs;&#xD;&#xA;unHatEggsGroup += unHatEggs;&#xD;&#xA;chicksGroup += chicks;&#xD;&#xA;&#xD;&#xA;groupSumEggsAndChicks += (deadsGroup + cullsGroup + destroyedEggsGroup + unHatEggsGroup + chicksGroup );&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell77_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;          xrTableCell77.Text = groupSumOpenEggs.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell20_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;         xrTableCell20.Text = OpenMachineReport.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell58_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       // --- Declare values ---&#xD;&#xA;decimal closeSetterEggs = 0;&#xD;&#xA;decimal closeHatcherEggs = 0;&#xD;&#xA;&#xD;&#xA;// --- OpenSetterEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CloseSetterEggs&quot;) != null)&#xD;&#xA;    closeSetterEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;CloseSetterEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- OpenHatcherEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CloseHatcherEggs&quot;) != null)&#xD;&#xA;    closeHatcherEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;CloseHatcherEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Result (sum) ---&#xD;&#xA;decimal result = closeSetterEggs + closeHatcherEggs ;&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N0&quot;); // no decimals, adjust format if needed&#xD;&#xA;closeSetterEggsReport += closeSetterEggs ;&#xD;&#xA;closeHatcherEggsReport += closeHatcherEggs ;&#xD;&#xA;CloseMachineReport = closeSetterEggsReport  + closeHatcherEggsReport ;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell33_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal openEggStoreEggs = 0;&#xD;&#xA;decimal recEggs = 0;&#xD;&#xA;&#xD;&#xA;// --- OpenEggStoreEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;OpenEggStoreEggs&quot;) != null)&#xD;&#xA;    openEggStoreEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;OpenEggStoreEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- RecEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecEggs&quot;) != null)&#xD;&#xA;    recEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Result (sum) ---&#xD;&#xA;decimal result = openEggStoreEggs + recEggs;&#xD;&#xA;&#xD;&#xA;// --- Assign result to the cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N0&quot;); // no decimals, adjust format if needed&#xD;&#xA;openEggStoreEggsReport += openEggStoreEggs ;&#xD;&#xA;recEggsReport += recEggs ;&#xD;&#xA;OpenEggsReport = openEggStoreEggsReport + recEggsReport ;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell79_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;         xrTableCell79.Text = groupSumOpenBalance.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell22.Text = OpenEggsReport.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell49_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal deads = 0;&#xD;&#xA;decimal culls = 0;&#xD;&#xA;decimal destroyedEggs = 0;&#xD;&#xA;decimal unHatEggs = 0;&#xD;&#xA;decimal chicks = 0;&#xD;&#xA;decimal deadsTotalReport = 0;&#xD;&#xA;decimal cullsTotalReport = 0;&#xD;&#xA;decimal destroyedEggsTotalReport = 0;&#xD;&#xA;decimal unHatEggsTotalReport = 0;&#xD;&#xA;decimal chicksTotalReport = 0;&#xD;&#xA;&#xD;&#xA;// --- Deads ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Deads&quot;) != null)&#xD;&#xA;    deads = Convert.ToDecimal(GetCurrentColumnValue(&quot;Deads&quot;));&#xD;&#xA;&#xD;&#xA;// --- Culls ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;&#xD;&#xA;// --- DestroyedEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;DestroyedEggs&quot;) != null)&#xD;&#xA;    destroyedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;DestroyedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- UnHatEggs ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;UnHatEggs&quot;) != null)&#xD;&#xA;    unHatEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;UnHatEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Chicks ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Chicks&quot;) != null)&#xD;&#xA;    chicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;Chicks&quot;));&#xD;&#xA;&#xD;&#xA;// --- Result (sum) ---&#xD;&#xA;decimal result = deads + culls + destroyedEggs + unHatEggs + chicks;&#xD;&#xA;&#xD;&#xA;// --- Assign result to the cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0&quot;); // no decimals, adjust format if needed&#xD;&#xA;deadsTotalReport += deads;&#xD;&#xA;cullsTotalReport += culls;&#xD;&#xA;destroyedEggsTotalReport += destroyedEggs;&#xD;&#xA;unHatEggsTotalReport += unHatEggs;&#xD;&#xA;chicksTotalReport += chicks;&#xD;&#xA;TotalEggsAndChicksReport = deadsTotalReport  + cullsTotalReport  + destroyedEggsTotalReport  + unHatEggsTotalReport  + chicksTotalReport ;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell82_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell82.Text = groupSumEggsAndChicks.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell62_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell62.Text = TotalEggsAndChicksReport.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell91_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;          xrTableCell91.Text = groupSumCloseEggs.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell71_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;          xrTableCell71.Text = CloseMachineReport.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;" PageWidth="1169" PageHeight="1654" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="24.2" DataMember="SR_HT_RecAndSettedEggs" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
