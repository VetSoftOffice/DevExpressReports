<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_FlkSumProdReport" ScriptsSource="&#xD;&#xA;private void xrTableCell180_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    var femalesTrans = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemalesTrans&quot;));&#xD;&#xA;    var femalesDepleted = Convert.ToDecimal(GetCurrentColumnValue(&quot;FemalesDepleted&quot;));&#xD;&#xA;&#xD;&#xA;    if (femalesTrans != 0)&#xD;&#xA;        ((XRTableCell)sender).Text = ((femalesDepleted / femalesTrans) * 100).ToString(&quot;N2&quot;);&#xD;&#xA;    else&#xD;&#xA;        ((XRTableCell)sender).Text = &quot;0&quot;;&#xD;&#xA;}&#xD;&#xA;" PageWidth="1169" PageHeight="1654" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="24.2" DataMember="SR_HT_FlkSumProdReport" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
