}&#xD;&#xA;    &#xD;&#xA;    // --- STEP 1: Calculate RejBroken_1 from HT_RejBroken_1 and ST_RejBroken_1 ---&#xD;&#xA;    decimal htRejBroken_1 = 0;&#xD;&#xA;    object valHtBroken = GetCurrentColumnValue(&quot;HT_RejBroken_1&quot;);&#xD;&#xA;    if (valHtBroken != null &amp;&amp; !string.IsNullOrEmpty(valHtBroken.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valHtBroken.ToString(), out decimal tempHtBroken))&#xD;&#xA;            htRejBroken_1 = tempHtBroken;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal stRejBroken_1 = 0;&#xD;&#xA;    object valStBroken = GetCurrentColumnValue(&quot;ST_RejBroken_1&quot;);&#xD;&#xA;    if (valStBroken != null &amp;&amp; !string.IsNullOrEmpty(valStBroken.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valStBroken.ToString(), out decimal tempStBroken))&#xD;&#xA;            stRejBroken_1 = tempStBroken;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal rejBroken_1 = htRejBroken_1 + stRejBroken_1;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 2: Calculate RejCrack_1 from HT_RejCracks_1 and ST_RejCracks_1 ---&#xD;&#xA;    decimal htRejCracks_1 = 0;&#xD;&#xA;    object valHtCracks = GetCurrentColumnValue(&quot;HT_RejCracks_1&quot;);&#xD;&#xA;    if (valHtCracks != null &amp;&amp; !string.IsNullOrEmpty(valHtCracks.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valHtCracks.ToString(), out decimal tempHtCracks))&#xD;&#xA;            htRejCracks_1 = tempHtCracks;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal stRejCracks_1 = 0;&#xD;&#xA;    object valStCracks = GetCurrentColumnValue(&quot;ST_RejCracks_1&quot;);&#xD;&#xA;    if (valStCracks != null &amp;&amp; !string.IsNullOrEmpty(valStCracks.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valStCracks.ToString(), out decimal tempStCracks))&#xD;&#xA;            stRejCracks_1 = tempStCracks;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal rejCrack_1 = htRejCracks_1 + stRejCracks_1;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 3: Calculate RejDef_1 from HT_RejDeformed_1 and ST_RejDeformed_1 ---&#xD;&#xA;    decimal htRejDeformed_1 = 0;&#xD;&#xA;    object valHtDeformed = GetCurrentColumnValue(&quot;HT_RejDeformed_1&quot;);&#xD;&#xA;    if (valHtDeformed != null &amp;&amp; !string.IsNullOrEmpty(valHtDeformed.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valHtDeformed.ToString(), out decimal tempHtDeformed))&#xD;&#xA;            htRejDeformed_1 = tempHtDeformed;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal stRejDeformed_1 = 0;&#xD;&#xA;    object valStDeformed = GetCurrentColumnValue(&quot;ST_RejDeformed_1&quot;);&#xD;&#xA;    if (valStDeformed != null &amp;&amp; !string.IsNullOrEmpty(valStDeformed.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valStDeformed.ToString(), out decimal tempStDeformed))&#xD;&#xA;            stRejDeformed_1 = tempStDeformed;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal rejDef_1 = htRejDeformed_1 + stRejDeformed_1;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 4: Calculate RejOther_1 from HT_RejOther_1 and ST_RejOther_1 ---&#xD;&#xA;    decimal htRejOther_1 = 0;&#xD;&#xA;    object valHtOther = GetCurrentColumnValue(&quot;HT_RejOther_1&quot;);&#xD;&#xA;    if (valHtOther != null &amp;&amp; !string.IsNullOrEmpty(valHtOther.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valHtOther.ToString(), out decimal tempHtOther))&#xD;&#xA;            htRejOther_1 = tempHtOther;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal stRejOther_1 = 0;&#xD;&#xA;    object valStOther = GetCurrentColumnValue(&quot;ST_RejOther_1&quot;);&#xD;&#xA;    if (valStOther != null &amp;&amp; !string.IsNullOrEmpty(valStOther.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valStOther.ToString(), out decimal tempStOther))&#xD;&#xA;            stRejOther_1 = tempStOther;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal rejOther_1 = htRejOther_1 + stRejOther_1;&#xD;&#xA;    &#xD;&#xA;    // --- Calculate Total_RejEggs_1 ---&#xD;&#xA;    decimal totalRejEggs_1 = rejBroken_1 + rejCrack_1 + rejDef_1 + rejOther_1;&#xD;&#xA;    &#xD;&#xA;    // --- Equation: FarmInTake_1 - Total_RejEggs_1 ---&#xD;&#xA;    decimal result_1 = farmInTake_1 - totalRejEggs_1;&#xD;&#xA;    &#xD;&#xA;    // --- Assign result to cell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result_1.ToString(&quot;0.##&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell160_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;  // --- STEP 1: Read basic values ---&#xD;&#xA;    decimal farmInTake = 0;&#xD;&#xA;    object valFarm = GetCurrentColumnValue(&quot;FarmInTake&quot;);&#xD;&#xA;    if (valFarm != null &amp;&amp; !string.IsNullOrEmpty(valFarm.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valFarm.ToString(), out decimal tempFarm))&#xD;&#xA;            farmInTake = tempFarm;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal settedEggs = 0;&#xD;&#xA;    object valSetted = GetCurrentColumnValue(&quot;SettedEggs&quot;);&#xD;&#xA;    if (valSetted != null &amp;&amp; !string.IsNullOrEmpty(valSetted.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valSetted.ToString(), out decimal tempSetted))&#xD;&#xA;            settedEggs = tempSetted;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal settedEggs_1 = 0;&#xD;&#xA;    object valSetted1 = GetCurrentColumnValue(&quot;SettedEggs_1&quot;);&#xD;&#xA;    if (valSetted1 != null &amp;&amp; !string.IsNullOrEmpty(valSetted1.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valSetted1.ToString(), out decimal tempSetted1))&#xD;&#xA;            settedEggs_1 = tempSetted1;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- STEP 2: Calculate Total_RejEggs ---&#xD;&#xA;    decimal htRejBroken = 0, stRejBroken = 0;&#xD;&#xA;    object valHtBroken = GetCurrentColumnValue(&quot;HT_RejBroken&quot;);&#xD;&#xA;    if (valHtBroken != null &amp;&amp; !string.IsNullOrEmpty(valHtBroken.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valHtBroken.ToString(), out decimal tempHtBroken))&#xD;&#xA;            htRejBroken = tempHtBroken;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    object valStBroken = GetCurrentColumnValue(&quot;ST_RejBroken&quot;);&#xD;&#xA;    if (valStBroken != null &amp;&amp; !string.IsNullOrEmpty(valStBroken.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valStBroken.ToString(), out decimal tempStBroken))&#xD;&#xA;            stRejBroken = tempStBroken;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal htRejCracks = 0, stRejCracks = 0;&#xD;&#xA;    object valHtCracks = GetCurrentColumnValue(&quot;HT_RejCracks&quot;);&#xD;&#xA;    if (valHtCracks != null &amp;&amp; !string.IsNullOrEmpty(valHtCracks.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valHtCracks.ToString(), out decimal tempHtCracks))&#xD;&#xA;            htRejCracks = tempHtCracks;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    object valStCracks = GetCurrentColumnValue(&quot;ST_RejCracks&quot;);&#xD;&#xA;    if (valStCracks != null &amp;&amp; !string.IsNullOrEmpty(valStCracks.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valStCracks.ToString(), out decimal tempStCracks))&#xD;&#xA;            stRejCracks = tempStCracks;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal htRejDeformed = 0, stRejDeformed = 0;&#xD;&#xA;    object valHtDeformed = GetCurrentColumnValue(&quot;HT_RejDeformed&quot;);&#xD;&#xA;    if (valHtDeformed != null &amp;&amp; !string.IsNullOrEmpty(valHtDeformed.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valHtDeformed.ToString(), out decimal tempHtDeformed))&#xD;&#xA;            htRejDeformed = tempHtDeformed;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    object valStDeformed = GetCurrentColumnValue(&quot;ST_RejDeformed&quot;);&#xD;&#xA;    if (valStDeformed != null &amp;&amp; !string.IsNullOrEmpty(valStDeformed.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valStDeformed.ToString(), out decimal tempStDeformed))&#xD;&#xA;            stRejDeformed = tempStDeformed;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal htRejOther = 0, stRejOther = 0;&#xD;&#xA;    object valHtOther = GetCurrentColumnValue(&quot;HT_RejOther&quot;);&#xD;&#xA;    if (valHtOther != null &amp;&amp; !string.IsNullOrEmpty(valHtOther.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valHtOther.ToString(), out decimal tempHtOther))&#xD;&#xA;            htRejOther = tempHtOther;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    object valStOther = GetCurrentColumnValue(&quot;ST_RejOther&quot;);&#xD;&#xA;    if (valStOther != null &amp;&amp; !string.IsNullOrEmpty(valStOther.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valStOther.ToString(), out decimal tempStOther))&#xD;&#xA;            stRejOther = tempStOther;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal rejBroken = htRejBroken + stRejBroken;&#xD;&#xA;    decimal rejCrack = htRejCracks + stRejCracks;&#xD;&#xA;    decimal rejDef = htRejDeformed + stRejDeformed;&#xD;&#xA;    decimal rejOther = htRejOther + stRejOther;&#xD;&#xA;    decimal totalRejEggs = rejBroken + rejCrack + rejDef + rejOther;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 3: Calculate BalOfHatEggs ---&#xD;&#xA;    decimal balOfHatEggs = farmInTake - totalRejEggs;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 4: Calculate TotalEggSold ---&#xD;&#xA;    decimal erSoldAsHatEggs = 0, esSoldAsHatEggs = 0;&#xD;&#xA;    object valErHat = GetCurrentColumnValue(&quot;ER_SoldAsHatEggs&quot;);&#xD;&#xA;    if (valErHat != null &amp;&amp; !string.IsNullOrEmpty(valErHat.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valErHat.ToString(), out decimal tempErHat))&#xD;&#xA;            erSoldAsHatEggs = tempErHat;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    object valEsHat = GetCurrentColumnValue(&quot;ES_SoldAsHatEggs&quot;);&#xD;&#xA;    if (valEsHat != null &amp;&amp; !string.IsNullOrEmpty(valEsHat.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valEsHat.ToString(), out decimal tempEsHat))&#xD;&#xA;            esSoldAsHatEggs = tempEsHat;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal erSoldAsTableEggs = 0, esSoldAsTableEggs = 0;&#xD;&#xA;    object valErTable = GetCurrentColumnValue(&quot;ER_SoldAsTableEggs&quot;);&#xD;&#xA;    if (valErTable != null &amp;&amp; !string.IsNullOrEmpty(valErTable.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valErTable.ToString(), out decimal tempErTable))&#xD;&#xA;            erSoldAsTableEggs = tempErTable;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    object valEsTable = GetCurrentColumnValue(&quot;ES_SoldAsTableEggs&quot;);&#xD;&#xA;    if (valEsTable != null &amp;&amp; !string.IsNullOrEmpty(valEsTable.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valEsTable.ToString(), out decimal tempEsTable))&#xD;&#xA;            esSoldAsTableEggs = tempEsTable;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal erSendToOffal = 0, esSendToOffal = 0;&#xD;&#xA;    object valErOffal = GetCurrentColumnValue(&quot;ER_SendToOffal&quot;);&#xD;&#xA;    if (valErOffal != null &amp;&amp; !string.IsNullOrEmpty(valErOffal.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valErOffal.ToString(), out decimal tempErOffal))&#xD;&#xA;            erSendToOffal = tempErOffal;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    object valEsOffal = GetCurrentColumnValue(&quot;ES_SendToOffal&quot;);&#xD;&#xA;    if (valEsOffal != null &amp;&amp; !string.IsNullOrEmpty(valEsOffal.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valEsOffal.ToString(), out decimal tempEsOffal))&#xD;&#xA;            esSendToOffal = tempEsOffal;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal soldHatEggs = erSoldAsHatEggs + esSoldAsHatEggs;&#xD;&#xA;    decimal soldTableEggs = erSoldAsTableEggs + esSoldAsTableEggs;&#xD;&#xA;    decimal eggsToOffal = erSendToOffal + esSendToOffal;&#xD;&#xA;    decimal totalEggSold = soldHatEggs + soldTableEggs + eggsToOffal;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 5: Calculate StockHatEggBal ---&#xD;&#xA;    decimal stockHatEggBal = balOfHatEggs - (settedEggs + totalEggSold);&#xD;&#xA;    &#xD;&#xA;    // --- STEP 6: Calculate the difference ---&#xD;&#xA;    decimal difference = settedEggs_1 - stockHatEggBal;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 7: Apply condition ---&#xD;&#xA;    decimal result = 0;&#xD;&#xA;    if (difference &gt;= 0)&#xD;&#xA;    {&#xD;&#xA;        result = difference;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- Assign result to cell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell162_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- STEP 1: Read all basic values ---&#xD;&#xA;    decimal farmInTake = 0;&#xD;&#xA;    object valFarm = GetCurrentColumnValue(&quot;FarmInTake&quot;);&#xD;&#xA;    if (valFarm != null &amp;&amp; !string.IsNullOrEmpty(valFarm.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valFarm.ToString(), out decimal tempFarm))&#xD;&#xA;            farmInTake = tempFarm;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal settedEggs = 0;&#xD;&#xA;    object valSetted = GetCurrentColumnValue(&quot;SettedEggs&quot;);&#xD;&#xA;    if (valSetted != null &amp;&amp; !string.IsNullOrEmpty(valSetted.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valSetted.ToString(), out decimal tempSetted))&#xD;&#xA;            settedEggs = tempSetted;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal settedEggs_1 = 0;&#xD;&#xA;    object valSetted1 = GetCurrentColumnValue(&quot;SettedEggs_1&quot;);&#xD;&#xA;    if (valSetted1 != null &amp;&amp; !string.IsNullOrEmpty(valSetted1.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valSetted1.ToString(), out decimal tempSetted1))&#xD;&#xA;            settedEggs_1 = tempSetted1;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal selChicks_1 = 0;&#xD;&#xA;    object valSel1 = GetCurrentColumnValue(&quot;SelChicks_1&quot;);&#xD;&#xA;    if (valSel1 != null &amp;&amp; !string.IsNullOrEmpty(valSel1.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valSel1.ToString(), out decimal tempSel1))&#xD;&#xA;            selChicks_1 = tempSel1;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal cullsChicks_1 = 0;&#xD;&#xA;    object valCulls1 = GetCurrentColumnValue(&quot;CullsChicks_1&quot;);&#xD;&#xA;    if (valCulls1 != null &amp;&amp; !string.IsNullOrEmpty(valCulls1.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valCulls1.ToString(), out decimal tempCulls1))&#xD;&#xA;            cullsChicks_1 = tempCulls1;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal deadChicks_1 = 0;&#xD;&#xA;    object valDead1 = GetCurrentColumnValue(&quot;DeadChicks_1&quot;);&#xD;&#xA;    if (valDead1 != null &amp;&amp; !string.IsNullOrEmpty(valDead1.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valDead1.ToString(), out decimal tempDead1))&#xD;&#xA;            deadChicks_1 = tempDead1;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- STEP 2: Calculate Total_RejEggs ---&#xD;&#xA;    decimal GetFieldValue(string fieldName)&#xD;&#xA;    {&#xD;&#xA;        object value = GetCurrentColumnValue(fieldName);&#xD;&#xA;        if (value != null &amp;&amp; !string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        {&#xD;&#xA;            if (decimal.TryParse(value.ToString(), out decimal result))&#xD;&#xA;                return result;&#xD;&#xA;        }&#xD;&#xA;        return 0;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal rejBroken = GetFieldValue(&quot;HT_RejBroken&quot;) + GetFieldValue(&quot;ST_RejBroken&quot;);&#xD;&#xA;    decimal rejCrack = GetFieldValue(&quot;HT_RejCracks&quot;) + GetFieldValue(&quot;ST_RejCracks&quot;);&#xD;&#xA;    decimal rejDef = GetFieldValue(&quot;HT_RejDeformed&quot;) + GetFieldValue(&quot;ST_RejDeformed&quot;);&#xD;&#xA;    decimal rejOther = GetFieldValue(&quot;HT_RejOther&quot;) + GetFieldValue(&quot;ST_RejOther&quot;);&#xD;&#xA;    decimal totalRejEggs = rejBroken + rejCrack + rejDef + rejOther;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 3: Calculate BalOfHatEggs ---&#xD;&#xA;    decimal balOfHatEggs = farmInTake - totalRejEggs;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 4: Calculate TotalEggSold ---&#xD;&#xA;    decimal erSoldAsHatEggs = GetFieldValue(&quot;ER_SoldAsHatEggs&quot;);&#xD;&#xA;    decimal esSoldAsHatEggs = GetFieldValue(&quot;ES_SoldAsHatEggs&quot;);&#xD;&#xA;    decimal erSoldAsTableEggs = GetFieldValue(&quot;ER_SoldAsTableEggs&quot;);&#xD;&#xA;    decimal esSoldAsTableEggs = GetFieldValue(&quot;ES_SoldAsTableEggs&quot;);&#xD;&#xA;    decimal erSendToOffal = GetFieldValue(&quot;ER_SendToOffal&quot;);&#xD;&#xA;    decimal esSendToOffal = GetFieldValue(&quot;ES_SendToOffal&quot;);&#xD;&#xA;    &#xD;&#xA;    decimal soldHatEggs = erSoldAsHatEggs + esSoldAsHatEggs;&#xD;&#xA;    decimal soldTableEggs = erSoldAsTableEggs + esSoldAsTableEggs;&#xD;&#xA;    decimal eggsToOffal = erSendToOffal + esSendToOffal;&#xD;&#xA;    decimal totalEggSold = soldHatEggs + soldTableEggs + eggsToOffal;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 5: Calculate StockHatEggBal ---&#xD;&#xA;    decimal stockHatEggBal = balOfHatEggs - (settedEggs + totalEggSold);&#xD;&#xA;    &#xD;&#xA;    // --- STEP 6: Calculate SettedEggs_1 (with condition) ---&#xD;&#xA;    decimal settedEggs_1_Calculated = 0;&#xD;&#xA;    decimal difference = settedEggs_1 - stockHatEggBal;&#xD;&#xA;    if (difference &gt;= 0)&#xD;&#xA;    {&#xD;&#xA;        settedEggs_1_Calculated = difference;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- STEP 7: Calculate GradeA_1 ---&#xD;&#xA;    decimal gradeA_1 = 0;&#xD;&#xA;    if (settedEggs_1 != 0)&#xD;&#xA;    {&#xD;&#xA;        gradeA_1 = selChicks_1 * (settedEggs_1_Calculated / settedEggs_1);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- STEP 8: Calculate RejChicks_1 ---&#xD;&#xA;    decimal rejChicks_1 = 0;&#xD;&#xA;    if (settedEggs_1 != 0)&#xD;&#xA;    {&#xD;&#xA;        rejChicks_1 = (cullsChicks_1 + deadChicks_1) * (settedEggs_1_Calculated / settedEggs_1);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- STEP 9: Final Equation ---&#xD;&#xA;    decimal total_1 = gradeA_1 + rejChicks_1;&#xD;&#xA;    &#xD;&#xA;    // --- Assign result to cell ---&#xD;&#xA;    XRTableCell cell_1 = sender as XRTableCell;&#xD;&#xA;    cell_1.Text = total_1.ToString(&quot;N0&quot;);&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell166_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Helper function for safe parsing&#xD;&#xA;    decimal GetFieldValue(string fieldName)&#xD;&#xA;    {&#xD;&#xA;        object value = GetCurrentColumnValue(fieldName);&#xD;&#xA;        if (value != null &amp;&amp; !string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        {&#xD;&#xA;            if (decimal.TryParse(value.ToString(), out decimal result))&#xD;&#xA;                return result;&#xD;&#xA;        }&#xD;&#xA;        return 0;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- STEP 1: Read all basic values ---&#xD;&#xA;    decimal farmInTake = 0;&#xD;&#xA;    object valFarm = GetCurrentColumnValue(&quot;FarmInTake&quot;);&#xD;&#xA;    if (valFarm != null &amp;&amp; !string.IsNullOrEmpty(valFarm.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valFarm.ToString(), out decimal tempFarm))&#xD;&#xA;            farmInTake = tempFarm;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal settedEggs = 0;&#xD;&#xA;    object valSetted = GetCurrentColumnValue(&quot;SettedEggs&quot;);&#xD;&#xA;    if (valSetted != null &amp;&amp; !string.IsNullOrEmpty(valSetted.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valSetted.ToString(), out decimal tempSetted))&#xD;&#xA;            settedEggs = tempSetted;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal settedEggs_1 =