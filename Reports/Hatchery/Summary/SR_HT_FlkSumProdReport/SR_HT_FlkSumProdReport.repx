alculate RejDef_1 from HT_RejDeformed and ST_RejDeformed ---&#xD;&#xA;    decimal htRejDeformed_1 = 0;&#xD;&#xA;    object valHtDeformed = GetCurrentColumnValue(&quot;HT_RejDeformed_1&quot;);&#xD;&#xA;    if (valHtDeformed != null &amp;&amp; !string.IsNullOrEmpty(valHtDeformed.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valHtDeformed.ToString(), out decimal tempHtDeformed))&#xD;&#xA;            htRejDeformed_1 = tempHtDeformed;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal stRejDeformed_1 = 0;&#xD;&#xA;    object valStDeformed = GetCurrentColumnValue(&quot;ST_RejDeformed_1&quot;);&#xD;&#xA;    if (valStDeformed != null &amp;&amp; !string.IsNullOrEmpty(valStDeformed.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valStDeformed.ToString(), out decimal tempStDeformed))&#xD;&#xA;            stRejDeformed_1 = tempStDeformed;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    rejDef_1 = htRejDeformed_1 + stRejDeformed_1;&#xD;&#xA;&#xD;&#xA;    // --- STEP 4: Calculate RejOther_1 from HT_RejOther and ST_RejOther ---&#xD;&#xA;    decimal htRejOther_1 = 0;&#xD;&#xA;    object valHtOther = GetCurrentColumnValue(&quot;HT_RejOther_1&quot;);&#xD;&#xA;    if (valHtOther != null &amp;&amp; !string.IsNullOrEmpty(valHtOther.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valHtOther.ToString(), out decimal tempHtOther))&#xD;&#xA;            htRejOther_1 = tempHtOther;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal stRejOther_1 = 0;&#xD;&#xA;    object valStOther = GetCurrentColumnValue(&quot;ST_RejOther_1&quot;);&#xD;&#xA;    if (valStOther != null &amp;&amp; !string.IsNullOrEmpty(valStOther.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valStOther.ToString(), out decimal tempStOther))&#xD;&#xA;            stRejOther_1 = tempStOther;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    rejOther_1 = htRejOther_1 + stRejOther_1;&#xD;&#xA;&#xD;&#xA;    // --- Equation ---&#xD;&#xA;    decimal result = rejBroken_1 + rejCrack_1 + rejDef_1 + rejOther_1;&#xD;&#xA;&#xD;&#xA;    // --- Assign result to cell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell164_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal result = 0;&#xD;&#xA;    &#xD;&#xA;    // --- Read SettedEggs_1 ---&#xD;&#xA;    decimal settedEggs_1 = 0;&#xD;&#xA;    object valSetted1 = GetCurrentColumnValue(&quot;SettedEggs_1&quot;);&#xD;&#xA;    if (valSetted1 != null &amp;&amp; !string.IsNullOrEmpty(valSetted1.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valSetted1.ToString(), out decimal tempSetted1))&#xD;&#xA;            settedEggs_1 = tempSetted1;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- Main condition: if SettedEggs_1 &lt;&gt; 0 ---&#xD;&#xA;    if (settedEggs_1 != 0)&#xD;&#xA;    {&#xD;&#xA;        // --- Read values for first calculation ---&#xD;&#xA;        decimal selChicks_1 = 0;&#xD;&#xA;        object valSel1 = GetCurrentColumnValue(&quot;SelChicks_1&quot;);&#xD;&#xA;        if (valSel1 != null &amp;&amp; !string.IsNullOrEmpty(valSel1.ToString()))&#xD;&#xA;        {&#xD;&#xA;            if (decimal.TryParse(valSel1.ToString(), out decimal tempSel1))&#xD;&#xA;                selChicks_1 = tempSel1;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        decimal cullsChicks_1 = 0;&#xD;&#xA;        object valCulls1 = GetCurrentColumnValue(&quot;CullsChicks_1&quot;);&#xD;&#xA;        if (valCulls1 != null &amp;&amp; !string.IsNullOrEmpty(valCulls1.ToString()))&#xD;&#xA;        {&#xD;&#xA;            if (decimal.TryParse(valCulls1.ToString(), out decimal tempCulls1))&#xD;&#xA;                cullsChicks_1 = tempCulls1;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        decimal deadChicks_1 = 0;&#xD;&#xA;        object valDead1 = GetCurrentColumnValue(&quot;DeadChicks_1&quot;);&#xD;&#xA;        if (valDead1 != null &amp;&amp; !string.IsNullOrEmpty(valDead1.ToString()))&#xD;&#xA;        {&#xD;&#xA;            if (decimal.TryParse(valDead1.ToString(), out decimal tempDead1))&#xD;&#xA;                deadChicks_1 = tempDead1;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // Calculate: (SelChicks_1 + CullsChicks_1 + DeadChicks_1) * 100 / SettedEggs_1&#xD;&#xA;        decimal totalChicks_1 = selChicks_1 + cullsChicks_1 + deadChicks_1;&#xD;&#xA;        result = totalChicks_1 * 100 / settedEggs_1;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        // --- Read values for ActHatchBalanceEggs calculation ---&#xD;&#xA;        decimal setEggBalHatEgg = 0;&#xD;&#xA;        object valSetEgg = GetCurrentColumnValue(&quot;SetEggBalHatEgg&quot;);&#xD;&#xA;        if (valSetEgg != null &amp;&amp; !string.IsNullOrEmpty(valSetEgg.ToString()))&#xD;&#xA;        {&#xD;&#xA;            if (decimal.TryParse(valSetEgg.ToString(), out decimal tempSetEgg))&#xD;&#xA;                setEggBalHatEgg = tempSetEgg;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        // Calculate ActHatchBalanceEggs: if SetEggBalHatEgg &lt;&gt; 0&#xD;&#xA;        decimal actHatchBalanceEggs = 0;&#xD;&#xA;        if (setEggBalHatEgg != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal selChickBal = 0;&#xD;&#xA;            object valSelBal = GetCurrentColumnValue(&quot;SelChickBalHatEgg&quot;);&#xD;&#xA;            if (valSelBal != null &amp;&amp; !string.IsNullOrEmpty(valSelBal.ToString()))&#xD;&#xA;            {&#xD;&#xA;                if (decimal.TryParse(valSelBal.ToString(), out decimal tempSelBal))&#xD;&#xA;                    selChickBal = tempSelBal;&#xD;&#xA;            }&#xD;&#xA;            &#xD;&#xA;            decimal cullsBal = 0;&#xD;&#xA;            object valCullsBal = GetCurrentColumnValue(&quot;CullsBalHatEgg&quot;);&#xD;&#xA;            if (valCullsBal != null &amp;&amp; !string.IsNullOrEmpty(valCullsBal.ToString()))&#xD;&#xA;            {&#xD;&#xA;                if (decimal.TryParse(valCullsBal.ToString(), out decimal tempCullsBal))&#xD;&#xA;                    cullsBal = tempCullsBal;&#xD;&#xA;            }&#xD;&#xA;            &#xD;&#xA;            decimal deadsBal = 0;&#xD;&#xA;            object valDeadsBal = GetCurrentColumnValue(&quot;DeadsBalHatEgg&quot;);&#xD;&#xA;            if (valDeadsBal != null &amp;&amp; !string.IsNullOrEmpty(valDeadsBal.ToString()))&#xD;&#xA;            {&#xD;&#xA;                if (decimal.TryParse(valDeadsBal.ToString(), out decimal tempDeadsBal))&#xD;&#xA;                    deadsBal = tempDeadsBal;&#xD;&#xA;            }&#xD;&#xA;            &#xD;&#xA;            decimal totalBal = selChickBal + cullsBal + deadsBal;&#xD;&#xA;            actHatchBalanceEggs = totalBal / setEggBalHatEgg * 100;&#xD;&#xA;        }&#xD;&#xA;        &#xD;&#xA;        result = actHatchBalanceEggs;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- Assign result to cell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;0.##&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell168_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // Helper function for safe parsing&#xD;&#xA;    decimal GetFieldValue(string fieldName)&#xD;&#xA;    {&#xD;&#xA;        object value = GetCurrentColumnValue(fieldName);&#xD;&#xA;        if (value != null &amp;&amp; !string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        {&#xD;&#xA;            if (decimal.TryParse(value.ToString(), out decimal result))&#xD;&#xA;                return result;&#xD;&#xA;        }&#xD;&#xA;        return 0;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- STEP 1: Read all basic values ---&#xD;&#xA;    decimal farmInTake = GetFieldValue(&quot;FarmInTake&quot;);&#xD;&#xA;    decimal settedEggs = GetFieldValue(&quot;SettedEggs&quot;);&#xD;&#xA;    decimal settedEggs_1 = GetFieldValue(&quot;SettedEggs_1&quot;);&#xD;&#xA;    decimal selChicks_1 = GetFieldValue(&quot;SelChicks_1&quot;);&#xD;&#xA;    &#xD;&#xA;    // --- STEP 2: Calculate Total_RejEggs ---&#xD;&#xA;    decimal rejBroken = GetFieldValue(&quot;HT_RejBroken&quot;) + GetFieldValue(&quot;ST_RejBroken&quot;);&#xD;&#xA;    decimal rejCrack = GetFieldValue(&quot;HT_RejCracks&quot;) + GetFieldValue(&quot;ST_RejCracks&quot;);&#xD;&#xA;    decimal rejDef = GetFieldValue(&quot;HT_RejDeformed&quot;) + GetFieldValue(&quot;ST_RejDeformed&quot;);&#xD;&#xA;    decimal rejOther = GetFieldValue(&quot;HT_RejOther&quot;) + GetFieldValue(&quot;ST_RejOther&quot;);&#xD;&#xA;    decimal totalRejEggs = rejBroken + rejCrack + rejDef + rejOther;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 3: Calculate BalOfHatEggs ---&#xD;&#xA;    decimal balOfHatEggs = farmInTake - totalRejEggs;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 4: Calculate TotalEggSold ---&#xD;&#xA;    decimal erSoldAsHatEggs = GetFieldValue(&quot;ER_SoldAsHatEggs&quot;);&#xD;&#xA;    decimal esSoldAsHatEggs = GetFieldValue(&quot;ES_SoldAsHatEggs&quot;);&#xD;&#xA;    decimal erSoldAsTableEggs = GetFieldValue(&quot;ER_SoldAsTableEggs&quot;);&#xD;&#xA;    decimal esSoldAsTableEggs = GetFieldValue(&quot;ES_SoldAsTableEggs&quot;);&#xD;&#xA;    decimal erSendToOffal = GetFieldValue(&quot;ER_SendToOffal&quot;);&#xD;&#xA;    decimal esSendToOffal = GetFieldValue(&quot;ES_SendToOffal&quot;);&#xD;&#xA;    &#xD;&#xA;    decimal soldHatEggs = erSoldAsHatEggs + esSoldAsHatEggs;&#xD;&#xA;    decimal soldTableEggs = erSoldAsTableEggs + esSoldAsTableEggs;&#xD;&#xA;    decimal eggsToOffal = erSendToOffal + esSendToOffal;&#xD;&#xA;    decimal totalEggSold = soldHatEggs + soldTableEggs + eggsToOffal;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 5: Calculate StockHatEggBal ---&#xD;&#xA;    decimal stockHatEggBal = balOfHatEggs - (settedEggs + totalEggSold);&#xD;&#xA;    &#xD;&#xA;    // --- STEP 6: Calculate SettedEggs_1 (with condition) ---&#xD;&#xA;    decimal settedEggs_1_Calculated = 0;&#xD;&#xA;    decimal difference = settedEggs_1 - stockHatEggBal;&#xD;&#xA;    if (difference &gt;= 0)&#xD;&#xA;    {&#xD;&#xA;        settedEggs_1_Calculated = difference;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- STEP 7: Main Equation ---&#xD;&#xA;    decimal result = 0;&#xD;&#xA;    if (settedEggs_1 != 0)&#xD;&#xA;    {&#xD;&#xA;        decimal ratio = settedEggs_1_Calculated / settedEggs_1;&#xD;&#xA;        result = selChicks_1 * ratio;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- Assign result to cell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;0.##&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell204_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Helper function for safe parsing&#xD;&#xA;decimal GetFieldValue(string fieldName)&#xD;&#xA;{&#xD;&#xA;    object value = GetCurrentColumnValue(fieldName);&#xD;&#xA;    if (value != null &amp;&amp; !string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(value.ToString(), out decimal result))&#xD;&#xA;            return result;&#xD;&#xA;    }&#xD;&#xA;    return 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Calculate individual rejection components for Part 2 ---&#xD;&#xA;decimal rejBroken_1 = GetFieldValue(&quot;ST_RejBroken_1&quot;) + GetFieldValue(&quot;HT_RejBroken_1&quot;);&#xD;&#xA;decimal rejCrack_1 = GetFieldValue(&quot;ST_RejCracks_1&quot;) + GetFieldValue(&quot;HT_RejCracks_1&quot;);&#xD;&#xA;decimal rejDef_1 = GetFieldValue(&quot;HT_RejDeformed_1&quot;) + GetFieldValue(&quot;ST_RejDeformed_1&quot;);&#xD;&#xA;decimal rejOther_1 = GetFieldValue(&quot;ST_RejOther_1&quot;) + GetFieldValue(&quot;HT_RejOther_1&quot;);&#xD;&#xA;&#xD;&#xA;// --- Calculate Total_RejEggs_1 ---&#xD;&#xA;decimal totalRejEggs_1 = rejBroken_1 + rejCrack_1 + rejDef_1 + rejOther_1;&#xD;&#xA;&#xD;&#xA;// --- Get POL value ---&#xD;&#xA;decimal pol = GetFieldValue(&quot;POL&quot;);&#xD;&#xA;&#xD;&#xA;// --- Calculate the rejection rate ---&#xD;&#xA;decimal rejectionRate = 0;&#xD;&#xA;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    rejectionRate = totalRejEggs_1 / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Format the result - choose one of these options:&#xD;&#xA;&#xD;&#xA;// Option 1: Simple decimal (e.g., 0.1234)&#xD;&#xA;cell.Text = rejectionRate.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell207_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Helper function for safe parsing&#xD;&#xA;decimal GetFieldValue(string fieldName)&#xD;&#xA;{&#xD;&#xA;    object value = GetCurrentColumnValue(fieldName);&#xD;&#xA;    if (value != null &amp;&amp; !string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(value.ToString(), out decimal result))&#xD;&#xA;            return result;&#xD;&#xA;    }&#xD;&#xA;    return 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Calculate individual rejection components for Part 2 ---&#xD;&#xA;decimal rejBroken_1 = GetFieldValue(&quot;ST_RejBroken_1&quot;) + GetFieldValue(&quot;HT_RejBroken_1&quot;);&#xD;&#xA;decimal rejCrack_1 = GetFieldValue(&quot;ST_RejCracks_1&quot;) + GetFieldValue(&quot;HT_RejCracks_1&quot;);&#xD;&#xA;decimal rejDef_1 = GetFieldValue(&quot;HT_RejDeformed_1&quot;) + GetFieldValue(&quot;ST_RejDeformed_1&quot;);&#xD;&#xA;decimal rejOther_1 = GetFieldValue(&quot;ST_RejOther_1&quot;) + GetFieldValue(&quot;HT_RejOther_1&quot;);&#xD;&#xA;&#xD;&#xA;// --- Calculate Total_RejEggs_1 ---&#xD;&#xA;decimal totalRejEggs_1 = rejBroken_1 + rejCrack_1 + rejDef_1 + rejOther_1;&#xD;&#xA;&#xD;&#xA;// --- Calculate BalOfHatEggs_1 ---&#xD;&#xA;decimal farmInTake_1 = GetFieldValue(&quot;FarmInTake_1&quot;);&#xD;&#xA;decimal balOfHatEggs_1 = farmInTake_1 - totalRejEggs_1;&#xD;&#xA;&#xD;&#xA;// --- Get POL value ---&#xD;&#xA;decimal pol = GetFieldValue(&quot;POL&quot;);&#xD;&#xA;&#xD;&#xA;// --- Calculate the ratio ---&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    result = balOfHatEggs_1 / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Format options:&#xD;&#xA;&#xD;&#xA;// Option 1: Decimal ratio (e.g., 0.8765)&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell213_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Helper function for safe parsing&#xD;&#xA;decimal GetFieldValue(string fieldName)&#xD;&#xA;{&#xD;&#xA;    object value = GetCurrentColumnValue(fieldName);&#xD;&#xA;    if (value != null &amp;&amp; !string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(value.ToString(), out decimal result))&#xD;&#xA;            return result;&#xD;&#xA;    }&#xD;&#xA;    return 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- STEP 1: Calculate Part 1 components (for StockHatEggBal) ---&#xD;&#xA;&#xD;&#xA;// Calculate rejection components for Part 1&#xD;&#xA;decimal rejBroken = GetFieldValue(&quot;ST_RejBroken&quot;) + GetFieldValue(&quot;HT_RejBroken&quot;);&#xD;&#xA;decimal rejCrack = GetFieldValue(&quot;ST_RejCracks&quot;) + GetFieldValue(&quot;HT_RejCracks&quot;);&#xD;&#xA;decimal rejDef = GetFieldValue(&quot;HT_RejDeformed&quot;) + GetFieldValue(&quot;ST_RejDeformed&quot;);&#xD;&#xA;decimal rejOther = GetFieldValue(&quot;ST_RejOther&quot;) + GetFieldValue(&quot;HT_RejOther&quot;);&#xD;&#xA;decimal totalRejEggs = rejBroken + rejCrack + rejDef + rejOther;&#xD;&#xA;&#xD;&#xA;// Calculate BalOfHatEggs for Part 1&#xD;&#xA;decimal farmInTake = GetFieldValue(&quot;FarmInTake&quot;);&#xD;&#xA;decimal balOfHatEggs = farmInTake - totalRejEggs;&#xD;&#xA;&#xD;&#xA;// Calculate TotalEggSold for Part 1&#xD;&#xA;decimal soldHatEggs = GetFieldValue(&quot;ER_SoldAsHatEggs&quot;) + GetFieldValue(&quot;ES_SoldAsHatEggs&quot;);&#xD;&#xA;decimal soldTableEggs = GetFieldValue(&q