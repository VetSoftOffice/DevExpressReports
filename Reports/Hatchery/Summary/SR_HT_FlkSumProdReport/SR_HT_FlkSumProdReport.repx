 SafeConvert(GetCurrentColumnValue(&quot;ST_RejDeformed_1&quot;));&#xD;&#xA;decimal stRejOther_1 = SafeConvert(GetCurrentColumnValue(&quot;ST_RejOther_1&quot;));&#xD;&#xA;decimal htRejOther_1 = SafeConvert(GetCurrentColumnValue(&quot;HT_RejOther_1&quot;));&#xD;&#xA;decimal erSoldAsHatEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;ER_SoldAsHatEggs_1&quot;));&#xD;&#xA;decimal esSoldAsHatEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;ES_SoldAsHatEggs_1&quot;));&#xD;&#xA;decimal erSoldAsTableEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;ER_SoldAsTableEggs_1&quot;));&#xD;&#xA;decimal esSoldAsTableEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;ES_SoldAsTableEggs_1&quot;));&#xD;&#xA;decimal erSendToOffal_1 = SafeConvert(GetCurrentColumnValue(&quot;ER_SendToOffal_1&quot;));&#xD;&#xA;decimal esSendToOffal_1 = SafeConvert(GetCurrentColumnValue(&quot;ES_SendToOffal_1&quot;));&#xD;&#xA;decimal settledEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;SettedEggs_1&quot;));&#xD;&#xA;decimal selChicks_1 = SafeConvert(GetCurrentColumnValue(&quot;SelChicks_1&quot;));&#xD;&#xA;decimal cullsChicks_1 = SafeConvert(GetCurrentColumnValue(&quot;CullsChicks_1&quot;));&#xD;&#xA;decimal deadChicks_1 = SafeConvert(GetCurrentColumnValue(&quot;DeadChicks_1&quot;));&#xD;&#xA;decimal setEggBalHatEgg_1 = SafeConvert(GetCurrentColumnValue(&quot;SetEggBalHatEgg_1&quot;));&#xD;&#xA;decimal selChickBalHatEgg_1 = SafeConvert(GetCurrentColumnValue(&quot;SelChickBalHatEgg_1&quot;));&#xD;&#xA;decimal cullsBalHatEgg_1 = SafeConvert(GetCurrentColumnValue(&quot;CullsBalHatEgg_1&quot;));&#xD;&#xA;decimal deadsBalHatEgg_1 = SafeConvert(GetCurrentColumnValue(&quot;DeadsBalHatEgg_1&quot;));&#xD;&#xA;&#xD;&#xA;// ==================== Set 1 Calculations ====================&#xD;&#xA;&#xD;&#xA;// @RejBroken, @RejCrack, @RejDef, @RejOther&#xD;&#xA;decimal rejBroken = stRejBroken + htRejBroken;&#xD;&#xA;decimal rejCrack = stRejCracks + htRejCracks;&#xD;&#xA;decimal rejDef = htRejDeformed + stRejDeformed;&#xD;&#xA;decimal rejOther = stRejOther + htRejOther;&#xD;&#xA;&#xD;&#xA;// @Total_RejEggs&#xD;&#xA;decimal totalRejEggs = rejBroken + rejCrack + rejDef + rejOther;&#xD;&#xA;&#xD;&#xA;// @BalOfHatEggs&#xD;&#xA;decimal balOfHatEggs = farmInTake - totalRejEggs;&#xD;&#xA;&#xD;&#xA;// @SoldHatEggs, @SoldTableEggs, @EggsToOffal&#xD;&#xA;decimal soldHatEggs = erSoldAsHatEggs + esSoldAsHatEggs;&#xD;&#xA;decimal soldTableEggs = erSoldAsTableEggs + esSoldAsTableEggs;&#xD;&#xA;decimal eggsToOffal = erSendToOffal + esSendToOffal;&#xD;&#xA;&#xD;&#xA;// @TotalEggSold&#xD;&#xA;decimal totalEggSold = soldHatEggs + soldTableEggs + eggsToOffal;&#xD;&#xA;&#xD;&#xA;// @StockHatEggBal&#xD;&#xA;decimal stockHatEggBal = balOfHatEggs - (settledEggs + totalEggSold);&#xD;&#xA;&#xD;&#xA;// @ActHatchBalanceEggs&#xD;&#xA;decimal actHatchBalanceEggs = 0;&#xD;&#xA;if (setEggBalHatEgg != 0)&#xD;&#xA;{&#xD;&#xA;    actHatchBalanceEggs = ((selChickBalHatEgg + cullsBalHatEgg + deadsBalHatEgg) / setEggBalHatEgg) * 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @ESTChicks_PerStock_HE&#xD;&#xA;decimal estChicksPerStock_HE = (stockHatEggBal * actHatchBalanceEggs) / 100.0m;&#xD;&#xA;&#xD;&#xA;// @CumHatchability&#xD;&#xA;decimal cumHatchability = 0;&#xD;&#xA;if (settledEggs != 0)&#xD;&#xA;{&#xD;&#xA;    cumHatchability = ((selChicks + cullsChicks + deadChicks) / settledEggs) * 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @EstChicks_PerEgg&#xD;&#xA;decimal estChicksPerEgg = 0;&#xD;&#xA;if (totalEggSold != 0)&#xD;&#xA;{&#xD;&#xA;    estChicksPerEgg = totalEggSold * cumHatchability / 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @CumChicks&#xD;&#xA;decimal cumChicks = selChicks + cullsChicks + deadChicks;&#xD;&#xA;&#xD;&#xA;// @CumChicks_Act_Est&#xD;&#xA;decimal cumChicks_Act_Est = estChicksPerEgg + estChicksPerStock_HE + cumChicks;&#xD;&#xA;&#xD;&#xA;// @CumChicks_ActEst_HH&#xD;&#xA;decimal cumChicks_ActEst_HH = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    cumChicks_ActEst_HH = cumChicks_Act_Est / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// ==================== Set 2 Calculations ====================&#xD;&#xA;&#xD;&#xA;// @RejBroken_1, @RejCrack_1, @RejDef_1, @RejOther_1&#xD;&#xA;decimal rejBroken_1 = stRejBroken_1 + htRejBroken_1;&#xD;&#xA;decimal rejCrack_1 = stRejCracks_1 + htRejCracks_1;&#xD;&#xA;decimal rejDef_1 = htRejDeformed_1 + stRejDeformed_1;&#xD;&#xA;decimal rejOther_1 = stRejOther_1 + htRejOther_1;&#xD;&#xA;&#xD;&#xA;// @Total_RejEggs_1&#xD;&#xA;decimal totalRejEggs_1 = rejBroken_1 + rejCrack_1 + rejDef_1 + rejOther_1;&#xD;&#xA;&#xD;&#xA;// @BalOfHatEggs_1&#xD;&#xA;decimal balOfHatEggs_1 = farmInTake_1 - totalRejEggs_1;&#xD;&#xA;&#xD;&#xA;// @SoldHatEggs_1, @SoldTableEggs_1, @EggsToOffal_1&#xD;&#xA;decimal soldHatEggs_1 = erSoldAsHatEggs_1 + esSoldAsHatEggs_1;&#xD;&#xA;decimal soldTableEggs_1 = erSoldAsTableEggs_1 + esSoldAsTableEggs_1;&#xD;&#xA;decimal eggsToOffal_1 = erSendToOffal_1 + esSendToOffal_1;&#xD;&#xA;&#xD;&#xA;// @TotalEggSold_1&#xD;&#xA;decimal totalEggSold_1 = soldHatEggs_1 + soldTableEggs_1 + eggsToOffal_1;&#xD;&#xA;&#xD;&#xA;// @StockHatEggBal_1&#xD;&#xA;decimal stockHatEggBal_1 = balOfHatEggs_1 - (settledEggs_1 + totalEggSold_1);&#xD;&#xA;&#xD;&#xA;// @ActHatchBalanceEggs_1&#xD;&#xA;decimal actHatchBalanceEggs_1 = 0;&#xD;&#xA;if (setEggBalHatEgg_1 != 0)&#xD;&#xA;{&#xD;&#xA;    actHatchBalanceEggs_1 = ((selChickBalHatEgg_1 + cullsBalHatEgg_1 + deadsBalHatEgg_1) / setEggBalHatEgg_1) * 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @CumHatchability_1&#xD;&#xA;decimal cumHatchability_1 = 0;&#xD;&#xA;if (settledEggs_1 != 0)&#xD;&#xA;{&#xD;&#xA;    cumHatchability_1 = ((selChicks_1 + cullsChicks_1 + deadChicks_1) * 100) / settledEggs_1;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cumHatchability_1 = actHatchBalanceEggs;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @SettedEggs_1&#xD;&#xA;decimal settedEggs_1 = 0;&#xD;&#xA;if (settledEggs_1 - stockHatEggBal &lt; 0)&#xD;&#xA;{&#xD;&#xA;    settedEggs_1 = 0;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    settedEggs_1 = settledEggs_1 - stockHatEggBal;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @GradeA_1&#xD;&#xA;decimal gradeA_1 = 0;&#xD;&#xA;if (settledEggs_1 != 0)&#xD;&#xA;{&#xD;&#xA;    gradeA_1 = selChicks_1 * (settedEggs_1 / settledEggs_1);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @RejChicks_1&#xD;&#xA;decimal rejChicks_1 = 0;&#xD;&#xA;if (settledEggs_1 != 0)&#xD;&#xA;{&#xD;&#xA;    rejChicks_1 = (cullsChicks_1 + deadChicks_1) * (settedEggs_1 / settledEggs_1);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @CumChicks_1&#xD;&#xA;decimal cumChicks_1 = gradeA_1 + rejChicks_1;&#xD;&#xA;&#xD;&#xA;// @EstChicks_PerEgg_1&#xD;&#xA;decimal estChicks_PerEgg_1 = 0;&#xD;&#xA;if (balOfHatEggs_1 - settledEggs_1 &gt; 0)&#xD;&#xA;{&#xD;&#xA;    estChicks_PerEgg_1 = (balOfHatEggs_1 - settledEggs_1) * cumHatchability_1 / 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @CumChicks_Act_Est_1&#xD;&#xA;decimal cumChicks_Act_Est_1 = estChicks_PerEgg_1 + cumChicks_1;&#xD;&#xA;&#xD;&#xA;// @CumChicks_ActEst_HH_1&#xD;&#xA;decimal cumChicks_ActEst_HH_1 = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    cumChicks_ActEst_HH_1 = cumChicks_Act_Est_1 / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// ==================== Final Result ====================&#xD;&#xA;decimal totalCumChicks = cumChicks_ActEst_HH + cumChicks_ActEst_HH_1;&#xD;&#xA;cell.Text = totalCumChicks.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell266_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// ==================== Helper for safe conversion ====================&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// ==================== Get All Values ====================&#xD;&#xA;// Set 1 - Basic fields&#xD;&#xA;decimal stRejBroken = SafeConvert(GetCurrentColumnValue(&quot;ST_RejBroken&quot;));&#xD;&#xA;decimal htRejBroken = SafeConvert(GetCurrentColumnValue(&quot;HT_RejBroken&quot;));&#xD;&#xA;decimal stRejCracks = SafeConvert(GetCurrentColumnValue(&quot;ST_RejCracks&quot;));&#xD;&#xA;decimal htRejCracks = SafeConvert(GetCurrentColumnValue(&quot;HT_RejCracks&quot;));&#xD;&#xA;decimal htRejDeformed = SafeConvert(GetCurrentColumnValue(&quot;HT_RejDeformed&quot;));&#xD;&#xA;decimal stRejDeformed = SafeConvert(GetCurrentColumnValue(&quot;ST_RejDeformed&quot;));&#xD;&#xA;decimal stRejOther = SafeConvert(GetCurrentColumnValue(&quot;ST_RejOther&quot;));&#xD;&#xA;decimal htRejOther = SafeConvert(GetCurrentColumnValue(&quot;HT_RejOther&quot;));&#xD;&#xA;decimal erSoldAsHatEggs = SafeConvert(GetCurrentColumnValue(&quot;ER_SoldAsHatEggs&quot;));&#xD;&#xA;decimal esSoldAsHatEggs = SafeConvert(GetCurrentColumnValue(&quot;ES_SoldAsHatEggs&quot;));&#xD;&#xA;decimal erSoldAsTableEggs = SafeConvert(GetCurrentColumnValue(&quot;ER_SoldAsTableEggs&quot;));&#xD;&#xA;decimal esSoldAsTableEggs = SafeConvert(GetCurrentColumnValue(&quot;ES_SoldAsTableEggs&quot;));&#xD;&#xA;decimal erSendToOffal = SafeConvert(GetCurrentColumnValue(&quot;ER_SendToOffal&quot;));&#xD;&#xA;decimal esSendToOffal = SafeConvert(GetCurrentColumnValue(&quot;ES_SendToOffal&quot;));&#xD;&#xA;decimal farmInTake = SafeConvert(GetCurrentColumnValue(&quot;FarmInTake&quot;));&#xD;&#xA;decimal settledEggs = SafeConvert(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;decimal cullsChicks = SafeConvert(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;decimal deadChicks = SafeConvert(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;decimal pol = SafeConvert(GetCurrentColumnValue(&quot;POL&quot;));&#xD;&#xA;&#xD;&#xA;// Set 2 - Fields with _1 suffix&#xD;&#xA;decimal farmInTake_1 = SafeConvert(GetCurrentColumnValue(&quot;FarmInTake_1&quot;));&#xD;&#xA;decimal stRejBroken_1 = SafeConvert(GetCurrentColumnValue(&quot;ST_RejBroken_1&quot;));&#xD;&#xA;decimal htRejBroken_1 = SafeConvert(GetCurrentColumnValue(&quot;HT_RejBroken_1&quot;));&#xD;&#xA;decimal stRejCracks_1 = SafeConvert(GetCurrentColumnValue(&quot;ST_RejCracks_1&quot;));&#xD;&#xA;decimal htRejCracks_1 = SafeConvert(GetCurrentColumnValue(&quot;HT_RejCracks_1&quot;));&#xD;&#xA;decimal htRejDeformed_1 = SafeConvert(GetCurrentColumnValue(&quot;HT_RejDeformed_1&quot;));&#xD;&#xA;decimal stRejDeformed_1 = SafeConvert(GetCurrentColumnValue(&quot;ST_RejDeformed_1&quot;));&#xD;&#xA;decimal stRejOther_1 = SafeConvert(GetCurrentColumnValue(&quot;ST_RejOther_1&quot;));&#xD;&#xA;decimal htRejOther_1 = SafeConvert(GetCurrentColumnValue(&quot;HT_RejOther_1&quot;));&#xD;&#xA;decimal erSoldAsHatEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;ER_SoldAsHatEggs_1&quot;));&#xD;&#xA;decimal esSoldAsHatEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;ES_SoldAsHatEggs_1&quot;));&#xD;&#xA;decimal erSoldAsTableEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;ER_SoldAsTableEggs_1&quot;));&#xD;&#xA;decimal esSoldAsTableEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;ES_SoldAsTableEggs_1&quot;));&#xD;&#xA;decimal erSendToOffal_1 = SafeConvert(GetCurrentColumnValue(&quot;ER_SendToOffal_1&quot;));&#xD;&#xA;decimal esSendToOffal_1 = SafeConvert(GetCurrentColumnValue(&quot;ES_SendToOffal_1&quot;));&#xD;&#xA;decimal settledEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;SettedEggs_1&quot;));&#xD;&#xA;decimal cullsChicks_1 = SafeConvert(GetCurrentColumnValue(&quot;CullsChicks_1&quot;));&#xD;&#xA;decimal deadChicks_1 = SafeConvert(GetCurrentColumnValue(&quot;DeadChicks_1&quot;));&#xD;&#xA;&#xD;&#xA;// ==================== Set 1 Calculations ====================&#xD;&#xA;&#xD;&#xA;// @RejBroken, @RejCrack, @RejDef, @RejOther&#xD;&#xA;decimal rejBroken = stRejBroken + htRejBroken;&#xD;&#xA;decimal rejCrack = stRejCracks + htRejCracks;&#xD;&#xA;decimal rejDef = htRejDeformed + stRejDeformed;&#xD;&#xA;decimal rejOther = stRejOther + htRejOther;&#xD;&#xA;&#xD;&#xA;// @Total_RejEggs&#xD;&#xA;decimal totalRejEggs = rejBroken + rejCrack + rejDef + rejOther;&#xD;&#xA;&#xD;&#xA;// @BalOfHatEggs&#xD;&#xA;decimal balOfHatEggs = farmInTake - totalRejEggs;&#xD;&#xA;&#xD;&#xA;// @SoldHatEggs, @SoldTableEggs, @EggsToOffal&#xD;&#xA;decimal soldHatEggs = erSoldAsHatEggs + esSoldAsHatEggs;&#xD;&#xA;decimal soldTableEggs = erSoldAsTableEggs + esSoldAsTableEggs;&#xD;&#xA;decimal eggsToOffal = erSendToOffal + esSendToOffal;&#xD;&#xA;&#xD;&#xA;// @TotalEggSold&#xD;&#xA;decimal totalEggSold = soldHatEggs + soldTableEggs + eggsToOffal;&#xD;&#xA;&#xD;&#xA;// @StockHatEggBal&#xD;&#xA;decimal stockHatEggBal = balOfHatEggs - (settledEggs + totalEggSold);&#xD;&#xA;&#xD;&#xA;// @RejChicks&#xD;&#xA;decimal rejChicks = cullsChicks + deadChicks;&#xD;&#xA;&#xD;&#xA;// @CumChicksRej_HH&#xD;&#xA;decimal cumChicksRej_HH = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    cumChicksRej_HH = rejChicks / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// ==================== Set 2 Calculations ====================&#xD;&#xA;&#xD;&#xA;// @RejBroken_1, @RejCrack_1, @RejDef_1, @RejOther_1&#xD;&#xA;decimal rejBroken_1 = stRejBroken_1 + htRejBroken_1;&#xD;&#xA;decimal rejCrack_1 = stRejCracks_1 + htRejCracks_1;&#xD;&#xA;decimal rejDef_1 = htRejDeformed_1 + stRejDeformed_1;&#xD;&#xA;decimal rejOther_1 = stRejOther_1 + htRejOther_1;&#xD;&#xA;&#xD;&#xA;// @Total_RejEggs_1&#xD;&#xA;decimal totalRejEggs_1 = rejBroken_1 + rejCrack_1 + rejDef_1 + rejOther_1;&#xD;&#xA;&#xD;&#xA;// @BalOfHatEggs_1&#xD;&#xA;decimal balOfHatEggs_1 = farmInTake_1 - totalRejEggs_1;&#xD;&#xA;&#xD;&#xA;// @SoldHatEggs_1, @SoldTableEggs_1, @EggsToOffal_1&#xD;&#xA;decimal soldHatEggs_1 = erSoldAsHatEggs_1 + esSoldAsHatEggs_1;&#xD;&#xA;decimal soldTableEggs_1 = erSoldAsTableEggs_1 + esSoldAsTableEggs_1;&#xD;&#xA;decimal eggsToOffal_1 = erSendToOffal_1 + esSendToOffal_1;&#xD;&#xA;&#xD;&#xA;// @TotalEggSold_1&#xD;&#xA;decimal totalEggSold_1 = soldHatEggs_1 + soldTableEggs_1 + eggsToOffal_1;&#xD;&#xA;&#xD;&#xA;// @StockHatEggBal_1&#xD;&#xA;decimal stockHatEggBal_1 = balOfHatEggs_1 - (settledEggs_1 + totalEggSold_1);&#xD;&#xA;&#xD;&#xA;// @SettedEggs_1&#xD;&#xA;decimal settedEggs_1 = 0;&#xD;&#xA;if (settledEggs_1 - stockHatEggBal &lt; 0)&#xD;&#xA;{&#xD;&#xA;    settedEggs_1 = 0;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    settedEggs_1 = settledEggs_1 - stockHatEggBal;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @RejChicks_1&#xD;&#xA;decimal rejChicks_1 = 0;&#xD;&#xA;if (settledEggs_1 != 0)&#xD;&#xA;{&#xD;&#xA;    rejChicks_1 = (cullsChicks_1 + deadChicks_1) * (settedEggs_1 / settledEggs_1);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @CumChicksRej_HH_1&#xD;&#xA;decimal cumChicksRej_HH_1 = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    cumChicksRej_HH_1 = rejChicks_1 / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// ==================== Final Result ====================&#xD;&#xA;decimal totalCumChicksRej = cumChicksRej_HH + cumChicksRej_HH_1;&#xD;&#xA;cell.Text = totalCumChicksRej.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell268_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// ==================== Helper for safe conversion ====================&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// ==================== Get All Values ====================&#xD;&#xA;// Set 1 - Basic fields&#xD;&#xA;decimal stRejBroken = SafeConvert(GetCurrentColumnValue(&quot;ST_RejBroken&quot;));&#xD;&#xA;decimal htRejBroken = SafeConvert(GetCurrentColumnValue(&quot;HT_RejBroken&quot;));&#xD;&#xA;decimal stRejCracks = SafeConvert(GetCurrentColumnValue(&quot;ST_RejCracks&quot;));&#xD;&#xA;decimal htRejCracks = SafeConvert(GetCurrentColumnValue(&quot;HT_RejCracks&quot;));&#xD;&#xA;decimal htRejDeformed = SafeConvert(GetCurrentColumnValue(&quot;HT_RejDeformed&quot;));&#xD;&#xA;decimal stRejDeformed = SafeConvert(GetCurrentColumnValue(&quot;ST_RejDeformed&quot;));&#xD;&#xA;decimal stRejOther = SafeConvert(GetCurrentColumnValue(&quot;ST_RejOther&quot;));&#xD;&#xA;decimal htRejOther = SafeConvert(GetCurrentColumnValue(&quot;HT_RejOther&quot;));&#xD;&#xA;decimal erSoldAsHatEggs = SafeConvert(GetCurrentColumnValue(&quot;ER_SoldAsHatEggs&quot;));&#xD;&#xA;decimal esSoldAsHatEggs = SafeConvert(GetCurrentColumnValue(&quot;ES_SoldAsHatEggs&quot;));&#xD;&#xA;decimal erSoldAsTableEggs = SafeConvert(GetCurrentColumnValue(&quot;ER_SoldAsTableEggs&quot;));&#xD;&#xA;decimal esSoldAsTableEggs = SafeConvert(GetCurrentColumnValue(&quot;ES_SoldAsTableEggs&quot;));&#xD;&#xA;decimal erSendToOffal = SafeConvert(GetCurrentColumnValue(&quot;ER_SendToOffal&quot;));&#xD;&#xA;decimal esSendToOffal = SafeConvert(GetCurrentColumnValue(&quot;ES_SendToOffal&quot;));&#xD;&#xA;decimal farmInTake = SafeConvert(GetCurrentColumnValue(&quot;FarmInTake&quot;));&#xD;&#xA;decimal settledEggs = SafeConvert(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;decimal selChicks = SafeConvert(GetCurrentColumnValue(&quot;SelChicks&quot;));&#xD;&#xA;decimal cullsChicks = SafeConvert(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;decimal deadChicks = SafeConvert(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;decimal setEggBalHatEgg = SafeConvert(GetCurrentColumnValue(&quot;SetEggBalHatEgg&quot;));&#xD;&#xA;decimal selChickBalHatEgg = SafeConvert(GetCurrentColumnValue(&quot;SelChickBalHatEgg&quot;));&#xD;&#xA;decimal cullsBalHatEgg = SafeConvert(GetCurrentColumnValue(&quot;CullsBalHatEgg&quot;));&#xD;&#xA;decimal deadsBalHatEgg = SafeConvert(GetCurrentColumnValue(&quot;DeadsBalHatEgg&quot;));&#xD;&#xA;decimal pol = SafeConvert(GetCurrentColumnValue(&quot;POL&quot;));&#xD;&#xA;&#xD;&#xA;// Set 2 - Fields with _1 suffix&#xD;&#xA;decimal farmInTake_1 = SafeConvert(GetCurrentColumnValue(&quot;FarmInTake_1&quot;));&#xD;&#xA;decimal stRejBroken_1 = SafeConvert(GetCurrentColumnValue(&quot;ST_RejBroken_1&quot;));&#xD;&#xA;decimal htRejBroken_1 = SafeConvert(GetCurrentColumnValue(&quot;HT_RejBroken_1&quot;));&#xD;&#xA;decimal stRejCracks_1 = SafeConvert(GetCurrentColumnValue(&quot;ST_RejCracks_1&quot;));&#xD;&#xA;decimal htRejCracks_1 = SafeConvert(GetCurrentColumnValue(&quot;HT_RejCracks_1&quot;));&#xD;&#xA;decimal htRejDeformed_1 = SafeConvert(GetCurrentColumnValue(&quot;HT_RejDeformed_1&quot;));&#xD;&#xA;decimal stRejDeformed_1 = SafeConvert(GetCurrentColumnValue(&quot;ST_RejDeformed_1&quot;));&#xD;&#xA;decimal stRejOther_1 = SafeConvert(GetCurrentColumnValue(&quot;ST_RejOther_1&quot;));&#xD;&#xA;decimal htRejOther_1 = SafeConvert(GetCurrentColumnValue(&quot;HT_RejOther_1&quot;));&#xD;&#xA;decimal erSoldAsHatEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;ER_SoldAsHatEggs_1&quot;));&#xD;&#xA;decimal esSoldAsHatEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;ES_SoldAsHatEggs_1&quot;));&#xD;&#xA;decimal erSoldAsTableEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;ER_SoldAsTableEggs_1&quot;));&#xD;&#xA;decimal esSoldAsTableEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;ES_SoldAsTableEggs_1&quot;));&#xD;&#xA;decimal erSendToOffal_1 = SafeConvert(GetCurrentColumnValue(&quot;ER_SendToOffal_1&quot;));&#xD;&#xA;decimal esSendToOffal_1 = SafeConvert(GetCurrentColumnValue(&quot;ES_SendToOffal_1&quot;));&#xD;&#xA;decimal settledEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;SettedEggs_1&quot;));&#xD;&#xA;decimal selChicks_1 = SafeConvert(GetCurrentColumnValue(&quot;SelChicks_1&quot;));&#xD;&#xA;decimal cullsChicks_1 = SafeConvert(GetCurrentColumnValue(&quot;CullsChicks_1&quot;));&#xD;&#xA;decimal deadChicks_1 = SafeConvert(GetCurrentColumnValue(&quot;DeadChicks_1&quot;));&#xD;&#xA;decimal setEggBalHatEgg_1 = SafeConvert(GetCurrentColumnValue(&quot;SetEggBalHatEgg_1&quot;));&#xD;&#xA;decimal selChickBalHatEgg_1 = SafeConvert(GetCurrentColumnValue(&quot;SelChickBalHatEgg_1&quot;));&#xD;&#xA;decimal cullsBalHatEgg_1 = SafeConvert(GetCurrentColumnValue(&quot;CullsBalHatEgg_1&quot;));&#xD;&#xA;decimal deadsBalHatEgg_1 = SafeConvert(GetCurrentColumnValue(&quot;DeadsBalHatEgg_1&quot;));&#xD;&#xA;&#xD;&#xA;// ==================== Set 1 Calculations for @AB_CumTotalChicksHH ====================&#xD;&#xA;&#xD;&#xA;// @RejBroken, @RejCrack, @RejDef, @RejOther&#xD;&#xA;decimal rejBroken = stRejBroken + htRejBroken;&#xD;&#xA;decimal rejCrack = stRejCracks + htRejCracks;&#xD;&#xA;decimal rejDef = htRejDeformed + stRejDeformed;&#xD;&#xA;decimal rejOther = stRejOther + htRejOther;&#xD;&#xA;&#xD;&#xA;// @Total_RejEggs&#xD;&#xA;decimal totalRejEggs = rejBroken + rejCrack + rejDef + rejOther;&#xD;&#xA;&#xD;&#xA;// @BalOfHatEggs&#xD;&#xA;decimal balOfHatEggs = farmInTake - totalRejEggs;&#xD;&#xA;&#xD;&#xA;// @SoldHatEggs, @SoldTableEggs, @EggsToOffal&#xD;&#xA;decimal soldHatEggs = erSoldAsHatEggs + esSoldAsHatEggs;&#xD;&#xA;decimal soldTableEggs = erSoldAsTableEggs + esSoldAsTableEggs;&#xD;&#xA;decimal eggsToOffal = erSendToOffal + esSendToOffal;&#xD;&#xA;&#xD;&#xA;// @TotalEggSold&#xD;&#xA;decimal totalEggSold = soldHatEggs + soldTableEggs + eggsToOffal;&#xD;&#xA;&#xD;&#xA;// @StockHatEggBal&#xD;&#xA;decimal stockHatEggBal = balOfHatEggs - (settledEggs + totalEggSold);&#xD;&#xA;&#xD;&#xA;// @ActHatchBalanceEggs&#xD;&#xA;decimal actHatchBalanceEggs = 0;&#xD;&#xA;if (setEggBalHatEgg != 0)&#xD;&#xA;{&#xD;&#xA;    actHatchBalanceEggs = ((selChickBalHatEgg + cullsBalHatEgg + deadsBalHatEgg) / setEggBalHatEgg) * 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @ESTChicks_PerStock_HE&#xD;&#xA;decimal estChicksPerStock_HE = (stockHatEggBal * actHatchBalanceEggs) / 100.0m;&#xD;&#xA;&#xD;&#xA;// @CumHatchability&#xD;&#xA;decimal cumHatchability = 0;&#xD;&#xA;if (settledEggs != 0)&#xD;&#xA;{&#xD;&#xA;    cumHatchability = ((selChicks + cullsChicks + deadChicks) / settledEggs) * 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @EstChicks_PerEgg&#xD;&#xA;decimal estChicksPerEgg = 0;&#xD;&#xA;if (totalEggSold != 0)&#xD;&#xA;{&#xD;&#xA;    estChicksPerEgg = totalEggSold * cumHatchability / 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @CumChicks&#xD;&#xA;decimal cumChicks = selChicks + cullsChicks + deadChicks;&#xD;&#xA;&#xD;&#xA;// @CumChicks_Act_Est&#xD;&#xA;decimal cumChicks_Act_Est = estChicksPerEgg + estChicksPerStock_HE + cumChicks;&#xD;&#xA;&#xD;&#xA;// @CumChicks_ActEst_HH&#xD;&#xA;decimal cumChicks_ActEst_HH = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    cumChicks_ActEst_HH = cumChicks_Act_Est / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// ==================== Set 2 Calculations for @AB_CumTotalChicksHH ====================&#xD;&#xA;&#xD;&#xA;// @RejBroken_1, @RejCrack_1, @RejDef_1, @RejOther_1&#xD;&#xA;decimal rejBroken_1 = stRejBroken_1 + htRejBroken_1;&#xD;&#xA;decimal rejCrack_1 = stRejCracks_1 + htRejCracks_1;&#xD;&#xA;decimal rejDef_1 = htRejDeformed_1 + stRejDeformed_1;&#xD;&#xA;decimal rejOther_1 = stRejOther_1 + htRejOther_1;&#xD;&#xA;&#xD;&#xA;// @Total_RejEggs_1&#xD;&#xA;decimal totalRejEggs_1 = rejBroken_1 + rejCrack_1 + rejDef_1 + rejOther_1;&#xD;&#xA;&#xD;&#xA;// @BalOfHatEggs_1&#xD;&#xA;decimal balOfHatEggs_1 = farmInTake_1 - totalRejEggs_1;&#xD;&#xA;&#xD;&#xA;// @SoldHatEggs_1, @SoldTableEggs_1, @EggsToOffal_1&#xD;&#xA;decimal soldHatEggs_1 = erSoldAsHatEggs_1 + esSoldAsHatEggs_1;&#xD;&#xA;decimal soldTableEggs_1 = erSoldAsTableEggs_1 + esSoldAsTableEggs_1;&#xD;&#xA;decimal eggsToOffal_1 = erSendToOffal_1 + esSendToOffal_1;&#xD;&#xA;&#xD;&#xA;// @TotalEggSold_1&#xD;&#xA;decimal totalEggSold_1 = soldHatEggs_1 + soldTableEggs_1 + eggsToOffal_1;&#xD;&#xA;&#xD;&#xA;// @StockHatEggBal_1&#xD;&#xA;decimal stockHatEggBal_1 = balOfHatEggs_1 - (settledEggs_1 + totalEggSold_1);&#xD;&#xA;&#xD;&#xA;// @ActHatchBalanceEggs_1&#xD;&#xA;decimal actHatchBalanceEggs_1 = 0;&#xD;&#xA;if (setEggBalHatEgg_1 != 0)&#xD;&#xA;{&#xD;&#xA;    actHatchBalanceEggs_1 = ((selChickBalHatEgg_1 + cullsBalHatEgg_1 + deadsBalHatEgg_1) / setEggBalHatEgg_1) * 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @CumHatchability_1&#xD;&#xA;decimal cumHatchability_1 = 0;&#xD;&#xA;if (settledEggs_1 != 0)&#xD;&#xA;{&#xD;&#xA;    cumHatchability_1 = ((selChicks_1 + cullsChicks_1 + deadChicks_1) * 100) / settledEggs_1;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cumHatchability_1 = actHatchBalanceEggs;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @SettedEggs_1&#xD;&#xA;decimal settedEggs_1 = 0;&#xD;&#xA;if (settledEggs_1 - stockHatEggBal &lt; 0)&#xD;&#xA;{&#xD;&#xA;    settedEggs_1 = 0;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    settedEggs_1 = settledEggs_1 - stockHatEggBal;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @GradeA_1&#xD;&#xA;decimal gradeA_1 = 0;&#xD;&#xA;if (settledEggs_1 != 0)&#xD;&#xA;{&#xD;&#xA;    gradeA_1 = selChicks_1 * (settedEggs_1 / settledEggs_1);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @RejChicks_1&#xD;&#xA;decimal rejChicks_1_temp = 0;&#xD;&#xA;if (settledEggs_1 != 0)&#xD;&#xA;{&#xD;&#xA;    rejChicks_1_temp = (cullsChicks_1 + deadChicks_1) * (settedEggs_1 / settledEggs_1);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @CumChicks_1&#xD;&#xA;decimal cumChicks_1 = gradeA_1 + rejChicks_1_temp;&#xD;&#xA;&#xD;&#xA;// @EstChicks_PerEgg_1&#xD;&#xA;decimal estChicks_PerEgg_1 = 0;&#xD;&#xA;if (balOfHatEggs_1 - settledEggs_1 &gt; 0)&#xD;&#xA;{&#xD;&#xA;    estChicks_PerEgg_1 = (balOfHatEggs_1 - settledEggs_1) * cumHatchability_1 / 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @CumChicks_Act_Est_1&#xD;&#xA;decimal cumChicks_Act_Est_1 = estChicks_PerEgg_1 + cumChicks_1;&#xD;&#xA;&#xD;&#xA;// @CumChicks_ActEst_HH_1&#xD;&#xA;decimal cumChicks_ActEst_HH_1 = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    cumChicks_ActEst_HH_1 = cumChicks_Act_Est_1 / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @AB_CumTotalChicksHH&#xD;&#xA;decimal abCumTotalChicksHH = cumChicks_ActEst_HH + cumChicks_ActEst_HH_1;&#xD;&#xA;&#xD;&#xA;// ==================== Calculations for @AB_RejChicksHH ====================&#xD;&#xA;&#xD;&#xA;// @RejChicks&#xD;&#xA;decimal rejChicks = cullsChicks + deadChicks;&#xD;&#xA;&#xD;&#xA;// @CumChicksRej_HH&#xD;&#xA;decimal cumChicksRej_HH = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    cumChicksRej_HH = rejChicks / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @RejChicks_1&#xD;&#xA;decimal rejChicks_1 = 0;&#xD;&#xA;if (settledEggs_1 != 0)&#xD;&#xA;{&#xD;&#xA;    rejChicks_1 = (cullsChicks_1 + deadChicks_1) * (settedEggs_1 / settledEggs_1);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @CumChicksRej_HH_1&#xD;&#xA;decimal cumChicksRej_HH_1 = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    cumChicksRej_HH_1 = rejChicks_1 / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// @AB_RejChicksHH&#xD;&#xA;decimal abRejChicksHH = cumChicksRej_HH + cumChicksRej_HH_1;&#xD;&#xA;&#xD;&#xA;// ==================== Final Result ====================&#xD;&#xA;decimal result = abCumTotalChicksHH - abRejChicksHH;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;" PageWidthF="1169.29138" PageHeightF="1653.54333" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="25.2" DataMember="SR_HT_FlkSumProdReport" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
  <Parameters>
    <Item1 Ref="3" Visible="false" ValueInfo="False" Name="IsRTL" Type="#Ref-2" />
    <Item2 Ref="4" Visible="false" ValueInfo="False" Name="IsCustomReportFooter" Type="#Ref-2" />
    <Item3 Ref="5" Visible="false" ValueInfo="False" Name="IsCustomReportHeader" Type="#Ref-2" />
    <Item4 Ref="6" Visible="false" ValueInfo="False" Name="ShowSignature" Type="#Ref-2" />
    <Item5 Ref="7" Visible="false" ValueInfo="False" Name="ShowSignatureAllPages" Type="#Ref-2" />
    <Item6 Ref="8" ValueInfo="False" Name="HideReportHeader" Type="#Ref-2" />
    <Item7 Ref="9" ValueInfo="False" Name="HideReportFooter" Type="#Ref-2" />
    <Item8 Ref="10" Visible="false" Enabled="false" ValueInfo="True" Name="IsDealType" Type="#Ref-2" />
    <Item9 Ref="12" Name="NoOfGroupsPerPage" />
    <Item10 Ref="13" Visible="false" Name="FontSize" />
    <Item11 Ref="14" Visible="false" Name="DateFrom" />
    <Item12 Ref="15" Visible="false" Name="DateTo" />
    <Item13 Ref="16" Visible="false" Enabled="false" AllowNull="true" Name="Code_Str" />
    <Item14 Ref="17" Visible="false" Enabled="false" Name="CustSupp" />
    <Item15 Ref="18" Visible="false" Name="PageType" />
    <Item16 Ref="19" Visible="false" Name="FarmCode" />
    <Item17 Ref="20" Visible="false" Name="CropNo" />
    <Item18 Ref="21" Name="BookPerf" />
  </Parameters>
  <CalculatedFields>
    <Item1 Ref="22" Name="Abs_OpenBal" Expression="Abs([OpenBalance])" DataMember="SR_FC_CustSuppSheet" />
    <Item2 Ref="23" Name="DebitCreditOpenBalRes" Expression="Iif([OpenBalance] &gt; 0,[Debit_Str] , Iif([OpenBalance] &lt; 0, [Credit_Str], ''))" DataMember="SR_FC_CustSuppSheet" />
    <Item3 Ref="24" Name="Debit_Str" Expression="Iif(?IsRTL == true,'(مدين)' , '(Debit)')" DataMember="SR_FC_CustSuppSheet" />
    <Item4 Ref="25" Name="Credit_Str" Expression="Iif(?IsRTL == true,'(دائن)' , '(Credit)')" DataMember="SR_FC_CustSuppSheet" />
    <Item5 Ref="26" Name="OpenDebit" Expression="Iif([OpenBalance] &gt; 0, [OpenBalance], NULL)" DataMember="SR_FC_CustSuppSheet" />
    <Item6 Ref="27" Name="OpenCredit" Expression="Iif([OpenBalance] &lt; 0, Abs([OpenBalance]), NULL)&#xA;" DataMember="SR_FC_CustSuppSheet" />
    <Item7 Ref="28" Name="Result" Expression="[Debit] - [Credit]" DataMember="SR_FC_CustSuppSheet" />
    <Item8 Ref="29" Name="CloseDebit" Expression="Iif([CloseBalance] &gt; 0, [CloseBalance], 0)" DataMember="SR_FC_CustSuppSheet" />
    <Item9 Ref="30" Name="Open_Balance_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([OpenBalance])/[FormulaOperand_Prod] ,0 )" DataMember="SR_FC_FM_StockMovement" />
    <Item10 Ref="31" Name="Inputs_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([InputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
    <Item11 Ref="32" Name="Consumed_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([Consumed])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
    <Item12 Ref="33" Name="Outputs_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([SoldTransferOut])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
    <Item13 Ref="34" Name="Other_Output_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([OtherOutputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
    <Item14 Ref="35" Name="Close_Balance_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([CloseBalance])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
    <Item15 Ref="36" Name="Test" DataMember="SR_FC_FM_StockMovement" />
    <Item16 Ref="37" Name="SumOfHours" Expression="sum([TotalSecond]) /3600" DataMember="SR_MO_TrackUserActions" />
    <Item17 Ref="38" Name="calculatedField1" DataMember="SR_MO_TrackUserActions" />
    <Item18 Ref="39" Name="Data_1" Expression="[Data] + ' (' + ToStr([AgePartA]) + [Week] + ') ' + [DaysNO] + ' ' + [Day]&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item19 Ref="40" Name="AgePartA" Expression="Iif([LastDays] &gt; 0, [DeplAge] - 1, [DeplAge])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item20 Ref="41" Name="DaysNO" Expression="[AgePartA] * 7" DataMember="SR_HT_FlkSumProdReport" />
    <Item21 Ref="42" Name="Data" Expression="Iif(?IsRTL, 'تاريخ' , 'Date' )" DataMember="SR_HT_FlkSumProdReport" />
    <Item22 Ref="43" Name="Week" Expression="Iif(?IsRTL, 'أسبوع' , 'Week' )" DataMember="SR_HT_FlkSumProdReport" />
    <Item23 Ref="44" Name="Day" Expression="Iif(?IsRTL,'يوم', 'Day')" DataMember="SR_HT_FlkSumProdReport" />
    <Item24 Ref="45" Name="Performance" Expression="Iif(?IsRTL,'أداء' , 'Performance')" DataMember="SR_HT_FlkSumProdReport" />
    <Item25 Ref="46" Name="Perf1" Expression="Iif(?IsRTL,[Performance] + ' (' + ToStr([AgePartA]) + ' ' + [Week] + ') ' + ToStr([DaysNO]) + ' ' + [Day]&#xA; , [Performance] + ' (' + ToStr([AgePartA]) + ' weeks) ' + ToStr([DaysNO]) + [Days])" DataMember="SR_HT_FlkSumProdReport" />
    <Item26 Ref="47" Name="Days" Expression="iif(?IsRTL,'أيام','days')" DataMember="SR_HT_FlkSumProdReport" />
    <Item27 Ref="48" Name="RejDef" Expression="iif(IsNullOrEmpty([HT_RejDeformed]),0,[HT_RejDeformed]) + iif(IsNullOrEmpty([ST_RejDeformed]),0,[ST_RejDeformed])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item28 Ref="49" Name="RejCrack" Expression="iif(IsNullOrEmpty([HT_RejCracks]),0,[HT_RejCracks]) + iif(IsNullOrEmpty([ST_RejCracks]),0,[ST_RejCracks])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item29 Ref="50" Name="RejBroken" Expression="iif(IsNullOrEmpty([HT_RejBroken]),0,[HT_RejBroken]) + iif(IsNullOrEmpty([ST_RejBroken]),0,[ST_RejBroken])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item30 Ref="51" Name="RejOther" Expression="iif(IsNullOrEmpty([HT_RejOther]),0,[HT_RejOther]) + iif(IsNullOrEmpty([ST_RejOther]),0,[ST_RejOther])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item31 Ref="52" Name="Total_RejEggs" Expression="Iif(IsNullOrEmpty([RejBroken]) Or [RejBroken] == 0, 0, [RejBroken]) +&#xD;&#xA;Iif(IsNullOrEmpty([RejCrack]) Or [RejCrack] == 0, 0, [RejCrack]) +&#xD;&#xA;Iif(IsNullOrEmpty([RejDef]) Or [RejDef] == 0, 0, [RejDef]) +&#xD;&#xA;Iif(IsNullOrEmpty([RejOther]) Or [RejOther] == 0, 0, [RejOther])&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item32 Ref="53" Name="BalOfHatEggs" Expression="[FarmInTake] - [Total_RejEggs]&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item33 Ref="54" Name="CumChicks" Expression="Iif(IsNull([SelChicks]) Or [SelChicks] == 0, 0, [SelChicks]) +&#xA;Iif(IsNull([CullsChicks]) Or [CullsChicks] == 0, 0, [CullsChicks]) +&#xA;Iif(IsNull([DeadChicks]) Or [DeadChicks] == 0, 0, [DeadChicks])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item34 Ref="55" Name="CumHatchability" Expression="Iif([SR_HT_FlkSumProdReport.SettedEggs] &lt;&gt; 0, &#xD;&#xA;    ([SR_HT_FlkSumProdReport.SelChicks] + [SR_HT_FlkSumProdReport.CullsChicks] + [SR_HT_FlkSumProdReport.DeadChicks]) / [SR_HT_FlkSumProdReport.SettedEggs] * 100, &#xD;&#xA;    0&#xD;&#xA;)&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item35 Ref="56" Name="RejChicks" Expression="[CullsChicks] + [DeadChicks]" DataMember="SR_HT_FlkSumProdReport" />
    <Item36 Ref="57" Name="SoldHatEggs" Expression="Iif(IsNullOrEmpty([ER_SoldAsHatEggs]) Or [ER_SoldAsHatEggs] == 0, 0, [ER_SoldAsHatEggs]) +&#xA;Iif(IsNullOrEmpty([ES_SoldAsHatEggs]) Or [ES_SoldAsHatEggs] == 0, 0, [ES_SoldAsHatEggs])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item37 Ref="58" Name="SoldTableEggs" Expression="Iif(IsNullOrEmpty([ER_SoldAsTableEggs]) Or [ER_SoldAsTableEggs] == 0, 0, [ER_SoldAsTableEggs]) +&#xA;Iif(IsNullOrEmpty([ES_SoldAsTableEggs]) Or [ES_SoldAsTableEggs] == 0, 0, [ES_SoldAsTableEggs])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item38 Ref="59" Name="EggsToOffal" Expression="Iif(IsNullOrEmpty([ER_SendToOffal]) Or [ER_SendToOffal] == 0, 0, [ER_SendToOffal]) +&#xA;Iif(IsNullOrEmpty([ES_SendToOffal]) Or [ES_SendToOffal] == 0, 0, [ES_SendToOffal])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item39 Ref="60" Name="TotalEggSold" Expression="Iif(IsNullOrEmpty([SoldHatEggs]) Or [SoldHatEggs] == 0, 0, [SoldHatEggs]) +&#xD;&#xA;Iif(IsNullOrEmpty([SoldTableEggs]) Or [SoldTableEggs] == 0, 0, [SoldTableEggs]) +&#xD;&#xA;Iif(IsNullOrEmpty([EggsToOffal]) Or [EggsToOffal] == 0, 0, [EggsToOffal])&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item40 Ref="61" Name="EstChicks_PerEgg" Expression="Iif(IsNullOrEmpty([TotalEggSold]) Or [TotalEggSold] == 0, 0, [TotalEggSold]) *&#xA;Iif(IsNullOrEmpty([CumHatchability]) Or [CumHatchability] == 0, 0, [CumHatchability]) / 100&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item41 Ref="62" Name="StockHatEggBal" Expression="Iif(IsNullOrEmpty([BalOfHatEggs]) Or [BalOfHatEggs] == 0, 0, [BalOfHatEggs]) -&#xD;&#xA;(&#xD;&#xA;    Iif(IsNullOrEmpty([SR_HT_FlkSumProdReport.SettedEggs]) Or [SR_HT_FlkSumProdReport.SettedEggs] == 0, 0, [SR_HT_FlkSumProdReport.SettedEggs]) +&#xD;&#xA;    Iif(IsNullOrEmpty([TotalEggSold]) Or [TotalEggSold] == 0, 0, [TotalEggSold])&#xD;&#xA;)&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item42 Ref="63" Name="ESTChicks_PerStock_HE" Expression="Iif(IsNullOrEmpty([StockHatEggBal]) Or [StockHatEggBal] == 0, 0, [StockHatEggBal]) *&#xA;Iif(IsNullOrEmpty([ActHatchBalanceEggs]) Or [ActHatchBalanceEggs] == 0, 0, [ActHatchBalanceEggs]) / 100&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item43 Ref="64" Name="ActHatchBalanceEggs" Expression="Iif(&#xD;&#xA;    (IsNullOrEmpty([SetEggBalHatEgg]) Or [SetEggBalHatEgg] == 0), &#xD;&#xA;    0, &#xD;&#xA;    (Iif(IsNullOrEmpty([SelChickBalHatEgg]), 0, [SelChickBalHatEgg]) &#xD;&#xA;    + Iif(IsNullOrEmpty([CullsBalHatEgg]), 0, [CullsBalHatEgg]) &#xD;&#xA;    + Iif(IsNullOrEmpty([DeadsBalHatEgg]), 0, [DeadsBalHatEgg])) &#xD;&#xA;    / [SetEggBalHatEgg] * 100&#xD;&#xA;)&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item44 Ref="65" Name="CumChicks_Act_Est" Expression="Iif(IsNullOrEmpty([EstChicks_PerEgg]), 0, [EstChicks_PerEgg]) &#xA;+ Iif(IsNullOrEmpty([ESTChicks_PerStock_HE]), 0, [ESTChicks_PerStock_HE]) &#xA;+ Iif(IsNullOrEmpty([CumChicks]), 0, [CumChicks])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item45 Ref="66" Name="CumRecEggs_HH" Expression="Iif([POL] &lt;&gt; 0, [FarmInTake] / [POL], 0)&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item46 Ref="67" Name="Total_RejEggs_HH" Expression="Iif(IsNullOrEmpty([POL]) Or [POL] = 0, 0, [Total_RejEggs] / [POL])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item47 Ref="68" Name="CumFinalHatEgg_HH" Expression="Iif(IsNullOrEmpty([POL]) Or [POL] = 0, 0, [BalOfHatEggs] / [POL])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item48 Ref="69" Name="CumChicksAct_HH" Expression="Iif(IsNullOrEmpty([POL]) Or [POL] = 0, 0, [CumChicks] / [POL])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item49 Ref="70" Name="CumHatchability_HH" Expression="[CumHatchability]" DataMember="SR_HT_FlkSumProdReport" />
    <Item50 Ref="71" Name="CumChicksRej_HH" Expression="Iif(IsNullOrEmpty([POL]) Or [POL] = 0, 0, [RejChicks] / [POL])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item51 Ref="72" Name="CumAGradeChicks_HH" Expression="Iif(IsNullOrEmpty([POL]) Or [POL] = 0, 0, [SelChicks] / [POL])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item52 Ref="73" Name="EstChicks_PerEgg_HH" Expression="Iif(IsNullOrEmpty([POL]) Or [POL] = 0, 0, [EstChicks_PerEgg] / [POL])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item53 Ref="74" Name="EStChicks_PerStockHE_HH" Expression="Iif(IsNullOrEmpty([POL]) Or [POL] = 0, 0, [ESTChicks_PerStock_HE] / [POL])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item54 Ref="75" Name="CumChicks_ActEst_HH" Expression="Iif(IsNullOrEmpty([POL]) Or [POL] = 0, 0, [CumChicks_Act_Est] / [POL])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item55 Ref="76" Name="CumRecEggs_HH_1" Expression="Iif([POL] &lt;&gt; 0, [FarmInTake_1] / [POL], 0)&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item56 Ref="77" Name="AB_CumTotalEggs_HH" Expression="Iif(IsNullOrEmpty([CumRecEggs_HH]) OR [CumRecEggs_HH] == 0, 0, [CumRecEggs_HH])&#xA;+&#xA;Iif(IsNullOrEmpty([CumRecEggs_HH_1]) OR [CumRecEggs_HH_1] == 0, 0, [CumRecEggs_HH_1])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item57 Ref="78" Name="AB_RejEggsHH" Expression="Iif([POL1] &lt;&gt; 0, [Total_RejEggs_1] / [POL1], 0)&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item58 Ref="79" Name="Total_RejEggs_1" Expression="Iif(IsNullOrEmpty([RejBroken_1]) Or [RejBroken_1] = 0&#xD;&#xA; Or IsNullOrEmpty([RejCrack_1]) Or [RejCrack_1] = 0&#xD;&#xA; Or IsNullOrEmpty([RejDef_1]) Or [RejDef_1] = 0&#xD;&#xA; Or IsNullOrEmpty([RejOther_1]) Or [RejOther_1] = 0,&#xD;&#xA; 0,&#xD;&#xA; [RejBroken_1] + [RejCrack_1] + [RejDef_1] + [RejOther_1])&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item59 Ref="80" Name="RejDef_1" Expression="Iif(IsNullOrEmpty([HT_RejDeformed_1]) Or [HT_RejDeformed_1] = 0 &#xA;    Or IsNullOrEmpty([ST_RejDeformed_1]) Or [ST_RejDeformed_1] = 0,&#xA;    0,&#xA;    [HT_RejDeformed_1] + [ST_RejDeformed_1])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item60 Ref="81" Name="RejCrack_1" Expression="Iif(IsNullOrEmpty([ST_RejCracks_1]) Or [ST_RejCracks_1] = 0&#xA; Or IsNullOrEmpty([HT_RejCracks_1]) Or [HT_RejCracks_1] = 0,&#xA; 0,&#xA; [ST_RejCracks_1] + [HT_RejCracks_1])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item61 Ref="82" Name="RejBroken_1" Expression="Iif(IsNullOrEmpty([ST_RejBroken_1]) Or [ST_RejBroken_1] = 0&#xA; Or IsNullOrEmpty([HT_RejBroken_1]) Or [HT_RejBroken_1] = 0,&#xA; 0,&#xA; [ST_RejBroken_1] + [HT_RejBroken_1])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item62 Ref="83" Name="RejOther_1" Expression="Iif(IsNullOrEmpty([ST_RejOther]) Or [ST_RejOther] = 0&#xA; Or IsNullOrEmpty([ST_RejOther_1]) Or [ST_RejOther_1] = 0,&#xA; 0,&#xA; [ST_RejOther] + [ST_RejOther_1])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item63 Ref="84" Name="BalOfHatEggs_1" Expression="Iif(IsNullOrEmpty([FarmInTake_1]) Or [FarmInTake_1] = 0&#xA; Or IsNullOrEmpty([Total_RejEggs_1]) Or [Total_RejEggs_1] = 0,&#xA; 0,&#xA; [FarmInTake_1] - [Total_RejEggs_1])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item64 Ref="85" Name="CumFinalHatEgg_HH_1" Expression="Iif([POL1] &lt;&gt; 0, [BalOfHatEggs_1] / [POL1], 0)&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item65 Ref="86" Name="AB_CumHatchEggsHH" Expression="Iif(IsNullOrEmpty([CumFinalHatEgg_HH]) OR [CumFinalHatEgg_HH] == 0, 0, [CumFinalHatEgg_HH])&#xA;+&#xA;Iif(IsNullOrEmpty([CumFinalHatEgg_HH_1]) OR [CumFinalHatEgg_HH_1] == 0, 0, [CumFinalHatEgg_HH_1])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item66 Ref="87" Name="CumChicks_1" Expression="Iif(IsNullOrEmpty([SelChicks_1]) Or [SelChicks_1] = 0&#xD;&#xA; Or IsNullOrEmpty([CullsChicks_1]) Or [CullsChicks_1] = 0&#xD;&#xA; Or IsNullOrEmpty([DeadChicks_1]) Or [DeadChicks_1] = 0,&#xD;&#xA; 0,&#xD;&#xA; [SelChicks_1] + [CullsChicks_1] + [DeadChicks_1])&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item67 Ref="88" Name="CumHatchability_1" Expression="Iif(&#xD;&#xA;    IsNullOrEmpty([SettedEggs_1]) Or [SettedEggs_1] = 0,&#xD;&#xA;    0,&#xD;&#xA;    (&#xD;&#xA;        Iif(IsNullOrEmpty([SelChicks_1]) Or [SelChicks_1] = 0, 0, [SelChicks_1]) +&#xD;&#xA;        Iif(IsNullOrEmpty([CullsChicks_1]) Or [CullsChicks_1] = 0, 0, [CullsChicks_1]) +&#xD;&#xA;        Iif(IsNullOrEmpty([DeadChicks_1]) Or [DeadChicks_1] = 0, 0, [DeadChicks_1])&#xD;&#xA;    ) / [SettedEggs_1] * 100&#xD;&#xA;)&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item68 Ref="89" Name="SoldTableEggs_1" Expression="Iif(IsNullOrEmpty([ER_SoldAsTableEggs_1]) Or [ER_SoldAsTableEggs_1] == 0, 0, [ER_SoldAsTableEggs_1]) &#xD;&#xA;+ Iif(IsNullOrEmpty([ES_SoldAsTableEggs_1]) Or [ES_SoldAsTableEggs_1] == 0, 0, [ES_SoldAsTableEggs_1])&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item69 Ref="90" Name="EggsToOffal_1" Expression="Iif(IsNullOrEmpty([SR_HT_FlkSumProdReport.ER_SendToOffal_1]) OR [SR_HT_FlkSumProdReport.ER_SendToOffal_1] == 0, 0, [SR_HT_FlkSumProdReport.ER_SendToOffal_1]) &#xD;&#xA;+ &#xD;&#xA;Iif(IsNullOrEmpty([SR_HT_FlkSumProdReport.ES_SendToOffal_1]) OR [SR_HT_FlkSumProdReport.ES_SendToOffal_1] == 0, 0, [SR_HT_FlkSumProdReport.ES_SendToOffal_1])&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item70 Ref="91" Name="SoldHatEggs_1" Expression="Iif(IsNullOrEmpty([ER_SoldAsHatEggs_1]), 0, [ER_SoldAsHatEggs_1]) &#xA;+ Iif(IsNullOrEmpty([ES_SoldAsHatEggs_1]), 0, [ES_SoldAsHatEggs_1])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item71 Ref="92" Name="TotalEggSold_1" Expression="Iif(IsNullOrEmpty([SoldHatEggs_1]) OR [SoldHatEggs_1] == 0, 0, [SoldHatEggs_1])&#xD;&#xA;+&#xD;&#xA;Iif(IsNullOrEmpty([SoldTableEggs_1]) OR [SoldTableEggs_1] == 0, 0, [SoldTableEggs_1])&#xD;&#xA;+&#xD;&#xA;Iif(IsNullOrEmpty([EggsToOffal_1]) OR [EggsToOffal_1] == 0, 0, [EggsToOffal_1])&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item72 Ref="93" Name="ESTChicks_PerStock_HE_1" Expression="[StockHatEggBal_1] * [ActHatchBalanceEggs_1] / 100&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item73 Ref="94" Name="AB_CumHatchability" Expression="Iif([AB_CumHatchEggsHH] &lt;&gt; 0, [AB_CumTotalChicksHH] / [AB_CumHatchEggsHH] * 100, 0)&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item74 Ref="95" Name="CumChicks_Act_Est_1" Expression="Iif(IsNullOrEmpty([EstChicks_PerEgg_1]) OR [EstChicks_PerEgg_1] == 0, 0, [EstChicks_PerEgg_1])&#xD;&#xA;+&#xD;&#xA;Iif(IsNullOrEmpty([ESTChicks_PerStock_HE_1]) OR [ESTChicks_PerStock_HE_1] == 0, 0, [ESTChicks_PerStock_HE_1])&#xD;&#xA;+&#xD;&#xA;Iif(IsNullOrEmpty([CumChicks_1]) OR [CumChicks_1] == 0, 0, [CumChicks_1])&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item75 Ref="96" Name="AB_CumTotalChicksHH_VS_Act" Expression="Iif(&#xD;&#xA;    [POL] &lt;&gt; 0,&#xD;&#xA;    (&#xD;&#xA;        Iif(IsNullOrEmpty([CumChicks]) OR [CumChicks] == 0, 0, [CumChicks])&#xD;&#xA;        +&#xD;&#xA;        Iif(IsNullOrEmpty([SelChicks_1]) OR [SelChicks_1] == 0, 0, [SelChicks_1])&#xD;&#xA;        +&#xD;&#xA;        Iif(IsNullOrEmpty([CullsChicks_1]) OR [CullsChicks_1] == 0, 0, [CullsChicks_1])&#xD;&#xA;        +&#xD;&#xA;        Iif(IsNullOrEmpty([DeadChicks_1]) OR [DeadChicks_1] == 0, 0, [DeadChicks_1])&#xD;&#xA;    )&#xD;&#xA;    / [POL],&#xD;&#xA;    0&#xD;&#xA;)&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item76 Ref="97" Name="AB_RejChicksHH_VS_Act" Expression="Iif(&#xD;&#xA;    [POL] &lt;&gt; 0,&#xD;&#xA;    (&#xD;&#xA;        Iif(IsNullOrEmpty([RejChicks]) OR [RejChicks] == 0, 0, [RejChicks])&#xD;&#xA;        +&#xD;&#xA;        Iif(IsNullOrEmpty([CullsChicks_1]) OR [CullsChicks_1] == 0, 0, [CullsChicks_1])&#xD;&#xA;        +&#xD;&#xA;        Iif(IsNullOrEmpty([DeadChicks_1]) OR [DeadChicks_1] == 0, 0, [DeadChicks_1])&#xD;&#xA;    )&#xD;&#xA;    / [POL],&#xD;&#xA;    0&#xD;&#xA;)&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item77 Ref="98" Name="AB_CumAGradeChicksHH_VS_Act" Expression="Iif(&#xD;&#xA;    [POL] &lt;&gt; 0,&#xD;&#xA;    (&#xD;&#xA;        Iif(IsNullOrEmpty([RejChicks]) OR [RejChicks] == 0, 0, [RejChicks])&#xD;&#xA;        +&#xD;&#xA;        Iif(IsNullOrEmpty([CullsChicks_1]) OR [CullsChicks_1] == 0, 0, [CullsChicks_1])&#xD;&#xA;        +&#xD;&#xA;        Iif(IsNullOrEmpty([DeadChicks_1]) OR [DeadChicks_1] == 0, 0, [DeadChicks_1])&#xD;&#xA;    )&#xD;&#xA;    / [POL],&#xD;&#xA;    0&#xD;&#xA;)&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item78 Ref="99" Name="AB_CumTotalChicksHH" Expression="Iif(IsNullOrEmpty([CumChicks_ActEst_HH]) OR [CumChicks_ActEst_HH] == 0, 0, [CumChicks_ActEst_HH])&#xD;&#xA;+&#xD;&#xA;Iif(IsNullOrEmpty([CumChicks_ActEst_HH_1]) OR [CumChicks_ActEst_HH_1] == 0, 0, [CumChicks_ActEst_HH_1])&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item79 Ref="100" Name="AB_RejChicksHH" Expression="Iif(IsNullOrEmpty([CumChicksRej_HH]) OR [CumChicksRej_HH] == 0, 0, [CumChicksRej_HH])&#xA;+&#xA;Iif(IsNullOrEmpty([CumChicksRej_HH_1]) OR [CumChicksRej_HH_1] == 0, 0, [CumChicksRej_HH_1])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item80 Ref="101" Name="AB_CumAGradeChicksHH" Expression="Iif(IsNullOrEmpty([AB_CumTotalChicksHH]) OR [AB_CumTotalChicksHH] == 0, 0, [AB_CumTotalChicksHH])&#xA;-&#xA;Iif(IsNullOrEmpty([AB_RejChicksHH]) OR [AB_RejChicksHH] == 0, 0, [AB_RejChicksHH])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item81 Ref="102" Name="Data_2" Expression="Iif(?IsRTL,[Data] + ' (' + [After] + ' ' + ToStr([DaysNO]) + ' ' + [Day] + ') ' + [Data] + ToStr([SR_HT_FlkSumProdReport.LastDays]) + ' ' + [Day] + ' ' + [Only]&#xD;&#xA; , [Data] + ' (' + [After] + ' ' + ToStr([DaysNO]) + ' ' + [Days] + ') ' + [Data] + + [Only]+ ToStr([SR_HT_FlkSumProdReport.LastDays]) + ' ' + [Days] &#xD;&#xA;)" DataMember="SR_HT_FlkSumProdReport" />
    <Item82 Ref="103" Name="After" Expression="iif(?IsRTL,'بعد','After')" DataMember="SR_HT_FlkSumProdReport" />
    <Item83 Ref="104" Name="Perf2" Expression="Iif(?IsRTL,&#xD;&#xA;    [Performance] + ' (' + [After] + ' ' + ToStr([DaysNO]) + ' ' + [Day] + ') ' + [Data] + ToStr([SR_HT_FlkSumProdReport.LastDays]) + ' ' + [Day] + ' ' + [Only],&#xD;&#xA;    'Performance (After ' + ToStr([DaysNO]) + ' days) Data only ' + ToStr([SR_HT_FlkSumProdReport.LastDays]) + ' days'&#xD;&#xA;)&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item84 Ref="105" Name="RejChicks_1" Expression="Iif(&#xA;    IsNullOrEmpty([CullsChicks_1]) Or [CullsChicks_1] = 0, 0, [CullsChicks_1]&#xA;) &#xA;+ &#xA;Iif(&#xA;    IsNullOrEmpty([DeadChicks_1]) Or [DeadChicks_1] = 0, 0, [DeadChicks_1]&#xA;)&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item85 Ref="106" Name="EstChicks_PerEgg_1" Expression="(&#xA;    Iif(IsNullOrEmpty([TotalEggSold_1]) OR [TotalEggSold_1] == 0, 0, [TotalEggSold_1])&#xA;)&#xA;*&#xA;(&#xA;    Iif(IsNullOrEmpty([CumHatchability_1]) OR [CumHatchability_1] == 0, 0, [CumHatchability_1])&#xA;)&#xA;/&#xA;100&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item86 Ref="107" Name="StockHatEggBal_1" Expression="[BalOfHatEggs_1] - ([SR_HT_FlkSumProdReport.SettedEggs_1] + [TotalEggSold_1])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item87 Ref="108" Name="ActHatchBalanceEggs_1" Expression="Iif([SR_HT_FlkSumProdReport.SetEggBalHatEgg_1] &lt;&gt; 0, &#xD;&#xA;    ([SR_HT_FlkSumProdReport.SelChickBalHatEgg_1] + [SR_HT_FlkSumProdReport.CullsBalHatEgg_1] + [SR_HT_FlkSumProdReport.DeadsBalHatEgg_1]) / [SR_HT_FlkSumProdReport.SetEggBalHatEgg_1] * 100, &#xD;&#xA;    0&#xD;&#xA;)&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item88 Ref="109" Name="Total_RejEggs_HH_1" Expression="Iif([POL_1] &lt;&gt; 0, [Total_RejEggs_1] / [POL_1], 0)&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item89 Ref="110" Name="CumChicksAct_HH_1" Expression="Iif([POL_1] &lt;&gt; 0, [CumChicks_1] / [POL_1], 0)&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item90 Ref="111" Name="CumHatchability_HH_1" Expression="[CumHatchability_1]" DataMember="SR_HT_FlkSumProdReport" />
    <Item91 Ref="112" Name="CumChicksRej_HH_1" Expression="Iif([POL_1] &lt;&gt; 0, [RejChicks_1] / [POL_1], 0)&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item92 Ref="113" Name="CumAGradeChicks_HH_1" Expression="Iif([POL_1] &lt;&gt; 0, [SelChicks_1] / [POL_1], 0)&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item93 Ref="114" Name="EstChicks_PerEgg_HH_1" Expression="Iif([POL_1] &lt;&gt; 0, [EstChicks_PerEgg_1] / [POL_1], 0)&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item94 Ref="115" Name="EStChicks_PerStockHE_HH_1" Expression="Iif([SR_HT_FlkSumProdReport.POL_1] &lt;&gt; 0, [ESTChicks_PerStock_HE_1] / [SR_HT_FlkSumProdReport.POL_1], 0)&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item95 Ref="116" Name="CumChicks_ActEst_HH_1" Expression="Iif([POL_1] &lt;&gt; 0, [CumChicks_Act_Est_1] / [POL_1], 0)&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item96 Ref="117" Name="SettedEggs_1_FromPartA" Expression="[SettedEggs_1]" DataMember="SR_HT_FlkSumProdReport" />
    <Item97 Ref="118" Name="RejChicks_1_FromPartA" Expression="Iif(IsNullOrEmpty([CullsChicks_1]), 0, [CullsChicks_1]) &#xA;+ Iif(IsNullOrEmpty([DeadChicks_1]), 0, [DeadChicks_1])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item98 Ref="119" Name="GradeA_1_FromPartA" Expression="[SelChicks_1]" DataMember="SR_HT_FlkSumProdReport" />
    <Item99 Ref="120" Name="CumChicks_1_FromPartA" Expression="[GradeA_1_FromPartA] + [RejChicks_1_FromPartA]" DataMember="SR_HT_FlkSumProdReport" />
    <Item100 Ref="121" Name="CumHatchability_1_FromPartA" Expression="Iif([SettedEggs_1_FromPartA] != 0, [CumChicks_1_FromPartA] * 100 / [SettedEggs_1_FromPartA], 0)&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item101 Ref="122" Name="SoldHatEggs_1_FromPartA" Expression="Iif(IsNullOrEmpty([ER_SoldAsHatEggs_1]) Or [ER_SoldAsHatEggs_1] == 0, 0, [ER_SoldAsHatEggs_1]) &#xA;+ Iif(IsNullOrEmpty([ES_SoldAsHatEggs_1]) Or [ES_SoldAsHatEggs_1] == 0, 0, [ES_SoldAsHatEggs_1])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item102 Ref="123" Name="SoldTableEggs_1_FromPartA" Expression="Iif(IsNullOrEmpty([ER_SoldAsTableEggs_1]) Or [ER_SoldAsTableEggs_1] == 0, 0, [ER_SoldAsTableEggs_1]) &#xD;&#xA;+ Iif(IsNullOrEmpty([ES_SoldAsTableEggs_1]) Or [ES_SoldAsTableEggs_1] == 0, 0, [ES_SoldAsTableEggs_1])&#xD;&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item103 Ref="124" Name="EggsToOffal_1_FromPartA" Expression="Iif(IsNullOrEmpty([ER_SendToOffal_1]) OR [ER_SendToOffal_1] == 0, 0, [ER_SendToOffal_1])&#xA;+&#xA;Iif(IsNullOrEmpty([ES_SendToOffal_1]) OR [ES_SendToOffal_1] == 0, 0, [ES_SendToOffal_1])&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item104 Ref="125" Name="TotalEggSold_1_FromPartA" Expression="[SoldHatEggs_1_FromPartA] + [SoldTableEggs_1_FromPartA] + [EggsToOffal_1_FromPartA]&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item105 Ref="126" Name="Female_Per" Expression="Iif([SR_HT_FlkSumProdReport.FemalesTrans] &lt;&gt; 0, &#xA;    [SR_HT_FlkSumProdReport.FemalesDepleted] / [SR_HT_FlkSumProdReport.FemalesTrans] * 100, &#xA;    0)&#xA;" DataMember="SR_HT_FlkSumProdReport" />
    <Item106 Ref="127" Name="Week_CF" Expression="Iif(?IsRTL, 'أسابيع' , 'Weeks')" DataMember="SR_HT_FlkSumProdReport" />
    <Item107 Ref="128" Name="calculatedField2" DataMember="SR_HT_FlkSumProdReport" />
  </CalculatedFields>
