       if (value != null &amp;&amp; !string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        {&#xD;&#xA;            if (decimal.TryParse(value.ToString(), out decimal result))&#xD;&#xA;                return result;&#xD;&#xA;        }&#xD;&#xA;        return 0;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- STEP 1: Read PART 1 values (for StockHatEggBal calculation) ---&#xD;&#xA;    decimal farmInTake = GetDecimalValue(&quot;FarmInTake&quot;);&#xD;&#xA;    decimal settedEggs = GetDecimalValue(&quot;SettedEggs&quot;);&#xD;&#xA;    &#xD;&#xA;    // --- Calculate Total_RejEggs for PART 1 ---&#xD;&#xA;    decimal rejBroken = GetDecimalValue(&quot;HT_RejBroken&quot;) + GetDecimalValue(&quot;ST_RejBroken&quot;);&#xD;&#xA;    decimal rejCrack = GetDecimalValue(&quot;HT_RejCracks&quot;) + GetDecimalValue(&quot;ST_RejCracks&quot;);&#xD;&#xA;    decimal rejDef = GetDecimalValue(&quot;HT_RejDeformed&quot;) + GetDecimalValue(&quot;ST_RejDeformed&quot;);&#xD;&#xA;    decimal rejOther = GetDecimalValue(&quot;HT_RejOther&quot;) + GetDecimalValue(&quot;ST_RejOther&quot;);&#xD;&#xA;    decimal totalRejEggs = rejBroken + rejCrack + rejDef + rejOther;&#xD;&#xA;    &#xD;&#xA;    // --- Calculate BalOfHatEggs for PART 1 ---&#xD;&#xA;    decimal balOfHatEggs = farmInTake - totalRejEggs;&#xD;&#xA;    &#xD;&#xA;    // --- Calculate TotalEggSold for PART 1 ---&#xD;&#xA;    decimal erSoldAsHatEggs = GetDecimalValue(&quot;ER_SoldAsHatEggs&quot;);&#xD;&#xA;    decimal esSoldAsHatEggs = GetDecimalValue(&quot;ES_SoldAsHatEggs&quot;);&#xD;&#xA;    decimal erSoldAsTableEggs = GetDecimalValue(&quot;ER_SoldAsTableEggs&quot;);&#xD;&#xA;    decimal esSoldAsTableEggs = GetDecimalValue(&quot;ES_SoldAsTableEggs&quot;);&#xD;&#xA;    decimal erSendToOffal = GetDecimalValue(&quot;ER_SendToOffal&quot;);&#xD;&#xA;    decimal esSendToOffal = GetDecimalValue(&quot;ES_SendToOffal&quot;);&#xD;&#xA;    &#xD;&#xA;    decimal soldHatEggs = erSoldAsHatEggs + esSoldAsHatEggs;&#xD;&#xA;    decimal soldTableEggs = erSoldAsTableEggs + esSoldAsTableEggs;&#xD;&#xA;    decimal eggsToOffal = erSendToOffal + esSendToOffal;&#xD;&#xA;    decimal totalEggSold = soldHatEggs + soldTableEggs + eggsToOffal;&#xD;&#xA;    &#xD;&#xA;    // --- Calculate StockHatEggBal for PART 1 ---&#xD;&#xA;    decimal stockHatEggBal = balOfHatEggs - (settedEggs + totalEggSold);&#xD;&#xA;    &#xD;&#xA;    // --- STEP 2: Read PART 2 values ---&#xD;&#xA;    decimal farmInTake_1 = GetDecimalValue(&quot;FarmInTake_1&quot;);&#xD;&#xA;    decimal settedEggs_1 = GetDecimalValue(&quot;SettedEggs_1&quot;);&#xD;&#xA;    &#xD;&#xA;    // --- Calculate Total_RejEggs_1 for PART 2 ---&#xD;&#xA;    decimal rejBroken_1 = GetDecimalValue(&quot;HT_RejBroken_1&quot;) + GetDecimalValue(&quot;ST_RejBroken_1&quot;);&#xD;&#xA;    decimal rejCrack_1 = GetDecimalValue(&quot;HT_RejCracks_1&quot;) + GetDecimalValue(&quot;ST_RejCracks_1&quot;);&#xD;&#xA;    decimal rejDef_1 = GetDecimalValue(&quot;HT_RejDeformed_1&quot;) + GetDecimalValue(&quot;ST_RejDeformed_1&quot;);&#xD;&#xA;    decimal rejOther_1 = GetDecimalValue(&quot;HT_RejOther_1&quot;) + GetDecimalValue(&quot;ST_RejOther_1&quot;);&#xD;&#xA;    decimal totalRejEggs_1 = rejBroken_1 + rejCrack_1 + rejDef_1 + rejOther_1;&#xD;&#xA;    &#xD;&#xA;    // --- Calculate BalOfHatEggs_1 for PART 2 ---&#xD;&#xA;    decimal balOfHatEggs_1 = farmInTake_1 - totalRejEggs_1;&#xD;&#xA;    &#xD;&#xA;    // --- Calculate SettedEggs_1 (with condition) ---&#xD;&#xA;    decimal settedEggs_1_Calculated = 0;&#xD;&#xA;    decimal difference = settedEggs_1 - stockHatEggBal;&#xD;&#xA;    if (difference &gt;= 0)&#xD;&#xA;    {&#xD;&#xA;        settedEggs_1_Calculated = difference;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- STEP 3: Calculate CumHatchability_1 ---&#xD;&#xA;    decimal cumHatchability_1 = 0;&#xD;&#xA;    &#xD;&#xA;    // Check if SettedEggs_1 is not zero&#xD;&#xA;    if (settedEggs_1 != 0)&#xD;&#xA;    {&#xD;&#xA;        decimal selChicks_1 = GetDecimalValue(&quot;SelChicks_1&quot;);&#xD;&#xA;        decimal cullsChicks_1 = GetDecimalValue(&quot;CullsChicks_1&quot;);&#xD;&#xA;        decimal deadChicks_1 = GetDecimalValue(&quot;DeadChicks_1&quot;);&#xD;&#xA;        &#xD;&#xA;        decimal totalChicks_1 = selChicks_1 + cullsChicks_1 + deadChicks_1;&#xD;&#xA;        cumHatchability_1 = totalChicks_1 * 100 / settedEggs_1;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        // Calculate ActHatchBalanceEggs&#xD;&#xA;        decimal setEggBalHatEgg = GetDecimalValue(&quot;SetEggBalHatEgg&quot;);&#xD;&#xA;        if (setEggBalHatEgg != 0)&#xD;&#xA;        {&#xD;&#xA;            decimal selChickBal = GetDecimalValue(&quot;SelChickBalHatEgg&quot;);&#xD;&#xA;            decimal cullsBal = GetDecimalValue(&quot;CullsBalHatEgg&quot;);&#xD;&#xA;            decimal deadsBal = GetDecimalValue(&quot;DeadsBalHatEgg&quot;);&#xD;&#xA;            &#xD;&#xA;            decimal totalBal = selChickBal + cullsBal + deadsBal;&#xD;&#xA;            cumHatchability_1 = totalBal / setEggBalHatEgg * 100;&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- STEP 4: Final Equation ---&#xD;&#xA;    decimal result = 0;&#xD;&#xA;    decimal difference_1 = balOfHatEggs_1 - settedEggs_1_Calculated;&#xD;&#xA;    result = difference_1 * cumHatchability_1 / 100;&#xD;&#xA;    &#xD;&#xA;    // --- Assign result to cell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;private void xrTableCell187_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Helper function for safe parsing&#xD;&#xA;decimal GetFieldValue(string fieldName)&#xD;&#xA;{&#xD;&#xA;    object value = GetCurrentColumnValue(fieldName);&#xD;&#xA;    if (value != null &amp;&amp; !string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(value.ToString(), out decimal result))&#xD;&#xA;            return result;&#xD;&#xA;    }&#xD;&#xA;    return 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Helper function to get field value by report field name&#xD;&#xA;decimal GetReportFieldValue(string fieldName)&#xD;&#xA;{&#xD;&#xA;    // Assuming SR_HT_FlkSumProdReport is the data source&#xD;&#xA;    // You'll need to adjust this based on your actual data access method&#xD;&#xA;    return GetFieldValue(fieldName);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Calculate Part 1 components ---&#xD;&#xA;&#xD;&#xA;// Rejected eggs for Part 1&#xD;&#xA;decimal RejBroken = GetReportFieldValue(&quot;ST_RejBroken&quot;) + GetReportFieldValue(&quot;HT_RejBroken&quot;);&#xD;&#xA;decimal RejCrack = GetReportFieldValue(&quot;ST_RejCracks&quot;) + GetReportFieldValue(&quot;HT_RejCracks&quot;);&#xD;&#xA;decimal RejDef = GetReportFieldValue(&quot;HT_RejDeformed&quot;) + GetReportFieldValue(&quot;ST_RejDeformed&quot;);&#xD;&#xA;decimal RejOther = GetReportFieldValue(&quot;ST_RejOther&quot;) + GetReportFieldValue(&quot;HT_RejOther&quot;);&#xD;&#xA;decimal Total_RejEggs = RejBroken + RejCrack + RejDef + RejOther;&#xD;&#xA;&#xD;&#xA;// Balance of Hatchery Eggs for Part 1&#xD;&#xA;decimal FarmInTake = GetReportFieldValue(&quot;FarmInTake&quot;);&#xD;&#xA;decimal BalOfHatEggs = FarmInTake - Total_RejEggs;&#xD;&#xA;&#xD;&#xA;// Total Eggs Sold for Part 1&#xD;&#xA;decimal SoldHatEggs = GetReportFieldValue(&quot;ER_SoldAsHatEggs&quot;) + GetReportFieldValue(&quot;ES_SoldAsHatEggs&quot;);&#xD;&#xA;decimal SoldTableEggs = GetReportFieldValue(&quot;ER_SoldAsTableEggs&quot;) + GetReportFieldValue(&quot;ES_SoldAsTableEggs&quot;);&#xD;&#xA;decimal EggsToOffal = GetReportFieldValue(&quot;ER_SendToOffal&quot;) + GetReportFieldValue(&quot;ES_SendToOffal&quot;);&#xD;&#xA;decimal TotalEggSold = SoldHatEggs + SoldTableEggs + EggsToOffal;&#xD;&#xA;&#xD;&#xA;// Stock Hatchery Egg Balance&#xD;&#xA;decimal SettedEggs = GetReportFieldValue(&quot;SettedEggs&quot;);&#xD;&#xA;decimal StockHatEggBal = BalOfHatEggs - (SettedEggs + TotalEggSold);&#xD;&#xA;&#xD;&#xA;// --- Calculate Part 2 components ---&#xD;&#xA;&#xD;&#xA;// Rejected eggs for Part 2&#xD;&#xA;decimal RejBroken_1 = GetReportFieldValue(&quot;ST_RejBroken_1&quot;) + GetReportFieldValue(&quot;HT_RejBroken_1&quot;);&#xD;&#xA;decimal RejCrack_1 = GetReportFieldValue(&quot;ST_RejCracks_1&quot;) + GetReportFieldValue(&quot;HT_RejCracks_1&quot;);&#xD;&#xA;decimal RejDef_1 = GetReportFieldValue(&quot;HT_RejDeformed_1&quot;) + GetReportFieldValue(&quot;ST_RejDeformed_1&quot;);&#xD;&#xA;decimal RejOther_1 = GetReportFieldValue(&quot;ST_RejOther_1&quot;) + GetReportFieldValue(&quot;HT_RejOther_1&quot;);&#xD;&#xA;decimal Total_RejEggs_1 = RejBroken_1 + RejCrack_1 + RejDef_1 + RejOther_1;&#xD;&#xA;&#xD;&#xA;// Balance of Hatchery Eggs for Part 2&#xD;&#xA;decimal FarmInTake_1 = GetReportFieldValue(&quot;FarmInTake_1&quot;);&#xD;&#xA;decimal BalOfHatEggs_1 = FarmInTake_1 - Total_RejEggs_1;&#xD;&#xA;&#xD;&#xA;// Setted Eggs for Part 2 (with condition)&#xD;&#xA;decimal SettedEggs_1_Raw = GetReportFieldValue(&quot;SettedEggs_1&quot;);&#xD;&#xA;decimal SettedEggs_1 = 0;&#xD;&#xA;decimal difference = SettedEggs_1_Raw - StockHatEggBal;&#xD;&#xA;if (difference &gt;= 0)&#xD;&#xA;{&#xD;&#xA;    SettedEggs_1 = difference;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Calculate CumHatchability_1 ---&#xD;&#xA;decimal CumHatchability_1 = 0;&#xD;&#xA;&#xD;&#xA;if (SettedEggs_1_Raw != 0)&#xD;&#xA;{&#xD;&#xA;    decimal SelChicks_1 = GetReportFieldValue(&quot;SelChicks_1&quot;);&#xD;&#xA;    decimal CullsChicks_1 = GetReportFieldValue(&quot;CullsChicks_1&quot;);&#xD;&#xA;    decimal DeadChicks_1 = GetReportFieldValue(&quot;DeadChicks_1&quot;);&#xD;&#xA;    &#xD;&#xA;    decimal totalChicks = SelChicks_1 + CullsChicks_1 + DeadChicks_1;&#xD;&#xA;    CumHatchability_1 = totalChicks * 100 / SettedEggs_1_Raw;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    decimal SetEggBalHatEgg = GetReportFieldValue(&quot;SetEggBalHatEgg&quot;);&#xD;&#xA;    if (SetEggBalHatEgg != 0)&#xD;&#xA;    {&#xD;&#xA;        decimal SelChickBal = GetReportFieldValue(&quot;SelChickBalHatEgg&quot;);&#xD;&#xA;        decimal CullsBal = GetReportFieldValue(&quot;CullsBalHatEgg&quot;);&#xD;&#xA;        decimal DeadsBal = GetReportFieldValue(&quot;DeadsBalHatEgg&quot;);&#xD;&#xA;        &#xD;&#xA;        decimal totalBal = SelChickBal + CullsBal + DeadsBal;&#xD;&#xA;        CumHatchability_1 = totalBal / SetEggBalHatEgg * 100;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Calculate EstChicks_PerEgg_1 ---&#xD;&#xA;decimal EstChicks_PerEgg_1 = (BalOfHatEggs_1 - SettedEggs_1) * CumHatchability_1 / 100;&#xD;&#xA;&#xD;&#xA;// --- Calculate CumChicks_1 ---&#xD;&#xA;// Note: This calculation differs from the previous one&#xD;&#xA;// Based on the formula: {@CumChicks_1}---&gt;{@GradeA_1} + {@RejChicks_1}&#xD;&#xA;&#xD;&#xA;// Calculate GradeA_1&#xD;&#xA;decimal GradeA_1 = 0;&#xD;&#xA;if (SettedEggs_1_Raw != 0)&#xD;&#xA;{&#xD;&#xA;    decimal SelChicks_1 = GetReportFieldValue(&quot;SelChicks_1&quot;);&#xD;&#xA;    GradeA_1 = SelChicks_1 * (SettedEggs_1 / SettedEggs_1_Raw);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Calculate RejChicks_1&#xD;&#xA;decimal RejChicks_1 = 0;&#xD;&#xA;if (SettedEggs_1_Raw != 0)&#xD;&#xA;{&#xD;&#xA;    decimal CullsChicks_1 = GetReportFieldValue(&quot;CullsChicks_1&quot;);&#xD;&#xA;    decimal DeadChicks_1 = GetReportFieldValue(&quot;DeadChicks_1&quot;);&#xD;&#xA;    RejChicks_1 = (CullsChicks_1 + DeadChicks_1) * (SettedEggs_1 / SettedEggs_1_Raw);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// Calculate CumChicks_1&#xD;&#xA;decimal CumChicks_1 = GradeA_1 + RejChicks_1;&#xD;&#xA;&#xD;&#xA;// --- Final Calculation ---&#xD;&#xA;decimal result = EstChicks_PerEgg_1 + CumChicks_1;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA; }&#xD;&#xA;&#xD;&#xA;private void xrTableCell214_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal gradeA_1_FromPartA = 0;&#xD;&#xA;decimal rejChicks_1_FromPartA = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;GradeA_1_FromPartA&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;GradeA_1_FromPartA&quot;).ToString()) &amp;&amp;&#xD;&#xA;    Convert.ToDecimal(GetCurrentColumnValue(&quot;GradeA_1_FromPartA&quot;)) != 0)&#xD;&#xA;{&#xD;&#xA;    gradeA_1_FromPartA = Convert.ToDecimal(GetCurrentColumnValue(&quot;GradeA_1_FromPartA&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RejChicks_1_FromPartA&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;RejChicks_1_FromPartA&quot;).ToString()) &amp;&amp;&#xD;&#xA;    Convert.ToDecimal(GetCurrentColumnValue(&quot;RejChicks_1_FromPartA&quot;)) != 0)&#xD;&#xA;{&#xD;&#xA;    rejChicks_1_FromPartA = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejChicks_1_FromPartA&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal total_1 = gradeA_1_FromPartA + rejChicks_1_FromPartA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell_1 = sender as XRTableCell;&#xD;&#xA;cell_1.Text = total_1.ToString(&quot;N0&quot;);   // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell217_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     // --- Read SettedEggs_1_FromPartA (which is SettedEggs_1) ---&#xD;&#xA;    decimal settedEggs_1_FromPartA = 0;&#xD;&#xA;    object valSetted = GetCurrentColumnValue(&quot;SettedEggs_1&quot;);&#xD;&#xA;    if (valSetted != null &amp;&amp; !string.IsNullOrEmpty(valSetted.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valSetted.ToString(), out decimal tempSetted))&#xD;&#xA;            settedEggs_1_FromPartA = tempSetted;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- Read GradeA_1_FromPartA (which is SelChicks_1) ---&#xD;&#xA;    decimal gradeA_1_FromPartA = 0;&#xD;&#xA;    object valSel = GetCurrentColumnValue(&quot;SelChicks_1&quot;);&#xD;&#xA;    if (valSel != null &amp;&amp; !string.IsNullOrEmpty(valSel.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valSel.ToString(), out decimal tempSel))&#xD;&#xA;            gradeA_1_FromPartA = tempSel;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- Read RejChicks_1_FromPartA components ---&#xD;&#xA;    decimal cullsChicks_1 = 0;&#xD;&#xA;    object valCulls = GetCurrentColumnValue(&quot;CullsChicks_1&quot;);&#xD;&#xA;    if (valCulls != null &amp;&amp; !string.IsNullOrEmpty(valCulls.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valCulls.ToString(), out decimal tempCulls))&#xD;&#xA;            cullsChicks_1 = tempCulls;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    decimal deadChicks_1 = 0;&#xD;&#xA;    object valDead = GetCurrentColumnValue(&quot;DeadChicks_1&quot;);&#xD;&#xA;    if (valDead != null &amp;&amp; !string.IsNullOrEmpty(valDead.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valDead.ToString(), out decimal tempDead))&#xD;&#xA;            deadChicks_1 = tempDead;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- Calculate RejChicks_1_FromPartA ---&#xD;&#xA;    decimal rejChicks_1_FromPartA = cullsChicks_1 + deadChicks_1;&#xD;&#xA;    &#xD;&#xA;    // --- Calculate CumChicks_1_FromPartA ---&#xD;&#xA;    decimal cumChicks_1_FromPartA = gradeA_1_FromPartA + rejChicks_1_FromPartA;&#xD;&#xA;    &#xD;&#xA;    // --- Equation ---&#xD;&#xA;    decimal result = 0;&#xD;&#xA;    if (settedEggs_1_FromPartA != 0)&#xD;&#xA;    {&#xD;&#xA;        result = cumChicks_1_FromPartA * 100 / settedEggs_1_FromPartA;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- Assign result to cell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;0.##&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell220_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal cullsChicks_1 = 0;&#xD;&#xA;decimal deadChicks_1 = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CullsChicks_1&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CullsChicks_1&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    cullsChicks_1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks_1&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DeadChicks_1&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;DeadChicks_1&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    deadChicks_1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks_1&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal result = cullsChicks_1 + deadChicks_1;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N0&quot;);   // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell226_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal erSoldAsHatEggs_1 = 0;&#xD;&#xA;decimal esSoldAsHatEggs_1 = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;ER_SoldAsHatEggs_1&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;ER_SoldAsHatEggs_1&quot;).ToString()) &amp;&amp;&#xD;&#xA;    Convert.ToDecimal(GetCurrentColumnValue(&quot;ER_SoldAsHatEggs_1&quot;)) != 0)&#xD;&#xA;{&#xD;&#xA;    erSoldAsHatEggs_1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;ER_SoldAsHatEggs_1&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;ES_SoldAsHatEggs_1&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;ES_SoldAsHatEggs_1&quot;).ToString()) &amp;&amp;&#xD;&#xA;    Convert.ToDecimal(GetCurrentColumnValue(&quot;ES_SoldAsHatEggs_1&quot;)) != 0)&#xD;&#xA;{&#xD;&#xA;    esSoldAsHatEggs_1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;ES_SoldAsHatEggs_1&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal result = erSoldAsHatEggs_1 + esSoldAsHatEggs_1;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;);  // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell229_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal erSoldAsTableEggs_1 = 0;&#xD;&#xA;decimal esSoldAsTableEggs_1 = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;ER_SoldAsTableEggs_1&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;ER_SoldAsTableEggs_1&quot;).ToString()) &amp;&amp;&#xD;&#xA;    Convert.ToDecimal(GetCurrentColumnValue(&quot;ER_SoldAsTableEggs_1&quot;)) != 0)&#xD;&#xA;{&#xD;&#xA;    erSoldAsTableEggs_1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;ER_SoldAsTableEggs_1&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;ES_SoldAsTableEggs_1&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;ES_SoldAsTableEggs_1&quot;).ToString()) &amp;&amp;&#xD;&#xA;    Convert.ToDecimal(GetCurrentColumnValue(&quot;ES_SoldAsTableEggs_1&quot;)) != 0)&#xD;&#xA;{&#xD;&#xA;    esSoldAsTableEggs_1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;ES_SoldAsTableEggs_1&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal result = erSoldAsTableEggs_1 + esSoldAsTableEggs_1;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N0&quot;);  // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell232_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal erValue = 0;&#xD;&#xA;    decimal esValue = 0;&#xD;&#xA;&#xD;&#xA;    // --- Read ER value safely ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;ER_SendToOffal_1&quot;) != null &amp;&amp;&#xD;&#xA;        !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;ER_SendToOffal_1&quot;).ToString()) &amp;&amp;&#xD;&#xA;        Convert.ToDecimal(GetCurrentColumnValue(&quot;ER_SendToOffal_1&quot;)) != 0)&#xD;&#xA;    {&#xD;&#xA;        erValue = Convert.ToDecimal(GetCurrentColumnValue(&quot;ER_SendToOffal_1&quot;));&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    // --- Read ES value safely ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;ES_SendToOffal_1&quot;) != null &amp;&amp;&#xD;&#xA;        !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;ES_SendToOffal_1&quot;).ToString()) &amp;&amp;&#xD;&#xA;        Convert.ToDecimal(GetCurrentColumnValue(&quot;ES_SendToOffal_1&quot;)) != 0)&#xD;&#xA;    {&#xD;&#xA;        esValue = Convert.ToDecimal(GetCurrentColumnValue(&quot;ES_SendToOffal_1&quot;));&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    // --- Equation ---&#xD;&#xA;    decimal totalValue = erValue + esValue;&#xD;&#xA;&#xD;&#xA;    // --- Assign result to cell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = totalValue.ToString(&quot;0.##&quot;); // display up to 2 decimals&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell235_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // --- Declare variables ---&#xD;&#xA;    decimal erSoldAsHatEggs = 0;&#xD;&#xA;    decimal esSoldAsHatEggs = 0;&#xD;&#xA;    decimal erSoldAsTableEggs = 0;&#xD;&#xA;    decimal esSoldAsTableEggs = 0;&#xD;&#xA;    decimal erSendToOffal = 0;&#xD;&#xA;    decimal esSendToOffal = 0;&#xD;&#xA;    &#xD;&#xA;    // --- Read ER_SoldAsHatEggs_1 ---&#xD;&#xA;    object valErHat = GetCurrentColumnValue(&quot;ER_SoldAsHatEggs_1&quot;);&#xD;&#xA;    if (valErHat != null &amp;&amp; !string.IsNullOrEmpty(valErHat.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valErHat.ToString(), out decimal tempErHat))&#xD;&#xA;            erSoldAsHatEggs = tempErHat;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- Read ES_SoldAsHatEggs_1 ---&#xD;&#xA;    object valEsHat = GetCurrentColumnValue(&quot;ES_SoldAsHatEggs_1&quot;);&#xD;&#xA;    if (valEsHat != null &amp;&amp; !string.IsNullOrEmpty(valEsHat.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valEsHat.ToString(), out decimal tempEsHat))&#xD;&#xA;            esSoldAsHatEggs = tempEsHat;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- Read ER_SoldAsTableEggs_1 ---&#xD;&#xA;    object valErTable = GetCurrentColumnValue(&quot;ER_SoldAsTableEggs_1&quot;);&#xD;&#xA;    if (valErTable != null &amp;&amp; !string.IsNullOrEmpty(valErTable.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valErTable.ToString(), out decimal tempErTable))&#xD;&#xA;            erSoldAsTableEggs = tempErTable;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- Read ES_SoldAsTableEggs_1 ---&#xD;&#xA;    object valEsTable = GetCurrentColumnValue(&quot;ES_SoldAsTableEggs_1&quot;);&#xD;&#xA;    if (valEsTable != null &amp;&amp; !string.IsNullOrEmpty(valEsTable.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valEsTable.ToString(), out decimal tempEsTable))&#xD;&#xA;            esSoldAsTableEggs = tempEsTable;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- Read ER_SendToOffal_1 ---&#xD;&#xA;    object valErOffal = GetCurrentColumnValue(&quot;ER_SendToOffal_1&quot;);&#xD;&#xA;    if (valErOffal != null &amp;&amp; !string.IsNullOrEmpty(valErOffal.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valErOffal.ToString(), out decimal tempErOffal))&#xD;&#xA;            erSendToOffal = tempErOffal;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- Read ES_SendToOffal_1 ---&#xD;&#xA;    object valEsOffal = GetCurrentColumnValue(&quot;ES_SendToOffal_1&quot;);&#xD;&#xA;    if (valEsOffal != null &amp;&amp; !string.IsNullOrEmpty(valEsOffal.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(valEsOffal.ToString(), out decimal tempEsOffal))&#xD;&#xA;            esSendToOffal = tempEsOffal;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- Calculate components ---&#xD;&#xA;    decimal soldHatEggs_1_FromPartA = erSoldAsHatEggs + esSoldAsHatEggs;&#xD;&#xA;    decimal soldTableEggs_1_FromPartA = erSoldAsTableEggs + esSoldAsTableEggs;&#xD;&#xA;    decimal eggsToOffal_1_FromPartA = erSendToOffal + esSendToOffal;&#xD;&#xA;    &#xD;&#xA;    // --- Calculate total ---&#xD;&#xA;    decimal total = soldHatEggs_1_FromPartA + soldTableEggs_1_FromPartA + eggsToOffal_1_FromPartA;&#xD;&#xA;    &#xD;&#xA;    // --- Assign result to XRTableCell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = total.ToString(&quot;N0&quot;);&#xD;&#xA;   }&#xD;&#xA;&#xD;&#xA;private void xrTableCell189_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;    decimal farmInTake_1 = 0;&#xD;&#xA;    decimal pol = 0;&#xD;&#xA;&#xD;&#xA;    // --- Read values safely ---&#xD;&#xA;    if (GetCurrentColumnValue(&quot;FarmInTake_1&quot;) != null &amp;&amp;&#xD;&#xA;        !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;FarmInTake_1&quot;).ToString()))&#xD;&#xA;    {&#xD;&#xA;        farmInTake_1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;FarmInTake_1&quot;));&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    if (GetCurrentColumnValue(&quot;POL&quot;) != null &amp;&amp;&#xD;&#xA;        !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;POL&quot;).ToString()))&#xD;&#xA;    {&#xD;&#xA;        pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;));&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    // --- Equation ---&#xD;&#xA;    decimal result = 0;&#xD;&#xA;    if (pol != 0)&#xD;&#xA;        result = farmInTake_1 / pol;&#xD;&#xA;&#xD;&#xA;    // --- Assign result to cell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell58_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       // --- Declare values ---&#xD;&#xA;decimal selChicks = 0;&#xD;&#xA;decimal cullsChicks = 0;&#xD;&#xA;decimal deadChicks = 0;&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values directly ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SelChicks&quot;) != null)&#xD;&#xA;    selChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CullsChicks&quot;) != null)&#xD;&#xA;    cullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DeadChicks&quot;) != null)&#xD;&#xA;    deadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Calculate CumHatchability ---&#xD;&#xA;if (settedEggs != 0)&#xD;&#xA;    cumHatchability = (selChicks + cullsChicks + deadChicks) / settedEggs * 100m;&#xD;&#xA;    &#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = cumHatchability.ToString(&quot;0.##&quot;); // format with 2 decimals&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell246_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Helper function for safe parsing&#xD;&#xA;decimal GetFieldValue(string fieldName)&#xD;&#xA;{&#xD;&#xA;    object value = GetCurrentColumnValue(fieldName);&#xD;&#xA;    if (value != null &amp;&amp; !string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(value.ToString(), out decimal result))&#xD;&#xA;            return result;&#xD;&#xA;    }&#xD;&#xA;    return 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- STEP 1: Calculate Part 1 components (for StockHatEggBal) ---&#xD;&#xA;&#xD;&#xA;// Calculate rejection components for Part 1&#xD;&#xA;decimal rejBroken = GetFieldValue(&quot;ST_RejBroken&quot;) + GetFieldValue(&quot;HT_RejBroken&quot;);&#xD;&#xA;decimal rejCrack = GetFieldValue(&quot;ST_RejCracks&quot;) + GetFieldValue(&quot;HT_RejCracks&quot;);&#xD;&#xA;decimal rejDef = GetFieldValue(&quot;HT_RejDeformed&quot;) + GetFieldValue(&quot;ST_RejDeformed&quot;);&#xD;&#xA;decimal rejOther = GetFieldValue(&quot;ST_RejOther&quot;) + GetFieldValue(&quot;HT_RejOther&quot;);&#xD;&#xA;decimal totalRejEggs = rejBroken + rejCrack + rejDef + rejOther;&#xD;&#xA;&#xD;&#xA;// Calculate BalOfHatEggs for Part 1&#xD;&#xA;decimal farmInTake = GetFieldValue(&quot;FarmInTake&quot;);&#xD;&#xA;decimal balOfHatEggs = farmInTake - totalRejEggs;&#xD;&#xA;&#xD;&#xA;// Calculate TotalEggSold for Part 1&#xD;&#xA;decimal soldHatEggs = GetFieldValue(&quot;ER_SoldAsHatEggs&quot;) + GetFieldValue(&quot;ES_SoldAsHatEggs&quot;);&#xD;&#xA;decimal soldTableEggs = GetFieldValue(&quot;ER_SoldAsTableEggs&quot;) + GetFieldValue(&quot;ES_SoldAsTableEggs&quot;);&#xD;&#xA;decimal eggsToOffal = GetFieldValue(&quot;ER_SendToOffal&quot;) + GetFieldValue(&quot;ES_SendToOffal&quot;);&#xD;&#xA;decimal totalEggSold = soldHatEggs + soldTableEggs + eggsToOffal;&#xD;&#xA;&#xD;&#xA;// Calculate StockHatEggBal&#xD;&#xA;decimal settedEggs = GetFieldValue(&quot;SettedEggs&quot;);&#xD;&#xA;decimal stockHatEggBal = balOfHatEggs - (settedEggs + totalEggSold);&#xD;&#xA;&#xD;&#xA;// --- STEP 2: Calculate Part 2 rejection components ---&#xD;&#xA;&#xD;&#xA;// Calculate rejection components for Part 2&#xD;&#xA;decimal rejBroken_1 = GetFieldValue(&quot;ST_RejBroken_1&quot;) + GetFieldValue(&quot;HT_RejBroken_1&quot;);&#xD;&#xA;decimal rejCrack_1 = GetFieldValue(&quot;ST_RejCracks_1&quot;) + GetFieldValue(&quot;HT_RejCracks_1&quot;);&#xD;&#xA;decimal rejDef_1 = GetFieldValue(&quot;HT_RejDeformed_1&quot;) + GetFieldValue(&quot;ST_RejDeformed_1&quot;);&#xD;&#xA;decimal rejOther_1 = GetFieldValue(&quot;ST_RejOther_1&quot;) + GetFieldValue(&quot;HT_RejOther_1&quot;);&#xD;&#xA;decimal totalRejEggs_1 = rejBroken_1 + rejCrack_1 + rejDef_1 + rejOther_1;&#xD;&#xA;&#xD;&#xA;// Calculate BalOfHatEggs_1 for Part 2&#xD;&#xA;decimal farmInTake_1 = GetFieldValue(&quot;FarmInTake_1&quot;);&#xD;&#xA;decimal balOfHatEggs_1 = farmInTake_1 - totalRejEggs_1;&#xD;&#xA;&#xD;&#xA;// --- STEP 3: Calculate SettedEggs_1 (adjusted) ---&#xD;&#xA;decimal settedEggs_1_Raw = GetFieldValue(&quot;SettedEggs_1&quot;);&#xD;&#xA;decimal settedEggs_1 = 0;&#xD;&#xA;decimal difference = settedEggs_1_Raw - stockHatEggBal;&#xD;&#xA;if (difference &gt;= 0)&#xD;&#xA;{&#xD;&#xA;    settedEggs_1 = difference;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- STEP 4: Calculate CumHatchability_1 ---&#xD;&#xA;decimal cumHatchability_1 = 0;&#xD;&#xA;&#xD;&#xA;if (settedEggs_1_Raw != 0)&#xD;&#xA;{&#xD;&#xA;    decimal selChicks_1 = GetFieldValue(&quot;SelChicks_1&quot;);&#xD;&#xA;    decimal cullsChicks_1 = GetFieldValue(&quot;CullsChicks_1&quot;);&#xD;&#xA;    decimal deadChicks_1 = GetFieldValue(&quot;DeadChicks_1&quot;);&#xD;&#xA;    &#xD;&#xA;    decimal totalChicks_1 = selChicks_1 + cullsChicks_1 + deadChicks_1;&#xD;&#xA;    cumHatchability_1 = totalChicks_1 * 100 / settedEggs_1_Raw;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    decimal setEggBalHatEgg = GetFieldValue(&quot;SetEggBalHatEgg&quot;);&#xD;&#xA;    if (setEggBalHatEgg != 0)&#xD;&#xA;    {&#xD;&#xA;        decimal selChickBal = GetFieldValue(&quot;SelChickBalHatEgg&quot;);&#xD;&#xA;        decimal cullsBal = GetFieldValue(&quot;CullsBalHatEgg&quot;);&#xD;&#xA;        decimal deadsBal = GetFieldValue(&quot;DeadsBalHatEgg&quot;);&#xD;&#xA;        &#xD;&#xA;        decimal totalBal = selChickBal + cullsBal + deadsBal;&#xD;&#xA;        cumHatchability_1 = totalBal / setEggBalHatEgg * 100;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- STEP 5: Calculate EstChicks_PerEgg_1 ---&#xD;&#xA;decimal estChicks_PerEgg_1 = (balOfHatEggs_1 - settedEggs_1) * cumHatchability_1 / 100;&#xD;&#xA;&#xD;&#xA;// --- STEP 6: Calculate GradeA_1 ---&#xD;&#xA;decimal gradeA_1 = 0;&#xD;&#xA;if (settedEggs_1_Raw != 0)&#xD;&#xA;{&#xD;&#xA;    decimal selChicks_1 = GetFieldValue(&quot;SelChicks_1&quot;);&#xD;&#xA;    gradeA_1 = selChicks_1 * (settedEggs_1 / settedEggs_1_Raw);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- STEP 7: Calculate RejChicks_1 ---&#xD;&#xA;decimal rejChicks_1 = 0;&#xD;&#xA;if (settedEggs_1_Raw != 0)&#xD;&#xA;{&#xD;&#xA;    decimal cullsChicks_1 = GetFieldValue(&quot;CullsChicks_1&quot;);&#xD;&#xA;    decimal deadChicks_1 = GetFieldValue(&quot;DeadChicks_1&quot;);&#xD;&#xA;    rejChicks_1 = (cullsChicks_1 + deadChicks_1) * (settedEggs_1 / settedEggs_1_Raw);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- STEP 8: Calculate CumChicks_1 ---&#xD;&#xA;decimal cumChicks_1 = gradeA_1 + rejChicks_1;&#xD;&#xA;&#xD;&#xA;// --- STEP 9: Calculate CumChicks_Act_Est_1 ---&#xD;&#xA;decimal cumChicks_Act_Est_1 = estChicks_PerEgg_1 + cumChicks_1;&#xD;&#xA;&#xD;&#xA;// --- STEP 10: Get POL and calculate the ratio ---&#xD;&#xA;decimal pol = GetFieldValue(&quot;POL&quot;);&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    result = cumChicks_Act_Est_1 / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;private void xrTableCell156_BeforePrint_1(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;       // --- Declare values --- &#xD;&#xA;    decimal rejBroken_1 = 0;&#xD;&#xA;    decimal rejCrack_1 = 0;&#xD;&#xA;    decimal rejDef_1 = 0;&#xD;