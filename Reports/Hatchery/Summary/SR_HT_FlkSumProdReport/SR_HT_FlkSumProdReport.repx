al cullsChicks_1 = GetFieldValue(&quot;CullsChicks_1&quot;);&#xD;&#xA;    decimal deadChicks_1 = GetFieldValue(&quot;DeadChicks_1&quot;);&#xD;&#xA;    &#xD;&#xA;    decimal totalChicks_1 = selChicks_1 + cullsChicks_1 + deadChicks_1;&#xD;&#xA;    cumHatchability_1 = totalChicks_1 * 100 / settedEggs_1_Raw;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    decimal setEggBalHatEgg = GetFieldValue(&quot;SetEggBalHatEgg&quot;);&#xD;&#xA;    if (setEggBalHatEgg != 0)&#xD;&#xA;    {&#xD;&#xA;        decimal selChickBal = GetFieldValue(&quot;SelChickBalHatEgg&quot;);&#xD;&#xA;        decimal cullsBal = GetFieldValue(&quot;CullsBalHatEgg&quot;);&#xD;&#xA;        decimal deadsBal = GetFieldValue(&quot;DeadsBalHatEgg&quot;);&#xD;&#xA;        &#xD;&#xA;        decimal totalBal = selChickBal + cullsBal + deadsBal;&#xD;&#xA;        cumHatchability_1 = totalBal / setEggBalHatEgg * 100;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- STEP 5: Calculate EstChicks_PerEgg_1 ---&#xD;&#xA;decimal estChicks_PerEgg_1 = (balOfHatEggs_1 - settedEggs_1) * cumHatchability_1 / 100;&#xD;&#xA;&#xD;&#xA;// --- STEP 6: Get POL and calculate the ratio ---&#xD;&#xA;decimal pol = GetFieldValue(&quot;POL&quot;);&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    result = estChicks_PerEgg_1 / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell252_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Helper function for safe parsing&#xD;&#xA;decimal GetFieldValue(string fieldName)&#xD;&#xA;{&#xD;&#xA;    object value = GetCurrentColumnValue(fieldName);&#xD;&#xA;    if (value != null &amp;&amp; !string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(value.ToString(), out decimal result))&#xD;&#xA;            return result;&#xD;&#xA;    }&#xD;&#xA;    return 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Get values ---&#xD;&#xA;decimal farmInTake = GetFieldValue(&quot;FarmInTake&quot;);&#xD;&#xA;decimal farmInTake_1 = GetFieldValue(&quot;FarmInTake_1&quot;);&#xD;&#xA;decimal pol = GetFieldValue(&quot;POL&quot;);&#xD;&#xA;&#xD;&#xA;// --- Calculate CumRecEggs_HH ---&#xD;&#xA;decimal cumRecEggs_HH = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    cumRecEggs_HH = farmInTake / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Calculate CumRecEggs_HH_1 ---&#xD;&#xA;decimal cumRecEggs_HH_1 = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    cumRecEggs_HH_1 = farmInTake_1 / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Calculate the sum ---&#xD;&#xA;decimal result = cumRecEggs_HH + cumRecEggs_HH_1;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell255_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Helper function for safe parsing&#xD;&#xA;decimal GetFieldValue(string fieldName)&#xD;&#xA;{&#xD;&#xA;    object value = GetCurrentColumnValue(fieldName);&#xD;&#xA;    if (value != null &amp;&amp; !string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(value.ToString(), out decimal result))&#xD;&#xA;            return result;&#xD;&#xA;    }&#xD;&#xA;    return 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Calculate Part 1 rejection components ---&#xD;&#xA;decimal rejBroken = GetFieldValue(&quot;ST_RejBroken&quot;) + GetFieldValue(&quot;HT_RejBroken&quot;);&#xD;&#xA;decimal rejCrack = GetFieldValue(&quot;ST_RejCracks&quot;) + GetFieldValue(&quot;HT_RejCracks&quot;);&#xD;&#xA;decimal rejDef = GetFieldValue(&quot;HT_RejDeformed&quot;) + GetFieldValue(&quot;ST_RejDeformed&quot;);&#xD;&#xA;decimal rejOther = GetFieldValue(&quot;ST_RejOther&quot;) + GetFieldValue(&quot;HT_RejOther&quot;);&#xD;&#xA;decimal totalRejEggs = rejBroken + rejCrack + rejDef + rejOther;&#xD;&#xA;&#xD;&#xA;// --- Calculate Part 2 rejection components ---&#xD;&#xA;decimal rejBroken_1 = GetFieldValue(&quot;ST_RejBroken_1&quot;) + GetFieldValue(&quot;HT_RejBroken_1&quot;);&#xD;&#xA;decimal rejCrack_1 = GetFieldValue(&quot;ST_RejCracks_1&quot;) + GetFieldValue(&quot;HT_RejCracks_1&quot;);&#xD;&#xA;decimal rejDef_1 = GetFieldValue(&quot;HT_RejDeformed_1&quot;) + GetFieldValue(&quot;ST_RejDeformed_1&quot;);&#xD;&#xA;decimal rejOther_1 = GetFieldValue(&quot;ST_RejOther_1&quot;) + GetFieldValue(&quot;HT_RejOther_1&quot;);&#xD;&#xA;decimal totalRejEggs_1 = rejBroken_1 + rejCrack_1 + rejDef_1 + rejOther_1;&#xD;&#xA;&#xD;&#xA;// --- Get POL value ---&#xD;&#xA;decimal pol = GetFieldValue(&quot;POL&quot;);&#xD;&#xA;&#xD;&#xA;// --- Calculate the ratios ---&#xD;&#xA;decimal totalRejEggs_HH = 0;&#xD;&#xA;decimal totalRejEggs_HH_1 = 0;&#xD;&#xA;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    totalRejEggs_HH = totalRejEggs / pol;&#xD;&#xA;    totalRejEggs_HH_1 = totalRejEggs_1 / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Calculate the sum ---&#xD;&#xA;decimal result = totalRejEggs_HH + totalRejEggs_HH_1;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell258_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Helper function for safe parsing&#xD;&#xA;decimal GetFieldValue(string fieldName)&#xD;&#xA;{&#xD;&#xA;    object value = GetCurrentColumnValue(fieldName);&#xD;&#xA;    if (value != null &amp;&amp; !string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;    {&#xD;&#xA;        if (decimal.TryParse(value.ToString(), out decimal result))&#xD;&#xA;            return result;&#xD;&#xA;    }&#xD;&#xA;    return 0;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Calculate Part 1 components ---&#xD;&#xA;&#xD;&#xA;// Calculate rejection components for Part 1&#xD;&#xA;decimal rejBroken = GetFieldValue(&quot;ST_RejBroken&quot;) + GetFieldValue(&quot;HT_RejBroken&quot;);&#xD;&#xA;decimal rejCrack = GetFieldValue(&quot;ST_RejCracks&quot;) + GetFieldValue(&quot;HT_RejCracks&quot;);&#xD;&#xA;decimal rejDef = GetFieldValue(&quot;HT_RejDeformed&quot;) + GetFieldValue(&quot;ST_RejDeformed&quot;);&#xD;&#xA;decimal rejOther = GetFieldValue(&quot;ST_RejOther&quot;) + GetFieldValue(&quot;HT_RejOther&quot;);&#xD;&#xA;decimal totalRejEggs = rejBroken + rejCrack + rejDef + rejOther;&#xD;&#xA;&#xD;&#xA;// Calculate BalOfHatEggs for Part 1&#xD;&#xA;decimal farmInTake = GetFieldValue(&quot;FarmInTake&quot;);&#xD;&#xA;decimal balOfHatEggs = farmInTake - totalRejEggs;&#xD;&#xA;&#xD;&#xA;// --- Calculate Part 2 components ---&#xD;&#xA;&#xD;&#xA;// Calculate rejection components for Part 2&#xD;&#xA;decimal rejBroken_1 = GetFieldValue(&quot;ST_RejBroken_1&quot;) + GetFieldValue(&quot;HT_RejBroken_1&quot;);&#xD;&#xA;decimal rejCrack_1 = GetFieldValue(&quot;ST_RejCracks_1&quot;) + GetFieldValue(&quot;HT_RejCracks_1&quot;);&#xD;&#xA;decimal rejDef_1 = GetFieldValue(&quot;HT_RejDeformed_1&quot;) + GetFieldValue(&quot;ST_RejDeformed_1&quot;);&#xD;&#xA;decimal rejOther_1 = GetFieldValue(&quot;ST_RejOther_1&quot;) + GetFieldValue(&quot;HT_RejOther_1&quot;);&#xD;&#xA;decimal totalRejEggs_1 = rejBroken_1 + rejCrack_1 + rejDef_1 + rejOther_1;&#xD;&#xA;&#xD;&#xA;// Calculate BalOfHatEggs_1 for Part 2&#xD;&#xA;decimal farmInTake_1 = GetFieldValue(&quot;FarmInTake_1&quot;);&#xD;&#xA;decimal balOfHatEggs_1 = farmInTake_1 - totalRejEggs_1;&#xD;&#xA;&#xD;&#xA;// --- Get POL value ---&#xD;&#xA;decimal pol = GetFieldValue(&quot;POL&quot;);&#xD;&#xA;&#xD;&#xA;// --- Calculate the ratios ---&#xD;&#xA;decimal cumFinalHatEgg_HH = 0;&#xD;&#xA;decimal cumHatEgg_HH_1 = 0;&#xD;&#xA;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    cumFinalHatEgg_HH = balOfHatEggs / pol;&#xD;&#xA;    cumHatEgg_HH_1 = balOfHatEggs_1 / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Calculate the sum ---&#xD;&#xA;decimal result = cumFinalHatEgg_HH + cumHatEgg_HH_1;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell261_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Helper function for safe conversion&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// ==================== Get All Raw Values - Set 1 ====================&#xD;&#xA;decimal stRejBroken = SafeConvert(GetCurrentColumnValue(&quot;ST_RejBroken&quot;));&#xD;&#xA;decimal htRejBroken = SafeConvert(GetCurrentColumnValue(&quot;HT_RejBroken&quot;));&#xD;&#xA;decimal stRejCracks = SafeConvert(GetCurrentColumnValue(&quot;ST_RejCracks&quot;));&#xD;&#xA;decimal htRejCracks = SafeConvert(GetCurrentColumnValue(&quot;HT_RejCracks&quot;));&#xD;&#xA;decimal htRejDeformed = SafeConvert(GetCurrentColumnValue(&quot;HT_RejDeformed&quot;));&#xD;&#xA;decimal stRejDeformed = SafeConvert(GetCurrentColumnValue(&quot;ST_RejDeformed&quot;));&#xD;&#xA;decimal stRejOther = SafeConvert(GetCurrentColumnValue(&quot;ST_RejOther&quot;));&#xD;&#xA;decimal htRejOther = SafeConvert(GetCurrentColumnValue(&quot;HT_RejOther&quot;));&#xD;&#xA;decimal farmInTake = SafeConvert(GetCurrentColumnValue(&quot;FarmInTake&quot;));&#xD;&#xA;decimal settledEggs = SafeConvert(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;decimal selChicks = SafeConvert(GetCurrentColumnValue(&quot;SelChicks&quot;));&#xD;&#xA;decimal cullsChicks = SafeConvert(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;decimal deadChicks = SafeConvert(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;decimal pol = SafeConvert(GetCurrentColumnValue(&quot;POL&quot;));&#xD;&#xA;decimal erSoldAsHatEggs = SafeConvert(GetCurrentColumnValue(&quot;ER_SoldAsHatEggs&quot;));&#xD;&#xA;decimal esSoldAsHatEggs = SafeConvert(GetCurrentColumnValue(&quot;ES_SoldAsHatEggs&quot;));&#xD;&#xA;decimal erSoldAsTableEggs = SafeConvert(GetCurrentColumnValue(&quot;ER_SoldAsTableEggs&quot;));&#xD;&#xA;decimal esSoldAsTableEggs = SafeConvert(GetCurrentColumnValue(&quot;ES_SoldAsTableEggs&quot;));&#xD;&#xA;decimal erSendToOffal = SafeConvert(GetCurrentColumnValue(&quot;ER_SendToOffal&quot;));&#xD;&#xA;decimal esSendToOffal = SafeConvert(GetCurrentColumnValue(&quot;ES_SendToOffal&quot;));&#xD;&#xA;decimal setEggBalHatEgg = SafeConvert(GetCurrentColumnValue(&quot;SetEggBalHatEgg&quot;));&#xD;&#xA;decimal selChickBalHatEgg = SafeConvert(GetCurrentColumnValue(&quot;SelChickBalHatEgg&quot;));&#xD;&#xA;decimal cullsBalHatEgg = SafeConvert(GetCurrentColumnValue(&quot;CullsBalHatEgg&quot;));&#xD;&#xA;decimal deadsBalHatEgg = SafeConvert(GetCurrentColumnValue(&quot;DeadsBalHatEgg&quot;));&#xD;&#xA;&#xD;&#xA;// ==================== Get All Raw Values - Set 2 ====================&#xD;&#xA;decimal farmInTake_1 = SafeConvert(GetCurrentColumnValue(&quot;FarmInTake_1&quot;));&#xD;&#xA;decimal settledEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;SettedEggs_1&quot;));&#xD;&#xA;decimal selChicks_1 = SafeConvert(GetCurrentColumnValue(&quot;SelChicks_1&quot;));&#xD;&#xA;decimal cullsChicks_1 = SafeConvert(GetCurrentColumnValue(&quot;CullsChicks_1&quot;));&#xD;&#xA;decimal deadChicks_1 = SafeConvert(GetCurrentColumnValue(&quot;DeadChicks_1&quot;));&#xD;&#xA;decimal stRejBroken_1 = SafeConvert(GetCurrentColumnValue(&quot;ST_RejBroken_1&quot;));&#xD;&#xA;decimal htRejBroken_1 = SafeConvert(GetCurrentColumnValue(&quot;HT_RejBroken_1&quot;));&#xD;&#xA;decimal stRejCracks_1 = SafeConvert(GetCurrentColumnValue(&quot;ST_RejCracks_1&quot;));&#xD;&#xA;decimal htRejCracks_1 = SafeConvert(GetCurrentColumnValue(&quot;HT_RejCracks_1&quot;));&#xD;&#xA;decimal htRejDeformed_1 = SafeConvert(GetCurrentColumnValue(&quot;HT_RejDeformed_1&quot;));&#xD;&#xA;decimal stRejDeformed_1 = SafeConvert(GetCurrentColumnValue(&quot;ST_RejDeformed_1&quot;));&#xD;&#xA;decimal stRejOther_1 = SafeConvert(GetCurrentColumnValue(&quot;ST_RejOther_1&quot;));&#xD;&#xA;decimal htRejOther_1 = SafeConvert(GetCurrentColumnValue(&quot;HT_RejOther_1&quot;));&#xD;&#xA;decimal erSoldAsHatEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;ER_SoldAsHatEggs_1&quot;));&#xD;&#xA;decimal esSoldAsHatEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;ES_SoldAsHatEggs_1&quot;));&#xD;&#xA;decimal erSoldAsTableEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;ER_SoldAsTableEggs_1&quot;));&#xD;&#xA;decimal esSoldAsTableEggs_1 = SafeConvert(GetCurrentColumnValue(&quot;ES_SoldAsTableEggs_1&quot;));&#xD;&#xA;decimal erSendToOffal_1 = SafeConvert(GetCurrentColumnValue(&quot;ER_SendToOffal_1&quot;));&#xD;&#xA;decimal esSendToOffal_1 = SafeConvert(GetCurrentColumnValue(&quot;ES_SendToOffal_1&quot;));&#xD;&#xA;decimal setEggBalHatEgg_1 = SafeConvert(GetCurrentColumnValue(&quot;SetEggBalHatEgg_1&quot;));&#xD;&#xA;decimal selChickBalHatEgg_1 = SafeConvert(GetCurrentColumnValue(&quot;SelChickBalHatEgg_1&quot;));&#xD;&#xA;decimal cullsBalHatEgg_1 = SafeConvert(GetCurrentColumnValue(&quot;CullsBalHatEgg_1&quot;));&#xD;&#xA;decimal deadsBalHatEgg_1 = SafeConvert(GetCurrentColumnValue(&quot;DeadsBalHatEgg_1&quot;));&#xD;&#xA;&#xD;&#xA;// ==================== Set 1 Calculations ====================&#xD;&#xA;decimal rejBroken = stRejBroken + htRejBroken;&#xD;&#xA;decimal rejCrack = stRejCracks + htRejCracks;&#xD;&#xA;decimal rejDef = htRejDeformed + stRejDeformed;&#xD;&#xA;decimal rejOther = stRejOther + htRejOther;&#xD;&#xA;decimal totalRejEggs = rejBroken + rejCrack + rejDef + rejOther;&#xD;&#xA;decimal balOfHatEggs = farmInTake - totalRejEggs;&#xD;&#xA;&#xD;&#xA;decimal soldHatEggs = erSoldAsHatEggs + esSoldAsHatEggs;&#xD;&#xA;decimal soldTableEggs = erSoldAsTableEggs + esSoldAsTableEggs;&#xD;&#xA;decimal eggsToOffal = erSendToOffal + esSendToOffal;&#xD;&#xA;decimal totalEggSold = soldHatEggs + soldTableEggs + eggsToOffal;&#xD;&#xA;&#xD;&#xA;decimal stockHatEggBal = balOfHatEggs - (settledEggs + totalEggSold);&#xD;&#xA;&#xD;&#xA;decimal actHatchBalanceEggs = 0;&#xD;&#xA;if (setEggBalHatEgg != 0)&#xD;&#xA;{&#xD;&#xA;    actHatchBalanceEggs = ((selChickBalHatEgg + cullsBalHatEgg + deadsBalHatEgg) / setEggBalHatEgg) * 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;decimal estChicksPerStock_HE = (stockHatEggBal * actHatchBalanceEggs) / 100.0m;&#xD;&#xA;&#xD;&#xA;decimal cumHatchability = 0;&#xD;&#xA;if (settledEggs != 0)&#xD;&#xA;{&#xD;&#xA;    cumHatchability = ((selChicks + cullsChicks + deadChicks) / settledEggs) * 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;decimal estChicksPerEgg = 0;&#xD;&#xA;if (totalEggSold != 0)&#xD;&#xA;{&#xD;&#xA;    estChicksPerEgg = totalEggSold * cumHatchability / 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;decimal cumChicks = selChicks + cullsChicks + deadChicks;&#xD;&#xA;decimal cumChicks_Act_Est = estChicksPerEgg + estChicksPerStock_HE + cumChicks;&#xD;&#xA;&#xD;&#xA;decimal cumChicks_ActEst_HH = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    cumChicks_ActEst_HH = cumChicks_Act_Est / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;decimal cumFinalHatEgg_HH = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    cumFinalHatEgg_HH = balOfHatEggs / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// ==================== Set 2 Calculations ====================&#xD;&#xA;decimal rejBroken_1 = stRejBroken_1 + htRejBroken_1;&#xD;&#xA;decimal rejCrack_1 = stRejCracks_1 + htRejCracks_1;&#xD;&#xA;decimal rejDef_1 = htRejDeformed_1 + stRejDeformed_1;&#xD;&#xA;decimal rejOther_1 = stRejOther_1 + htRejOther_1;&#xD;&#xA;decimal totalRejEggs_1 = rejBroken_1 + rejCrack_1 + rejDef_1 + rejOther_1;&#xD;&#xA;decimal balOfHatEggs_1 = farmInTake_1 - totalRejEggs_1;&#xD;&#xA;&#xD;&#xA;decimal soldHatEggs_1 = erSoldAsHatEggs_1 + esSoldAsHatEggs_1;&#xD;&#xA;decimal soldTableEggs_1 = erSoldAsTableEggs_1 + esSoldAsTableEggs_1;&#xD;&#xA;decimal eggsToOffal_1 = erSendToOffal_1 + esSendToOffal_1;&#xD;&#xA;decimal totalEggSold_1 = soldHatEggs_1 + soldTableEggs_1 + eggsToOffal_1;&#xD;&#xA;&#xD;&#xA;decimal stockHatEggBal_1 = balOfHatEggs_1 - (settledEggs_1 + totalEggSold_1);&#xD;&#xA;&#xD;&#xA;decimal actHatchBalanceEggs_1 = 0;&#xD;&#xA;if (setEggBalHatEgg_1 != 0)&#xD;&#xA;{&#xD;&#xA;    actHatchBalanceEggs_1 = ((selChickBalHatEgg_1 + cullsBalHatEgg_1 + deadsBalHatEgg_1) / setEggBalHatEgg_1) * 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;decimal cumHatchability_1 = 0;&#xD;&#xA;if (settledEggs_1 != 0)&#xD;&#xA;{&#xD;&#xA;    cumHatchability_1 = ((selChicks_1 + cullsChicks_1 + deadChicks_1) * 100) / settledEggs_1;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cumHatchability_1 = actHatchBalanceEggs;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;decimal settedEggs_1_adj = 0;&#xD;&#xA;if (settledEggs_1 - stockHatEggBal &lt; 0)&#xD;&#xA;{&#xD;&#xA;    settedEggs_1_adj = 0;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    settedEggs_1_adj = settledEggs_1 - stockHatEggBal;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;decimal gradeA_1 = 0;&#xD;&#xA;if (settledEggs_1 != 0)&#xD;&#xA;{&#xD;&#xA;    gradeA_1 = selChicks_1 * (settedEggs_1_adj / settledEggs_1);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;decimal rejChicks_1 = 0;&#xD;&#xA;if (settledEggs_1 != 0)&#xD;&#xA;{&#xD;&#xA;    rejChicks_1 = (cullsChicks_1 + deadChicks_1) * (settedEggs_1_adj / settledEggs_1);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;decimal cumChicks_1 = gradeA_1 + rejChicks_1;&#xD;&#xA;&#xD;&#xA;decimal estChicks_PerEgg_1 = 0;&#xD;&#xA;if (balOfHatEggs_1 - settledEggs_1 &gt; 0)&#xD;&#xA;{&#xD;&#xA;    estChicks_PerEgg_1 = (balOfHatEggs_1 - settledEggs_1) * cumHatchability_1 / 100.0m;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;decimal cumChicks_Act_Est_1 = estChicks_PerEgg_1 + cumChicks_1;&#xD;&#xA;&#xD;&#xA;decimal cumChicks_ActEst_HH_1 = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    cumChicks_ActEst_HH_1 = cumChicks_Act_Est_1 / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;decimal cumHatEgg_HH_1 = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    cumHatEgg_HH_1 = balOfHatEggs_1 / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// ==================== Final Calculations ====================&#xD;&#xA;decimal abCumHatchEggsHH = cumFinalHatEgg_HH + cumHatEgg_HH_1;&#xD;&#xA;decimal abCumTotalChicksHH = cumChicks_ActEst_HH + cumChicks_ActEst_HH_1;&#xD;&#xA;&#xD;&#xA;// ==================== Final Result ====================&#xD;&#xA;if (abCumHatchEggsHH != 0)&#xD;&#xA;{&#xD;&#xA;    decimal result = (abCumTotalChicksHH / abCumHatchEggsHH) * 100.0m;&#xD;&#xA;    result = Math.Round(result, 2);&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;    &#xD;&#xA;   }&#xD;&#xA;&#xD;&#xA;private void xrTableCell263_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;) ?? 0);&#xD;&#xA;decimal selChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;) ?? 0);&#xD;&#xA;decimal cullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;) ?? 0);&#xD;&#xA;decimal deadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;) ?? 0);&#xD;&#xA;decimal selChicks_1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks_1&quot;) ?? 0);&#xD;&#xA;decimal cullsChicks_1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks_1&quot;) ?? 0);&#xD;&#xA;decimal deadChicks_1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks_1&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Calculate {@CumChicks}&#xD;&#xA;decimal cumChicks = selChicks + cullsChicks + deadChicks;&#xD;&#xA;&#xD;&#xA;// Calculate total chicks from both sets&#xD;&#xA;decimal totalChicks = cumChicks + selChicks_1 + cullsChicks_1 + deadChicks_1;&#xD;&#xA;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    decimal result = totalChicks / pol;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell265_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;) ?? 0);&#xD;&#xA;decimal cullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;) ?? 0);&#xD;&#xA;decimal deadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;) ?? 0);&#xD;&#xA;decimal cullsChicks_1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks_1&quot;) ?? 0);&#xD;&#xA;decimal deadChicks_1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks_1&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Calculate {@RejChicks}&#xD;&#xA;decimal rejChicks = cullsChicks + deadChicks;&#xD;&#xA;&#xD;&#xA;// Calculate total rejected chicks from both sets&#xD;&#xA;decimal totalRejChicks = rejChicks + cullsChicks_1 + deadChicks_1;&#xD;&#xA;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    decimal result = totalRejChicks / pol;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell267_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;) ?? 0);&#xD;&#xA;decimal selChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;) ?? 0);&#xD;&#xA;decimal selChicks_1 = Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks_1&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;// Calculate total selected chicks from both sets&#xD;&#xA;decimal totalSelChicks = selChicks + selChicks_1;&#xD;&#xA;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    decimal result = totalSelChicks / pol;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell264_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// ==================== Helper for safe conversion ====================&#xD;&#xA;decimal SafeConvert(object value)&#xD;&#xA;{&#xD;&#xA;    if (value == null || value == DBNull.Value || string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        return 0;&#xD;&#xA;    return Convert.ToDecimal(value);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// ==================== Get All Values ====================&#xD;&#xA;// Set 1 - Basic fields&#xD;&#xA;decimal stRejBroken = SafeConvert(GetCurrentColumnValue(&quot;ST_RejBroken&quot;));&#xD;&#xA;decimal htRejBroken = SafeConvert(GetCurrentColumnValue(&quot;HT_RejBroken&quot;));&#xD;&#xA;decimal stRejCracks = SafeConvert(GetCurrentColumnValue(&quot;ST_RejCracks&quot;));&#xD;&#xA;decimal htRejCracks = SafeConvert(GetCurrentColumnValue(&quot;HT_RejCracks&quot;));&#xD;&#xA;decimal htRejDeformed = SafeConvert(GetCurrentColumnValue(&quot;HT_RejDeformed&quot;));&#xD;&#xA;decimal stRejDeformed = SafeConvert(GetCurrentColumnValue(&quot;ST_RejDeformed&quot;));&#xD;&#xA;decimal stRejOther = SafeConvert(GetCurrentColumnValue(&quot;ST_RejOther&quot;));&#xD;&#xA;decimal htRejOther = SafeConvert(GetCurrentColumnValue(&quot;HT_RejOther&quot;));&#xD;&#xA;decimal erSoldAsHatEggs = SafeConvert(GetCurrentColumnValue(&quot;ER_SoldAsHatEggs&quot;));&#xD;&#xA;decimal esSoldAsHatEggs = SafeConvert(GetCurrentColumnValue(&quot;ES_SoldAsHatEggs&quot;));&