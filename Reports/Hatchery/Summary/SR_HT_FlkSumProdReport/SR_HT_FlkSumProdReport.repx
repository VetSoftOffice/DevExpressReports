mpStCracks))&#xD;&#xA;        stRejCracks = tempStCracks;&#xD;&#xA;    &#xD;&#xA;    decimal htRejDeformed = 0, stRejDeformed = 0;&#xD;&#xA;    object valHtDeformed = GetCurrentColumnValue(&quot;HT_RejDeformed&quot;);&#xD;&#xA;    if (valHtDeformed != null &amp;&amp; decimal.TryParse(valHtDeformed.ToString(), out decimal tempHtDeformed))&#xD;&#xA;        htRejDeformed = tempHtDeformed;&#xD;&#xA;    &#xD;&#xA;    object valStDeformed = GetCurrentColumnValue(&quot;ST_RejDeformed&quot;);&#xD;&#xA;    if (valStDeformed != null &amp;&amp; decimal.TryParse(valStDeformed.ToString(), out decimal tempStDeformed))&#xD;&#xA;        stRejDeformed = tempStDeformed;&#xD;&#xA;    &#xD;&#xA;    decimal htRejOther = 0, stRejOther = 0;&#xD;&#xA;    object valHtOther = GetCurrentColumnValue(&quot;HT_RejOther&quot;);&#xD;&#xA;    if (valHtOther != null &amp;&amp; decimal.TryParse(valHtOther.ToString(), out decimal tempHtOther))&#xD;&#xA;        htRejOther = tempHtOther;&#xD;&#xA;    &#xD;&#xA;    object valStOther = GetCurrentColumnValue(&quot;ST_RejOther&quot;);&#xD;&#xA;    if (valStOther != null &amp;&amp; decimal.TryParse(valStOther.ToString(), out decimal tempStOther))&#xD;&#xA;        stRejOther = tempStOther;&#xD;&#xA;    &#xD;&#xA;    decimal rejBroken = htRejBroken + stRejBroken;&#xD;&#xA;    decimal rejCrack = htRejCracks + stRejCracks;&#xD;&#xA;    decimal rejDef = htRejDeformed + stRejDeformed;&#xD;&#xA;    decimal rejOther = htRejOther + stRejOther;&#xD;&#xA;    &#xD;&#xA;    decimal totalRejEggs = rejBroken + rejCrack + rejDef + rejOther;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 3: Calculate BalOfHatEggs ---&#xD;&#xA;    decimal balOfHatEggs = farmInTake - totalRejEggs;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 4: Calculate TotalEggSold ---&#xD;&#xA;    decimal erSoldAsHatEggs = 0, esSoldAsHatEggs = 0;&#xD;&#xA;    object valErHat = GetCurrentColumnValue(&quot;ER_SoldAsHatEggs&quot;);&#xD;&#xA;    if (valErHat != null &amp;&amp; decimal.TryParse(valErHat.ToString(), out decimal tempErHat))&#xD;&#xA;        erSoldAsHatEggs = tempErHat;&#xD;&#xA;    &#xD;&#xA;    object valEsHat = GetCurrentColumnValue(&quot;ES_SoldAsHatEggs&quot;);&#xD;&#xA;    if (valEsHat != null &amp;&amp; decimal.TryParse(valEsHat.ToString(), out decimal tempEsHat))&#xD;&#xA;        esSoldAsHatEggs = tempEsHat;&#xD;&#xA;    &#xD;&#xA;    decimal erSoldAsTableEggs = 0, esSoldAsTableEggs = 0;&#xD;&#xA;    object valErTable = GetCurrentColumnValue(&quot;ER_SoldAsTableEggs&quot;);&#xD;&#xA;    if (valErTable != null &amp;&amp; decimal.TryParse(valErTable.ToString(), out decimal tempErTable))&#xD;&#xA;        erSoldAsTableEggs = tempErTable;&#xD;&#xA;    &#xD;&#xA;    object valEsTable = GetCurrentColumnValue(&quot;ES_SoldAsTableEggs&quot;);&#xD;&#xA;    if (valEsTable != null &amp;&amp; decimal.TryParse(valEsTable.ToString(), out decimal tempEsTable))&#xD;&#xA;        esSoldAsTableEggs = tempEsTable;&#xD;&#xA;    &#xD;&#xA;    decimal erSendToOffal = 0, esSendToOffal = 0;&#xD;&#xA;    object valErOffal = GetCurrentColumnValue(&quot;ER_SendToOffal&quot;);&#xD;&#xA;    if (valErOffal != null &amp;&amp; decimal.TryParse(valErOffal.ToString(), out decimal tempErOffal))&#xD;&#xA;        erSendToOffal = tempErOffal;&#xD;&#xA;    &#xD;&#xA;    object valEsOffal = GetCurrentColumnValue(&quot;ES_SendToOffal&quot;);&#xD;&#xA;    if (valEsOffal != null &amp;&amp; decimal.TryParse(valEsOffal.ToString(), out decimal tempEsOffal))&#xD;&#xA;        esSendToOffal = tempEsOffal;&#xD;&#xA;    &#xD;&#xA;    decimal soldHatEggs = erSoldAsHatEggs + esSoldAsHatEggs;&#xD;&#xA;    decimal soldTableEggs = erSoldAsTableEggs + esSoldAsTableEggs;&#xD;&#xA;    decimal eggsToOffal = erSendToOffal + esSendToOffal;&#xD;&#xA;    decimal totalEggSold = soldHatEggs + soldTableEggs + eggsToOffal;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 5: Calculate StockHatEggBal ---&#xD;&#xA;    decimal stockHatEggBal = balOfHatEggs - (settedEggs + totalEggSold);&#xD;&#xA;    &#xD;&#xA;    // --- STEP 6: Calculate CumHatchability ---&#xD;&#xA;    decimal cumHatchability = 0;&#xD;&#xA;    decimal selChicks = 0, cullsChicks = 0, deadChicks = 0;  // Declared once here&#xD;&#xA;    &#xD;&#xA;    object valSel = GetCurrentColumnValue(&quot;SelChicks&quot;);&#xD;&#xA;    if (valSel != null &amp;&amp; decimal.TryParse(valSel.ToString(), out decimal tempSel))&#xD;&#xA;        selChicks = tempSel;&#xD;&#xA;    &#xD;&#xA;    object valCulls = GetCurrentColumnValue(&quot;CullsChicks&quot;);&#xD;&#xA;    if (valCulls != null &amp;&amp; decimal.TryParse(valCulls.ToString(), out decimal tempCulls))&#xD;&#xA;        cullsChicks = tempCulls;&#xD;&#xA;    &#xD;&#xA;    object valDead = GetCurrentColumnValue(&quot;DeadChicks&quot;);&#xD;&#xA;    if (valDead != null &amp;&amp; decimal.TryParse(valDead.ToString(), out decimal tempDead))&#xD;&#xA;        deadChicks = tempDead;&#xD;&#xA;    &#xD;&#xA;    if (settedEggs != 0)&#xD;&#xA;    {&#xD;&#xA;        cumHatchability = (selChicks + cullsChicks + deadChicks) / settedEggs * 100;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- STEP 7: Calculate EstChicks_PerEgg ---&#xD;&#xA;    decimal estChicks_PerEgg = totalEggSold * cumHatchability / 100;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 8: Calculate ActHatchBalanceEggs ---&#xD;&#xA;    decimal actHatchBalanceEggs = 0;&#xD;&#xA;    if (setEggBalHatEgg != 0)&#xD;&#xA;    {&#xD;&#xA;        decimal selChickBal = 0, cullsBal = 0, deadsBal = 0;&#xD;&#xA;        &#xD;&#xA;        object valSelBal = GetCurrentColumnValue(&quot;SelChickBalHatEgg&quot;);&#xD;&#xA;        if (valSelBal != null &amp;&amp; decimal.TryParse(valSelBal.ToString(), out decimal tempSelBal))&#xD;&#xA;            selChickBal = tempSelBal;&#xD;&#xA;        &#xD;&#xA;        object valCullsBal = GetCurrentColumnValue(&quot;CullsBalHatEgg&quot;);&#xD;&#xA;        if (valCullsBal != null &amp;&amp; decimal.TryParse(valCullsBal.ToString(), out decimal tempCullsBal))&#xD;&#xA;            cullsBal = tempCullsBal;&#xD;&#xA;        &#xD;&#xA;        object valDeadsBal = GetCurrentColumnValue(&quot;DeadsBalHatEgg&quot;);&#xD;&#xA;        if (valDeadsBal != null &amp;&amp; decimal.TryParse(valDeadsBal.ToString(), out decimal tempDeadsBal))&#xD;&#xA;            deadsBal = tempDeadsBal;&#xD;&#xA;        &#xD;&#xA;        actHatchBalanceEggs = (selChickBal + cullsBal + deadsBal) / setEggBalHatEgg * 100;&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    // --- STEP 9: Calculate ESTChicks_PerStock_HE ---&#xD;&#xA;    decimal estChicks_PerStock_HE = stockHatEggBal * actHatchBalanceEggs / 100;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 10: Calculate CumChicks ---&#xD;&#xA;    // Use the existing selChicks, cullsChicks, deadChicks variables (already declared in Step 6)&#xD;&#xA;    decimal cumChicks = selChicks + cullsChicks + deadChicks;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 11: Final Equation ---&#xD;&#xA;    decimal result = estChicks_PerEgg + estChicks_PerStock_HE + cumChicks;&#xD;&#xA;    &#xD;&#xA;    // --- Assign result to cell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;);&#xD;&#xA;   }&#xD;&#xA;&#xD;&#xA;private void xrTableCell73_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     decimal farmInTake = GetCurrentColumnValue(&quot;FarmInTake&quot;) != null ? Convert.ToDecimal(GetCurrentColumnValue(&quot;FarmInTake&quot;)) : 0;&#xD;&#xA;    decimal pol = GetCurrentColumnValue(&quot;POL&quot;) != null ? Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;)) : 0;&#xD;&#xA;&#xD;&#xA;    if (pol != 0)&#xD;&#xA;        ((XRTableCell)sender).Text = (farmInTake / pol).ToString(&quot;0.00&quot;); // formatted to 2 decimals&#xD;&#xA;    else&#xD;&#xA;        ((XRTableCell)sender).Text = &quot;0&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell95_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     // Get values safely with null checks&#xD;&#xA;    decimal pol = GetCurrentColumnValue(&quot;POL&quot;) != null ? Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;)) : 0;&#xD;&#xA;&#xD;&#xA;    decimal rejBroken = GetCurrentColumnValue(&quot;RejBroken&quot;) != null ? Convert.ToDecimal(GetCurrentColumnValue(&quot;RejBroken&quot;)) : 0;&#xD;&#xA;    decimal rejCrack  = GetCurrentColumnValue(&quot;RejCrack&quot;)  != null ? Convert.ToDecimal(GetCurrentColumnValue(&quot;RejCrack&quot;))  : 0;&#xD;&#xA;    decimal rejDef    = GetCurrentColumnValue(&quot;RejDef&quot;)    != null ? Convert.ToDecimal(GetCurrentColumnValue(&quot;RejDef&quot;))    : 0;&#xD;&#xA;    decimal rejOther  = GetCurrentColumnValue(&quot;RejOther&quot;)  != null ? Convert.ToDecimal(GetCurrentColumnValue(&quot;RejOther&quot;))  : 0;&#xD;&#xA;&#xD;&#xA;    // Total rejected eggs&#xD;&#xA;    decimal totalRejEggs = rejBroken + rejCrack + rejDef + rejOther;&#xD;&#xA;&#xD;&#xA;    // Final calculation&#xD;&#xA;    decimal result = (pol == 0) ? 0 : (totalRejEggs / pol);&#xD;&#xA;&#xD;&#xA;    // Assign to cell text (formatted with 2 decimals)&#xD;&#xA;    ((XRTableCell)sender).Text = result.ToString(&quot;0.00&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell98_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // Get POL&#xD;&#xA;    decimal pol = GetCurrentColumnValue(&quot;POL&quot;) != null ? Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;)) : 0;&#xD;&#xA;&#xD;&#xA;    // FarmInTake&#xD;&#xA;    decimal farmInTake = GetCurrentColumnValue(&quot;FarmInTake&quot;) != null ? Convert.ToDecimal(GetCurrentColumnValue(&quot;FarmInTake&quot;)) : 0;&#xD;&#xA;&#xD;&#xA;    // Rejections&#xD;&#xA;    decimal rejBroken = GetCurrentColumnValue(&quot;RejBroken&quot;) != null ? Convert.ToDecimal(GetCurrentColumnValue(&quot;RejBroken&quot;)) : 0;&#xD;&#xA;    decimal rejCrack  = GetCurrentColumnValue(&quot;RejCrack&quot;)  != null ? Convert.ToDecimal(GetCurrentColumnValue(&quot;RejCrack&quot;))  : 0;&#xD;&#xA;    decimal rejDef    = GetCurrentColumnValue(&quot;RejDef&quot;)    != null ? Convert.ToDecimal(GetCurrentColumnValue(&quot;RejDef&quot;))    : 0;&#xD;&#xA;    decimal rejOther  = GetCurrentColumnValue(&quot;RejOther&quot;)  != null ? Convert.ToDecimal(GetCurrentColumnValue(&quot;RejOther&quot;))  : 0;&#xD;&#xA;&#xD;&#xA;    // Total rejected eggs&#xD;&#xA;    decimal totalRejEggs = rejBroken + rejCrack + rejDef + rejOther;&#xD;&#xA;&#xD;&#xA;    // BalOfHatEggs = FarmInTake - Total_RejEggs&#xD;&#xA;    decimal balOfHatEggs = farmInTake - totalRejEggs;&#xD;&#xA;&#xD;&#xA;    // Final calculation&#xD;&#xA;    decimal result = (pol == 0) ? 0 : (balOfHatEggs / pol);&#xD;&#xA;&#xD;&#xA;    // Assign result to the cell (2 decimals formatting)&#xD;&#xA;    ((XRTableCell)sender).Text = result.ToString(&quot;0.00&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell104_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // Get POL&#xD;&#xA;    decimal pol = GetCurrentColumnValue(&quot;POL&quot;) != null ? Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;)) : 0;&#xD;&#xA;&#xD;&#xA;    // Get CumChicks&#xD;&#xA;    decimal cumChicks = GetCurrentColumnValue(&quot;CumChicks&quot;) != null ? Convert.ToDecimal(GetCurrentColumnValue(&quot;CumChicks&quot;)) : 0;&#xD;&#xA;&#xD;&#xA;    // Final calculation&#xD;&#xA;    decimal result = (pol == 0) ? 0 : (cumChicks / pol);&#xD;&#xA;&#xD;&#xA;    // Assign result to the cell (formatted with 2 decimals)&#xD;&#xA;    ((XRTableCell)sender).Text = result.ToString(&quot;0.00&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell107_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     // Get values from dataset&#xD;&#xA;    decimal settedEggs = GetCurrentColumnValue(&quot;SettedEggs&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    decimal selChicks = GetCurrentColumnValue(&quot;SelChicks&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    decimal cullsChicks = GetCurrentColumnValue(&quot;CullsChicks&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    decimal deadChicks = GetCurrentColumnValue(&quot;DeadChicks&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    // Compute CumHatchability&#xD;&#xA;    decimal result = (settedEggs != 0)&#xD;&#xA;        ? ((selChicks + cullsChicks + deadChicks) / settedEggs * 100)&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    // Assign result to the XRTableCell&#xD;&#xA;    ((XRTableCell)sender).Text = result.ToString(&quot;0.00&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell85_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // Get values&#xD;&#xA;    decimal pol = GetCurrentColumnValue(&quot;POL&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    decimal rejChicks = GetCurrentColumnValue(&quot;RejChicks&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;RejChicks&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    // Compute result&#xD;&#xA;    decimal result = (pol != 0) ? (rejChicks / pol) : 0;&#xD;&#xA;&#xD;&#xA;    // Assign result to cell&#xD;&#xA;    ((XRTableCell)sender).Text = result.ToString(&quot;0.00&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell94_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     // Get values&#xD;&#xA;    decimal pol = GetCurrentColumnValue(&quot;POL&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    decimal selChicks = GetCurrentColumnValue(&quot;SelChicks&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    // Compute result&#xD;&#xA;    decimal result = (pol != 0) ? (selChicks / pol) : 0;&#xD;&#xA;&#xD;&#xA;    // Assign result to the table cell&#xD;&#xA;    ((XRTableCell)sender).Text = result.ToString(&quot;0.00&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell118_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Read POL&#xD;&#xA;    decimal pol = GetCurrentColumnValue(&quot;POL&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    // Read TotalEggSold (from global variable &quot;total&quot;)&#xD;&#xA;    decimal totalEggSold = total;  // &lt;--- as you said, global from another script&#xD;&#xA;&#xD;&#xA;    // Compute CumHatchability&#xD;&#xA;    decimal settedEggs = GetCurrentColumnValue(&quot;SettedEggs&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;    decimal selChicks = GetCurrentColumnValue(&quot;SelChicks&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;SelChicks&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;    decimal cullsChicks = GetCurrentColumnValue(&quot;CullsChicks&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;    decimal deadChicks = GetCurrentColumnValue(&quot;DeadChicks&quot;) != null&#xD;&#xA;        ? Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;))&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    decimal cumHatchability = (settedEggs != 0)&#xD;&#xA;        ? ((selChicks + cullsChicks + deadChicks) / settedEggs) * 100&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    // Compute EstChicks_PerEgg&#xD;&#xA;    decimal estChicksPerEgg = (totalEggSold != 0 &amp;&amp; cumHatchability != 0)&#xD;&#xA;        ? (totalEggSold * cumHatchability / 100)&#xD;&#xA;        : 0;&#xD;&#xA;&#xD;&#xA;    // Final formula: divide by POL&#xD;&#xA;    decimal result = (pol != 0) ? (estChicksPerEgg / pol) : 0;&#xD;&#xA;&#xD;&#xA;    // Assign result&#xD;&#xA;    ((XRTableCell)sender).Text = result.ToString(&quot;0.00&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell124_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- STEP 1: Read POL ---&#xD;&#xA;    decimal pol = 0;&#xD;&#xA;    object valPol = GetCurrentColumnValue(&quot;POL&quot;);&#xD;&#xA;    if (valPol != null &amp;&amp; decimal.TryParse(valPol.ToString(), out decimal tempPol))&#xD;&#xA;        pol = tempPol;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 2: Read FarmInTake ---&#xD;&#xA;    decimal farmInTake = 0;&#xD;&#xA;    object valFarm = GetCurrentColumnValue(&quot;FarmInTake&quot;);&#xD;&#xA;    if (valFarm != null &amp;&amp; decimal.TryParse(valFarm.ToString(), out decimal tempFarm))&#xD;&#xA;        farmInTake = tempFarm;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 3: Read SettedEggs ---&#xD;&#xA;    decimal settedEggs = 0;&#xD;&#xA;    object valSetted = GetCurrentColumnValue(&quot;SettedEggs&quot;);&#xD;&#xA;    if (valSetted != null &amp;&amp; decimal.TryParse(valSetted.ToString(), out decimal tempSetted))&#xD;&#xA;        settedEggs = tempSetted;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 4: Read SetEggBalHatEgg ---&#xD;&#xA;    decimal setEggBalHatEgg = 0;&#xD;&#xA;    object valSetEgg = GetCurrentColumnValue(&quot;SetEggBalHatEgg&quot;);&#xD;&#xA;    if (valSetEgg != null &amp;&amp; decimal.TryParse(valSetEgg.ToString(), out decimal tempSetEgg))&#xD;&#xA;        setEggBalHatEgg = tempSetEgg;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 5: Calculate Total_RejEggs ---&#xD;&#xA;    decimal htRejBroken = 0, stRejBroken = 0;&#xD;&#xA;    object valHtBroken = GetCurrentColumnValue(&quot;HT_RejBroken&quot;);&#xD;&#xA;    if (valHtBroken != null &amp;&amp; decimal.TryParse(valHtBroken.ToString(), out decimal tempHtBroken))&#xD;&#xA;        htRejBroken = tempHtBroken;&#xD;&#xA;    &#xD;&#xA;    object valStBroken = GetCurrentColumnValue(&quot;ST_RejBroken&quot;);&#xD;&#xA;    if (valStBroken != null &amp;&amp; decimal.TryParse(valStBroken.ToString(), out decimal tempStBroken))&#xD;&#xA;        stRejBroken = tempStBroken;&#xD;&#xA;    &#xD;&#xA;    decimal htRejCracks = 0, stRejCracks = 0;&#xD;&#xA;    object valHtCracks = GetCurrentColumnValue(&quot;HT_RejCracks&quot;);&#xD;&#xA;    if (valHtCracks != null &amp;&amp; decimal.TryParse(valHtCracks.ToString(), out decimal tempHtCracks))&#xD;&#xA;        htRejCracks = tempHtCracks;&#xD;&#xA;    &#xD;&#xA;    object valStCracks = GetCurrentColumnValue(&quot;ST_RejCracks&quot;);&#xD;&#xA;    if (valStCracks != null &amp;&amp; decimal.TryParse(valStCracks.ToString(), out decimal tempStCracks))&#xD;&#xA;        stRejCracks = tempStCracks;&#xD;&#xA;    &#xD;&#xA;    decimal htRejDeformed = 0, stRejDeformed = 0;&#xD;&#xA;    object valHtDeformed = GetCurrentColumnValue(&quot;HT_RejDeformed&quot;);&#xD;&#xA;    if (valHtDeformed != null &amp;&amp; decimal.TryParse(valHtDeformed.ToString(), out decimal tempHtDeformed))&#xD;&#xA;        htRejDeformed = tempHtDeformed;&#xD;&#xA;    &#xD;&#xA;    object valStDeformed = GetCurrentColumnValue(&quot;ST_RejDeformed&quot;);&#xD;&#xA;    if (valStDeformed != null &amp;&amp; decimal.TryParse(valStDeformed.ToString(), out decimal tempStDeformed))&#xD;&#xA;        stRejDeformed = tempStDeformed;&#xD;&#xA;    &#xD;&#xA;    decimal htRejOther = 0, stRejOther = 0;&#xD;&#xA;    object valHtOther = GetCurrentColumnValue(&quot;HT_RejOther&quot;);&#xD;&#xA;    if (valHtOther != null &amp;&amp; decimal.TryParse(valHtOther.ToString(), out decimal tempHtOther))&#xD;&#xA;        htRejOther = tempHtOther;&#xD;&#xA;    &#xD;&#xA;    object valStOther = GetCurrentColumnValue(&quot;ST_RejOther&quot;);&#xD;&#xA;    if (valStOther != null &amp;&amp; decimal.TryParse(valStOther.ToString(), out decimal tempStOther))&#xD;&#xA;        stRejOther = tempStOther;&#xD;&#xA;    &#xD;&#xA;    decimal rejBroken = htRejBroken + stRejBroken;&#xD;&#xA;    decimal rejCrack = htRejCracks + stRejCracks;&#xD;&#xA;    decimal rejDef = htRejDeformed + stRejDeformed;&#xD;&#xA;    decimal rejOther = htRejOther + stRejOther;&#xD;&#xA;    &#xD;&#xA;    decimal totalRejEggs = rejBroken + rejCrack + rejDef + rejOther;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 6: Calculate BalOfHatEggs ---&#xD;&#xA;    decimal balOfHatEggs = farmInTake - totalRejEggs;&#xD;&#xA;    &#xD;&#xA;    // --- STEP 7: Calculate TotalEggSold ---&#xD;&#xA;    decimal erSoldAsHatEggs = 0, esSoldAsHatEggs = 0;&#xD;&#xA;    object valErHat = GetCurrentColumnValue(&quot;ER_SoldAsHatEggs&quot;);&#xD;&#xA;    if (valErHat != null &amp;&amp; decimal.TryParse(valErHat.ToString(), out decimal tempErHat))&#xD;&#xA;        erSoldAsHatEggs = tempErHat;&#xD;&#xA;    &#xD;&#xA;    object valEsHat = GetCurrentColumnValue(&quot;ES_SoldAsHatEggs&quot;);&#xD;&#xA;    if (valEsHat != null &amp;&amp; decimal.TryParse(valEsHat.ToString(), out decimal tempEsHat))&#xD;&#xA;        esSoldAsHatEggs = tempEsHat;&#xD;&#xA;    &#xD;&#xA;    decimal erSoldAsTableEggs = 0, esSoldAsTableEggs = 0;&#xD;&#xA;    object valErTable = GetCurrentColumnValue(&quot;ER_SoldAsTableEggs&quot;);&#xD;&#xA;    if (valErTable != null &amp;&amp; decimal.TryParse(valErTable.ToString(), out decimal tempErTable))&#xD;&#xA;        erSoldAsTableEggs = tempErTable;&#xD;&#xA;    &#xD;&#xA;    object valEsTable = GetCurrentColumnValue(&quot;ES_SoldAsTableEggs&quot;);&#xD;&#xA;    if (valEsTable != null &amp;&amp; decimal.TryParse(valEsTable.ToString(), out decimal tempEsTable))&#xD;&#xA;        esSoldAsTableEggs = tempEsTable;&#xD;&#xA;    &#xD;&#xA;    decimal erSendToOffal = 0, esSendToOffal = 0;&#xD;&#xA;    object valErOffal = GetCurrentColumnValue(&quot;ER_SendToOffal&quot;);&#xD;&#xA;    if (valErOffal != null &am