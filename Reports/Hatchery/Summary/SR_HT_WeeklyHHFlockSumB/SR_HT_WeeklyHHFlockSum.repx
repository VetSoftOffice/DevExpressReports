<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_WeeklyHHFlockSum" ScriptsSource="&#xD;&#xA;private void xrTableCell17_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     // Get the current row values&#xD;&#xA;    decimal actRecEggsBefore21days = Convert.ToDecimal(GetCurrentColumnValue(&quot;ActRecEggsBefore21days&quot;));&#xD;&#xA;    decimal rejEggsBefore21days = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejEggsBefore21days&quot;));&#xD;&#xA;    decimal settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;    decimal actChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;ActChicks&quot;));&#xD;&#xA;    decimal cullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;    decimal deadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;&#xD;&#xA;    // Calculate EstHatEggsBefore21days&#xD;&#xA;    decimal estHatEggsBefore21days = actRecEggsBefore21days - rejEggsBefore21days;&#xD;&#xA;&#xD;&#xA;    // Calculate ActHatch_Per_Cum safely&#xD;&#xA;    decimal actHatch_Per_Cum = 0;&#xD;&#xA;    if (settedEggs != 0)&#xD;&#xA;    {&#xD;&#xA;        actHatch_Per_Cum = (actChicks + cullsChicks + deadChicks) / settedEggs * 100;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    // Final calculation&#xD;&#xA;    decimal result = estHatEggsBefore21days * actHatch_Per_Cum / 100;&#xD;&#xA;    // --- Assign result to cell ---&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = result.ToString(&quot;N0&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;    &#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell20_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // --- Declare values ---&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal actChicks = 0;&#xD;&#xA;decimal cullsChicks = 0;&#xD;&#xA;decimal deadChicks = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;ActChicks&quot;) != null)&#xD;&#xA;    actChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;ActChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CullsChicks&quot;) != null)&#xD;&#xA;    cullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DeadChicks&quot;) != null)&#xD;&#xA;    deadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (settedEggs != 0)&#xD;&#xA;    percentage = ((actChicks + cullsChicks + deadChicks) / settedEggs) * 100m;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell21_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;        // --- Declare values ---&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal actChicks = 0;&#xD;&#xA;decimal cullsChicks = 0;&#xD;&#xA;decimal deadChicks = 0;&#xD;&#xA;decimal stdHatchCum = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;ActChicks&quot;) != null)&#xD;&#xA;    actChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;ActChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CullsChicks&quot;) != null)&#xD;&#xA;    cullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DeadChicks&quot;) != null)&#xD;&#xA;    deadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;StdHatchCum&quot;) != null)&#xD;&#xA;    stdHatchCum = Convert.ToDecimal(GetCurrentColumnValue(&quot;StdHatchCum&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;// Actual hatch % (if SettedEggs &gt; 0, else 0)&#xD;&#xA;decimal actualHatchPerc = 0;&#xD;&#xA;if (settedEggs != 0)&#xD;&#xA;    actualHatchPerc = ((actChicks + cullsChicks + deadChicks) / settedEggs) * 100m;&#xD;&#xA;&#xD;&#xA;// Difference: Actual - Standard&#xD;&#xA;decimal result = actualHatchPerc - stdHatchCum;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;" PageWidth="1169" PageHeight="1654" Version="24.2" DataMember="SR_HT_WeeklyHHFlockSum" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
