<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="24.2.6.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_HT_WeeklyHHFlockSum" ScriptsSource="&#xD;&#xA;private void tdDebit_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal pol = 0;&#xD;&#xA;decimal actRecEggs = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;POL&quot;) != null)&#xD;&#xA;    pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;ActRecEggs&quot;) != null)&#xD;&#xA;    actRecEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;ActRecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal result = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;    result = actRecEggs / pol;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell6_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal pol = 0;&#xD;&#xA;decimal rejEggs = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;POL&quot;) != null)&#xD;&#xA;    pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RejEggs&quot;) != null)&#xD;&#xA;    rejEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;    percentage = (rejEggs / pol) * 100m;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void tdCredit_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal pol = 0;&#xD;&#xA;decimal actRecEggs = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;POL&quot;) != null)&#xD;&#xA;    pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;ActRecEggs&quot;) != null)&#xD;&#xA;    actRecEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;ActRecEggs&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal perc1 = 0;&#xD;&#xA;decimal perc2 = 0;&#xD;&#xA;&#xD;&#xA;if (pol != 0)&#xD;&#xA;{&#xD;&#xA;    perc1 = (actRecEggs / pol) * 100m;&#xD;&#xA;    perc2 = (actRecEggs / pol) * 100m;   // same formula again&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;decimal result = perc1 - perc2; // will always be 0 in current form&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;); // up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell1_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal pol = 0;&#xD;&#xA;decimal actSetEggCum = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;POL&quot;) != null)&#xD;&#xA;    pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;ActSetEggCum&quot;) != null)&#xD;&#xA;    actSetEggCum = Convert.ToDecimal(GetCurrentColumnValue(&quot;ActSetEggCum&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;    percentage = (actSetEggCum / pol) * 100m;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell17_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal pol = 0;&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal estHatEggsBefore21days = 0;&#xD;&#xA;decimal actChicks = 0;&#xD;&#xA;decimal cullsChicks = 0;&#xD;&#xA;decimal deadChicks = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;POL&quot;) != null)&#xD;&#xA;    pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;EstHatEggsBefore21days&quot;) != null)&#xD;&#xA;    estHatEggsBefore21days = Convert.ToDecimal(GetCurrentColumnValue(&quot;EstHatEggsBefore21days&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;ActChicks&quot;) != null)&#xD;&#xA;    actChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;ActChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CullsChicks&quot;) != null)&#xD;&#xA;    cullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DeadChicks&quot;) != null)&#xD;&#xA;    deadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;&#xD;&#xA;if (pol &gt; 0)&#xD;&#xA;{&#xD;&#xA;    decimal hatchPerc = 0;&#xD;&#xA;    if (settedEggs != 0)&#xD;&#xA;        hatchPerc = ((actChicks + cullsChicks + deadChicks) / settedEggs) * 100m;&#xD;&#xA;&#xD;&#xA;    percentage = (estHatEggsBefore21days * (hatchPerc / 100m)) / pol;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell18_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal pol = 0;&#xD;&#xA;decimal actChicks = 0;&#xD;&#xA;decimal cullsChicks = 0;&#xD;&#xA;decimal deadChicks = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;POL&quot;) != null)&#xD;&#xA;    pol = Convert.ToDecimal(GetCurrentColumnValue(&quot;POL&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;ActChicks&quot;) != null)&#xD;&#xA;    actChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;ActChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CullsChicks&quot;) != null)&#xD;&#xA;    cullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DeadChicks&quot;) != null)&#xD;&#xA;    deadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (pol != 0)&#xD;&#xA;    percentage = ((actChicks + cullsChicks + deadChicks) / pol) * 100m;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell20_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal actChicks = 0;&#xD;&#xA;decimal cullsChicks = 0;&#xD;&#xA;decimal deadChicks = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;ActChicks&quot;) != null)&#xD;&#xA;    actChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;ActChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CullsChicks&quot;) != null)&#xD;&#xA;    cullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DeadChicks&quot;) != null)&#xD;&#xA;    deadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (settedEggs != 0)&#xD;&#xA;    percentage = ((actChicks + cullsChicks + deadChicks) / settedEggs) * 100m;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell21_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal settedEggs = 0;&#xD;&#xA;decimal actChicks = 0;&#xD;&#xA;decimal cullsChicks = 0;&#xD;&#xA;decimal deadChicks = 0;&#xD;&#xA;decimal stdHatchCum = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;SettedEggs&quot;) != null)&#xD;&#xA;    settedEggs = Convert.ToDecimal(GetCurrentColumnValue(&quot;SettedEggs&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;ActChicks&quot;) != null)&#xD;&#xA;    actChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;ActChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CullsChicks&quot;) != null)&#xD;&#xA;    cullsChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;CullsChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DeadChicks&quot;) != null)&#xD;&#xA;    deadChicks = Convert.ToDecimal(GetCurrentColumnValue(&quot;DeadChicks&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;StdHatchCum&quot;) != null)&#xD;&#xA;    stdHatchCum = Convert.ToDecimal(GetCurrentColumnValue(&quot;StdHatchCum&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;// Actual hatch % (if SettedEggs &gt; 0, else 0)&#xD;&#xA;decimal actualHatchPerc = 0;&#xD;&#xA;if (settedEggs != 0)&#xD;&#xA;    actualHatchPerc = ((actChicks + cullsChicks + deadChicks) / settedEggs) * 100m;&#xD;&#xA;&#xD;&#xA;// Difference: Actual - Standard&#xD;&#xA;decimal result = actualHatchPerc - stdHatchCum;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;" PageWidth="1169" PageHeight="1654" Version="24.2" DataMember="SR_HT_WeeklyHHFlockSum" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
