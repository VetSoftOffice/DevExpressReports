                    <Item1 Ref="526" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="527" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Credit])" />
                  </ExpressionBindings>
                  <StylePriority Ref="528" UseFont="false" />
                </Item5>
                <Item6 Ref="529" ControlType="XRTableCell" Name="xrTableCell56" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="530" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="531" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="532" EventName="BeforePrint" PropertyName="Text" Expression="Iif(&#xA;    (SumRunningSum([Result]) + (sumDSum([OpenResult]))) &gt; 0, (SumRunningSum([Result]) + (sumDSum([OpenResult]))) , &#xA;    0&#xA;)&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="533" UseFont="false" />
                </Item6>
                <Item7 Ref="534" ControlType="XRTableCell" Name="xrTableCell57" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="535" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="536" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="537" EventName="BeforePrint" PropertyName="Text" Expression="Iif(&#xA;     (SumRunningSum([Result]) + (sumDSum([OpenResult])))  &lt;0,&#xA;    Abs((SumRunningSum([Result]) + (sumDSum([OpenResult])))  ), &#xA;    0&#xA;)&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="538" UseFont="false" UseTextAlignment="false" />
                </Item7>
                <Item8 Ref="539" ControlType="XRTableCell" Name="xrTableCell58" Multiline="true" TextAlignment="MiddleRight">
                  <StylePriority Ref="540" UseFont="false" UseTextAlignment="false" />
                </Item8>
              </Cells>
            </Item1>
          </Rows>
          <StylePriority Ref="541" UseBorders="false" />
        </Item1>
      </Controls>
    </Item12>
