                <Item1 Ref="489" ControlType="XRTableCell" Name="xrTableCell45" Multiline="true" BorderWidth="1.4">
                  <StylePriority Ref="490" UseFont="false" UseBorderWidth="false" />
                </Item1>
                <Item2 Ref="491" ControlType="XRTableCell" Name="xrTableCell46" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="492" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="493" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Debit])" />
                    <Item2 Ref="494" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="495" UseFont="false" UseBorderWidth="false" />
                </Item2>
                <Item3 Ref="496" ControlType="XRTableCell" Name="xrTableCell47" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="497" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="498" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([Credit])" />
                    <Item2 Ref="499" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="500" UseFont="false" UseBorderWidth="false" />
                </Item3>
                <Item4 Ref="501" ControlType="XRTableCell" Name="xrTableCell48" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="502" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="503" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;&#xA;&#xA;" />
                    <Item2 Ref="504" EventName="BeforePrint" PropertyName="Text" Expression="Iif(&#xD;&#xA;    (SumRunningSum([Result]) + (sumDSum([OpenResult]))) &gt; 0, (SumRunningSum([Result]) + (sumDSum([OpenResult]))) , &#xD;&#xA;    0&#xD;&#xA;)&#xD;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="505" UseFont="false" UseBorderWidth="false" />
                </Item4>
                <Item5 Ref="506" ControlType="XRTableCell" Name="xrTableCell49" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="507" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="508" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;&#xA;" />
                    <Item2 Ref="509" EventName="BeforePrint" PropertyName="Text" Expression="Iif(&#xD;&#xA;     (SumRunningSum([Result]) + (sumDSum([OpenResult])))  &lt;0,&#xD;&#xA;    Abs((SumRunningSum([Result]) + (sumDSum([OpenResult])))  ), &#xD;&#xA;    0&#xD;&#xA;)&#xD;&#xA;&#xD;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="510" UseFont="false" UseBorderWidth="false" UseTextAlignment="false" />
                </Item5>
              </Cells>
            </Item1>
          </Rows>
          <StylePriority Ref="511" UseBorders="false" />
        </Item1>
      </Controls>
    </Item12>
