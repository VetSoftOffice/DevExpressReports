                  </ExpressionBindings>
                  <StylePriority Ref="493" UseFont="false" UseBorderWidth="false" />
                </Item4>
                <Item5 Ref="494" ControlType="XRTableCell" Name="xrTableCell49" Multiline="true" TextAlignment="MiddleRight" BorderWidth="1.4">
                  <Summary Ref="495" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="496" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;&#xA;" />
                    <Item2 Ref="497" EventName="BeforePrint" PropertyName="Text" Expression="Iif(&#xD;&#xA;     (SumRunningSum([Result]) + (sumDSum([OpenResult])))  &lt;0,&#xD;&#xA;    Abs((SumRunningSum([Result]) + (sumDSum([OpenResult])))  ), &#xD;&#xA;    0&#xD;&#xA;)&#xD;&#xA;&#xD;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="498" UseFont="false" UseBorderWidth="false" UseTextAlignment="false" />
                </Item5>
              </Cells>
            </Item1>
