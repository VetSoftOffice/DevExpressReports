<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_FC_CustSuppSheetDebitCredit" ScriptsSource="using System;&#xD;&#xA;using System.Collections;&#xD;&#xA;using System.Collections.Generic;  // ← This is what you need for Dictionary&#xD;&#xA;using System.Drawing;&#xD;&#xA;using System.ComponentModel;&#xD;&#xA;using DevExpress.XtraReports.UI;&#xD;&#xA;using System.Text.RegularExpressions;&#xD;&#xA;&#xD;&#xA;private Dictionary&lt;string, int&gt; dealTypeCategories = new Dictionary&lt;string, int&gt;();&#xD;&#xA;private Dictionary&lt;string, int&gt; custSuppCategories = new Dictionary&lt;string, int&gt;();  &#xD;&#xA;&#xD;&#xA;private void xrLabel9_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;         string rawValue = Parameters[&quot;AccountDim&quot;].Value as string;&#xD;&#xA;&#xD;&#xA;    if (!string.IsNullOrWhiteSpace(rawValue))&#xD;&#xA;    {&#xD;&#xA;        rawValue = rawValue.Trim();&#xD;&#xA;&#xD;&#xA;        // Remove single quotes only if they're wrapping the value&#xD;&#xA;        if (rawValue.StartsWith(&quot;'&quot;) &amp;&amp; rawValue.EndsWith(&quot;'&quot;))&#xD;&#xA;        {&#xD;&#xA;            rawValue = rawValue.Substring(1, rawValue.Length - 2);&#xD;&#xA;        }&#xD;&#xA;&#xD;&#xA;        // Optional: remove other special characters&#xD;&#xA;        rawValue = Regex.Replace(rawValue, @&quot;[^\w\s\-]&quot;, &quot;&quot;); // keeps letters, digits, space, dash&#xD;&#xA;&#xD;&#xA;        xrLabel9.Text = rawValue;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        xrLabel9.Text = string.Empty;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void Detail_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Get the Deal Type value&#xD;&#xA;    string dealType = Convert.ToString(GetCurrentColumnValue(&quot;DealType_To&quot;) ?? &quot;&quot;);&#xD;&#xA;    // Get Customer/Supplier Name&#xD;&#xA;    string custSuppName = Convert.ToString(GetCurrentColumnValue(&quot;CustSuppName&quot;) ?? &quot;&quot;);  &#xD;&#xA;    &#xD;&#xA;    if (!string.IsNullOrEmpty(dealType))&#xD;&#xA;    {&#xD;&#xA;        if (dealTypeCategories.ContainsKey(dealType))&#xD;&#xA;            dealTypeCategories[dealType]++;&#xD;&#xA;        else&#xD;&#xA;            dealTypeCategories.Add(dealType, 1);&#xD;&#xA;    }&#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;    // Build Customer/Supplier dictionary  &#xD;&#xA;    if (!string.IsNullOrEmpty(custSuppName))&#xD;&#xA;    {&#xD;&#xA;        if (custSuppCategories.ContainsKey(custSuppName))&#xD;&#xA;            custSuppCategories[custSuppName]++;&#xD;&#xA;        else&#xD;&#xA;            custSuppCategories.Add(custSuppName, 1);&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void GroupFooter_DealType_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Hide the footer if there's only one Deal Type category&#xD;&#xA;    if (dealTypeCategories.Count &lt;= 1)&#xD;&#xA;    {&#xD;&#xA;        GroupFooter_DealType.Visible = false;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        GroupFooter_DealType.Visible = true;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void GroupFooter2_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // Hide the footer if there's only one Customer/Supplier&#xD;&#xA;    if (custSuppCategories.Count &lt;= 1)&#xD;&#xA;    {&#xD;&#xA;        GroupFooter2.Visible = false;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        GroupFooter2.Visible = true;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void SubBand3_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     // Show Report Footer if either DealType OR CustSuppName has more than 1 category&#xD;&#xA;    if (dealTypeCategories.Count &gt; 1 || custSuppCategories.Count &gt; 1)&#xD;&#xA;    {&#xD;&#xA;        SubBand3.Visible = true;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        SubBand3.Visible = false;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" PageWidthF="826.771667" PageHeightF="1169.29138" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="25.2" DataMember="SR_FC_CustSuppSheet" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
