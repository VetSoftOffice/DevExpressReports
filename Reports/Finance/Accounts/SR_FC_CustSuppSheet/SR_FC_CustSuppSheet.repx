                    <Item1 Ref="531" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;&#xA;" />
                    <Item2 Ref="532" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([MoveValueForeign])" />
                  </ExpressionBindings>
                  <StylePriority Ref="533" UseFont="false" />
                </Item2>
                <Item3 Ref="534" ControlType="XRTableCell" Name="xrTableCell45" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="535" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="536" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="537" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([MoveValueForeign])+sumDSum(IsNull([OpenBalanceForeign],0 ))&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="538" UseFont="false" />
                </Item3>
                <Item4 Ref="539" ControlType="XRTableCell" Name="xrTableCell46" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="540" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="541" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="542" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([MoveValue])" />
                    <Item3 Ref="543" EventName="BeforePrint" PropertyName="Visible" Expression="?IsShowEquivalentData&#xA;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="544" UseFont="false" />
                </Item4>
                <Item5 Ref="545" ControlType="XRTableCell" Name="xrTableCell47" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="546" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="547" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="548" EventName="BeforePrint" PropertyName="Visible" Expression="?IsShowEquivalentData&#xA;&#xA;" />
                    <Item3 Ref="549" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([MoveValue])+sumDSum(IsNull([OpenBalance],0 ))&#xD;&#xA;&#xD;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="550" UseFont="false" UseTextAlignment="false" />
                </Item5>
              </Cells>
            </Item1>
          </Rows>
          <StylePriority Ref="551" UseBorders="false" />
        </Item1>
      </Controls>
