                <Item3 Ref="531" ControlType="XRTableCell" Name="xrTableCell45" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="532" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="533" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="534" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([MoveValueForeign])+sumDSum(IsNull([OpenBalanceForeign],0 ))&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="535" UseFont="false" />
                </Item3>
                <Item4 Ref="536" ControlType="XRTableCell" Name="xrTableCell46" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="537" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="538" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="539" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([MoveValue])" />
                    <Item3 Ref="540" EventName="BeforePrint" PropertyName="Visible" Expression="?IsShowEquivalentData&#xA;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="541" UseFont="false" />
                </Item4>
                <Item5 Ref="542" ControlType="XRTableCell" Name="xrTableCell47" Multiline="true" TextAlignment="MiddleRight">
                  <Summary Ref="543" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="544" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;&#xA;" />
                    <Item2 Ref="545" EventName="BeforePrint" PropertyName="Visible" Expression="?IsShowEquivalentData&#xA;&#xA;" />
                    <Item3 Ref="546" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([MoveValue])+sumDSum(IsNull([OpenBalance],0 ))&#xD;&#xA;&#xD;&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="547" UseFont="false" UseTextAlignment="false" />
                </Item5>
              </Cells>
            </Item1>
          </Rows>
          <StylePriority Ref="548" UseBorders="false" />
        </Item1>
      </Controls>
