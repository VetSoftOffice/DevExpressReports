                    <Item2 Ref="523" EventName="BeforePrint" PropertyName="Visible" Expression="?IsShowEquivalentData&#xA;&#xA;" />
                    <Item3 Ref="524" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([MoveValue])+sumDSum(IsNull([OpenBalance],0 ))&#xA;" />
