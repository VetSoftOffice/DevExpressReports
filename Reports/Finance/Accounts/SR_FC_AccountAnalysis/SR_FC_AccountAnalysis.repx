)&#xD;&#xA;    {&#xD;&#xA;        object value = GetCurrentColumnValue(fieldName);&#xD;&#xA;        if (value != null &amp;&amp; !string.IsNullOrEmpty(value.ToString()))&#xD;&#xA;        {&#xD;&#xA;            if (decimal.TryParse(value.ToString(), out decimal result))&#xD;&#xA;                return result;&#xD;&#xA;        }&#xD;&#xA;        return 0;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    // Get tFcAccountNatureID&#xD;&#xA;    decimal tFcAccountNatureID = GetFieldValue(&quot;tFcAccountNatureID&quot;);&#xD;&#xA;    &#xD;&#xA;    // Get CloseBalance&#xD;&#xA;    decimal closeBalance = GetFieldValue(&quot;CloseBalance&quot;);&#xD;&#xA;&#xD;&#xA;    // Calculate CloseBalance_All_GT for current record&#xD;&#xA;    decimal closeBalanceAllGT = 0;&#xD;&#xA;    &#xD;&#xA;    if (tFcAccountNatureID == 1)&#xD;&#xA;    {&#xD;&#xA;        closeBalanceAllGT = closeBalance;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    // Add to running total&#xD;&#xA;    runningTotalCloseBalanceAllGT += closeBalanceAllGT;&#xD;&#xA;&#xD;&#xA;    // Assign the running total to cell&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    cell.Text = runningTotalCloseBalanceAllGT.ToString(&quot;N0&quot;);&#xD;&#xA;}&#xD;&#xA;" PageWidthF="826.771667" PageHeightF="1169.29138" Version="25.2" DataMember="SR_FC_AccountAnalysis" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
