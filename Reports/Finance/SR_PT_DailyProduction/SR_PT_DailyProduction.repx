                  <Item8 Ref="157" Name="CloseDebit" Expression="Iif([CloseBalance] &gt; 0, [CloseBalance], 0)" DataMember="SR_FC_CustSuppSheet" />
                  <Item9 Ref="158" Name="Open_Balance_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([OpenBalance])/[FormulaOperand_Prod] ,0 )" DataMember="SR_FC_FM_StockMovement" />
                  <Item10 Ref="159" Name="Inputs_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([InputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item11 Ref="160" Name="Consumed_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([Consumed])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item12 Ref="161" Name="Outputs_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([SoldTransferOut])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item13 Ref="162" Name="Other_Output_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([OtherOutputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item14 Ref="163" Name="Close_Balance_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([CloseBalance])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item15 Ref="164" Name="Test" DataMember="SR_FC_FM_StockMovement" />
                  <Item16 Ref="165" Name="SumOfHours" Expression="sum([TotalSecond]) /3600" DataMember="SR_MO_TrackUserActions" />
                  <Item17 Ref="166" Name="calculatedField1" DataMember="SR_MO_TrackUserActions" />
                  <Item18 Ref="167" Name="OpenDebitCF" Expression="Iif([OpenBalance] &gt; 0 , [OpenBalance], '')&#xA;" DataMember="SR_SL_CustomerData" />
                  <Item19 Ref="168" Name="CloseDebitCF" Expression="Iif([CurrentBalance] &gt; 0 , [CurrentBalance], '')&#xA;" DataMember="SR_SL_CustomerData" />
                  <Item20 Ref="169" Name="OpenCreditCF" Expression="Iif([OpenBalance] &gt; 0 , [OpenBalance], '')&#xA;" DataMember="SR_SL_CustomerData" />
                  <Item21 Ref="170" Name="ClodeCreditCF" Expression="Iif([CurrentBalance] &lt; 0 , Abs([CurrentBalance]), '')&#xA;" DataMember="SR_SL_CustomerData" />
