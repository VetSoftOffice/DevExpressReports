                </Item3>
                <Item4 Ref="358" ControlType="XRTableCell" Name="xrTableCell37" Multiline="true" Padding="2,2,0,0,100" Borders="Left, Top, Right">
                  <Summary Ref="359" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="360" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([FemaleQtyKg]) / 1000" />
                    <Item2 Ref="361" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="362" UseFont="false" UsePadding="false" UseBorders="false" />
                </Item4>
                <Item5 Ref="363" ControlType="XRTableCell" Name="xrTableCell24" Multiline="true" Padding="2,2,0,0,100" Borders="Left, Top, Right">
                  <Summary Ref="364" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="365" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([MaleQtyKg]) / 1000&#xA;" />
                    <Item2 Ref="366" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="367" UseFont="false" UsePadding="false" UseBorders="false" />
                </Item5>
                <Item6 Ref="368" ControlType="XRTableCell" Name="xrTableCell23" Multiline="true" Padding="2,2,0,0,100" Borders="Left, Top, Right">
                  <Summary Ref="369" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="370" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([TotalFeed])" />
                    <Item2 Ref="371" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="372" UseFont="false" UsePadding="false" UseBorders="false" />
                </Item6>
                <Item7 Ref="373" ControlType="XRTableCell" Name="xrTableCell30" Multiline="true" TextAlignment="MiddleCenter" Padding="2,2,0,0,100" Borders="Left, Top, Right">
                  <Summary Ref="374" Running="Group" />
                  <ExpressionBindings>
                    <Item1 Ref="375" EventName="BeforePrint" PropertyName="Text" Expression="sumSum([CloseFeed])" />
                    <Item2 Ref="376" EventName="BeforePrint" PropertyName="TextAlignment" Expression="Iif(?IsRTL == True, 'MiddleLeft', 'MiddleRight')&#xA;" />
                  </ExpressionBindings>
                  <StylePriority Ref="377" UseFont="false" UsePadding="false" UseBorders="false" UseTextAlignment="false" />
                </Item7>
                <Item8 Ref="378" ControlType="XRTableCell" Name="xrTableCell25" Multiline="true" TextAlignment="MiddleCenter" Padding="2,2,0,0,100" Borders="Left, Top, Right">
                  <ExpressionBindings>
