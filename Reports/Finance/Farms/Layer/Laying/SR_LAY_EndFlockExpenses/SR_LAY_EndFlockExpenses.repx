String(&quot;N2&quot;); // formats as 0.00&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTableCell36_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare local variable ---&#xD;&#xA;decimal feedConsPerHEgg = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;// --- Read value safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;FeedConsPerHEgg&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;FeedConsPerHEgg&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    feedConsPerHEgg = Convert.ToDecimal(GetCurrentColumnValue(&quot;FeedConsPerHEgg&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Convert from kg to g (1 kg = 1000 g) ---&#xD;&#xA;result = feedConsPerHEgg * 1000;&#xD;&#xA;&#xD;&#xA;// --- Assign converted value to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N0&quot;);   // format with 2 decimals (e.g., 1250.00)&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void tdClosingFlockEndDate_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;DateTime startDate = DateTime.MinValue;&#xD;&#xA;DateTime endDate = DateTime.MinValue;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;LayCloseFlkStartDate&quot;) != null &amp;&amp;&#xD;&#xA;    DateTime.TryParse(GetCurrentColumnValue(&quot;LayCloseFlkStartDate&quot;).ToString(), out DateTime parsedStart))&#xD;&#xA;{&#xD;&#xA;    startDate = parsedStart;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;LayCloseFlkEndDate&quot;) != null &amp;&amp;&#xD;&#xA;    DateTime.TryParse(GetCurrentColumnValue(&quot;LayCloseFlkEndDate&quot;).ToString(), out DateTime parsedEnd))&#xD;&#xA;{&#xD;&#xA;    endDate = parsedEnd;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Logic: if equal show one date, else show both separated by &quot;/&quot; ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;if (startDate == endDate)&#xD;&#xA;{&#xD;&#xA;    cell.Text = startDate.ToString(&quot;dd-MM-yyyy&quot;);  // &lt;-- Your desired format&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = $&quot;{startDate:dd-MM-yyyy} / {endDate:dd-MM-yyyy}&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;" PageWidth="827" PageHeight="1169" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="24.2" DataMember="SR_BRD_EndFlockExpenses" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
