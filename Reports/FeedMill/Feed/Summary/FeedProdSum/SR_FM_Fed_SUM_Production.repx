    <Item20 Ref="44" Name="MonthName" Expression="IIf(&#xA;    ?IsRTL, &#xA;    IIf([RegMONTH] == 1, 'يناير',&#xA;        IIf([RegMONTH] == 2, 'فبراير',&#xA;            IIf([RegMONTH] == 3, 'مارس',&#xA;                IIf([RegMONTH] == 4, 'أبريل',&#xA;                    IIf([RegMONTH] == 5, 'مايو',&#xA;                        IIf([RegMONTH] == 6, 'يونيو',&#xA;                            IIf([RegMONTH] == 7, 'يوليو',&#xA;                                IIf([RegMONTH] == 8, 'أغسطس',&#xA;                                    IIf([RegMONTH] == 9, 'سبتمبر',&#xA;                                        IIf([RegMONTH] == 10, 'أكتوبر',&#xA;                                            IIf([RegMONTH] == 11, 'نوفمبر',&#xA;                                                'ديسمبر'&#xA;                                            )&#xA;                                        )&#xA;                                    )&#xA;                                )&#xA;                            )&#xA;                        )&#xA;                    )&#xA;                )&#xA;            )&#xA;        )&#xA;    ),&#xA;    IIf([RegMONTH] == 1, 'Jan',&#xA;        IIf([RegMONTH] == 2, 'Feb',&#xA;            IIf([RegMONTH] == 3, 'Mar',&#xA;                IIf([RegMONTH] == 4, 'Apr',&#xA;                    IIf([RegMONTH] == 5, 'May',&#xA;                        IIf([RegMONTH] == 6, 'Jun',&#xA;                            IIf([RegMONTH] == 7, 'Jul',&#xA;                                IIf([RegMONTH] == 8, 'Aug',&#xA;                                    IIf([RegMONTH] == 9, 'Sep',&#xA;                                        IIf([RegMONTH] == 10, 'Oct',&#xA;                                            IIf([RegMONTH] == 11, 'Nov',&#xA;                                                'Dec'&#xA;                                            )&#xA;                                        )&#xA;                                    )&#xA;                                )&#xA;                            )&#xA;    