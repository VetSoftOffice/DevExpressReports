<?xml version="1.0" encoding="utf-8"?>
<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="PT_DailyProcessing" ScriptsSource="decimal avgLiveWeightRatio = 0;&#xD;&#xA;decimal avgRatio = 0;&#xD;&#xA;decimal avgCounterMinusPluck  = 0;&#xD;&#xA;decimal netBirdTotalReport  = 0;&#xD;&#xA;decimal chickRehangReport = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;decimal TotalDressedWeightReport = 0;&#xD;&#xA;private void xrTableCell33_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal liveWeight = 0;&#xD;&#xA;decimal counterTotal = 0;&#xD;&#xA;decimal doa = 0;&#xD;&#xA;decimal culls = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;LiveWeight&quot;) != null)&#xD;&#xA;    liveWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveWeight&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CounterTotal&quot;) != null)&#xD;&#xA;    counterTotal = Convert.ToDecimal(GetCurrentColumnValue(&quot;CounterTotal&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DOA&quot;) != null)&#xD;&#xA;    doa = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal denominator = counterTotal + doa + culls;&#xD;&#xA;decimal result = 0;&#xD;&#xA;if (denominator &gt; 0)&#xD;&#xA;    result = liveWeight / denominator;&#xD;&#xA;&#xD;&#xA;    avgLiveWeightRatio += result;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;          xrTableCell22.Text = avgLiveWeightRatio.ToString(&quot;0&quot;);&#xD;&#xA;          avgLiveWeightRatio = 0; // reset for next LineType group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell13_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal liveWeight = 0;&#xD;&#xA;decimal counterTotal = 0;&#xD;&#xA;decimal doa = 0;&#xD;&#xA;decimal culls = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;LiveWeight&quot;) != null)&#xD;&#xA;    liveWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveWeight&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CounterTotal&quot;) != null)&#xD;&#xA;    counterTotal = Convert.ToDecimal(GetCurrentColumnValue(&quot;CounterTotal&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DOA&quot;) != null)&#xD;&#xA;    doa = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal denominator = counterTotal + doa + culls;&#xD;&#xA;decimal ratio = 0;&#xD;&#xA;&#xD;&#xA;if (denominator &gt; 0)&#xD;&#xA;    ratio = liveWeight / denominator;&#xD;&#xA;&#xD;&#xA;// --- Add to report totals (for average) ---&#xD;&#xA;decimal ratioReportSum = 0;&#xD;&#xA;int ratioReportCount = 0;&#xD;&#xA;ratioReportSum += ratio;     // keep sum of ratios&#xD;&#xA;ratioReportCount++;          // count how many ratios added&#xD;&#xA;&#xD;&#xA;// --- Compute running average ---&#xD;&#xA;if (ratioReportCount &gt; 0)&#xD;&#xA;    avgRatio = ratioReportSum / ratioReportCount;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = ratio.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell23_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;           xrTableCell23.Text = avgRatio.ToString(&quot;0&quot;);&#xD;&#xA;           avgRatio= 0; // reset for next LineType group&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell16_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal counterTotal = 0;&#xD;&#xA;decimal pluckReject = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CounterTotal&quot;) != null)&#xD;&#xA;    counterTotal = Convert.ToDecimal(GetCurrentColumnValue(&quot;CounterTotal&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;PluckReject&quot;) != null)&#xD;&#xA;    pluckReject = Convert.ToDecimal(GetCurrentColumnValue(&quot;PluckReject&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal result = counterTotal - pluckReject;&#xD;&#xA;        avgCounterMinusPluck += result ;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell29_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;          xrTableCell29.Text = avgCounterMinusPluck.ToString(&quot;0&quot;);&#xD;&#xA;          avgCounterMinusPluck = 0; // reset for next LineType group&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;private void xrTable2_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;   // --- Declare values ---&#xD;&#xA;decimal netBirdTotal = 0;&#xD;&#xA;decimal chickRehang = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;NetBirdTotaal&quot;) != null)&#xD;&#xA;    netBirdTotal = Convert.ToDecimal(GetCurrentColumnValue(&quot;NetBirdTotaal&quot;));&#xD;&#xA;    netBirdTotalReport += netBirdTotal;&#xD;&#xA;if (GetCurrentColumnValue(&quot;ChickRehang&quot;) != null)&#xD;&#xA;    chickRehang = Convert.ToDecimal(GetCurrentColumnValue(&quot;ChickRehang&quot;));&#xD;&#xA;    chickRehangReport += chickRehang;&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;result = chickRehangReport + netBirdTotalReport ;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell37_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;                // --- Declare values ---&#xD;&#xA;decimal totalDressedWeight = 0;&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;TotalDressedWeight&quot;) != null)&#xD;&#xA;    totalDressedWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalDressedWeight&quot;));&#xD;&#xA;&#xD;&#xA;// --- Keep running sum for Avg ---&#xD;&#xA;decimal dressedWeightSum = 0;&#xD;&#xA;int dressedWeightCount = 0;&#xD;&#xA;&#xD;&#xA;dressedWeightSum += totalDressedWeight;&#xD;&#xA;dressedWeightCount++;&#xD;&#xA;&#xD;&#xA;// --- Compute average ---&#xD;&#xA;decimal avgDressedWeight = 0;&#xD;&#xA;if (dressedWeightCount &gt; 0)&#xD;&#xA;    avgDressedWeight = dressedWeightSum / dressedWeightCount;&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal TotalDressedWeightReport = result * avgDressedWeight;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = TotalDressedWeightReport.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;" Landscape="true" PageWidthF="1169.29138" PageHeightF="826.771667" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="25.2" DataMember="SR_PT_Da