    <Item7 Ref="15" Name="PuckRejectPer_GT" Expression="Iif(&#xA;  Sum([SR_PT_DailyRecePlucking.CounterTotal]) &gt; 0,&#xA;  Sum([SR_PT_DailyRecePlucking.PluckReject]) / Sum([SR_PT_DailyRecePlucking.CounterTotal]) * 100,&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailyRecePlucking" />
