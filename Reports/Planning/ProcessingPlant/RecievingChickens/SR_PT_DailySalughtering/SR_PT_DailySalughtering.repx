              <ReportSource Ref="325" ControlType="DevExpressReports.Reports.Planning.ProcessingPlant.RecievingChickens.SR_PT_DailySalughtering_SubReports.SR_PT_DailySalughtering_SubReports, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="decimal recQtySum = 0;&#xD;&#xA;decimal doaSum = 0;&#xD;&#xA;decimal recQtyRejSum = 0;&#xD;&#xA;decimal rejectedQtySum = 0;&#xD;&#xA;decimal recQtyPlukRejSum = 0;&#xD;&#xA;decimal pluckRejectSum = 0;&#xD;&#xA;decimal recQtyMedicalCondemnationSum  = 0;&#xD;&#xA;decimal medicalCondemnationSum  = 0;&#xD;&#xA;decimal recQtyAcceptWtSum = 0;&#xD;&#xA;decimal acceptWtSum = 0;&#xD;&#xA;&#xD;&#xA;private void xrTableCell24_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare local variables for current record ---&#xD;&#xA;decimal recQty = 0;&#xD;&#xA;decimal doa = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecQty&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;RecQty&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    recQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecQty&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DOA&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;DOA&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    doa = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Accumulate totals across all records ---&#xD;&#xA;&#xD;&#xA;recQtySum += recQty;&#xD;&#xA;doaSum += doa;&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif(Sum([RecQty]) &lt;&gt; 0, Sum([DOA]) * 100 / Sum([RecQty]), 0)) ---&#xD;&#xA;decimal result = 0;&#xD;&#xA;if (recQtySum != 0)&#xD;&#xA;    result = (doaSum * 100) / recQtySum;&#xD;&#xA;else&#xD;&#xA;    result = 0;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = resul