    <Item6 Ref="320" ControlType="ReportFooterBand" Name="ReportFooter">
      <SubBands>
        <Item1 Ref="321" ControlType="SubBand" Name="SubBand7">
          <Controls>
            <Item1 Ref="322" ControlType="XRSubreport" Name="SR_PT_DailySalughtering_SubReports">
              <ReportSource Ref="324" ControlType="DevExpressReports.Reports.Planning.ProcessingPlant.RecievingChickens.SR_PT_DailySalughtering_SubReports.SR_PT_DailySalughtering_SubReports, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="using System.ComponentModel;&#xD;&#xA;using DevExpress.XtraReports.Parameters;&#xD;&#xA;&#xD;&#xA;int groupCounter = 1;&#xD;&#xA;&#xD;&#xA;private void GroupFooter1_BeforePrint(object sender, CancelEventArgs e)&#xD;&#xA;{&#xD;&#xA;    GroupFooterBand groupFooter = (GroupFooterBand)sender;&#xD;&#xA;    XtraReport report = (XtraReport)groupFooter.Report;&#xD;&#xA;    &#xD;&#xA;    Parameter noOfGroupsPerPageParam = report.Parameters[&quot;NoOfGroupsPerPage&quot;];&#xD;&#xA;    if(noOfGroupsPerPageParam != null &amp;&amp; noOfGroupsPerPageParam.Value != &quot;&quot;)&#xD;&#xA;    {&#xD;&#xA;        int noOfGroupsPerPage = Convert.ToInt32(noOfGroupsPerPageParam.Value);&#xD;&#xA;        if (noOfGroupsPerPage &gt; 0)&#xD;&#xA;        {&#xD;&#xA;            if (groupCounter == noOfGroupsPerPage)&#xD;&#xA;            {&#xD;&#xA;                groupFooter.PageBreak = PageBreak.AfterBand;&#xD;&#xA;                groupCounter = 1;&#xD;&#xA;            }&#xD;&#xA;            else&#xD;&#xA;            {&#xD;&#xA;                groupFooter.PageBreak = PageBreak.None;&#xD;&#xA;                groupCounter += 1;&#xD;&#xA;            }&#xD;&#xA;        }&#xD;&#xA;    }&#xD;&#xA;}" PageWidth="1169" PageHeight="1654" Version="24.2" DataMember="SR_PT_DailySalughtering" DataSource="#Ref-323" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
                <Parameters>
                  <Item1 Ref="325" Visible="false" ValueInfo="False" Name="IsRTL" Type="#Ref-2" />
                  <Item2 Ref="326" Visible="false" ValueInfo="False" Name="IsCustomReportHeader" Type="#Ref-2" />
