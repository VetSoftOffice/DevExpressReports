                </Parameters>
                <CalculatedFields>
                  <Item1 Ref="346" Name="TotalCostPerc_CF" DisplayName="TotalCostPerc_CF" Expression="(ToDecimal([TotalCost]) / ToDecimal(Sum([TotalCost])))*ToDecimal(100)&#xA;" DataMember="SR_FM_Stocktaking" />
                  <Item2 Ref="347" Name="Per_Chick_CF" Expression="Iif([FemaleChicks]!=0,[TotalCost]/[FemaleChicks] ,[FemaleChicks] )" DataMember="SR_FM_Stocktaking" />
                  <Item3 Ref="348" Name="PerHH_CF" DisplayName="PerHH_CF" Expression="Iif([FemalePOL]!=0,[TotalCost]/[FemalePOL] ,[FemalePOL] )&#xA;" DataMember="SR_FM_Stocktaking" />
                  <Item4 Ref="349" Name="PerHE_CF" Expression="Iif([HatchingEggs]!=0,[TotalCost]/[HatchingEggs] ,[HatchingEggs] )&#xA;&#xA;" DataMember="SR_FM_Stocktaking" />
                  <Item5 Ref="350" Name="DiffQtyq" Expression="IsNull([ActualQty], 0) - IsNull([SentOrClacQty], 0)" DataMember="SR_FM_Stocktaking" />
                  <Item6 Ref="351" Name="DiffPriceq" Expression="Iif([CalcPriceUnit] &gt; 0, IsNull([AdjustedPriceUnit], 0) - IsNull([CalcPriceUnit], 0), 0)" DataMember="SR_FM_Stocktaking" />
                  <Item7 Ref="352" Name="ActEggRecHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.ActRecEggs] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item8 Ref="353" Name="RejEggHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.RejEggs] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item9 Ref="354" Name="EstHatEggs" Expression="[ActEggRecHHCum] - [RejEggHHCum]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item10 Ref="355" Name="ActEggSetHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, [SR_HT_WeeklyHHFlockSum.ActSetEggCum] / [SR_HT_WeeklyHHFlockSum.POL], 0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item11 Ref="356" Name="EstHatEggsBefore21days" Expression="[SR_HT_WeeklyHHFlockSum.ActRecEggsBefore21days] - [SR_HT_WeeklyHHFlockSum.RejEggsBefore21days]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item12 Ref="357" Name="ActHatch_Per_Cum" Expression="Iif([SR_HT_WeeklyHHFlockSum.SettedEggs] &lt;&gt; 0, &#xD;&#xA;    ([SR_HT_WeeklyHHFlockSum.ActChicks] + [SR_HT_WeeklyHHFlockSum.CullsChicks] + [SR_HT_WeeklyHHFlockSum.DeadChicks]) &#xD;&#xA;    / [SR_HT_WeeklyHHFlockSum.SettedEggs] * 100, &#xD;&#xA;    0)&#xD;&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item13 Ref="358" Name="EstChiks" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &gt; 0, &#xA;    ([EstHatEggsBefore21days] * [ActHatch_Per_Cum] / 100) / [SR_HT_WeeklyHHFlockSum.POL], &#xA;    0)&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item14 Ref="359" Name="ActChicksHHCum" Expression="Iif([SR_HT_WeeklyHHFlockSum.POL] &lt;&gt; 0, &#xD;&#xA;    ([SR_HT_WeeklyHHFlockSum.ActChicks] + [SR_HT_WeeklyHHFlockSum.CullsChicks] + [SR_HT_WeeklyHHFlockSum.DeadChicks]) &#xD;&#xA;    / [SR_HT_WeeklyHHFlockSum.POL], &#xD;&#xA;    0)&#xD;&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item15 Ref="360" Name="Diviation" Expression="[ActHatch_Per_Cum] - [SR_HT_WeeklyHHFlockSum.StdHatchCum]&#xA;" DataMember="SR_HT_WeeklyHHFlockSum" />
                  <Item16 Ref="361" Name="TotalHatchedEggs" Expression="[ChicksSettedEggs]" DataMember="SR_HT_Production" />
                  <Item17 Ref="362" Name="HatchPer" Expression="Iif([TotalHatchedEggs] &lt;&gt; 0, [SR_HT_Production.Chicks] * 100 / [TotalHatchedEggs], 0)&#xA;" DataMember="SR_HT_Production" />
                  <Item18 Ref="363" Name="HOFPer" Expression="Iif([SR_HT_Production.FertPer] &lt;&gt; 0, [HatchPer] * 100.0 / [SR_HT_Production.FertPer], 0)&#xA;" DataMember="SR_HT_Production" />
                  <Item19 Ref="364" Name="HatchPerc" Expression="Iif([SR_HT_Hatch.SettedEggs] &lt;&gt; 0, [SR_HT_Hatch.SellableChicks] * 100 / [SR_HT_Hatch.SettedEggs], 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item20 Ref="365" Name="HOFPerc" Expression="Iif([SR_HT_Hatch.FertPer] &lt;&gt; 0, [HatchPer] * 100.0 / [SR_HT_Hatch.FertPer], 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item21 Ref="366" Name="TotalHatchPerc" Expression="Iif(Sum([SR_HT_Hatch.SettedEggs]) &lt;&gt; 0, Sum([SR_HT_Hatch.SellableChicks]) * 100 / Sum([SR_HT_Hatch.SettedEggs]), 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item22 Ref="367" Name="FertileEggs_CF" Expression="[SR_HT_Hatch.FertPer] * [SR_HT_Hatch.SettedEggs] / 100&#xA;&#xA;" DataMember="SR_HT_Hatch" />
                  <Item23 Ref="368" Name="FertPerc" Expression="Iif(Sum([SR_HT_Hatch.SettedEggs]) &lt;&gt; 0, Sum([FertileEggs]) * 100 / Sum([SR_HT_Hatch.SettedEggs]), 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item24 Ref="369" Name="TotalHOFPerc" Expression="Iif([FertPerc] &lt;&gt; 0, [TotalHatchPerc] * 100 / [FertPerc], 0)&#xA;" DataMember="SR_HT_Hatch" />
                  <Item25 Ref="370" Name="MortUnderWt" Expression="[DOA] + [RejectedQty]" DataMember="SR_PT_DailySalughtering" />
                  <Item26 Ref="371" Name="MortUnerWtWt" Expression="[DOAWeight] + [RejectedQtyWeight]" DataMember="SR_PT_DailySalughtering" />
                  <Item27 Ref="372" Name="AcceptQty" Expression="[RecQty] - [MortUnderWt] + [MedicalCondemnation] + [PluckReject]" DataMember="SR_PT_DailySalughtering" />
                  <Item28 Ref="373" Name="AcceptQtyWt" Expression="[RecWeight] - [MortUnerWtWt] + [MedicalCondWeight] + [PluckRejectWeight]&#xA;" DataMember="SR_PT_DailySalughtering" />
                  <Item29 Ref="374" Name="PluckMedAcc" Expression="[MedicalCondemnation] + [PluckReject] + [AcceptQty]" DataMember="SR_PT_DailySalughtering" />
                  <Item30 Ref="375" Name="PluckMedAccWt" Expression="[MedicalCondWeight] + [PluckRejectWeight] + [AcceptQtyWt]&#xA;" DataMember="SR_PT_DailySalughtering" />
                  <Item31 Ref="376" Name="DiffranceQty" Expression="[PluckMedAcc] - [CounterQty]" DataMember="SR_PT_DailySalughtering" />
                  <Item32 Ref="377" Name="MortPerc" Expression="Iif(&#xA;  Sum([RecQty]) &lt;&gt; 0,&#xA;  Sum([DOA]) * 100 / Sum([RecQty]),&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailySalughtering" />
                  <Item33 Ref="378" Name="UnderPerc" Expression="Iif(&#xA;  Sum([RecQty]) &lt;&gt; 0,&#xA;  Sum([RejectedQty]) * 100 / Sum([RecQty]),&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailySalughtering" />
                  <Item34 Ref="379" Name="PluckRejectPerc" Expression="Iif(&#xA;  Sum([RecQty]) &lt;&gt; 0,&#xA;  Sum([PluckReject]) * 100 / Sum([RecQty]),&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailySalughtering" />
                  <Item35 Ref="380" Name="MedPerc" Expression="Iif(&#xA;  Sum([RecQty]) &lt;&gt; 0,&#xA;  Sum([MedicalCondemnation]) * 100 / Sum([RecQty]),&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailySalughtering" />
                  <Item36 Ref="381" Name="AcceptPerc" Expression="Iif(&#xA;  Sum([RecQty]) &lt;&gt; 0,&#xA;  Sum([AcceptWt]) * 100 / Sum([RecQty]),&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailySalughtering" />
                  <Item37 Ref="382" Name="CounterPerc" Expression="Iif(&#xA;  Sum([RecQty]) &lt;&gt; 0,&#xA;  Sum([CounterQty]) * 100 / Sum([RecQty]),&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailySalughtering" />
                  <Item38 Ref="383" Name="TotalProblem" Expression="Sum([TotalProblem])&#xA;" DataMember="SR_PT_DailySalughtering" />
                </CalculatedFields>
