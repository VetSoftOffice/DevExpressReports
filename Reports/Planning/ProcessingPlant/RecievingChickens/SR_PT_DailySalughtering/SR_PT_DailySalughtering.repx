#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;TotalProblem&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    totalProblem = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalProblem&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Accumulate total across all records ---&#xD;&#xA;// (Define this field once at the top of your report class)&#xD;&#xA;// decimal totalProblemSum = 0;&#xD;&#xA;&#xD;&#xA;totalProblemSum += totalProblem;&#xD;&#xA;&#xD;&#xA;// --- Assign result to the cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = totalProblemSum.ToString(&quot;N2&quot;); // format with 2 decimal places&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;" PageWidthF="1169.29138" PageHeightF="1653.54333" Version="26.1" DataMember="SR_PT_DailySalughtering" DataSource="#Ref-324" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
