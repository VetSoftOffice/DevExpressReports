<XtraReportsLayoutSerializer SerializerVersion="25.2.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_PT_DailySalughteringDateWise" ScriptsSource="decimal TotalRecQtyCalc  = 0;&#xD;&#xA;decimal TotalRecWeightCalc  = 0;&#xD;&#xA;decimal TotalMedPluckAcceptCalc = 0;&#xD;&#xA;decimal TotalMedPluckAcceptWtCalc = 0;&#xD;&#xA;decimal TotalPluckMedAccMinusCounterQty = 0;&#xD;&#xA;decimal recQtyReport = 0;&#xD;&#xA;decimal DOAReport = 0;&#xD;&#xA;decimal RejectedQtyReport = 0;&#xD;&#xA;decimal MedicalCondemnationReport = 0;&#xD;&#xA;decimal PluckRejectReport = 0;&#xD;&#xA;decimal recWeightReportMort = 0;&#xD;&#xA;decimal DOAWeightReportMort = 0;&#xD;&#xA;decimal RejectedQtyWeightReportMort = 0;&#xD;&#xA;decimal MedicalCondWeightReportMort = 0;&#xD;&#xA;decimal PluckRejectWeightReportMort = 0;&#xD;&#xA;decimal medicalCondemnationReportTotalCounter = 0;&#xD;&#xA;decimal pluckRejectReportTotalCounter = 0;&#xD;&#xA;decimal acceptQtyReportTotalCounter = 0;&#xD;&#xA;decimal medicalCondWeightReportTotalCounterWt = 0;&#xD;&#xA;decimal pluckRejectWeightReportTotalCounterWt = 0;&#xD;&#xA;decimal acceptQtyWtReportTotalCounterWt = 0;&#xD;&#xA;decimal pluckMedAccReportDiff = 0;&#xD;&#xA;decimal counterQtyReportDiff = 0;&#xD;&#xA;&#xD;&#xA;private void xrTableCell58_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values --- &#xD;&#xA;decimal recQty = 0;&#xD;&#xA;decimal DOA = 0;&#xD;&#xA;decimal RejectedQty  = 0;&#xD;&#xA;decimal medicalCondemnation = 0;&#xD;&#xA;decimal pluckReject = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecQty&quot;) != null)&#xD;&#xA;    recQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecQty&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DOA&quot;) != null)&#xD;&#xA;    DOA = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RejectedQty&quot;) != null)&#xD;&#xA;    RejectedQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;RejectedQty&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;MedicalCondemnation&quot;) != null)&#xD;&#xA;    medicalCondemnation = Convert.ToDecimal(GetCurrentColumnValue(&quot;MedicalCondemnation&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;PluckReject&quot;) != null)&#xD;&#xA;    pluckReject = Convert.ToDecimal(GetCurrentColumnValue(&quot;PluckReject&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal result = recQty  - (DOA + RejectedQty ) + medicalCondemnation +pluckReject ;&#xD;&#xA;    recQtyReport += recQty;&#xD;&#xA;    DOAReport += DOA;&#xD;&#xA;    RejectedQtyReport += RejectedQty;&#xD;&#xA;    MedicalCondemnationReport += medicalCondemnation;&#xD;&#xA;    PluckRejectReport += pluckReject;&#xD;&#xA;&#xD;&#xA;// --- Add to report total (if required for average/summaries) ---&#xD;&#xA;TotalRecQtyCalc = recQtyReport  - (DOAReport +RejectedQtyReport) + MedicalCondemnationReport +PluckRejectReport ;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell52_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;           xrTableCell52.Text = TotalRecQtyCalc.ToString(&quot;0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell59_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values --- &#xD;&#xA;decimal recWeight = 0;&#xD;&#xA;decimal DOAWeight= 0;&#xD;&#xA;decimal RejectedQtyWeight = 0;&#xD;&#xA;decimal medicalCondWeight = 0;&#xD;&#xA;decimal pluckRejectWeight = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;RecWeight&quot;) != null)&#xD;&#xA;    recWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;RecWeight&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DOAWeight&quot;) != null)&#xD;&#xA;    DOAWeight= Convert.ToDecimal(GetCurrentColumnValue(&quot;DOAWeight&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;RejectedQtyWeight&quot;) != null)&#xD;&#xA;    RejectedQtyWeight= Convert.ToDecimal(GetCurrentColumnValue(&quot;RejectedQtyWeight&quot;));&#xD;&#xA;    &#xD;&#xA;if (GetCurrentColumnValue(&quot;MedicalCondWeight&quot;) != null)&#xD;&#xA;    medicalCondWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;MedicalCondWeight&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;PluckRejectWeight&quot;) != null)&#xD;&#xA;    pluckRejectWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;PluckRejectWeight&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal result = recWeight - (DOAWeight + RejectedQtyWeight) + medicalCondWeight + pluckRejectWeight;&#xD;&#xA;&#xD;&#xA;// --- Add to report total (if required for average/summaries) ---&#xD;&#xA;    recWeightReportMort += recWeight;&#xD;&#xA;    DOAWeightReportMort += DOAWeight;&#xD;&#xA;    RejectedQtyWeightReportMort += RejectedQtyWeight;&#xD;&#xA;    MedicalCondWeightReportMort += medicalCondWeight;&#xD;&#xA;    PluckRejectWeightReportMort += pluckRejectWeight;&#xD;&#xA;&#xD;&#xA;TotalRecWeightCalc = recWeightReportMort -( DOAWeightReportMort  + RejectedQtyWeightReportMort )+ MedicalCondWeightReportMort  + PluckRejectWeightReportMort ;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell65_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell65.Text = TotalRecWeightCalc.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell60_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values --- &#xD;&#xA;decimal medicalCondemnation = 0;&#xD;&#xA;decimal pluckReject = 0;&#xD;&#xA;decimal acceptQty = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;MedicalCondemnation&quot;) != null)&#xD;&#xA;    medicalCondemnation = Convert.ToDecimal(GetCurrentColumnValue(&quot;MedicalCondemnation&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;PluckReject&quot;) != null)&#xD;&#xA;    pluckReject = Convert.ToDecimal(GetCurrentColumnValue(&quot;PluckReject&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;AcceptQty&quot;) != null)&#xD;&#xA;    acceptQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;AcceptQty&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal result = medicalCondemnation + pluckReject + acceptQty;&#xD;&#xA;&#xD;&#xA;// --- Add to report total (if required for average/summaries) ---&#xD;&#xA;    medicalCondemnationReportTotalCounter += medicalCondemnation;&#xD;&#xA;    pluckRejectReportTotalCounter += pluckReject;&#xD;&#xA;    acceptQtyReportTotalCounter += acceptQty;&#xD;&#xA;&#xD;&#xA;TotalMedPluckAcceptCalc = medicalCondemnationReportTotalCounter  + pluckRejectReportTotalCounter  + acceptQtyReportTotalCounter ;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell66_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    &#xD;&#xA;       xrTableCell66.Text = TotalMedPluckAcceptCalc.ToString(&quot;N0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell61_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values --- &#xD;&#xA;decimal medicalCondWeight = 0;&#xD;&#xA;decimal pluckRejectWeight = 0;&#xD;&#xA;decimal acceptQtyWt = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;MedicalCondWeight&quot;) != null)&#xD;&#xA;    medicalCondWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;MedicalCondWeight&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;PluckRejectWeight&quot;) != null)&#xD;&#xA;    pluckRejectWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;PluckRejectWeight&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;AcceptQtyWt&quot;) != null)&#xD;&#xA;    acceptQtyWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;AcceptQtyWt&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal result = medicalCondWeight + pluckRejectWeight + acceptQtyWt;&#xD;&#xA;&#xD;&#xA;// --- Add to report total (if required for average/summaries) ---&#xD;&#xA;    medicalCondWeightReportTotalCounterWt += medicalCondWeight;&#xD;&#xA;    pluckRejectWeightReportTotalCounterWt += pluckRejectWeight;&#xD;&#xA;    acceptQtyWtReportTotalCounterWt += acceptQtyWt;&#xD;&#xA;&#xD;&#xA;TotalMedPluckAcceptWtCalc = medicalCondWeightReportTotalCounterWt  + pluckRejectWeightReportTotalCounterWt  +  acceptQtyWtReportTotalCounterWt; &#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell67_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    &#xD;&#xA;    &#xD;&#xA;       xrTableCell67.Text = TotalMedPluckAcceptWtCalc.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell63_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values --- &#xD;&#xA;decimal pluckMedAcc = 0;&#xD;&#xA;decimal counterQty = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;PluckMedAcc&quot;) != null)&#xD;&#xA;    pluckMedAcc = Convert.ToDecimal(GetCurrentColumnValue(&quot;PluckMedAcc&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CounterQty&quot;) != null)&#xD;&#xA;    counterQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;CounterQty&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal result = pluckMedAcc - counterQty;&#xD;&#xA;&#xD;&#xA;// --- Add to report total (if required for summaries/averages) ---&#xD;&#xA;    pluckMedAccReportDiff += pluckMedAcc;&#xD;&#xA;    counterQtyReportDiff += counterQty;&#xD;&#xA;&#xD;&#xA;TotalPluckMedAccMinusCounterQty = pluckMedAccReportDiff  - counterQtyReportDiff  ;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell69_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;     xrTableCell69.Text = TotalPluckMedAccMinusCounterQty.ToString(&quot;N2&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;" Landscape="true" PageWidthF="1653.54333" PageHeightF="1169.29138" Version="25.2" DataMember="SR_PT_DailySalughtering" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" Borders="Top, Bottom" BorderWidth="0.5">
