                <CalculatedFields>
                  <Item1 Ref="161" Name="Abs_OpenBal" Expression="Abs([OpenBalance])" DataMember="SR_FC_CustSuppSheet" />
                  <Item2 Ref="162" Name="DebitCreditOpenBalRes" Expression="Iif([OpenBalance] &gt; 0,[Debit_Str] , Iif([OpenBalance] &lt; 0, [Credit_Str], ''))" DataMember="SR_FC_CustSuppSheet" />
                  <Item3 Ref="163" Name="Debit_Str" Expression="Iif(?IsRTL == true,'(مدين)' , '(Debit)')" DataMember="SR_FC_CustSuppSheet" />
                  <Item4 Ref="164" Name="Credit_Str" Expression="Iif(?IsRTL == true,'(دائن)' , '(Credit)')" DataMember="SR_FC_CustSuppSheet" />
                  <Item5 Ref="165" Name="OpenDebit" Expression="Iif([OpenBalance] &gt; 0, [OpenBalance], NULL)" DataMember="SR_FC_CustSuppSheet" />
                  <Item6 Ref="166" Name="OpenCredit" Expression="Iif([OpenBalance] &lt; 0, Abs([OpenBalance]), NULL)&#xA;" DataMember="SR_FC_CustSuppSheet" />
                  <Item7 Ref="167" Name="Result" Expression="[Debit] - [Credit]" DataMember="SR_FC_CustSuppSheet" />
                  <Item8 Ref="168" Name="CloseDebit" Expression="Iif([CloseBalance] &gt; 0, [CloseBalance], 0)" DataMember="SR_FC_CustSuppSheet" />
                  <Item9 Ref="169" Name="Open_Balance_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([OpenBalance])/[FormulaOperand_Prod] ,0 )" DataMember="SR_FC_FM_StockMovement" />
                  <Item10 Ref="170" Name="Inputs_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([InputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item11 Ref="171" Name="Consumed_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([Consumed])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item12 Ref="172" Name="Outputs_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([SoldTransferOut])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item13 Ref="173" Name="Other_Output_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([OtherOutputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item14 Ref="174" Name="Close_Balance_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([CloseBalance])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item15 Ref="175" Name="Test" DataMember="SR_FC_FM_StockMovement" />
                  <Item16 Ref="176" Name="SumOfHours" Expression="sum([TotalSecond]) /3600" DataMember="SR_MO_TrackUserActions" />
                  <Item17 Ref="177" Name="calculatedField1" DataMember="SR_MO_TrackUserActions" />
                  <Item18 Ref="178" Name="SubTotal" Expression="[Culls] + [DOA]" DataMember="SR_PT_DailyProdReport" />
                  <Item19 Ref="179" Name="Total_PR" Expression="[LiveBirds] - [SubTotal]" DataMember="SR_PT_DailyProdReport" />
                  <Item20 Ref="180" Name="Total" Expression="[Total_PR] + [SubTotal]" DataMember="SR_PT_DailyProdReport" />
                  <Item21 Ref="181" Name="SubTotal_Wt" Expression="[Culls_Wt] + [PluckRej_Wt] + [DOA_Wt]" DataMember="SR_PT_DailyProdReport" />
                  <Item22 Ref="182" Name="Total_PR_Wt" Expression="[LiveBirds_Wt] = [SubTotal_Wt]" DataMember="SR_PT_DailyProdReport" />
                  <Item23 Ref="183" Name="Total_Wt" Expression="[Total_PR_Wt] + [SubTotal_Wt]" DataMember="SR_PT_DailyProdReport" />
                  <Item24 Ref="184" Name="Yield" Expression="Iif([Total_PR_Wt] &gt; 0, [PortionsTotalWeight] / [Total_PR_Wt] * 100, 0 )" DataMember="SR_PT_DailyProdReport" />
                  <Item25 Ref="185" Name="Avg_LiveBirdWts" Expression="Iif(&#xA;  [LiveBirds] &gt; 0,&#xA;  [LiveBirds_Wt] / [LiveBirds],&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailyProdReport" />
