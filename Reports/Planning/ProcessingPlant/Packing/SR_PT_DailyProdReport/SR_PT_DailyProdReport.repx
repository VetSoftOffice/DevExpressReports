              <ReportSource Ref="144" ControlType="DevExpressReports.Reports.Planning.ProcessingPlant.Packing.SR_PT_DailyProdReport_SubReport.SR_PT_DailyProdReport_SubReport, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="decimal PortionsPercReport = 0;&#xD;&#xA;private void xrTableCell44_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal liveBirds = 0;&#xD;&#xA;decimal liveBirdsWt = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;LiveBirds&quot;) != null)&#xD;&#xA;    liveBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveBirds&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;LiveBirds_Wt&quot;) != null)&#xD;&#xA;    liveBirdsWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveBirds_Wt&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal avgWeightPerBird = 0;&#xD;&#xA;if (liveBirds &gt; 0)&#xD;&#xA;    avgWeightPerBird = liveBirdsWt / liveBirds;&#xD;&#xA;&#xD;&#xA;// --- (Optional) Add to report-level total if you want to calculate averages later ---&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = avgWeightPerBird.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;AvgLiveBirdWeightReport += avgWeightPerBird;   // define AvgLiveBirdWeightReport at report level&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell14_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal culls = 0;&#xD;&#xA;decimal doa = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DOA&quot;) != null)&#xD;&#xA;    doa = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal result = culls + doa;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N0&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell31_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal liveBirds = 0;&#xD;&#xA;decimal culls = 0;&#xD;&#xA;decimal doa = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;LiveBirds&quot;) != null)&#xD;&#xA;    liveBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveBirds&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DOA&quot;) != null)&#xD;&#xA;    doa = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal result = liveBirds - (culls + doa);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N0&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell35_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal liveBirds = 0;&#xD;&#xA;decimal culls = 0;&#xD;&#xA;decimal doa = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;LiveBirds&quot;) != null)&#xD;&#xA;    liveBirds = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveBirds&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null)&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DOA&quot;) != null)&#xD;&#xA;    doa = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;// First part: (Culls + DOA)&#xD;&#xA;decimal cullsDoa = culls + doa;&#xD;&#xA;&#xD;&#xA;// Second part: (LiveBirds - (Culls + DOA))&#xD;&#xA;decimal remaining = liveBirds - cullsDoa;&#xD;&#xA;&#xD;&#xA;// Final result: (Culls + DOA) + (LiveBirds - (Culls + DOA))&#xD;&#xA;decimal result = cullsDoa + remaining;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N0&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell9_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal cullsWt = 0;&#xD;&#xA;decimal pluckRejWt = 0;&#xD;&#xA;decimal doaWt = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls_Wt&quot;) != null)&#xD;&#xA;    cullsWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls_Wt&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;PluckRej_Wt&quot;) != null)&#xD;&#xA;    pluckRejWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;PluckRej_Wt&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DOA_Wt&quot;) != null)&#xD;&#xA;    doaWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA_Wt&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal result = cullsWt + pluckRejWt + doaWt;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell32_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal liveBirdsWt = 0;&#xD;&#xA;decimal cullsWt = 0;&#xD;&#xA;decimal pluckRejWt = 0;&#xD;&#xA;decimal doaWt = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;LiveBirds_Wt&quot;) != null)&#xD;&#xA;    liveBirdsWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveBirds_Wt&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls_Wt&quot;) != null)&#xD;&#xA;    cullsWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls_Wt&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;PluckRej_Wt&quot;) != null)&#xD;&#xA;    pluckRejWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;PluckRej_Wt&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DOA_Wt&quot;) != null)&#xD;&#xA;    doaWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA_Wt&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal result = liveBirdsWt + (cullsWt + pluckRejWt + doaWt);&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell36_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values --- &#xD;&#xA;decimal cullsWt = 0;&#xD;&#xA;decimal pluckRejWt = 0;&#xD;&#xA;decimal doaWt = 0;&#xD;&#xA;decimal liveBirdsWt = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls_Wt&quot;) != null)&#xD;&#xA;    cullsWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls_Wt&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;PluckRej_Wt&quot;) != null)&#xD;&#xA;    pluckRejWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;PluckRej_Wt&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DOA_Wt&quot;) != null)&#xD;&#xA;    doaWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA_Wt&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;LiveBirds_Wt&quot;) != null)&#xD;&#xA;    liveBirdsWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveBirds_Wt&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;// Formula = (Culls_Wt + PluckRej_Wt + DOA_Wt) + LiveBirds_Wt + (Culls_Wt + PluckRej_Wt + DOA_Wt)&#xD;&#xA;decimal result = (cullsWt + pluckRejWt + doaWt) + liveBirdsWt + (cullsWt + pluckRejWt + doaWt);&#xD;&#xA;&#xD;&#xA;// --- Add to group total ---&#xD;&#xA;groupSumCullsPluckDOALive += result;   // define at report level&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell40_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal liveBirdsWt = 0;&#xD;&#xA;decimal cullsWt = 0;&#xD;&#xA;decimal pluckRejWt = 0;&#xD;&#xA;decimal doaWt = 0;&#xD;&#xA;decimal portionsTotalWeight = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;LiveBirds_Wt&quot;) != null)&#xD;&#xA;    liveBirdsWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;LiveBirds_Wt&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls_Wt&quot;) != null)&#xD;&#xA;    cullsWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls_Wt&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;PluckRej_Wt&quot;) != null)&#xD;&#xA;    pluckRejWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;PluckRej_Wt&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DOA_Wt&quot;) != null)&#xD;&#xA;    doaWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA_Wt&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;PortionsTotalWeight&quot;) != null)&#xD;&#xA;    portionsTotalWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;PortionsTotalWeight&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal denominator = liveBirdsWt + cullsWt + pluckRejWt + doaWt;&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (denominator &gt; 0)&#xD;&#xA;    percentage = (portionsTotalWeight / denominator) * 100m;&#xD;&#xA;&#xD;&#xA;// --- (Optional) Add to report-level accumulator ---&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // up to 2 decimals&#xD;&#xA;PortionsPercReport += percentage;   // define PortionsPercReport at report level if needed&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;" PageWidthF="826.771667" PageHeightF="1169.29138" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="26.1" DataMember="SR_PT_DailyProdReport" DataSource="#Ref-143" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
