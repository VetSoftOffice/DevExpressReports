              <ReportSource Ref="222" ControlType="DevExpressReports.Reports.Planning.ProcessingPlant.Packing.SR_PT_DailyProdWholeChickens_SubReport2.SR_PT_DailyProdWholeChickens_SubReport2, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="decimal AccumulatedProdWt  = 0;&#xD;&#xA;&#xD;&#xA;private void xrTableCell12_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal totalCheckensPortionWeight = 0;&#xD;&#xA;decimal totalWeightProduct = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;TotalCheckensPortionWeight&quot;) != null)&#xD;&#xA;    totalCheckensPortionWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalCheckensPortionWeight&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;TotalWeightproduct&quot;) != null)&#xD;&#xA;    totalWeightProduct = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalWeightproduct&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal result = totalCheckensPortionWeight + totalWeightProduct;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell14_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal totalWeightChickens = 0;&#xD;&#xA;decimal totalWeightPluacking = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;TotalWeightChickens&quot;) != null)&#xD;&#xA;    totalWeightChickens = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalWeightChickens&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;TotalWeightPluacking&quot;) != null)&#xD;&#xA;    totalWeightPluacking = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalWeightPluacking&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (totalWeightPluacking != 0)&#xD;&#xA;    percentage = (totalWeightChickens * 100m) / totalWeightPluacking;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell18_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal prodWt = 0;&#xD;&#xA;decimal totalWeightPluacking = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;ProdWt&quot;) != null)&#xD;&#xA;    prodWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;ProdWt&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;TotalWeightPluacking&quot;) != null)&#xD;&#xA;    totalWeightPluacking = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalWeightPluacking&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (totalWeightPluacking != 0)&#xD;&#xA;    percentage = (AccumulatedProdWt * 100m) / totalWeightPluacking;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;// --- Accumulate ProdWt for SUM ---&#xD;&#xA;AccumulatedProdWt += prodWt;   // define AccumulatedProdWt at report level&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal prodWt = 0;&#xD;&#xA;decimal totalCheckensPortionWeight = 0;&#xD;&#xA;decimal totalWeightProduct = 0;&#xD;&#xA;decimal totalWeightPluacking = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;ProdWt&quot;) != null)&#xD;&#xA;    prodWt = Convert.ToDecimal(GetCurrentColumnValue(&quot;ProdWt&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;TotalCheckensPortionWeight&quot;) != null)&#xD;&#xA;    totalCheckensPortionWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalCheckensPortionWeight&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;TotalWeightProduct&quot;) != null)&#xD;&#xA;    totalWeightProduct = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalWeightProduct&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;TotalWeightPluacking&quot;) != null)&#xD;&#xA;    totalWeightPluacking = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalWeightPluacking&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (totalWeightPluacking != 0)&#xD;&#xA;    percentage = ((AccumulatedProdWt + totalCheckensPortionWeight + totalWeightProduct) * 100m) &#xD;&#xA;                  / totalWeightPluacking;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;// --- Accumulate ProdWt for SUM ---&#xD;&#xA;AccumulatedProdWt += prodWt;   // define AccumulatedProdWt at report level&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;" PageWidthF="826.771667" PageHeightF="1169.29138" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="25.2" DataMember="SR_PT_DailyProdWholeChickens2" DataSource="#Ref-221" TextAlignment="MiddleLeft" BackColor="255,235,235,235" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
