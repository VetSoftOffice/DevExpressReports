<XtraReportsLayoutSerializer SerializerVersion="26.1.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v24.2, Version=24.2.6.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_PT_DailyProdPortionCheckens" ScriptsSource="&#xD;&#xA;private void xrTableCell11_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal prodWeight = 0;&#xD;&#xA;decimal totalCheckensPortionWeight = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;ProdWeight&quot;) != null)&#xD;&#xA;    prodWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;ProdWeight&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;TotalCheckensPortionWeight&quot;) != null)&#xD;&#xA;    totalCheckensPortionWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalCheckensPortionWeight&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (totalCheckensPortionWeight != 0)&#xD;&#xA;    percentage = (prodWeight * 100m) / totalCheckensPortionWeight;&#xD;&#xA;&#xD;&#xA;// --- Add to report total (optional for summaries/averages) ---&#xD;&#xA;ProdPortionPercReport += percentage;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell17_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal lossQty = 0;&#xD;&#xA;decimal totalCheckensPortionWeight = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;LossQty&quot;) != null)&#xD;&#xA;    lossQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;LossQty&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;TotalCheckensPortionWeight&quot;) != null)&#xD;&#xA;    totalCheckensPortionWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalCheckensPortionWeight&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (totalCheckensPortionWeight != 0)&#xD;&#xA;    percentage = (lossQty * 100m) / totalCheckensPortionWeight;&#xD;&#xA;&#xD;&#xA;// --- Add to report total (optional for summaries/averages) ---&#xD;&#xA;LossQtyPercReport += percentage;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell15_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare values ---&#xD;&#xA;decimal condQty = 0;&#xD;&#xA;decimal totalCheckensPortionWeight = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CondQty&quot;) != null)&#xD;&#xA;    condQty = Convert.ToDecimal(GetCurrentColumnValue(&quot;CondQty&quot;));&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;TotalCheckensPortionWeight&quot;) != null)&#xD;&#xA;    totalCheckensPortionWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;TotalCheckensPortionWeight&quot;));&#xD;&#xA;&#xD;&#xA;// --- Equation ---&#xD;&#xA;decimal percentage = 0;&#xD;&#xA;if (totalCheckensPortionWeight != 0)&#xD;&#xA;    percentage = (condQty * 100m) / totalCheckensPortionWeight;&#xD;&#xA;&#xD;&#xA;// --- Add to report total (optional for summaries/averages) ---&#xD;&#xA;CondQtyPercReport += percentage;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = percentage.ToString(&quot;0.##&quot;); // format with up to 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;" PageWidth="827" PageHeight="1169" Version="26.1" DataMember="SR_PT_DailyProdPortionCheckens" DataSource="#Ref-0" TextAlignment="MiddleLeft" BorderColor="255,75,75,75" 