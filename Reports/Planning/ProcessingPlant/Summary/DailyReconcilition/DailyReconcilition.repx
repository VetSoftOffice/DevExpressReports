        <Item1 Ref="207" ControlType="SubBand" Name="SubBand6">
          <Controls>
            <Item1 Ref="208" ControlType="XRSubreport" Name="DailyReconcilition_SubReport">
              <ReportSource Ref="210" ControlType="DevExpressReports.Reports.Planning.ProcessingPlant.Summary.DailyReconcilition_SubReport.DailyReconcilition_SubReport, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="decimal pluckRejectPercentTotal  = 0;&#xD;&#xA;private void xrTableCell33_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare running total variables (outside or static in the class scope if cumulative across rows) ---&#xD;&#xA;decimal counterTotal = 0;&#xD;&#xA;decimal doa = 0;&#xD;&#xA;decimal culls = 0;&#xD;&#xA;decimal scaleWeight = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely from the current record ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CounterTotal&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CounterTotal&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    counterTotal = Convert.ToDecimal(GetCurrentColumnValue(&quot;CounterTotal&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DOA&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;DOA&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    doa = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;Culls&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;ScaleWeight&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;ScaleWeight&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    scaleWeight = Convert.ToDecimal(GetCurrentColumnValue(&quot;ScaleWeight&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Accumulate totals across all records (these must be declared as class-level variables above the method) ---&#xD;&#xA;counterTotalSum += counterTotal;&#xD;&#xA;doaSum += doa;&#xD;&#xA;cullsSum += culls;&#xD;&#xA;scaleWeightSum += scaleWeight;&#xD;&#xA;&#xD;&#xA;// --- Compute denominator and final result ---&#xD;&#xA;decimal denominator = counterTotalSum + doaSum + cullsSum;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;if (counterTotalSum &gt; 0 &amp;&amp; denominator != 0)&#xD;&#xA;    result = scaleWeightSum / denominator;&#xD;&#xA;else&#xD;&#xA;    result = 0;&#xD;&#xA;&#xD;&#xA;// --- Assign result to table cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);  // format with 2 decimal places&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell72_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;            //-- new logic for Pluck Reject Percentage&#xD;&#xA;// --- Declare variables ---&#xD;&#xA;decimal counterTotal = 0;&#xD;&#xA;decimal pluckReject = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CounterTotal&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CounterTotal&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    counterTotal = Convert.ToDecimal(GetCurrentColumnValue(&quot;CounterTotal&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;PluckReject&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;PluckReject&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    pluckReject = Convert.ToDecimal(GetCurrentColumnValue(&quot;PluckReject&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif([CounterTotal] != 0, [PluckReject] / [CounterTotal] * 100, 0)) ---&#xD;&#xA;if (counterTotal != 0)&#xD;&#xA;    result = (pluckReject / counterTotal) * 100;&#xD;&#xA;else&#xD;&#xA;    result = 0;&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;pluckRejectPercentTotal += result;&#xD;&#xA;// --- Assign result to table cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);  // format with 2 decimal places&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell24_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare local variables for current record ---&#xD;&#xA;decimal rfFemaleStarted = 0;&#xD;&#xA;decimal deplation = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;rf_Female_Started&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;rf_Female_Started&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    rfFemaleStarted = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_Female_Started&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DEPLATION&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;DEPLATION&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    deplation = Convert.ToDecimal(GetCurrentColumnValue(&quot;DEPLATION&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Accumulate sums across all records ---&#xD;&#xA;// (these should be declared as class-level variables at the top of the report)&#xD;&#xA;decimal rfFemaleStartedSum = 0;&#xD;&#xA;decimal deplationSum = 0;&#xD;&#xA;&#xD;&#xA;rfFemaleStartedSum += rfFemaleStarted;&#xD;&#xA;deplationSum += deplation;&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif(Sum(...) &lt;&gt; 0, Sum(DEPLATION)/Sum(rf_Female_Started)*100, 0)) ---&#xD;&#xA;decimal result = 0;&#xD;&#xA;if (rfFemaleStartedSum != 0)&#xD;&#xA;    result = (deplationSum / rfFemaleStartedSum) * 100;&#xD;&#xA;else&#xD;&#xA;    result = 0;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);  // format with 2 decimal places&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell6_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare local variables for current record ---&#xD;&#xA;decimal rfFemaleStarted = 0;&#xD;&#xA;decimal rfLiveFemale = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;rf_Female_Started&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;rf_Female_Started&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    rfFemaleStarted = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_Female_Started&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;rf_LiveFemale&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;rf_LiveFemale&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    rfLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_LiveFemale&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Accumulate sums across all records ---&#xD;&#xA;// (define these variables at the top of your report class)&#xD;&#xA;decimal rfFemaleStartedSum = 0;&#xD;&#xA;decimal rfLiveFemaleSum = 0;&#xD;&#xA;&#xD;&#xA;rfFemaleStartedSum += rfFemaleStarted;&#xD;&#xA;rfLiveFemaleSum += rfLiveFemale;&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif(Sum([rf_Female_Started]) &lt;&gt; 0, (Sum([rf_LiveFemale]) / Sum([rf_Female_Started])) * 100, 0)) ---&#xD;&#xA;decimal result = 0;&#xD;&#xA;if (rfFemaleStartedSum != 0)&#xD;&#xA;    result = (rfLiveFemaleSum / rfFemaleStartedSum) * 100;&#xD;&#xA;else&#xD;&#xA;    result = 0;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);  // format with 2 decimal places&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell14_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare local variables for current record ---&#xD;&#xA;decimal rfLiveFemale = 0;&#xD;&#xA;decimal doa = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;rf_LiveFemale&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;rf_LiveFemale&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    rfLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_LiveFemale&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;DOA&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;DOA&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    doa = Convert.ToDecimal(GetCurrentColumnValue(&quot;DOA&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Accumulate sums across all records ---&#xD;&#xA;// (define these at the top of your report class)&#xD;&#xA;decimal rfLiveFemaleSum  = 0;&#xD;&#xA;decimal doaSum = 0;&#xD;&#xA;&#xD;&#xA;rfLiveFemaleSum += rfLiveFemale;&#xD;&#xA;doaSum += doa;&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif(Sum([rf_LiveFemale]) &lt;&gt; 0, Sum([DOA]) * 100 / Sum([rf_LiveFemale]), 0)) ---&#xD;&#xA;decimal result = 0;&#xD;&#xA;if (rfLiveFemaleSum != 0)&#xD;&#xA;    result = (doaSum * 100) / rfLiveFemaleSum;&#xD;&#xA;else&#xD;&#xA;    result = 0;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);   // format with 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell18_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare local variables for current record ---&#xD;&#xA;decimal rfLiveFemale = 0;&#xD;&#xA;decimal culls = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;rf_LiveFemale&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;rf_LiveFemale&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    rfLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_LiveFemale&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Culls&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;Culls&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    culls = Convert.ToDecimal(GetCurrentColumnValue(&quot;Culls&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Accumulate sums across all records ---&#xD;&#xA;// (define these at the top of your report class)&#xD;&#xA;decimal rfLiveFemaleSum  = 0;&#xD;&#xA;decimal cullsSum  = 0;&#xD;&#xA;rfLiveFemaleSum += rfLiveFemale;&#xD;&#xA;cullsSum += culls;&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif(Sum([rf_LiveFemale]) &lt;&gt; 0, Sum([Culls]) * 100 / Sum([rf_LiveFemale]), 0)) ---&#xD;&#xA;decimal result = 0;&#xD;&#xA;if (rfLiveFemaleSum != 0)&#xD;&#xA;    result = (cullsSum * 100) / rfLiveFemaleSum;&#xD;&#xA;else&#xD;&#xA;    result = 0;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);   // format with 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell19_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare local variables for current record ---&#xD;&#xA;decimal rfLiveFemale = 0;&#xD;&#xA;decimal counterTotal = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;rf_LiveFemale&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;rf_LiveFemale&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    rfLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_LiveFemale&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;CounterTotal&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CounterTotal&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    counterTotal = Convert.ToDecimal(GetCurrentColumnValue(&quot;CounterTotal&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Accumulate sums across all records ---&#xD;&#xA;// (define these at the top of your report class)&#xD;&#xA;decimal rfLiveFemaleSum  = 0;&#xD;&#xA;decimal counterTotalSum  = 0;&#xD;&#xA;rfLiveFemaleSum += rfLiveFemale;&#xD;&#xA;counterTotalSum += counterTotal;&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif(Sum([rf_LiveFemale]) &lt;&gt; 0, Sum([CounterTotal]) * 100 / Sum([rf_LiveFemale]), 0)) ---&#xD;&#xA;decimal result = 0;&#xD;&#xA;if (rfLiveFemaleSum != 0)&#xD;&#xA;    result = (counterTotalSum * 100) / rfLiveFemaleSum;&#xD;&#xA;else&#xD;&#xA;    result = 0;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);   // format with 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell22_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    // --- Declare local variables for current record ---&#xD;&#xA;decimal rfLiveFemale = 0;&#xD;&#xA;decimal deviation = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;rf_LiveFemale&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;rf_LiveFemale&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    rfLiveFemale = Convert.ToDecimal(GetCurrentColumnValue(&quot;rf_LiveFemale&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;Deviation&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;Deviation&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    deviation = Convert.ToDecimal(GetCurrentColumnValue(&quot;Deviation&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Accumulate sums across all records ---&#xD;&#xA;// (define these at the top of your report class)&#xD;&#xA;decimal rfLiveFemaleSum = 0;&#xD;&#xA;decimal deviationSum = 0;&#xD;&#xA;&#xD;&#xA;rfLiveFemaleSum += rfLiveFemale;&#xD;&#xA;deviationSum += deviation;&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif(Sum([rf_LiveFemale]) &lt;&gt; 0, Sum([Deviation]) * 100 / Sum([rf_LiveFemale]), 0)) ---&#xD;&#xA;decimal result = 0;&#xD;&#xA;if (rfLiveFemaleSum != 0)&#xD;&#xA;    result = (deviationSum * 100) / rfLiveFemaleSum;&#xD;&#xA;else&#xD;&#xA;    result = 0;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);   // format with 2 decimals&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;" PageWidth="1169" PageHeight="1654" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="24.2" DataMember="SR_PT_DailyReconcilition_1" DataSource="#Ref-209" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
