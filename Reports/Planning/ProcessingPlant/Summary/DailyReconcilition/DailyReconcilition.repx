                <CalculatedFields>
                  <Item1 Ref="225" Name="Abs_OpenBal" Expression="Abs([OpenBalance])" DataMember="SR_FC_CustSuppSheet" />
                  <Item2 Ref="226" Name="DebitCreditOpenBalRes" Expression="Iif([OpenBalance] &gt; 0,[Debit_Str] , Iif([OpenBalance] &lt; 0, [Credit_Str], ''))" DataMember="SR_FC_CustSuppSheet" />
                  <Item3 Ref="227" Name="Debit_Str" Expression="Iif(?IsRTL == true,'(????)' , '(Debit)')" DataMember="SR_FC_CustSuppSheet" />
                  <Item4 Ref="228" Name="Credit_Str" Expression="Iif(?IsRTL == true,'(????)' , '(Credit)')" DataMember="SR_FC_CustSuppSheet" />
                  <Item5 Ref="229" Name="OpenDebit" Expression="Iif([OpenBalance] &gt; 0, [OpenBalance], NULL)" DataMember="SR_FC_CustSuppSheet" />
                  <Item6 Ref="230" Name="OpenCredit" Expression="Iif([OpenBalance] &lt; 0, Abs([OpenBalance]), NULL)&#xA;" DataMember="SR_FC_CustSuppSheet" />
                  <Item7 Ref="231" Name="Result" Expression="[Debit] - [Credit]" DataMember="SR_FC_CustSuppSheet" />
                  <Item8 Ref="232" Name="CloseDebit" Expression="Iif([CloseBalance] &gt; 0, [CloseBalance], 0)" DataMember="SR_FC_CustSuppSheet" />
                  <Item9 Ref="233" Name="Open_Balance_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([OpenBalance])/[FormulaOperand_Prod] ,0 )" DataMember="SR_FC_FM_StockMovement" />
                  <Item10 Ref="234" Name="Inputs_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([InputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item11 Ref="235" Name="Consumed_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([Consumed])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item12 Ref="236" Name="Outputs_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([SoldTransferOut])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item13 Ref="237" Name="Other_Output_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([OtherOutputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item14 Ref="238" Name="Close_Balance_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([CloseBalance])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item15 Ref="239" Name="Test" DataMember="SR_FC_FM_StockMovement" />
                  <Item16 Ref="240" Name="AvgScaleWeight_GT" Expression="Iif(&#xA;  Sum([CounterTotal]) &gt; 0,&#xA;  Sum([ScaleWeight]) / (Sum([CounterTotal]) + Sum([DOA]) + Sum([Culls])),&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailyReconcilition_1" />
                  <Item17 Ref="241" Name="PluckRejectPerc" Expression="Iif([CounterTotal] != 0,[PluckReject]/ [CounterTotal] * 100, 0)&#xA;" DataMember="SR_PT_DailyReconcilition_1" />
                  <Item18 Ref="242" Name="FarmMortPrecent" Expression="Iif(&#xA;  Sum([rf_Female_Started]) &lt;&gt; 0,&#xA;  Sum([DEPLATION]) / Sum([rf_Female_Started]) * 100,&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailyReconcilition_1" />
                  <Item19 Ref="243" Name="NetChickenPrecent" Expression="Iif(&#xA;  Sum([rf_Female_Started]) &lt;&gt; 0,&#xA;  (Sum([rf_LiveFemale]) / Sum([rf_Female_Started])) * 100,&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailyReconcilition_1" />
                  <Item20 Ref="244" Name="DOAPRECENT" Expression="Iif(&#xA;  Sum([rf_LiveFemale]) &lt;&gt; 0,&#xA;  Sum([DOA]) * 100 / Sum([rf_LiveFemale]),&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailyReconcilition_1" />
                  <Item21 Ref="245" Name="CullsPrecent" Expression="Iif(&#xA;  Sum([rf_LiveFemale]) &lt;&gt; 0,&#xA;  Sum([Culls]) * 100 / Sum([rf_LiveFemale]),&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailyReconcilition_1" />
                  <Item22 Ref="246" Name="CounterPrecent" Expression="Iif(&#xA;  Sum([rf_LiveFemale]) &lt;&gt; 0,&#xA;  Sum([CounterTotal]) * 100 / Sum([rf_LiveFemale]),&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailyReconcilition_1" />
                  <Item23 Ref="247" Name="DeviationPrecent" Expression="Iif(&#xA;  Sum([rf_LiveFemale]) &lt;&gt; 0,&#xA;  Sum([Deviation]) * 100 / Sum([rf_LiveFemale]),&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailyReconcilition_1" />
