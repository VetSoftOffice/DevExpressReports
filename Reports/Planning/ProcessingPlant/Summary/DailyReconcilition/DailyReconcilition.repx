        <Item2 Ref="562" ControlType="SubBand" Name="SubBand8">
          <Controls>
            <Item1 Ref="563" ControlType="XRSubreport" Name="DailyReconcilition_SubReportDetail">
              <ReportSource Ref="565" ControlType="DevExpressReports.Reports.Planning.ProcessingPlant.Summary.DailyReconcilition_SubReportDetail.DailyReconcilition_SubReportDetail, DevExpressReports, Version=1.0.0.0, Culture=neutral, PublicKeyToken=null" ScriptsSource="&#xD;&#xA;private void xrTableCell72_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    decimal counterTotal = 0;&#xD;&#xA;decimal pluckReject = 0;&#xD;&#xA;decimal result = 0;&#xD;&#xA;&#xD;&#xA;// --- Read values safely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CounterTotal&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CounterTotal&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    counterTotal = Convert.ToDecimal(GetCurrentColumnValue(&quot;CounterTotal&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;PluckReject&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;PluckReject&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    pluckReject = Convert.ToDecimal(GetCurrentColumnValue(&quot;PluckReject&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif([CounterTotal] != 0, [PluckReject] / [CounterTotal] * 100, 0)) ---&#xD;&#xA;if (counterTotal != 0)&#xD;&#xA;    result = (pluckReject / counterTotal) * 100;&#xD;&#xA;else&#xD;&#xA;    result = 0;&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;pluckRejectPercentTotal += result;&#xD;&#xA;&#xD;&#xA;// --- Assign result to cell ---&#xD;&#xA;XRTableCell cell = sender as XRTableCell;&#xD;&#xA;cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;" PageWidth="1169" PageHeight="1654" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="24.2" DataMember="SR_PT_DailyReconcilition_1" DataSource="#Ref-564" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
                <Parameters>
                  <Item1 Ref="566" Visible="false" ValueInfo="False" Name="IsRTL" Type="#Ref-2" />
                  <Item2 Ref="567" Visible="false" ValueInfo="False" Name="IsCustomReportFooter" Type="#Ref-2" />
                  <Item3 Ref="568" Visible="false" ValueInfo="False" Name="IsCustomReportHeader" Type="#Ref-2" />
                  <Item4 Ref="569" Visible="false" ValueInfo="False" Name="ShowSignature" Type="#Ref-2" />
                  <Item5 Ref="570" Visible="false" ValueInfo="False" Name="ShowSignatureAllPages" Type="#Ref-2" />
                  <Item6 Ref="571" ValueInfo="False" Name="HideReportHeader" Type="#Ref-2" />
                  <Item7 Ref="572" ValueInfo="False" Name="HideReportFooter" Type="#Ref-2" />
                  <Item8 Ref="573" Visible="false" Enabled="false" ValueInfo="True" Name="IsDealType" Type="#Ref-2" />
                  <Item9 Ref="574" Name="NoOfGroupsPerPage" />
                  <Item10 Ref="575" Visible="false" Name="FontSize" />
                  <Item11 Ref="576" Visible="false" Name="DateFrom" />
                  <Item12 Ref="577" Visible="false" Name="DateTo" />
                  <Item13 Ref="578" Visible="false" Enabled="false" AllowNull="true" Name="Code_Str" />
                  <Item14 Ref="579" Visible="false" Enabled="false" Name="CustSupp" />
                </Parameters>
                <CalculatedFields>
                  <Item1 Ref="580" Name="Abs_OpenBal" Expression="Abs([OpenBalance])" DataMember="SR_FC_CustSuppSheet" />
                  <Item2 Ref="581" Name="DebitCreditOpenBalRes" Expression="Iif([OpenBalance] &gt; 0,[Debit_Str] , Iif([OpenBalance] &lt; 0, [Credit_Str], ''))" DataMember="SR_FC_CustSuppSheet" />
                  <Item3 Ref="582" Name="Debit_Str" Expression="Iif(?IsRTL == true,'(مدين)' , '(Debit)')" DataMember="SR_FC_CustSuppSheet" />
                  <Item4 Ref="583" Name="Credit_Str" Expression="Iif(?IsRTL == true,'(دائن)' , '(Credit)')" DataMember="SR_FC_CustSuppSheet" />
                  <Item5 Ref="584" Name="OpenDebit" Expression="Iif([OpenBalance] &gt; 0, [OpenBalance], NULL)" DataMember="SR_FC_CustSuppSheet" />
                  <Item6 Ref="585" Name="OpenCredit" Expression="Iif([OpenBalance] &lt; 0, Abs([OpenBalance]), NULL)&#xA;" DataMember="SR_FC_CustSuppSheet" />
                  <Item7 Ref="586" Name="Result" Expression="[Debit] - [Credit]" DataMember="SR_FC_CustSuppSheet" />
                  <Item8 Ref="587" Name="CloseDebit" Expression="Iif([CloseBalance] &gt; 0, [CloseBalance], 0)" DataMember="SR_FC_CustSuppSheet" />
                  <Item9 Ref="588" Name="Open_Balance_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([OpenBalance])/[FormulaOperand_Prod] ,0 )" DataMember="SR_FC_FM_StockMovement" />
                  <Item10 Ref="589" Name="Inputs_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([InputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item11 Ref="590" Name="Consumed_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([Consumed])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item12 Ref="591" Name="Outputs_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([SoldTransferOut])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item13 Ref="592" Name="Other_Output_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([OtherOutputsStdUnit])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item14 Ref="593" Name="Close_Balance_Prod" Expression="Iif([FormulaOperand_Prod]&lt;&gt;0,ToDecimal([CloseBalance])/[FormulaOperand_Prod] ,0 )&#xA;" DataMember="SR_FC_FM_StockMovement" />
                  <Item15 Ref="594" Name="Test" DataMember="SR_FC_FM_StockMovement" />
                  <Item16 Ref="595" Name="AvgScaleWeight_GT" Expression="Iif(&#xA;  Sum([CounterTotal]) &gt; 0,&#xA;  Sum([ScaleWeight]) / (Sum([CounterTotal]) + Sum([DOA]) + Sum([Culls])),&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailyReconcilition_1" />
                  <Item17 Ref="596" Name="PluckRejectPerc" Expression="Iif([CounterTotal] != 0,[PluckReject]/ [CounterTotal] * 100, 0)&#xA;" DataMember="SR_PT_DailyReconcilition_1" />
                  <Item18 Ref="597" Name="FarmMortPrecent" Expression="Iif(&#xA;  Sum([rf_Female_Started]) &lt;&gt; 0,&#xA;  Sum([DEPLATION]) / Sum([rf_Female_Started]) * 100,&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailyReconcilition_1" />
                  <Item19 Ref="598" Name="NetChickenPrecent" Expression="Iif(&#xA;  Sum([rf_Female_Started]) &lt;&gt; 0,&#xA;  (Sum([rf_LiveFemale]) / Sum([rf_Female_Started])) * 100,&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailyReconcilition_1" />
                  <Item20 Ref="599" Name="DOAPRECENT" Expression="Iif(&#xA;  Sum([rf_LiveFemale]) &lt;&gt; 0,&#xA;  Sum([DOA]) * 100 / Sum([rf_LiveFemale]),&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailyReconcilition_1" />
                  <Item21 Ref="600" Name="CullsPrecent" Expression="Iif(&#xA;  Sum([rf_LiveFemale]) &lt;&gt; 0,&#xA;  Sum([Culls]) * 100 / Sum([rf_LiveFemale]),&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailyReconcilition_1" />
                  <Item22 Ref="601" Name="CounterPrecent" Expression="Iif(&#xA;  Sum([rf_LiveFemale]) &lt;&gt; 0,&#xA;  Sum([CounterTotal]) * 100 / Sum([rf_LiveFemale]),&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailyReconcilition_1" />
                  <Item23 Ref="602" Name="DeviationPrecent" Expression="Iif(&#xA;  Sum([rf_LiveFemale]) &lt;&gt; 0,&#xA;  Sum([Deviation]) * 100 / Sum([rf_LiveFemale]),&#xA;  0&#xA;)&#xA;" DataMember="SR_PT_DailyReconcilition_1" />
                </CalculatedFields>
