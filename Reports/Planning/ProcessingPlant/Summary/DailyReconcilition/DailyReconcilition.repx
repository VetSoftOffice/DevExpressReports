afely ---&#xD;&#xA;if (GetCurrentColumnValue(&quot;CounterTotal&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;CounterTotal&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    counterTotal = Convert.ToDecimal(GetCurrentColumnValue(&quot;CounterTotal&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;if (GetCurrentColumnValue(&quot;PluckReject&quot;) != null &amp;&amp;&#xD;&#xA;    !string.IsNullOrEmpty(GetCurrentColumnValue(&quot;PluckReject&quot;).ToString()))&#xD;&#xA;{&#xD;&#xA;    pluckReject = Convert.ToDecimal(GetCurrentColumnValue(&quot;PluckReject&quot;));&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;// --- Equation (same as Iif([CounterTotal] != 0, [PluckReject] / [CounterTotal] * 100, 0)) ---&#xD;&#xA;if (counterTotal != 0)&#xD;&#xA;    result = (pluckReject / counterTotal) * 100;&#xD;&#xA;else&#xD;&#xA;    result = 0;&#xD;&#xA;&#xD;&#xA;// --- Optional: accumulate total ---&#xD;&#xA;pluckRejectPercentTotal += result;&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell13_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;      xrTableCell13.Text = pluckRejectPercentTotal.ToString(&quot;0&quot;);&#xD;&#xA;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;" PageWidthF="1169.29138" PageHeightF="1653.54333" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="25.2" DataMember="SR_PT_DailyReconcilition" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
