<XtraReportsLayoutSerializer SerializerVersion="26.1.3.0" Ref="1" ControlType="DevExpress.XtraReports.UI.XtraReport, DevExpress.XtraReports.v25.2, Version=25.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Name="SR_PL_FM_FeedDeliveryDet_Det" ScriptsSource="decimal totalQty = 0;&#xD;&#xA;decimal totalNoOfTrips = 0;&#xD;&#xA;private void xrTableCell4_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;&#xD;&#xA;// Get values from the data source&#xD;&#xA;decimal noOfTrips = Convert.ToDecimal(GetCurrentColumnValue(&quot;NoOfTrips&quot;) ?? 0);&#xD;&#xA;decimal qty = Convert.ToDecimal(GetCurrentColumnValue(&quot;Qty&quot;) ?? 0);&#xD;&#xA;&#xD;&#xA;if (noOfTrips &gt; 0)&#xD;&#xA;{&#xD;&#xA;    // Calculate: Qty / NoOfTrips&#xD;&#xA;    decimal result = qty / noOfTrips;&#xD;&#xA;    cell.Text = result.ToString(&quot;N2&quot;);&#xD;&#xA;}&#xD;&#xA;else&#xD;&#xA;{&#xD;&#xA;    cell.Text = &quot;0.00&quot;;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;  totalQty += qty;&#xD;&#xA;  totalNoOfTrips += noOfTrips;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;private void xrTableCell12_BeforePrint(object sender, System.ComponentModel.CancelEventArgs e) {&#xD;&#xA;    XRTableCell cell = sender as XRTableCell;&#xD;&#xA;    &#xD;&#xA;    if (totalNoOfTrips &gt; 0)&#xD;&#xA;    {&#xD;&#xA;        decimal result = totalQty / totalNoOfTrips;&#xD;&#xA;        cell.Text = result.ToString(&quot;N2&quot;) ;&#xD;&#xA;    }&#xD;&#xA;    else&#xD;&#xA;    {&#xD;&#xA;        cell.Text = &quot;0.00&quot;;&#xD;&#xA;    }&#xD;&#xA;}&#xD;&#xA;" PageWidthF="826.771667" PageHeightF="1169.29138" ScriptReferencesString="E:\VetSoft Projects .Net2024\VetSoft Projects\VetSoftDevExpress\bin\Release\net8.0\VetSoftDevExpress.dll" Version="26.1" DataMember="SR_PL_FM_FeedDeliveryDet" DataSource="#Ref-0" TextAlignment="MiddleLeft" Padding="2,2,0,0,100" BorderColor="255,75,75,75" BorderWidth="0.5">
